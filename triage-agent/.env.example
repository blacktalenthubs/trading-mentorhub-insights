# ── Required ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
DATABASE_URL=postgresql://postgres:PASSWORD@trolley.proxy.rlwy.net:29711/railway

# ── Triage tuning ────────────────────────────────────────
TRIAGE_MODEL=claude-haiku-4-5         # alternatives: claude-sonnet-4-6, claude-opus-4-7
TRIAGE_USER_ID=3                       # whose alerts we process
TRIAGE_DAILY_USD_CAP=1.50              # hard cap; over budget → audit-only

# What gets posted to Telegram. During the validation phase use 'all'
# so you can compare every agent decision against the Pine alert you
# already received — that's how you judge accuracy. After ~1 week of
# trust, switch to 'high_only' or 'high_mute'.
#   all        — post HIGH + NORMAL + MUTE (default — validation)
#   high_mute  — post HIGH + MUTE (skip NORMAL; useful middle ground)
#   high_only  — post only HIGH (steady-state, post-trust)
TRIAGE_POST_MODE=all

# NOTICE alerts: deliver (default) or mute. SPY/QQQ only — non-index
# NOTICEs are filtered separately at the triage layer regardless of
# this flag. NOTICEs are macro session context (VWAP / open / W-M
# level NOTICEs). Set true to mute entirely.
MUTE_NOTICE_ALERTS=false

# MA/EMA rolling cooldown — better fit for 24/7 crypto than a midnight-
# anchored daily cap. After an MA alert fires, the same (symbol,
# alert_type) is blocked for the next MA_COOLDOWN_HOURS hours.
# Applies only to symbols in MA_COOLDOWN_SYMBOLS (default ETH-USD).
# Equities are not throttled — dedup/cooldown already handles them.
MA_COOLDOWN_HOURS=4
MA_COOLDOWN_SYMBOLS=ETH-USD


# ── Telegram (for live mode) ─────────────────────────────
# Use your existing bot OR a new one (BotFather → /newbot)
TELEGRAM_BOT_TOKEN=

# Chat / channel that receives HIGH-conviction alerts.
# To get this: create a private channel, add your bot as admin, then send any
# message and call https://api.telegram.org/bot<TOKEN>/getUpdates to find the id.
# Channel ids look like -100xxxxxxxxxx (negative; starts with -100).
CONVICTION_CHAT_ID=

# ── Persistence (Railway: mount a volume to /data) ───────
TRIAGE_CURSOR_FILE=.triage-cursor
TRIAGE_AUDIT_FILE=.triage-audit.jsonl

# ── Premarket + EOD brief scheduler ──────────────────────
# Set to true to activate the daily briefs. Default false so existing
# deploys don't get surprised by new behavior.
ENABLE_PREMARKET_BRIEF=false

# Schedule (defaults to 8:30 AM ET premarket + 16:05 ET EOD recap, Mon-Fri)
PREMARKET_HOUR_ET=8
PREMARKET_MINUTE_ET=30
EOD_HOUR_ET=16
EOD_MINUTE_ET=5

# LLM tier:
#   minimal  — basic format, no LLM polish (~$0.15/mo)
#   standard — adds 1-sentence reasoning ($0.60/mo)
#   heavy    — adds news headlines + earnings catalysts + macro context ($3/mo)
PREMARKET_LLM_TIER=heavy

# Where the morning brief stores its picks for EOD grading
PREMARKET_PICKS_FILE=/data/premarket-picks.json

# ── Chart snapshot in Telegram (optional) ────────────────────────
# When set, HIGH-conviction alerts include a TradingView-style chart
# inline in the Telegram message (with EMA 8/21, VWAP, volume,
# entry/stop/T1/T2 horizontal lines drawn).
# Get a free key at https://chart-img.com (free tier ~100 charts/day).
# Leave unset to disable; alerts fall back to text-only.
CHART_IMG_API_KEY=
