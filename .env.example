# Trade Alert Notification Configuration
# Copy this file to .env and fill in your credentials.

# --- SMTP (Email) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ALERT_EMAIL_FROM=your-email@gmail.com
ALERT_EMAIL_TO=your-email@gmail.com

# --- Telegram Bot (primary alert delivery) ---
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# --- SMS via email-to-SMS gateway (optional fallback) ---
# Carrier gateways: AT&T=@txt.att.net, T-Mobile=@tmomail.net, Verizon=@vtext.com
SMS_GATEWAY_TO=

# --- Twilio (optional fallback) ---
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+1234567890
ALERT_SMS_TO=+1234567890

# --- SnapTrade (real broker fill sync: Robinhood, Schwab, etc.) ---
# From the SnapTrade dashboard. Leave CLIENT_ID empty to disable the feature.
# CONSUMER_KEY is a secret — never expose it to the browser.
SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=
SNAPTRADE_REDIRECT_URI=https://busytradersdesk.com/settings?connected=1
SNAPTRADE_SYNC_ENABLED=true
SNAPTRADE_SYNC_LOOKBACK_DAYS=7

# --- Alpaca Paper Trading ---
ALPACA_API_KEY=your-alpaca-api-key
ALPACA_SECRET_KEY=your-alpaca-secret-key
PAPER_TRADE_ENABLED=false
PAPER_TRADE_POSITION_SIZE=10000
PAPER_TRADE_MAX_DAILY=4
PAPER_TRADE_MIN_SCORE=75
