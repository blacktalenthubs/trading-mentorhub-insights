// @version=5
//
// Daily MA Bounce / Rejection — visual-only marker indicator.
//
// Tracks 8 daily moving-average levels:
//   • EMAs:  8, 21, 50, 100, 200
//   • SMAs:  50, 100, 200
//
// Daily values are pulled via request.security so the indicator works on any
// intraday timeframe (drop on 1H or 15m and you'll see the daily MA lines as
// horizontal-ish levels — they evolve slightly intraday as the developing
// daily candle's close changes, but are stable compared to intraday MAs).
//
// Detection per MA:
//   • bounce_long  — low wicked the MA (within ATR*tol), close above MA,
//                    candle is green (close > open). LONG signal.
//   • reject_short — high tagged the MA from below, close back below,
//                    candle is red (close < open). SHORT signal.
//
// V2: visual + confluence alerts. Fires alerts ONLY when MA bounce/rejection
// coincides with PDH/PDL (high conviction). Solo MA touches stay visual-only —
// too noisy to alert on. Confluence is the edge (validated live: SPY SWEEP+
// at 8 EMA, NVDA 8 EMA bounce at PDL reclaim, META 8 EMA + PDL bounce).
//
indicator("Daily MA Bounce", overlay = true, max_labels_count = 500)

show_lines    = input.bool(true,  "Show daily MA lines")
show_markers  = input.bool(true,  "Show BOUNCE/REJECT markers")
tolerance_atr = input.float(0.3,  "Tolerance (× ATR14)", minval = 0.05, maxval = 2.0, step = 0.05)
label_size_in = input.string("tiny", "Marker label size", options = ["tiny", "small", "normal", "large"])

label_size = label_size_in == "tiny" ? size.tiny : label_size_in == "small" ? size.small : label_size_in == "large" ? size.large : size.normal

// Pull daily MAs with a HYBRID pattern:
//   • Historical bars → yesterday's daily-close MA value (stable horizontal
//     line, no future bias). Each intraday bar in day X sees day X-1's MA.
//   • Last bar (live) → today's developing daily-close MA value. Matches
//     TV's native daily EMA/SMA exactly so the on-chart value agrees with
//     the daily chart.
//
// Visual result: clean horizontal levels through history + a small step
// at the current bar pointing to the live value. Detection (bounce/reject)
// uses the same value as the line, so signals are internally consistent.
[ema8_live,   ema8_prev]   = request.security(syminfo.tickerid, "D", [ta.ema(close, 8),   ta.ema(close, 8)[1]],   lookahead = barmerge.lookahead_on)
[ema21_live,  ema21_prev]  = request.security(syminfo.tickerid, "D", [ta.ema(close, 21),  ta.ema(close, 21)[1]],  lookahead = barmerge.lookahead_on)
[ema50_live,  ema50_prev]  = request.security(syminfo.tickerid, "D", [ta.ema(close, 50),  ta.ema(close, 50)[1]],  lookahead = barmerge.lookahead_on)
[ema100_live, ema100_prev] = request.security(syminfo.tickerid, "D", [ta.ema(close, 100), ta.ema(close, 100)[1]], lookahead = barmerge.lookahead_on)
[ema200_live, ema200_prev] = request.security(syminfo.tickerid, "D", [ta.ema(close, 200), ta.ema(close, 200)[1]], lookahead = barmerge.lookahead_on)
[sma50_live,  sma50_prev]  = request.security(syminfo.tickerid, "D", [ta.sma(close, 50),  ta.sma(close, 50)[1]],  lookahead = barmerge.lookahead_on)
[sma100_live, sma100_prev] = request.security(syminfo.tickerid, "D", [ta.sma(close, 100), ta.sma(close, 100)[1]], lookahead = barmerge.lookahead_on)
[sma200_live, sma200_prev] = request.security(syminfo.tickerid, "D", [ta.sma(close, 200), ta.sma(close, 200)[1]], lookahead = barmerge.lookahead_on)

ema8   = barstate.islast ? ema8_live   : ema8_prev
ema21  = barstate.islast ? ema21_live  : ema21_prev
ema50  = barstate.islast ? ema50_live  : ema50_prev
ema100 = barstate.islast ? ema100_live : ema100_prev
ema200 = barstate.islast ? ema200_live : ema200_prev
sma50  = barstate.islast ? sma50_live  : sma50_prev
sma100 = barstate.islast ? sma100_live : sma100_prev
sma200 = barstate.islast ? sma200_live : sma200_prev

// Plot all 8 levels with distinct colors.
plot(show_lines ? ema8   : na, "EMA 8 (D)",   color = color.new(#FFEB3B, 30), linewidth = 1)
plot(show_lines ? ema21  : na, "EMA 21 (D)",  color = color.new(#FF9800, 30), linewidth = 1)
plot(show_lines ? ema50  : na, "EMA 50 (D)",  color = color.new(#E91E63, 10), linewidth = 2)
plot(show_lines ? ema100 : na, "EMA 100 (D)", color = color.new(#00BCD4, 10), linewidth = 2)
plot(show_lines ? ema200 : na, "EMA 200 (D)", color = color.new(#FFFFFF, 0),  linewidth = 3)
plot(show_lines ? sma50  : na, "SMA 50 (D)",  color = color.new(#2196F3, 30), linewidth = 1, style = plot.style_circles)
plot(show_lines ? sma100 : na, "SMA 100 (D)", color = color.new(#9C27B0, 30), linewidth = 1, style = plot.style_circles)
plot(show_lines ? sma200 : na, "SMA 200 (D)", color = color.new(#F44336, 0),  linewidth = 2, style = plot.style_circles)

// Tolerance — ATR-buffered, computed from previous bar for stability.
atr14 = nz(ta.atr(14)[1], close * 0.005)
tol   = atr14 * tolerance_atr

// Per-MA bounce / rejection detection.
bounce_long(float ma) =>
    not na(ma) and low <= ma + tol and low >= ma - tol * 2 and close > ma and close > open

reject_short(float ma) =>
    not na(ma) and high >= ma - tol and high <= ma + tol * 2 and close < ma and close < open

b_e8   = bounce_long(ema8)
b_e21  = bounce_long(ema21)
b_e50  = bounce_long(ema50)
b_e100 = bounce_long(ema100)
b_e200 = bounce_long(ema200)
b_s50  = bounce_long(sma50)
b_s100 = bounce_long(sma100)
b_s200 = bounce_long(sma200)

r_e8   = reject_short(ema8)
r_e21  = reject_short(ema21)
r_e50  = reject_short(ema50)
r_e100 = reject_short(ema100)
r_e200 = reject_short(ema200)
r_s50  = reject_short(sma50)
r_s100 = reject_short(sma100)
r_s200 = reject_short(sma200)

any_long  = b_e8 or b_e21 or b_e50 or b_e100 or b_e200 or b_s50 or b_s100 or b_s200
any_short = r_e8 or r_e21 or r_e50 or r_e100 or r_e200 or r_s50 or r_s100 or r_s200

// Build dynamic label text showing which MA(s) fired.
long_tag = (b_e8 ? "8E " : "") + (b_e21 ? "21E " : "") + (b_e50 ? "50E " : "") + (b_e100 ? "100E " : "") + (b_e200 ? "200E " : "") + (b_s50 ? "50S " : "") + (b_s100 ? "100S " : "") + (b_s200 ? "200S " : "")

short_tag = (r_e8 ? "8E " : "") + (r_e21 ? "21E " : "") + (r_e50 ? "50E " : "") + (r_e100 ? "100E " : "") + (r_e200 ? "200E " : "") + (r_s50 ? "50S " : "") + (r_s100 ? "100S " : "") + (r_s200 ? "200S " : "")

// Triangles always visible regardless of zoom; labels carry the MA tag.
plotshape(show_markers and any_long,
          title = "Bounce LONG", location = location.belowbar,
          color = color.new(color.green, 0), style = shape.triangleup,
          size = size.tiny)
plotshape(show_markers and any_short,
          title = "Reject SHORT", location = location.abovebar,
          color = color.new(color.red, 0), style = shape.triangledown,
          size = size.tiny)

if show_markers and any_long
    label.new(bar_index, low, long_tag,
              style = label.style_label_up,
              color = color.new(color.green, 0),
              textcolor = color.white,
              size = label_size,
              yloc = yloc.belowbar)
if show_markers and any_short
    label.new(bar_index, high, short_tag,
              style = label.style_label_down,
              color = color.new(color.red, 0),
              textcolor = color.white,
              size = label_size,
              yloc = yloc.abovebar)

bgcolor(any_long  ? color.new(color.green, 90) : na, title = "Bounce bg")
bgcolor(any_short ? color.new(color.red,   90) : na, title = "Reject bg")

// =====================================================================
// CONFLUENCE ALERTS — fire only when MA bounce/rejection coincides with
// PDH/PDL (high conviction) or when slow MAs above price reject (notice).
// Solo MA touches do NOT alert — too noisy. Confluence is the edge.
//
// Three signal types:
//   LONG    — any MA bounce + low touched PDL (within ATR tol)  → BUY
//   SHORT   — any MA rejection + high touched PDH (within ATR tol) → SHORT
//   NOTICE  — 100E/200E/100S/200S rejection (overhead resistance,
//             not at PDH) → informational, do NOT auto-trade on it
// =====================================================================

conf_tol_atr = input.float(0.5,  "Confluence tolerance (× ATR14) for PDH/PDL", minval = 0.1, maxval = 2.0, step = 0.1)
fire_alerts  = input.bool(true,  "Fire alerts on confluence (LONG / SHORT / NOTICE)")

pdh = request.security(syminfo.tickerid, "D", high[1], lookahead = barmerge.lookahead_on)
pdl = request.security(syminfo.tickerid, "D", low[1],  lookahead = barmerge.lookahead_on)

conf_buffer = atr14 * conf_tol_atr
near_pdl = not na(pdl) and math.abs(low  - pdl) <= conf_buffer
near_pdh = not na(pdh) and math.abs(high - pdh) <= conf_buffer

ma_long_at_pdl  = any_long  and near_pdl
ma_short_at_pdh = any_short and near_pdh
overhead_notice = (r_e100 or r_e200 or r_s100 or r_s200) and not ma_short_at_pdh

// Visual confluence markers — gold diamond for LONG confluence, purple for SHORT,
// gray diamond for overhead resistance NOTICE. Lets you spot the high-conviction
// bars at a glance without waiting for the alert.
plotshape(ma_long_at_pdl,  title = "LONG confluence",  location = location.belowbar,
          color = color.new(color.yellow, 0), style = shape.diamond, size = size.small)
plotshape(ma_short_at_pdh, title = "SHORT confluence", location = location.abovebar,
          color = color.new(color.purple, 0), style = shape.diamond, size = size.small)
plotshape(overhead_notice, title = "Overhead NOTICE",  location = location.abovebar,
          color = color.new(color.gray, 30),  style = shape.circle,  size = size.tiny)

// JSON payload for the existing /tv/webhook → Telegram pipeline. Same shape as
// prior_day_levels.pine so the webhook handler can route uniformly.
build_ma_payload(string rule, string direction, string ma_tag) =>
    '{"symbol":"' + syminfo.ticker
      + '","exchange":"' + syminfo.prefix
      + '","interval":"' + timeframe.period
      + '","price":"' + str.tostring(close, format.mintick)
      + '","high":"' + str.tostring(high, format.mintick)
      + '","low":"' + str.tostring(low, format.mintick)
      + '","volume":"' + str.tostring(volume)
      + '","rule":"' + rule
      + '","direction":"' + direction
      + '","ma_tag":"' + str.replace_all(ma_tag, " ", "")
      + '","pdh":"' + str.tostring(pdh, format.mintick)
      + '","pdl":"' + str.tostring(pdl, format.mintick)
      + '","fired_at":"' + str.tostring(timenow) + '"}'

if fire_alerts and ma_long_at_pdl
    alert(build_ma_payload("ma_pdl_confluence_long",  "BUY",    long_tag),  alert.freq_once_per_bar)
if fire_alerts and ma_short_at_pdh
    alert(build_ma_payload("ma_pdh_confluence_short", "SHORT",  short_tag), alert.freq_once_per_bar)
if fire_alerts and overhead_notice
    alert(build_ma_payload("ma_overhead_notice",      "NOTICE", short_tag), alert.freq_once_per_bar)
