//@version=5
//
// Bull / Bear Flag — independently toggleable visual detector
// ───────────────────────────────────────────────────────────────────────
// Detects flag continuation patterns on any timeframe. A flag has two
// parts:
//   • Pole  — N bars of strong directional move (≥ X × ATR over the window).
//   • Flag  — M bars of tight consolidation against the pole, retracing
//             less than a configurable % of the pole.
//
// Bull flag = up pole then tight pullback. Bear flag = down pole then tight
// bounce. Show bull only / bear only / both via the two toggles at the top.
//
// Visual: a coloured box around the flag bars + a label at its tip.
// No alerts — pure overlay. Combine with your levels and the fib script
// for confluence.
//
indicator("Bull/Bear Flag — TradeCoPilot", overlay=true, max_boxes_count=100, max_labels_count=100)

// ── Toggles ─────────────────────────────────────────────────────────────
show_bull = input.bool(true,  "Show Bull Flags", group="Toggle")
show_bear = input.bool(true,  "Show Bear Flags", group="Toggle")

// ── Detection knobs ─────────────────────────────────────────────────────
pole_len       = input.int(5,    "Pole length (bars)",          minval=3, maxval=20, group="Detection")
pole_atr_mult  = input.float(2.0,"Pole strength (× ATR-14)",    step=0.1, minval=1.0, group="Detection")
flag_len       = input.int(8,    "Flag length (bars)",          minval=3, maxval=20, group="Detection")
max_retrace    = input.float(0.50,"Max flag retracement (% of pole)", step=0.05, minval=0.1, maxval=0.7, group="Detection")
max_flag_range = input.float(0.50,"Max flag range vs pole",     step=0.05, minval=0.1, maxval=0.8, group="Detection")

// ── Inputs derived ──────────────────────────────────────────────────────
atr_n = ta.atr(14)

// Pole window: bars [flag_len, flag_len + pole_len - 1] ago
pole_high  = ta.highest(high, pole_len)[flag_len]
pole_low   = ta.lowest(low,   pole_len)[flag_len]
pole_start = close[flag_len + pole_len - 1]
pole_end   = close[flag_len]
pole_range = pole_high - pole_low
pole_up    = pole_end > pole_start
pole_down  = pole_end < pole_start

// Impulse strength relative to ATR at pole start
impulse_strong = pole_range >= pole_atr_mult * atr_n[flag_len + pole_len - 1]

// Flag window: most recent flag_len bars
flag_high  = ta.highest(high, flag_len)
flag_low   = ta.lowest(low,   flag_len)
flag_range = flag_high - flag_low

// Guard divisions with ternary (Pine v5 non-short-circuit on AND)
flag_tight         = pole_range > 0 ? (flag_range / pole_range) <= max_flag_range : false
bull_pullback_ok   = pole_range > 0 ? ((pole_high - flag_low) / pole_range) <= max_retrace : false
bear_bounce_ok     = pole_range > 0 ? ((flag_high - pole_low) / pole_range) <= max_retrace : false

// Bull flag = up pole + tight retracement that stays above the pole low
bull_flag = show_bull and pole_up   and impulse_strong and flag_tight and bull_pullback_ok and flag_low  > pole_low
// Bear flag = down pole + tight bounce that stays below the pole high
bear_flag = show_bear and pole_down and impulse_strong and flag_tight and bear_bounce_ok   and flag_high < pole_high

// ── Draw ────────────────────────────────────────────────────────────────
// Bar-confirmed only so we don't repaint flickers mid-bar.
if barstate.isconfirmed and bull_flag
    box.new(left=bar_index - flag_len + 1, top=flag_high, right=bar_index, bottom=flag_low, border_color=color.new(color.green, 30), bgcolor=color.new(color.green, 90), border_width=1)
    label.new(x=bar_index, y=flag_high, text="🚩 Bull Flag", style=label.style_label_down, color=color.new(color.green, 20), textcolor=color.white, size=size.small)

if barstate.isconfirmed and bear_flag
    box.new(left=bar_index - flag_len + 1, top=flag_high, right=bar_index, bottom=flag_low, border_color=color.new(color.red, 30), bgcolor=color.new(color.red, 90), border_width=1)
    label.new(x=bar_index, y=flag_low, text="🚩 Bear Flag", style=label.style_label_up, color=color.new(color.red, 20), textcolor=color.white, size=size.small)
