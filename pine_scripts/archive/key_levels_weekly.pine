//@version=5
indicator("Key Weekly Highs & Lows", overlay = true, max_lines_count = 60, max_labels_count = 60)

// VISUAL-ONLY. No alerts.
//
// Finds the most recent KEY swing highs and lows on the Weekly timeframe
// via ta.pivothigh/ta.pivotlow with N weekly bars of confirmation on each
// side. Keeps the last N highs and N lows as horizontal lines extending
// infinitely to the right — durable weekly structure visible on every
// chart regardless of intraday timeframe.
//
// CONFIRMATION DELAY (intentional): a pivot only appears `N` weekly bars
// AFTER the actual high/low. 3 weeks of confirmation is typical for a
// genuine weekly swing. If a pivot can't be drawn yet, the high/low is
// still live action — don't treat it as fixed yet.
//
// Weekly levels are HEAVIER than daily by default (width 2 vs 1, opaque
// labels) since they're more structurally durable.
//
// SIBLINGS:
//   key_levels_daily.pine      — same idea on Daily TF
//   levels_week_month.pine     — single PRIOR week H/L + PRIOR month H/L

// ── Inputs ──────────────────────────────────────────────────────────
strength = input.int(3, "Pivot strength (bars on each side)", group = "Pivots", minval = 2, maxval = 20, tooltip = "Higher = stronger / fewer. 3 ≈ ~3 weeks of confirmation. 5 ≈ ~5 weeks (monthly-scale).")
keepN    = input.int(5, "Keep last N highs and N lows",       group = "Pivots", minval = 1, maxval = 15)

showHi = input.bool(true, "Show weekly highs", group = "Display", inline = "h")
cHi    = input.color(color.new(#f59e0b, 0), "", group = "Display", inline = "h")
showLo = input.bool(true, "Show weekly lows",  group = "Display", inline = "l")
cLo    = input.color(color.new(#3b82f6, 0), "", group = "Display", inline = "l")

lw           = input.int(2,  "Line width",                group = "Style", minval = 1, maxval = 4)
lookbackBars = input.int(80, "Line extends back N bars",  group = "Style", minval = 10, maxval = 500, tooltip = "How far LEFT the line extends from the current bar. Right edge always extends forever.")
showLabels   = input.bool(true, "Right-edge labels",      group = "Style")

// ── Pull weekly pivots ──────────────────────────────────────────────
// lookahead_off → no future-bar leak. Pivot value lands on the intraday
// bar where the `strength`-th weekly bar after the actual pivot has closed.
wPH = request.security(syminfo.tickerid, "W", ta.pivothigh(high, strength, strength), lookahead = barmerge.lookahead_off)
wPL = request.security(syminfo.tickerid, "W", ta.pivotlow(low,   strength, strength), lookahead = barmerge.lookahead_off)

// ── Persistent pivot arrays ─────────────────────────────────────────
var array<float> hPx = array.new<float>()
var array<float> lPx = array.new<float>()

// Push only when v is non-na AND different from the last stored value
// (dedup across intraday bars within the same weekly candle).
// Nested ifs — Pine v5 `and`/`or` do NOT short-circuit.
f_push(array<float> a, float v, int cap) =>
    if not na(v)
        bool is_new = true
        if array.size(a) > 0
            is_new := array.get(a, array.size(a) - 1) != v
        if is_new
            array.push(a, v)
            if array.size(a) > cap
                array.shift(a)

f_push(hPx, wPH, keepN)
f_push(lPx, wPL, keepN)

// ── Draw / redraw on last bar only ──────────────────────────────────
var array<line>  drawnLines  = array.new<line>()
var array<label> drawnLabels = array.new<label>()

f_clear() =>
    if array.size(drawnLines) > 0
        for i = 0 to array.size(drawnLines) - 1
            line.delete(array.get(drawnLines, i))
        array.clear(drawnLines)
    if array.size(drawnLabels) > 0
        for i = 0 to array.size(drawnLabels) - 1
            label.delete(array.get(drawnLabels, i))
        array.clear(drawnLabels)

f_draw(array<float> a, color col, string tag) =>
    if array.size(a) > 0
        for i = 0 to array.size(a) - 1
            float p = array.get(a, i)
            line ln = line.new(bar_index - lookbackBars, p, bar_index, p, color = col, width = lw, extend = extend.right)
            array.push(drawnLines, ln)
            if showLabels
                label lb = label.new(bar_index, p, tag + " " + str.tostring(p, format.mintick), color = col, textcolor = color.white, style = label.style_label_left, size = size.small)
                array.push(drawnLabels, lb)

if barstate.islast
    f_clear()
    if showHi
        f_draw(hPx, cHi, "W Hi")
    if showLo
        f_draw(lPx, cLo, "W Lo")
