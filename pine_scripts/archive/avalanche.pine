// @version=5
//
// Avalanche — VISUAL ONLY (Trader Stewie / Art of Trading style).
//
// Catches the mid-morning CAPITULATION BOUNCE in a strong stock: a leader
// that opens flat / gaps up, then FADES sharply lower into ~10:45–11:00 ET,
// exhausts, and snaps back. It is mean-reversion INSIDE an uptrend — the
// opposite end of a breakout.
//
// The four ingredients (none of our existing pines combine them):
//   1. DAILY UPTREND  — price above a rising 8/21/50 EMA stack (leaders only).
//   2. STEEP FADE      — intraday drawdown from the session high of 7%+ ...
//   3. MORNING WINDOW  — ... reached BEFORE ~11:00 ET (the avalanche window).
//   4. REVERSAL BAR    — a green bar back up off the low = velocity dying.
//
// When all four line up it prints a ▲ AVL marker + entry / stop / target box.
// STOP = ~1.5% below the avalanche low (lose that = the bounce failed).
// TARGETS = fixed 3% / 5% from entry (Stewie's stated range); the morning high
// can be drawn as optional "fill-the-fade" context.
//
// This is a SCOUT, not an alert. Load it on a 3m/5m intraday chart, scroll it
// across MU / SNDK / SOXL / NVDA on real days, and confirm it lights up on the
// actual avalanche bounces and stays quiet on ordinary dips — BEFORE we wire
// any alert type off it.
//
// Pine v5 notes: single-line calls/ternaries only; and/or not short-circuited
// (guard na explicitly); state is var, reset on the first bar of each session.
//
indicator("avalanche", overlay = true)

// ── Setup criteria ─────────────────────────────────────────────────
min_drop_pct = input.float(7.0, "Min fade from session high (%)", minval = 1.0, step = 0.5, group = "Setup", tooltip = "Stewie's sweet spot is 7–12%. The steeper, the better. This is the MINIMUM peak-to-low intraday drawdown to arm the setup.")
max_drop_pct = input.float(0.0, "Max fade cap (%, 0 = no cap)", minval = 0.0, step = 0.5, group = "Setup", tooltip = "0 disables the cap (steeper is fine). Set e.g. 20 to ignore names in a genuine collapse rather than a shakeout.")
reclaim_band_pct = input.float(1.5, "Reversal must be within X% of the low", minval = 0.1, step = 0.1, group = "Setup", tooltip = "The green reversal bar must print near the avalanche low — catch the turn, not a bounce that already ran.")

// ── Morning window (ET) ────────────────────────────────────────────
// Stewie's textbook is 10:45–11:00, but real ones bottom later (AFRM 9/30/25
// didn't low until ~11:48). Default arm-by 12:00 + 30m grace catches those
// while still excluding the into-the-close chase. Tighten to 11:00 for the
// purest setups.
arm_end_hour = input.int(12, "Arm-by hour (ET)", minval = 10, maxval = 14, group = "Window")
arm_end_min  = input.int(0,  "Arm-by minute (ET)", minval = 0, maxval = 59, group = "Window")
fire_grace_min = input.int(30, "Fire grace after arm-by (min)", minval = 0, maxval = 90, group = "Window", tooltip = "The reversal often confirms just after the window. Allow the ▲ to fire up to this many minutes past the arm-by time.")

// ── Uptrend filter (daily EMAs) ────────────────────────────────────
require_uptrend = input.bool(true, "Require daily uptrend (leaders only)", group = "Trend")
ema_fast_len = input.int(8,  "Daily EMA fast", group = "Trend")
ema_mid_len  = input.int(21, "Daily EMA mid",  group = "Trend")
ema_slow_len = input.int(50, "Daily EMA slow", group = "Trend")

// ── Stop & targets (AFRM 9/30/25: stop ~1.5% below the low, targets 3–5%) ──
stop_buffer_pct = input.float(1.5, "Stop buffer below the avalanche low (%)", minval = 0.0, step = 0.25, group = "Stop & targets", tooltip = "Stewie's stop sits BELOW the low, not on it (AFRM low 70.83, stop 69.80 ≈ 1.5%), so a wick doesn't knock you out.")
max_risk_pct = input.float(3.0, "Max risk (entry→stop) to allow (%, 0 = off)", minval = 0.0, step = 0.25, group = "Stop & targets", tooltip = "Skip setups whose stop is more than this % below entry. 60d backtest: capping at 3% lifted avg R from +0.18 to +0.26 by cutting wide-stop entries (NBIS/SOXL) that pay poorly even when they win.")
t1_pct = input.float(3.0, "Target 1 from entry (%)", minval = 0.5, step = 0.5, group = "Stop & targets")
t2_pct = input.float(5.0, "Target 2 from entry (%)", minval = 0.5, step = 0.5, group = "Stop & targets")
show_box     = input.bool(true, "Draw entry / stop / target box", group = "Stop & targets")
show_morning_high = input.bool(false, "Also draw the morning high (fade-fill context)", group = "Stop & targets")
show_table   = input.bool(true, "Show status table", group = "Display")

// ── Daily uptrend read (non-repainting: last confirmed daily EMA) ──
ema_fast_d = request.security(syminfo.tickerid, "D", ta.ema(close, ema_fast_len), lookahead = barmerge.lookahead_off)
ema_mid_d  = request.security(syminfo.tickerid, "D", ta.ema(close, ema_mid_len),  lookahead = barmerge.lookahead_off)
ema_slow_d = request.security(syminfo.tickerid, "D", ta.ema(close, ema_slow_len), lookahead = barmerge.lookahead_off)
// The stock must be a LEADER (rising 8>21>50 daily stack) — but the avalanche
// fade deliberately shakes price UNDER the 8/21, so we do NOT require close
// above the 21. The floor is the 50-day: still above it = the intermediate
// uptrend is intact, just a shakeout. (AFRM 9/30/25: low 70.83 was below the
// 21 @ 72.29 but held the 50 @ 67.69 — requiring >21 would have missed it.)
ema_mid_rising = not na(ema_mid_d) and not na(ema_mid_d[1]) and ema_mid_d > ema_mid_d[1]
stack_ok = not na(ema_fast_d) and not na(ema_mid_d) and not na(ema_slow_d) and ema_fast_d > ema_mid_d and ema_mid_d > ema_slow_d
uptrend = not require_uptrend or (stack_ok and ema_mid_rising and close > ema_slow_d)

// ── ET clock + session tracking ────────────────────────────────────
mins_et    = hour(time, "America/New_York") * 60 + minute(time, "America/New_York")
open_min   = 9 * 60 + 30           // 9:30 ET
arm_by_min = arm_end_hour * 60 + arm_end_min
fire_by_min = arm_by_min + fire_grace_min
in_arm_window  = mins_et >= open_min and mins_et <= arm_by_min
in_fire_window = mins_et >= open_min and mins_et <= fire_by_min

// RTH-anchored session (NOT time("D") — that leaks pre/post-market prints when
// extended hours is on, polluting the session high/low and killing the fire.
// Reset at the 9:30 ET open, and only track the high/low during 9:30–16:00).
is_rth       = mins_et >= open_min and mins_et < 16 * 60
rth_open_now = is_rth and not is_rth[1]
var float day_open  = na
var float day_high  = na
var float day_low   = na
var float fade_high = na          // session high at the moment we armed
var float fade_low  = na          // running avalanche low
var bool  armed     = false
var bool  fired     = false

if rth_open_now
    day_open  := open
    day_high  := high
    day_low   := low
    fade_high := na
    fade_low  := na
    armed     := false
    fired     := false
else if is_rth
    day_high := na(day_high) ? high : math.max(day_high, high)
    day_low  := na(day_low)  ? low  : math.min(day_low, low)

// ── Fade magnitude (peak-to-current drawdown, intraday) ────────────
dd_from_high = (not na(day_high) and day_high > 0) ? (day_high - low) / day_high * 100.0 : na
drop_ok = not na(dd_from_high) and dd_from_high >= min_drop_pct and (max_drop_pct <= 0.0 or dd_from_high <= max_drop_pct)

// ── Arm: deep enough fade, in the morning window, in an uptrend ────
if in_arm_window and drop_ok and uptrend and not armed
    armed     := true
    fade_high := day_high
    fade_low  := day_low

// keep the avalanche low current while armed and still falling
if armed and not fired and not na(day_low)
    fade_low := math.min(fade_low, day_low)

// ── Reversal bar: green, higher close, printing near the low ───────
near_low = armed and not na(fade_low) and low <= fade_low * (1.0 + reclaim_band_pct / 100.0)
reversal_bar = not na(close[1]) and close > open and close > close[1]
// risk cap: skip the setup if the stop sits more than max_risk_pct below entry
cand_stop = na(fade_low) ? na : fade_low * (1.0 - stop_buffer_pct / 100.0)
cand_risk = (not na(cand_stop) and close > 0) ? (close - cand_stop) / close * 100.0 : na
risk_ok = max_risk_pct <= 0.0 or (not na(cand_risk) and cand_risk <= max_risk_pct)
avalanche_fire = armed and not fired and in_fire_window and near_low and reversal_bar and risk_ok

var float e_entry = na
var float e_stop  = na
var float e_t1    = na
var float e_t2    = na
var float e_ctx   = na           // morning-high fade-fill context
if avalanche_fire
    e_entry := close
    e_stop  := fade_low * (1.0 - stop_buffer_pct / 100.0)
    e_t1    := close * (1.0 + t1_pct / 100.0)
    e_t2    := close * (1.0 + t2_pct / 100.0)
    e_ctx   := fade_high
    fired   := true

// ── Visuals ────────────────────────────────────────────────────────
plot(day_open, title = "Session open", color = color.new(#F59E0B, 30), style = plot.style_linebr, linewidth = 1)

plotshape(avalanche_fire, title = "AVL bounce", location = location.belowbar, color = color.new(#16A34A, 0), style = shape.triangleup, size = size.normal, text = "AVL", textcolor = color.white)

if avalanche_fire
    txt = "AVL  -" + str.tostring(dd_from_high, "0.0") + "% fade\nE " + str.tostring(e_entry, format.mintick) + "  |  Stop " + str.tostring(e_stop, format.mintick) + "\nT1 " + str.tostring(e_t1, format.mintick) + "  |  T2 " + str.tostring(e_t2, format.mintick)
    label.new(bar_index, low, txt, style = label.style_label_up, color = color.new(#16A34A, 10), textcolor = color.white, size = size.small)
    if show_box
        line.new(bar_index, e_entry, bar_index + 20, e_entry, color = color.new(color.blue, 0),  width = 2)
        line.new(bar_index, e_stop,  bar_index + 20, e_stop,  color = color.new(color.red, 0),   width = 1, style = line.style_dashed)
        line.new(bar_index, e_t1,    bar_index + 20, e_t1,    color = color.new(color.green, 0), width = 1, style = line.style_dashed)
        line.new(bar_index, e_t2,    bar_index + 20, e_t2,    color = color.new(color.green, 0), width = 1, style = line.style_dashed)
    if show_morning_high
        line.new(bar_index, e_ctx, bar_index + 20, e_ctx, color = color.new(color.green, 40), width = 1, style = line.style_dotted)

// ── Status table ───────────────────────────────────────────────────
yes_no(bool b) => b ? "YES" : "no"
on_col(bool b) => b ? color.new(color.green, 0) : color.new(color.gray, 0)
var table tbl = table.new(position.top_right, 2, 5, border_width = 1, frame_color = color.new(color.gray, 60))
if show_table and barstate.islast
    table.cell(tbl, 0, 0, "AVALANCHE", text_color = color.white, bgcolor = color.new(color.gray, 70), text_size = size.small)
    table.cell(tbl, 1, 0, fired ? "FIRED" : armed ? "ARMED" : "watch", text_color = color.white, bgcolor = color.new(color.gray, 70), text_size = size.small)
    table.cell(tbl, 0, 1, "Uptrend", text_size = size.small)
    table.cell(tbl, 1, 1, yes_no(uptrend), text_color = on_col(uptrend), text_size = size.small)
    table.cell(tbl, 0, 2, "Fade from high", text_size = size.small)
    table.cell(tbl, 1, 2, na(dd_from_high) ? "—" : "-" + str.tostring(dd_from_high, "0.0") + "%", text_color = on_col(drop_ok), text_size = size.small)
    table.cell(tbl, 0, 3, "In window", text_size = size.small)
    table.cell(tbl, 1, 3, yes_no(in_arm_window), text_color = on_col(in_arm_window), text_size = size.small)
    table.cell(tbl, 0, 4, "Near low", text_size = size.small)
    table.cell(tbl, 1, 4, yes_no(near_low), text_color = on_col(near_low), text_size = size.small)
