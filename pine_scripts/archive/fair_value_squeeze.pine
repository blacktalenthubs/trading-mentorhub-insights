// This Pine Script™ code is subject to the terms of the Mozilla Public License 2.0 at https://mozilla.org/MPL/2.0/
// © Gemini_THT_Simplified · extended (squeeze + extension) — STANDALONE, not wired to alerts/backend
//@version=5
indicator("THT Fair Value Bands — Squeeze & Extension", overlay=true, max_labels_count=500)

// ── Inputs ──────────────────────────────────────────────────────────────────
len   = input.int(20,  "Period",     minval=1, group="Bands")
mult  = input.float(2.0,"Multiplier", step=0.1, group="Bands")
src   = input.source(close, "Source", group="Bands")

sqLkbk = input.int(126,  "Squeeze lookback (bars)",          minval=20, group="Squeeze")
sqPct  = input.float(20.0,"Squeeze percentile (≤ = coiling)", minval=1, maxval=50, step=1, group="Squeeze")
showSq = input.bool(true, "Shade squeeze (coiling) zones",   group="Squeeze")

showExt = input.bool(true, "Mark extension (outside bands)", group="Extension")
showTbl = input.bool(true, "Show status table",              group="Display")

// ── Core bands (unchanged) ──────────────────────────────────────────────────
basis = ta.sma(src, len)
dev   = mult * ta.stdev(src, len)
upper = basis + dev
lower = basis - dev

bool isBull = src > basis
bool isBear = src < basis

// ── Squeeze: volatility contraction = coiling / pre-breakout ─────────────────
// Band width normalised by price, then ranked vs its own recent history. A low
// rank = the tightest bands in months = energy building. The edge isn't the coil
// itself — it's the EXPANSION out of it (release), so we mark that too.
bandwidth = basis != 0 ? (upper - lower) / basis * 100 : 0.0
bwRank    = ta.percentrank(bandwidth, sqLkbk)        // 0..100; low = tight
bool inSqueeze = bwRank <= sqPct
bool sqRelease = inSqueeze[1] and not inSqueeze      // bands expanding after a coil
bool releaseUp = sqRelease and close > basis
bool releaseDn = sqRelease and close < basis

// ── Extension: where price sits in the band (%B) ────────────────────────────
// > upper = stretched above fair value (don't chase / trim watch); < lower =
// stretched below (mean-reversion watch toward the basis).
pctB  = (upper - lower) != 0 ? (src - lower) / (upper - lower) : 0.5
bool extUp = close > upper
bool extDn = close < lower

// ── Colors (kept from the original) ─────────────────────────────────────────
color bullColor = color.new(#00ffbb, 0)
color bearColor = color.new(#ff1100, 0)
color fillBull  = color.new(#00ffbb, 85)
color fillBear  = color.new(#ff1100, 85)

// ── Plots ───────────────────────────────────────────────────────────────────
plot(basis, "Basis (fair value)", color=color.new(color.gray, 50), linewidth=1)
pUpper = plot(upper, "Upper Band", color=isBear ? bearColor : color.new(color.gray, 80), linewidth=2)
pLower = plot(lower, "Lower Band", color=isBull ? bullColor : color.new(color.gray, 80), linewidth=2)
fill(pUpper, pLower, color=isBull ? fillBull : fillBear, title="Trend Ribbon")

// Squeeze shading — the coil. Subtle so it reads as CONTEXT, not a signal.
bgcolor(showSq and inSqueeze ? color.new(color.yellow, 90) : na, title="Squeeze (coiling)")

// Squeeze release — the expansion out of the coil (the actual move).
plotshape(showSq and releaseUp, "Squeeze release up",   shape.triangleup,   location.belowbar, color=bullColor, size=size.small)
plotshape(showSq and releaseDn, "Squeeze release down", shape.triangledown, location.abovebar, color=bearColor, size=size.small)

// Extension — price closed outside the band (stretched from fair value).
plotshape(showExt and extUp, "Extended up",   shape.diamond, location.abovebar, color=color.new(bearColor, 30), size=size.tiny)
plotshape(showExt and extDn, "Stretched down", shape.diamond, location.belowbar, color=color.new(bullColor, 30), size=size.tiny)

// ── Status table — the glanceable read ──────────────────────────────────────
var table t = table.new(position.top_right, 2, 4, border_width=1)
if showTbl and barstate.islast
    sqTxt  = inSqueeze ? "SQUEEZE " + str.tostring(bwRank, "#") + "%" : "expanding " + str.tostring(bwRank, "#") + "%"
    sqCol  = inSqueeze ? color.new(color.yellow, 0) : color.new(color.gray, 0)
    extTxt = extUp ? "EXTENDED up" : extDn ? "STRETCHED down" : "in band " + str.tostring(pctB * 100, "#") + "%"
    extCol = extUp ? bearColor : extDn ? bullColor : color.new(color.gray, 0)
    table.cell(t, 0, 0, "Regime",     text_color=color.gray, text_size=size.small)
    table.cell(t, 1, 0, isBull ? "BULL" : "BEAR", text_color=isBull ? bullColor : bearColor, text_size=size.small)
    table.cell(t, 0, 1, "Bands",      text_color=color.gray, text_size=size.small)
    table.cell(t, 1, 1, sqTxt,        text_color=sqCol, text_size=size.small)
    table.cell(t, 0, 2, "Position",   text_color=color.gray, text_size=size.small)
    table.cell(t, 1, 2, extTxt,       text_color=extCol, text_size=size.small)
    table.cell(t, 0, 3, "Fair value", text_color=color.gray, text_size=size.small)
    table.cell(t, 1, 3, str.tostring(basis, format.mintick), text_color=color.new(color.gray, 0), text_size=size.small)

// ── Optional manual alerts (standalone — NOT the backend payload format) ─────
alertcondition(releaseUp, "Squeeze release up",     "Volatility expanding out of a coil — upside")
alertcondition(releaseDn, "Squeeze release down",   "Volatility expanding out of a coil — downside")
alertcondition(extUp,     "Extended above band",    "Price stretched above fair value — don't chase / trim watch")
alertcondition(extDn,     "Stretched below band",   "Price stretched below fair value — reversion watch")
