// @version=5
//
// 4h support / resistance — VISUAL ONLY.
//
// Draws each recent 4h swing high (resistance) and 4h swing low (support)
// as a SINGLE horizontal line.new() that extends right indefinitely. Each
// line sits at its exact pivot price and doesn't change once drawn — no
// staircase, no historical forward-fill segments.
//
// When a new pivot confirms, a new line is added and (if the per-side
// limit is exceeded) the OLDEST line of that kind is deleted. The result
// is a fixed-size set of "the N most recent" resistance + support levels
// always visible on the chart.
//
// Indicator name retained as `pivots-4h` (history goes back to
// `pivots-1h-4h`). Re-paste this source into TradingView to swap behavior.
//
indicator("pivots-4h", overlay = true, max_lines_count = 50)

// ── Inputs ──────────────────────────────────────────────────────────
show_resistance = input.bool(true, "Show 4h resistance")
show_support    = input.bool(true, "Show 4h support")
show_n          = input.int(2, "Recent pivots per side", minval = 1, maxval = 5,
                             tooltip = "How many of the most recent 4h pivots to keep on chart. New pivots push older ones out.")
piv_left        = input.int(3, "4h pivot — left bars",  minval = 2, maxval = 10)
piv_right       = input.int(3, "4h pivot — right bars", minval = 2, maxval = 10,
                             tooltip = "Confirmation latency: a pivot confirms `right` 4h bars after the swing prints. Default 3 = 12 hours.")

// ── 4h pivot detection via request.security ─────────────────────────
[ph_4h_raw, pl_4h_raw] = request.security(syminfo.tickerid, "240", [ta.pivothigh(high, piv_left, piv_right), ta.pivotlow(low, piv_left, piv_right)], lookahead = barmerge.lookahead_off)

// ── Line objects, kept in arrays so we can cap at N ─────────────────
var array<line> r_lines = array.new<line>()
var array<line> s_lines = array.new<line>()

// Line x-anchor uses xloc.bar_time (absolute timestamp) instead of
// xloc.bar_index — bar_index is chart-specific (15m bars vs 4h bars
// produce different indices for the same wall-clock moment), so lines
// rendered with xloc.bar_index can appear at different positions
// across timeframes. xloc.bar_time anchors to a specific second of
// chart history regardless of bar size.

// New 4h resistance — create a horizontal line at the pivot price and
// rotate the oldest out if we're over the N-per-side cap.
if show_resistance and not na(ph_4h_raw)
    new_r = line.new(x1 = time, y1 = ph_4h_raw, x2 = time + 1, y2 = ph_4h_raw, xloc = xloc.bar_time, extend = extend.right, color = color.new(color.red, 0), style = line.style_dashed, width = 2)
    array.push(r_lines, new_r)
    while array.size(r_lines) > show_n
        oldest = array.shift(r_lines)
        line.delete(oldest)

// New 4h support — same pattern, green.
if show_support and not na(pl_4h_raw)
    new_s = line.new(x1 = time, y1 = pl_4h_raw, x2 = time + 1, y2 = pl_4h_raw, xloc = xloc.bar_time, extend = extend.right, color = color.new(color.green, 0), style = line.style_dashed, width = 2)
    array.push(s_lines, new_s)
    while array.size(s_lines) > show_n
        oldest = array.shift(s_lines)
        line.delete(oldest)
