// @version=5
//
// ORB — Opening Range Breakout (5m day-trade engine).
//
// ONE pattern: the FIRST confirmed 5m CLOSE that breaks OUT of the opening range,
// in the morning window, that passes hard quality gates. This is the initial
// BREAKOUT — distinct from rc.pine's ORH plays, which trade the range three OTHER
// ways (reclaim_long = dip & reclaim the ORH · ORL held/reclaim = the magnet bounce
// · ORH rejection = the failed-break fade). ORB is the clean punch through the box.
//
//   OR   = high/low of the first `orMin` minutes of the RTH session (the box).
//   ORB↑ = first 5m CLOSE above the OR high (morning, once/day)  → BUY.
//   ORB↓ = first 5m CLOSE below the OR low  (toggle, default OFF) → SELL.
//
// VALIDATION PINE — draws a box on EVERY historical session so you can backtest by
// eye, and shows every RAW breakout: all quality gates (volume · VWAP · OR-width)
// DEFAULT OFF so you see the pattern first, then switch them on one at a time to
// watch them prune. Base signal is just: confirmed close outside the OR, once/day.
//
// VISUAL-ONLY (no alerts yet) — load on a 5m REGULAR-SESSION chart (ETH prints
// would poison the OR) and eyeball the setups on SPY/QQQ/AAPL. Each breakout draws
// its stop + target so the trade geometry is judgeable at a glance.
//
// v2 — PDH/PDL TRUST LAYER. An ORB is only trustworthy in confluence with the
// prior day's levels. After a fire, every confirmed close is checked live:
//   ✗ broke PDL — a long closing below the prior-day LOW is a failed entry.
//   ✗ lost PDH  — once price has closed ABOVE the prior-day HIGH it must STAY
//                 above; a close back below PDH invalidates the trade.
//                 (SPY Jul-2: ORB↑ fired at PDH 749.3, lost it, bled to 740.)
// Shorts mirrored. The losing bar gets an orange "✗ INVAL — reason" tag the
// moment it happens — exit signal, not an EOD autopsy.
//
indicator("ORB · Opening Range Breakout", "ORB", overlay = true, max_labels_count = 300, max_lines_count = 500, max_boxes_count = 500)

// ── Enables ────────────────────────────────────────────────────────────────
gE = "ORB signals"
en_long  = input.bool(true,  "ORB↑ — break above the OR high (BUY)", group = gE)
en_short = input.bool(false, "ORB↓ — break below the OR low (SELL) — off by default", group = gE)

// ── PDH/PDL trust layer — the confluence that makes an ORB trustworthy ────────
gP = "PDH/PDL trust layer"
usePD  = input.bool(true, "Live invalidation — long dies on a close below PDL, or on losing PDH once crossed (short mirrored)", group = gP)
showPD = input.bool(true, "Draw the PDH / PDL lines across the day", group = gP)

// ── Opening range + timing (MINUTE-based → TF-agnostic, tuned for 5m) ────────
gW = "Opening range & window"
orMin    = input.int(15,  "Opening-range minutes", minval = 5, maxval = 60, step = 5, group = gW)
mornMin  = input.int(120, "Breakout window minutes from the open (morning only)", minval = 30, group = gW)

// ── Quality gates (the precision knobs) — ALL DEFAULT OFF. See every raw breakout
// first, THEN switch gates on one at a time to watch them prune (data before filter).
gQ = "Quality gates (default OFF — turn on to grade)"
useVol   = input.bool(false, "Require volume expansion on the break bar", group = gQ)
volMult  = input.float(1.2,  "  break-bar volume ≥ this × a rolling avg", minval = 1.0, step = 0.1, group = gQ)
volLb    = input.int(20,     "  rolling volume-average lookback (bars)", minval = 5, group = gQ)
useVwap  = input.bool(false, "Require close on the trend side of VWAP (above for ↑, below for ↓)", group = gQ)
useWidth = input.bool(false, "Require OR width inside a sane band", group = gQ)
orMinPct = input.float(0.3,  "  OR width FLOOR — box ≥ this % of price (noise)", minval = 0.0, step = 0.1, group = gQ)
orMaxPct = input.float(3.0,  "  OR width CAP — box ≤ this % of price (no room)", minval = 0.5, step = 0.5, group = gQ)

// ── Visual ───────────────────────────────────────────────────────────────────
gV = "Visual"
showOR    = input.bool(true,  "Draw the OR high / low lines", group = gV)
showBox   = input.bool(true,  "Shade the opening-range box", group = gV)
showTags  = input.bool(true,  "Mark the breakout bar", group = gV)
showTrade = input.bool(true,  "Draw stop / target lines on a breakout", group = gV)
colORH    = input.color(color.teal,   "OR high line",   group = gV, inline = "or")
colORL    = input.color(color.maroon, "OR low line",    group = gV, inline = "or")
colBox    = input.color(color.new(color.gray, 90), "OR box fill", group = gV)
colUp     = input.color(color.lime,   "ORB↑ marker",    group = gV, inline = "mk")
colDn     = input.color(color.red,    "ORB↓ marker",    group = gV, inline = "mk")
colTgt    = input.color(color.green,  "Target line",    group = gV, inline = "tr")
colStop   = input.color(color.red,    "Stop line",      group = gV, inline = "tr")

// ── Session anchor — new RTH session = the daily-bar rollover (9:30 ET on an
// RTH 5m chart). barsPerMin converts the minute windows to bar counts on any TF.
nD = ta.change(time("D")) != 0
barsPerMin = math.max(1.0, timeframe.in_seconds() / 60.0)
orBars   = math.max(1, math.round(orMin / barsPerMin))
mornBars = math.round(mornMin / barsPerMin)

// bar index within the session (0 = the open bar)
var int sbar = 0
sbar := nD ? 0 : sbar + 1

// ── Build the opening range over the first `orBars` bars.
var float orh = na
var float orl = na
if nD
    orh := high
    orl := low
else if sbar < orBars
    orh := math.max(orh, high)
    orl := math.min(orl, low)
orReady  = sbar >= orBars
inMorn   = sbar <= mornBars
// Volume yardstick = a rolling average (NOT the opening bars, which are the day's
// volume peak — beating them is nearly impossible, which killed every signal).
volAvg = ta.sma(volume, volLb)

// ── Prior-day levels (context + target; from COMPLETED daily bars, no repaint).
hDp = request.security(syminfo.tickerid, "D", high[1], lookahead = barmerge.lookahead_on)
lDp = request.security(syminfo.tickerid, "D", low[1],  lookahead = barmerge.lookahead_on)

vwap = ta.vwap(hlc3)

// ── OR-width gate — the box must be a sane size relative to price. Guard na first
// (Pine `and` is NOT short-circuited). Off unless useWidth.
orRange   = (not na(orh)) and (not na(orl)) ? orh - orl : na
orWidthPct = (not na(orRange)) and close > 0 ? orRange / close * 100.0 : na
widthOK = (not useWidth) or ((not na(orWidthPct)) and orWidthPct >= orMinPct and orWidthPct <= orMaxPct)

// volume gate on the current (potential break) bar — off unless useVol.
volOK = (not useVol) or ((not na(volAvg)) and volume >= volAvg * volMult)

// ── ORB↑ — first CLOSE above the OR high, once per session. armed only once the
// OR is complete + we're in the morning window + the box passed the width gate.
var bool long_fired = false
if nD
    long_fired := false
vwapUpOK = (not useVwap) or close > vwap
orbLong = en_long and orReady and inMorn and widthOK and (not long_fired) and (not na(orh)) and close > orh and volOK and vwapUpOK
if orbLong
    long_fired := true

// ── ORB↓ — first CLOSE below the OR low, once per session (toggle, default OFF).
var bool short_fired = false
if nD
    short_fired := false
vwapDnOK = (not useVwap) or close < vwap
orbShort = en_short and orReady and inMorn and widthOK and (not short_fired) and (not na(orl)) and close < orl and volOK and vwapDnOK
if orbShort
    short_fired := true

// ── Targets & stop. Long: stop = OR low · target = a measured move (ORH + 1× OR
// range), unless the prior-day high sits closer above (a real wall to trade into).
// Short: mirror (stop = OR high · target = ORL − range, PDL as context).
orbLongTgt  = (not na(orh)) and (not na(orRange)) ? orh + orRange : na
orbLongTgt2 = (not na(hDp)) and (not na(orbLongTgt)) and hDp > close and hDp < orbLongTgt ? hDp : orbLongTgt
orbShortTgt = (not na(orl)) and (not na(orRange)) ? orl - orRange : na

// ── TRUST LAYER — live invalidation on every confirmed close after the fire.
// Long : ✗ close below PDL (failed entry) · ✗ crossed above PDH then closed back
// below it (must STAY above once through). Short mirrored. The losing bar gets
// tagged the moment it happens — this is the EXIT signal, not an EOD autopsy.
var int  tradeDir = 0        // first fire wins the session: +1 long · -1 short
var bool pdInval  = false
var bool crossUp  = false    // long has closed above PDH → must now hold it
var bool crossDn  = false    // short has closed below PDL → must now hold it
if nD
    tradeDir := 0
    pdInval  := false
    crossUp  := false
    crossDn  := false
if orbLong and tradeDir == 0
    tradeDir := 1
if orbShort and tradeDir == 0
    tradeDir := -1

string invalWhy = na
if usePD and tradeDir != 0 and not pdInval and not na(hDp) and not na(lDp)
    if tradeDir > 0
        crossUp := crossUp or close > hDp
        if close < lDp
            invalWhy := "broke PDL"
        else if crossUp and close < hDp
            invalWhy := "lost PDH"
    else
        crossDn := crossDn or close < lDp
        if close > hDp
            invalWhy := "broke PDH"
        else if crossDn and close > lDp
            invalWhy := "reclaimed PDL"
if not na(invalWhy)
    pdInval := true
    label.new(bar_index, close, "✗ INVAL — " + invalWhy, style = tradeDir > 0 ? label.style_label_down : label.style_label_up, color = na, textcolor = color.orange, size = size.small)

// ── Visuals (no alerts — this is the validation pine) ────────────────────────
// Draw the OR box + edges ONCE PER SESSION, the moment the OR completes, framed
// across the morning window — so history shows a box on EVERY day (backtest by eye),
// not just the last. TV keeps the most recent ~50 boxes / 100 lines automatically.
orDone   = sbar == orBars                       // the single bar where the OR just closed
boxLeft  = bar_index - orBars                   // the session open bar
boxRight = bar_index + math.max(1, mornBars - orBars)   // out to the end of the morning window
dayBars  = math.round(390 / barsPerMin)         // full RTH session, for the PD rails
if orDone and not na(orh)
    if showBox
        box.new(boxLeft, orh, boxRight, orl, border_color = na, bgcolor = colBox)
    if showOR
        line.new(boxLeft, orh, boxRight, orh, color = colORH, width = 1)
        line.new(boxLeft, orl, boxRight, orl, color = colORL, width = 1)
    // PDH/PDL rails span the whole day — invalidation is judged against them all session
    if showPD and not na(hDp)
        line.new(boxLeft, hDp, boxLeft + dayBars, hDp, color = color.new(color.red, 40),    style = line.style_dashed)
        line.new(boxLeft, lDp, boxLeft + dayBars, lDp, color = color.new(color.maroon, 40), style = line.style_dashed)

plotshape(showTags and orbLong,  title = "ORB up",   style = shape.triangleup,   location = location.belowbar, color = colUp, size = size.small, text = "ORB↑")
plotshape(showTags and orbShort, title = "ORB down", style = shape.triangledown, location = location.abovebar, color = colDn, size = size.small, text = "ORB↓")

// ── Trade geometry — on a breakout, draw the stop + target so the setup is
// judgeable at a glance (extended a few bars to the right). Long only shown for ↑,
// mirror for ↓. Kept lightweight (a fresh pair per breakout, no cleanup needed —
// once/day/side means at most 2 pairs a session).
draw_trade(bool fire, float stp, float tgt) =>
    if fire and showTrade
        line.new(bar_index, tgt, bar_index + 8, tgt, color = colTgt,  width = 1, style = line.style_dashed)
        line.new(bar_index, stp, bar_index + 8, stp, color = colStop, width = 1, style = line.style_dashed)
        label.new(bar_index + 8, tgt, "T " + str.tostring(tgt, format.mintick), style = label.style_label_left, color = na, textcolor = colTgt,  size = size.small)
        label.new(bar_index + 8, stp, "S " + str.tostring(stp, format.mintick), style = label.style_label_left, color = na, textcolor = colStop, size = size.small)
draw_trade(orbLong,  orl, orbLongTgt2)
draw_trade(orbShort, orh, orbShortTgt)
