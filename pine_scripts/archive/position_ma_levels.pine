// @version=5
//
// Position Trade MA Levels + Minervini Stage Detection
//
// Tracks 4 daily simple moving averages:
//   • 20 SMA  — fast trail (momentum/swing trader's protection line)
//   • 50 SMA  — THE institutional gain-protection line
//   • 150 SMA — Minervini Trend Template intermediate-term reference
//   • 200 SMA — major long-term trend (the "bull/bear line")
//
// Mirrors Mark Minervini's "Trade Like a Stock Market Wizard" framework.
// His Trend Template requires: Price > 50 > 150 > 200 SMA + 200 SMA up.
//
// Stage badge (top-right corner) classifies the chart into one of:
//   • STAGE 2 ✓ ADVANCING — bullish, in the buy zone
//   • STAGE 4 ✗ DECLINING — bearish, no longs / consider shorts
//   • STAGE 1 ⏸ BASING    — sideways post-decline, wait for breakout
//   • STAGE 3 ⏸ TOPPING   — sideways post-advance, wait for breakdown
//   • TRANSITIONING ⚠     — between stages, no clean signal
//
// Detection per MA (mirrors daily_ma_bounce.pine):
//   • bounce_long  — low wicked the SMA, close above it, candle is green
//   • reject_short — high tagged the SMA from below, close below, red candle
//
// Add to a DAILY chart for true position trading. Will work on intraday TFs
// too (daily SMAs pulled via request.security).
//
// Alert rules (routed via /tv/webhook → Telegram):
//   • position_ma_bounce_long      (BUY)
//   • position_ma_rejection_short  (SHORT)
//
indicator("Position Trade MAs + Minervini Stage", overlay = true, max_labels_count = 500)

show_lines        = input.bool(true,  "Show daily SMA lines")
show_markers      = input.bool(true,  "Show BOUNCE/REJECT markers")
show_price_labels = input.bool(false, "Show MA values in right price scale (declutter when off)")
show_stage_badge  = input.bool(true,  "Show Minervini Stage badge (top-right)")
show_stage_bg     = input.bool(false, "Tint background by stage (subtle)")
tolerance_atr     = input.float(0.5,  "Tolerance (× ATR14)", minval = 0.1, maxval = 3.0, step = 0.1)
slope_lookback    = input.int(20,     "200 SMA slope lookback (days)", minval = 5, maxval = 60)
label_size_in     = input.string("small", "Marker label size", options = ["tiny", "small", "normal", "large"])
fire_alerts       = input.bool(true,  "Fire bounce/rejection alerts to webhook")

label_size = label_size_in == "tiny" ? size.tiny : label_size_in == "small" ? size.small : label_size_in == "large" ? size.large : size.normal

ma_disp = show_price_labels ? display.all : (display.pane + display.status_line + display.data_window)

// Pull daily SMAs with [1] offset + lookahead_on for stable horizontal lines.
sma20  = request.security(syminfo.tickerid, "D", ta.sma(close, 20)[1],  lookahead = barmerge.lookahead_on)
sma50  = request.security(syminfo.tickerid, "D", ta.sma(close, 50)[1],  lookahead = barmerge.lookahead_on)
sma150 = request.security(syminfo.tickerid, "D", ta.sma(close, 150)[1], lookahead = barmerge.lookahead_on)
sma200 = request.security(syminfo.tickerid, "D", ta.sma(close, 200)[1], lookahead = barmerge.lookahead_on)

// 200 SMA from N days ago, for slope detection. Uses request.security so we
// get DAILY-bar offsets regardless of chart timeframe.
sma200_past = request.security(syminfo.tickerid, "D", ta.sma(close, 200)[1 + slope_lookback], lookahead = barmerge.lookahead_on)

// Plot the 4 SMAs.
plot(show_lines ? sma20  : na, "SMA 20 (D)",  color = color.new(#F57F17,       20), linewidth = 2, display = ma_disp)
plot(show_lines ? sma50  : na, "SMA 50 (D)",  color = color.new(color.green,    0), linewidth = 3, display = ma_disp)
plot(show_lines ? sma150 : na, "SMA 150 (D)", color = color.new(#1565C0,       20), linewidth = 2, display = ma_disp)
plot(show_lines ? sma200 : na, "SMA 200 (D)", color = color.new(color.black,    0), linewidth = 3, display = ma_disp)

// =====================================================================
// MINERVINI STAGE DETECTION
// =====================================================================
// 200 SMA slope: rising, falling, or flat (within ±0.5% over lookback).
sma200_change_pct = not na(sma200) and not na(sma200_past) ? (sma200 - sma200_past) / sma200_past * 100 : na
sma200_rising  = not na(sma200_change_pct) and sma200_change_pct >  0.5
sma200_falling = not na(sma200_change_pct) and sma200_change_pct < -0.5
sma200_flat    = not na(sma200_change_pct) and not sma200_rising and not sma200_falling

// MA stack alignment.
stack_bullish = not na(sma200) and close > sma50 and sma50 > sma150 and sma150 > sma200
stack_bearish = not na(sma200) and close < sma50 and sma50 < sma150 and sma150 < sma200

// Stage classification.
is_stage2 = stack_bullish and sma200_rising
is_stage4 = stack_bearish and sma200_falling
is_stage1 = not is_stage2 and not is_stage4 and not na(sma200) and close <  sma200 and (sma200_flat or sma200_falling)
is_stage3 = not is_stage2 and not is_stage4 and not na(sma200) and close >= sma200 and (sma200_flat or sma200_rising)

// Stage label — if/else block (Pine v5 doesn't like deeply-chained
// multi-line ternaries; this is the safer pattern). ASCII-only to avoid
// any unicode round-trip issues across editors.
string stage_text = "TRANSITIONING"
color  stage_bg   = color.new(color.purple, 30)
if na(sma200)
    stage_text := "INSUFFICIENT DATA"
    stage_bg   := color.new(color.gray, 30)
else if is_stage2
    stage_text := "STAGE 2: ADVANCING"
    stage_bg   := color.new(color.green, 10)
else if is_stage4
    stage_text := "STAGE 4: DECLINING"
    stage_bg   := color.new(color.red, 10)
else if is_stage1
    stage_text := "STAGE 1: BASING"
    stage_bg   := color.new(color.gray, 30)
else if is_stage3
    stage_text := "STAGE 3: TOPPING"
    stage_bg   := color.new(color.orange, 10)

// Stage badge — top-right corner.
var table stage_t = table.new(position.top_right, 1, 1, frame_color = color.gray, frame_width = 1, border_width = 1)
if show_stage_badge and barstate.islast
    table.cell(stage_t, 0, 0, stage_text, text_color = color.white, bgcolor = stage_bg, text_size = size.normal)

// Optional bgcolor tint by stage (subtle — 95% transparent).
bgcolor(show_stage_bg and is_stage2 ? color.new(color.green,  95) : na, title = "Stage 2 bg")
bgcolor(show_stage_bg and is_stage4 ? color.new(color.red,    95) : na, title = "Stage 4 bg")

// =====================================================================
// BOUNCE / REJECTION DETECTION + ALERTS
// =====================================================================
atr14 = nz(ta.atr(14)[1], close * 0.005)
tol   = atr14 * tolerance_atr

bounce_long(float ma) =>
    not na(ma) and low <= ma + tol and low >= ma - tol * 2 and close > ma and close > open

reject_short(float ma) =>
    not na(ma) and high >= ma - tol and high <= ma + tol * 2 and close < ma and close < open

b_20  = bounce_long(sma20)
b_50  = bounce_long(sma50)
b_150 = bounce_long(sma150)
b_200 = bounce_long(sma200)

r_20  = reject_short(sma20)
r_50  = reject_short(sma50)
r_150 = reject_short(sma150)
r_200 = reject_short(sma200)

any_long  = b_20 or b_50 or b_150 or b_200
any_short = r_20 or r_50 or r_150 or r_200

long_tag  = (b_20 ? "20 "  : "") + (b_50 ? "50 "  : "") + (b_150 ? "150 " : "") + (b_200 ? "200 " : "")
short_tag = (r_20 ? "20 "  : "") + (r_50 ? "50 "  : "") + (r_150 ? "150 " : "") + (r_200 ? "200 " : "")

plotshape(show_markers and any_long,
          title = "Bounce LONG", location = location.belowbar,
          color = color.new(color.green, 0), style = shape.triangleup,
          size = size.small)
plotshape(show_markers and any_short,
          title = "Reject SHORT", location = location.abovebar,
          color = color.new(color.red, 0), style = shape.triangledown,
          size = size.small)

if show_markers and any_long
    label.new(bar_index, low, long_tag,
              style = label.style_label_up,
              color = color.new(color.green, 0),
              textcolor = color.white,
              size = label_size,
              yloc = yloc.belowbar)
if show_markers and any_short
    label.new(bar_index, high, short_tag,
              style = label.style_label_down,
              color = color.new(color.red, 0),
              textcolor = color.white,
              size = label_size,
              yloc = yloc.abovebar)

// JSON payload — includes stage info so Telegram side can highlight when
// a bounce happens IN STAGE 2 (high conviction) vs counter-trend.
build_payload(string rule, string direction, string ma_tag) =>
    '{"symbol":"' + syminfo.ticker
      + '","exchange":"' + syminfo.prefix
      + '","interval":"' + timeframe.period
      + '","price":"' + str.tostring(close, format.mintick)
      + '","high":"' + str.tostring(high, format.mintick)
      + '","low":"' + str.tostring(low, format.mintick)
      + '","volume":"' + str.tostring(volume)
      + '","rule":"' + rule
      + '","direction":"' + direction
      + '","ma_tag":"' + str.replace_all(ma_tag, " ", "")
      + '","sma20":"'  + str.tostring(sma20,  format.mintick)
      + '","sma50":"'  + str.tostring(sma50,  format.mintick)
      + '","sma150":"' + str.tostring(sma150, format.mintick)
      + '","sma200":"' + str.tostring(sma200, format.mintick)
      + '","stage":"'  + stage_text
      + '","fired_at":"' + str.tostring(timenow) + '"}'

if fire_alerts and any_long
    alert(build_payload("position_ma_bounce_long",     "BUY",   long_tag),  alert.freq_once_per_bar_close)
if fire_alerts and any_short
    alert(build_payload("position_ma_rejection_short", "SHORT", short_tag), alert.freq_once_per_bar_close)
