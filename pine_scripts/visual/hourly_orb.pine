// @version=5
// Hourly ORB — VISUAL ONLY (no alerts). The 1-HOUR opening range (ORH/ORL) plus the prior-day
// high/low (PDH/PDL). Every level is LOCKED to its source timeframe via request.security, so the
// lines stay put on ANY chart TF — flip 5m ↔ 15m ↔ 1h ↔ D and nothing moves.
//
// Load on a REGULAR-SESSION (RTH) chart so the opening range anchors at the 9:30 open (ETH poisons
// it). Companion to the 15-min ORB in rc.pine — this one is the slower, 1-hour range for context.
indicator("Hourly ORB · ORH/ORL + PDH/PDL + MA reclaim/reject · VISUAL", "H-ORB", overlay = true, max_lines_count = 200, max_labels_count = 500, max_boxes_count = 60)

gS = "Opening range (1-hour, locked to 1h bars)"
orMin   = input.int(60,  "Opening-range minutes", minval = 60, maxval = 240, step = 60, group = gS)
showBox = input.bool(true, "Draw the OR box (per session)", group = gS)
gV = "Display"
showOR  = input.bool(true, "ORH / ORL lines", group = gV)
showPD  = input.bool(true, "PDH / PDL lines", group = gV)
showLbl = input.bool(true, "Level labels", group = gV)
colORH  = input.color(color.new(color.teal, 0),  "ORH", group = gV, inline = "or")
colORL  = input.color(color.new(#0E7490, 0),     "ORL", group = gV, inline = "or")
colPDH  = input.color(color.new(color.red, 0),   "PDH", group = gV, inline = "pd")
colPDL  = input.color(color.new(color.green, 0), "PDL", group = gV, inline = "pd")
colBox  = input.color(color.new(color.teal, 90), "OR box fill", group = gV)

// ── PDH / PDL — prior COMPLETED daily bar, locked (lookahead_on + [1] ⇒ identical on every TF, no repaint) ──
[pdh, pdl] = request.security(syminfo.tickerid, "D", [high[1], low[1]], lookahead = barmerge.lookahead_on)

// ── 1-hour opening range — computed on 1h bars via request.security so it's identical on any chart TF.
// OR = the first ceil(orMin/60) 1h bars of the RTH session (orMin=60 ⇒ the first 1h bar, 9:30–10:30).
f_or60() =>
    var float _h = na
    var float _l = na
    var int   _sb = 0
    _new = ta.change(time("D")) != 0
    _sb := _new ? 0 : _sb + 1
    _bars = math.max(1, math.round(orMin / 60.0))
    if _new
        _h := high
        _l := low
    else if _sb < _bars
        _h := math.max(_h, high)
        _l := math.min(_l, low)
    [_h, _l]
[orh, orl] = request.security(syminfo.tickerid, "60", f_or60(), lookahead = barmerge.lookahead_on)

// ── Lines — TRUE flat horizontals (one line.new per level per session, y1 == y2 so it never
// curves; a fresh line each day so they don't connect across sessions) ──
nD = ta.change(time("D")) != 0

f_flat(line ln, bool show, float y, color col, int w, bool newDay) =>
    line _ln = ln
    if show and not na(y)
        if na(_ln) or newDay
            _ln := line.new(bar_index, y, bar_index, y, color = col, width = w)
        else
            line.set_y1(_ln, y)
            line.set_y2(_ln, y)
            line.set_x2(_ln, bar_index)
    _ln

var line lnORH = na
var line lnORL = na
var line lnPDH = na
var line lnPDL = na
lnORH := f_flat(lnORH, showOR, orh, colORH, 2, nD)
lnORL := f_flat(lnORL, showOR, orl, colORL, 2, nD)
lnPDH := f_flat(lnPDH, showPD, pdh, colPDH, 1, nD)
lnPDL := f_flat(lnPDL, showPD, pdl, colPDL, 1, nD)

// ── OR box — one per session, shaded between ORH/ORL across the RTH day ──
barsPerDay = math.round(390 / math.max(1.0, timeframe.in_seconds() / 60.0))
var box orBox = na
if showBox and nD and not na(orh) and not na(orl)
    orBox := box.new(bar_index, orh, bar_index + barsPerDay, orl, border_color = color.new(color.teal, 60), bgcolor = colBox)

// ── THE SIGNAL — a RECLAIM of the 1h OR low or high. The ONLY alert; no break/held/retest/exit
// noise (user 2026-07-07: "all we need is a reclaim of either the low or high"). ORL reclaim =
// undercut the OR low & close back above → bounce. ORH reclaim = broke the OR high, pulled back &
// reclaimed → breakout-retest. Both LONG, once per session (sweep-&-reclaim, the same logic as RC).
gA = "Reclaim entry (the only alert)"
en_orl_rc = input.bool(true, "ORL reclaim — undercut & reclaim the OR LOW (bounce, BUY)", group = gA)
en_orh_rc = input.bool(true, "ORH reclaim — broke & reclaimed the OR HIGH (retest, BUY)", group = gA)
showRc    = input.bool(true, "Show reclaim arrows", group = gA)

f_reclaim(float level, bool en, bool arm_break) =>
    var bool _armed = false
    var bool _swept = false
    var bool _fired = false
    if ta.change(time("D")) != 0
        _armed := false
        _swept := false
        _fired := false
    bool _fire = false
    if not na(level)
        if (close > level) or (arm_break and high > level)
            _armed := true
        if _armed and low < level
            _swept := true
        _fire := en and _swept and close > level and not _fired
        if _fire
            _fired := true
    _fire

orl_rc = f_reclaim(orl, en_orl_rc, false)
orh_rc = f_reclaim(orh, en_orh_rc, true)
plotshape(showRc and orl_rc, "ORL reclaim", style = shape.triangleup, location = location.belowbar, color = color.new(colORL, 0), size = size.small, text = "RC-L")
plotshape(showRc and orh_rc, "ORH reclaim", style = shape.triangleup, location = location.belowbar, color = color.new(colORH, 0), size = size.small, text = "RC-H")

// NO alert() here — H-ORB is VISUAL only (the arrows above just SHOW the reclaims). The actual
// orb_reclaim ALERT lives in rc.pine (an already-bound pine), since only 2 alert-pines can be bound.

// ══════════════════════════════════════════════════════════════════════════════════════════════
// MA / EMA reclaim (▲) + reject (▼) — a pure day-trade tool on the daily MA levels. A daily MA is a
// FLAT intraday level (it only updates on the daily close, like PDL). When a bar CLOSES BACK ABOVE
// an MA it was below = RECLAIM (bullish ▲); when it CLOSES BACK BELOW an MA it was above = REJECT /
// lose (bearish ▼). ta.crossover/under fire ON the crossing bar and render live on the forming bar,
// and each arrow is TAGGED with which MA crossed (8E / 21E / 100E / 200S …).
gM = "MA / EMA reclaim (▲) + reject (▼)"
enMA     = input.bool(true, "Mark MA reclaim (▲) / reject (▼) with a tag", group = gM)
showMAln = input.bool(true, "Draw the daily MA levels as flat lines", group = gM)
maSzIn   = input.string("small", "Arrow tag size", options = ["tiny", "small", "normal"], group = gM)
useE8   = input.bool(true, "EMA 8",   group = gM, inline = "e")
useE21  = input.bool(true, "EMA 21",  group = gM, inline = "e")
useE50  = input.bool(true, "EMA 50",  group = gM, inline = "e")
useE100 = input.bool(true, "EMA 100", group = gM, inline = "f")
useE200 = input.bool(true, "EMA 200", group = gM, inline = "f")
useS50  = input.bool(true, "SMA 50",  group = gM, inline = "s")
useS100 = input.bool(true, "SMA 100", group = gM, inline = "s")
useS200 = input.bool(true, "SMA 200", group = gM, inline = "s")
_maSz = maSzIn == "tiny" ? size.tiny : maSzIn == "normal" ? size.normal : size.small

// Daily MAs (yesterday's settled value via [1] — flat intraday), bundled into 2 security calls.
[ema8, ema21, ema50, ema100, ema200] = request.security(syminfo.tickerid, "D", [ta.ema(close, 8)[1], ta.ema(close, 21)[1], ta.ema(close, 50)[1], ta.ema(close, 100)[1], ta.ema(close, 200)[1]], lookahead = barmerge.lookahead_on)
[sma50, sma100, sma200] = request.security(syminfo.tickerid, "D", [ta.sma(close, 50)[1], ta.sma(close, 100)[1], ta.sma(close, 200)[1]], lookahead = barmerge.lookahead_on)

// Tag builders — ta.crossover/under evaluated unconditionally (Pine needs ta.* on every bar).
f_rc(bool use, float ma, string nm) =>
    bool x = ta.crossover(close, ma)
    use and not na(ma) and x ? nm + " " : ""
f_rj(bool use, float ma, string nm) =>
    bool x = ta.crossunder(close, ma)
    use and not na(ma) and x ? nm + " " : ""

rcTag = f_rc(useE8, ema8, "8E") + f_rc(useE21, ema21, "21E") + f_rc(useE50, ema50, "50E") + f_rc(useE100, ema100, "100E") + f_rc(useE200, ema200, "200E") + f_rc(useS50, sma50, "50S") + f_rc(useS100, sma100, "100S") + f_rc(useS200, sma200, "200S")
rjTag = f_rj(useE8, ema8, "8E") + f_rj(useE21, ema21, "21E") + f_rj(useE50, ema50, "50E") + f_rj(useE100, ema100, "100E") + f_rj(useE200, ema200, "200E") + f_rj(useS50, sma50, "50S") + f_rj(useS100, sma100, "100S") + f_rj(useS200, sma200, "200S")

if enMA and rcTag != ""
    label.new(bar_index, low, "▲ " + rcTag, yloc = yloc.belowbar, style = label.style_label_up, color = color.new(color.green, 0), textcolor = color.white, size = _maSz)
if enMA and rjTag != ""
    label.new(bar_index, high, "▼ " + rjTag, yloc = yloc.abovebar, style = label.style_label_down, color = color.new(color.red, 0), textcolor = color.white, size = _maSz)

// Flat MA lines — drawn once on the last bar, colored by role (green = support / red = resistance).
var line[]  maLines = array.new_line()
var label[] maLbls  = array.new_label()
f_maLine(float ma, string nm, bool dotted, bool use) =>
    if showMAln and use and not na(ma)
        bool sup = close > ma
        color mc = sup ? color.new(color.teal, 0) : color.new(color.red, 0)
        array.push(maLines, line.new(bar_index - 60, ma, bar_index + 4, ma, color = mc, width = 1, style = dotted ? line.style_dotted : line.style_solid))
        array.push(maLbls, label.new(bar_index + 4, ma, nm + (sup ? " S " : " R ") + str.tostring(ma, format.mintick), style = label.style_label_left, color = color.new(mc, 80), textcolor = mc, size = size.small))
if barstate.islast
    for l in maLines
        line.delete(l)
    for lb in maLbls
        label.delete(lb)
    array.clear(maLines)
    array.clear(maLbls)
    f_maLine(ema8,   "EMA 8",   false, useE8)
    f_maLine(ema21,  "EMA 21",  false, useE21)
    f_maLine(ema50,  "EMA 50",  false, useE50)
    f_maLine(ema100, "EMA 100", false, useE100)
    f_maLine(ema200, "EMA 200", false, useE200)
    f_maLine(sma50,  "SMA 50",  true,  useS50)
    f_maLine(sma100, "SMA 100", true,  useS100)
    f_maLine(sma200, "SMA 200", true,  useS200)

// ── Labels — the current value at the right edge, moved to the last bar each update ──
f_lbl(bool cond, float y, string txt, color col) =>
    var label _lb = na
    label.delete(_lb)
    _lb := cond and not na(y) ? label.new(bar_index, y, txt + " " + str.tostring(y, format.mintick), style = label.style_label_left, color = color.new(col, 85), textcolor = col, size = size.small) : na
    _lb
f_lbl(showLbl and showOR, orh, "ORH", colORH)
f_lbl(showLbl and showOR, orl, "ORL", colORL)
f_lbl(showLbl and showPD, pdh, "PDH", colPDH)
f_lbl(showLbl and showPD, pdl, "PDL", colPDL)
