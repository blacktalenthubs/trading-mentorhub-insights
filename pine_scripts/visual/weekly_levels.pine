//@version=5
// ─────────────────────────────────────────────────────────────────────────────
// Weekly Levels — VISUAL ONLY (chart-only; bind NO alert). Pure read, no entry/stop.
// ─────────────────────────────────────────────────────────────────────────────
// FLAT 10w + 30w weekly MA levels + three SIGNS, ALL computed on the WEEKLY via one
// request.security tuple with lookahead_on — so every sign sits in the SAME place on
// any chart TF (drop to 4h to time it; the weekly signs don't move). The ALERTS
// (weekly_ma_held + weekly_rc) fire from levels_day_vwap.pine.
//   • 10w↑ / 30w↑ — weekly RECLAIM (close back above the MA) or HOLD (pullback to the
//                   rising MA + bounce). Recent WEEKS only (they drift as the MA moves).
//   • wRC ◆       — undercut + reclaim of the prior-week low, closing up or in the top
//                   half of the bar (strong reclaim). Shown in full (a price event).
// ─────────────────────────────────────────────────────────────────────────────
indicator("Weekly Levels", "WkLvls", overlay = true, max_lines_count = 4, max_labels_count = 100)

show_10w  = input.bool(true, "Flat 10w MA line")
show_30w  = input.bool(true, "Flat 30w MA line")
show_marc = input.bool(true, "10w / 30w reclaim/hold signs")
show_rc   = input.bool(true, "Weekly RC sign (prior-week-low reclaim)")
recent    = input.int (8,    "10w↑/30w↑ signs: recent WEEKS only — they drift as the MA moves (0 = all)", minval = 0)
line_len  = input.int (60,   "Line length (bars back)", minval = 10, maxval = 500)
col_sup   = input.color(#26A69A, "Support (price above the line)")
col_res   = input.color(#EF5350, "Resistance (price below the line)")

// ── Everything on the WEEKLY (one tuple, lookahead_on) so the signs are TF-anchored:
// reclaim = close crosses back above the MA; hold = pullback to the rising MA + bounce
// (low tags it, prior bar cleanly above); wRC = strong prior-week-low reclaim. ──
f_wk() =>
    _m10  = ta.sma(close, 10)
    _m30  = ta.sma(close, 30)
    _rc10 = ta.crossover(close, _m10) or (close > _m10 and low <= _m10 and close[1] > _m10[1] and low[1] > _m10[1])
    _rc30 = ta.crossover(close, _m30) or (close > _m30 and low <= _m30 and close[1] > _m30[1] and low[1] > _m30[1])
    _wrc  = (low < low[1]) and (close > low[1]) and ((close > open) or (close - low >= (high - low) * 0.5))
    [_m10, _m30, _rc10, _rc30, _wrc]
[w10, w30, sig10, sig30, wrc] = request.security(syminfo.tickerid, "W", f_wk(), lookahead = barmerge.lookahead_on)

// ── Flat lines + value labels, redrawn on the last bar. ──
var line  ln10 = na
var line  ln30 = na
var label lb10 = na
var label lb30 = na
if barstate.islast
    line.delete(ln10)
    line.delete(ln30)
    label.delete(lb10)
    label.delete(lb30)
    if show_10w and not na(w10)
        c10 = close > w10 ? col_sup : col_res
        ln10 := line.new(bar_index - line_len, w10, bar_index + 10, w10, color = c10, width = 2)
        lb10 := label.new(bar_index + 10, w10, "10w " + str.tostring(w10, format.mintick), style = label.style_label_left, color = c10, textcolor = color.white, size = size.small)
    if show_30w and not na(w30)
        c30 = close > w30 ? col_sup : col_res
        ln30 := line.new(bar_index - line_len, w30, bar_index + 10, w30, color = c30, width = 2)
        lb30 := label.new(bar_index + 10, w30, "30w " + str.tostring(w30, format.mintick), style = label.style_label_left, color = c30, textcolor = color.white, size = size.small)

// ── Signs fire ONCE per weekly event via "and not [1]". 10w↑/30w↑ are recent-windowed by
// TIME (weeks, so it's identical on any chart TF); wRC is shown in full (a price event). ──
in_win = recent == 0 or (timenow - time) <= recent * 604800000
plotshape(show_marc and in_win and sig10 and not sig10[1], title = "10w reclaim/hold", style = shape.triangleup, location = location.belowbar, color = color.new(color.lime, 0), size = size.tiny, text = "10w↑")
plotshape(show_marc and in_win and sig30 and not sig30[1], title = "30w reclaim/hold", style = shape.triangleup, location = location.belowbar, color = color.new(color.teal, 0), size = size.tiny, text = "30w↑")
plotshape(show_rc and wrc and not wrc[1], title = "Weekly RC", style = shape.diamond, location = location.belowbar, color = color.new(#2962FF, 0), size = size.tiny, text = "wRC")
