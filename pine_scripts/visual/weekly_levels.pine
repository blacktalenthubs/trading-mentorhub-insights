//@version=5
// ─────────────────────────────────────────────────────────────────────────────
// Weekly Levels — VISUAL ONLY (chart-only; bind NO alert). Pure read, no entry/stop.
// ─────────────────────────────────────────────────────────────────────────────
// FLAT 10w + 30w weekly MA levels (one horizontal S/R line each at the current
// weekly value, like the prior-levels lines) + three reclaim SIGNS:
//   • 10w↑  — price reclaims the 10w MA   ┐ the weekly_ma_held setup
//   • 30w↑  — price reclaims the 30w MA   ┘
//   • wRC ◆ — undercut + reclaim of the prior-week low, green week (weekly_rc)
// Signs are limited to RECENT bars so old ones (when the MA sat far from today's
// flat level) don't float off the line. The ALERTS fire from levels_day_vwap.pine.
// ─────────────────────────────────────────────────────────────────────────────
indicator("Weekly Levels", "WkLvls", overlay = true, max_lines_count = 4, max_labels_count = 100)

show_10w  = input.bool(true, "Flat 10w MA line")
show_30w  = input.bool(true, "Flat 30w MA line")
show_marc = input.bool(true, "10w / 30w reclaim signs")
show_rc   = input.bool(true, "Weekly RC sign (prior-week-low reclaim)")
recent    = input.int (8,    "Signs: recent bars only — keeps signs near the flat line (0 = all)", minval = 0)
line_len  = input.int (60,   "Line length (bars back)", minval = 10, maxval = 500)
col_sup   = input.color(#26A69A, "Support (price above the line)")
col_res   = input.color(#EF5350, "Resistance (price below the line)")

w10 = request.security(syminfo.tickerid, "W", ta.sma(close, 10), lookahead = barmerge.lookahead_on)
w30 = request.security(syminfo.tickerid, "W", ta.sma(close, 30), lookahead = barmerge.lookahead_on)
// Weekly RC = undercut + reclaim of the prior-week low on a GREEN week (confirmed weekly).
wrc = request.security(syminfo.tickerid, "W", (low < low[1]) and (close > low[1]) and (close > open), lookahead = barmerge.lookahead_off)

// ── Flat lines + value labels, redrawn on the last bar. ──
var line  ln10 = na
var line  ln30 = na
var label lb10 = na
var label lb30 = na
if barstate.islast
    line.delete(ln10)
    line.delete(ln30)
    label.delete(lb10)
    label.delete(lb30)
    if show_10w and not na(w10)
        c10 = close > w10 ? col_sup : col_res
        ln10 := line.new(bar_index - line_len, w10, bar_index + 10, w10, color = c10, width = 2)
        lb10 := label.new(bar_index + 10, w10, "10w " + str.tostring(w10, format.mintick), style = label.style_label_left, color = c10, textcolor = color.white, size = size.small)
    if show_30w and not na(w30)
        c30 = close > w30 ? col_sup : col_res
        ln30 := line.new(bar_index - line_len, w30, bar_index + 10, w30, color = c30, width = 2)
        lb30 := label.new(bar_index + 10, w30, "30w " + str.tostring(w30, format.mintick), style = label.style_label_left, color = c30, textcolor = color.white, size = size.small)

// ── Reclaim signs (recent bars only so they sit near the flat line). ──
in_win = recent == 0 or (last_bar_index - bar_index) <= recent
plotshape(show_marc and in_win and ta.crossover(close, w10), title = "10w reclaim", style = shape.triangleup, location = location.belowbar, color = color.new(color.lime, 0), size = size.tiny, text = "10w↑")
plotshape(show_marc and in_win and ta.crossover(close, w30), title = "30w reclaim", style = shape.triangleup, location = location.belowbar, color = color.new(color.teal, 0), size = size.tiny, text = "30w↑")
plotshape(show_rc and in_win and wrc and not wrc[1], title = "Weekly RC", style = shape.diamond, location = location.belowbar, color = color.new(#2962FF, 0), size = size.tiny, text = "wRC")
