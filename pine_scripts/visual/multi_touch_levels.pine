// @version=5
//
// Multi-touch levels — double / triple TOPS & BOTTOMS (VISUAL). Daily charts.
//
// v3: CLUSTER + REDRAW. Every bar we re-derive the whole S/R map from scratch:
//   1. Greedily group confirmed pivots into DISTINCT levels — pivots within
//      tol_pct of each other collapse to ONE level; the touch count = how many
//      pivots landed there.
//   2. Keep levels with >= min_touches touches and draw each ONCE, labeled N×.
//   3. Redraw on every bar, so no stale lines linger, nothing stacks per-touch,
//      and a genuine double shows even when price ISN'T sitting on it now
//      (e.g. a prior double top above current price — the IREN 46.97 case).
//
// Relevance rule (so the map stays clean AND complete): levels with MORE than
// the floor count (3×+ by default) always show, anywhere on the chart; levels
// AT the floor (2×) show only within near_pct of current price. So heavily-
// tested far levels stay, near-price doubles stay, distant 2× junk drops.
// Tolerance is 1.0% by default so tops/bottoms "a few points apart" still group.
//
// Pine v5: every function call on one line; `and`/`or` not short-circuited
// (array reads guarded by size checks); typed arrays; one statement per line.
//
indicator("Multi-touch Levels", "MultiTB", overlay = true, max_lines_count = 100, max_labels_count = 100)

// ── Detection ───────────────────────────────────────────────────────
piv_len     = input.int  (3,   "Pivot strength (bars each side)", minval = 1, group = "Detection")
tol_pct     = input.float(1.0, "Match tolerance % — how close lows/highs must be to group (wider = 'a few points off' still cluster)", minval = 0.05, maxval = 5.0, step = 0.05, group = "Detection")
lookback    = input.int  (250, "Lookback (bars of history to scan)", minval = 20, group = "Detection")
min_touches = input.int  (2,   "Min touches (floor: 2 = double). Counts ABOVE this always show; AT it show only near price", minval = 2, maxval = 6, group = "Detection")

// ── Display ─────────────────────────────────────────────────────────
near_pct = input.float(8.0,  "Weakest (floor-count) levels only shown within this % of price (0 = show all everywhere)", minval = 0.0, step = 1.0, group = "Display")
show_bot = input.bool(true,  "Bottoms (support, green)", group = "Display")
show_top = input.bool(true,  "Tops (resistance, red)", group = "Display")
ext_r    = input.bool(true,  "Extend lines to the right", group = "Display")
show_piv = input.bool(false, "Mark raw pivots", group = "Display")

// ── Confirmed pivots, kept in rolling history ───────────────────────
ph = ta.pivothigh(high, piv_len, piv_len)
pl = ta.pivotlow (low,  piv_len, piv_len)
piv_b = bar_index - piv_len

var array<float> lowP  = array.new_float()
var array<int>   lowB  = array.new_int()
var array<float> highP = array.new_float()
var array<int>   highB = array.new_int()

if not na(pl)
    array.push(lowP, pl)
    array.push(lowB, piv_b)
    if array.size(lowP) > 250
        array.shift(lowP)
        array.shift(lowB)
if not na(ph)
    array.push(highP, ph)
    array.push(highB, piv_b)
    if array.size(highP) > 250
        array.shift(highP)
        array.shift(highB)

// ── Drawn handles (cleared + rebuilt each bar) ──────────────────────
var array<line>  dLn = array.new<line>()
var array<label> dLb = array.new<label>()

// ── Redraw the whole map on the last bar ────────────────────────────
if barstate.islast
    if array.size(dLn) > 0
        for i = 0 to array.size(dLn) - 1
            line.delete(array.get(dLn, i))
    if array.size(dLb) > 0
        for i = 0 to array.size(dLb) - 1
            label.delete(array.get(dLb, i))
    array.clear(dLn)
    array.clear(dLb)

    // ----- cluster BOTTOMS (support) -----
    nL = array.size(lowP)
    if show_bot and nL > 0
        usedL = array.new_bool(nL, false)
        for a = 0 to nL - 1
            if not array.get(usedL, a)
                base = array.get(lowP, a)
                cnt = 0
                lvl = base
                earliest = array.get(lowB, a)
                if base > 0
                    for b = a to nL - 1
                        if not array.get(usedL, b)
                            q = array.get(lowP, b)
                            if (q > 0) and (math.abs(q - base) / base * 100.0 <= tol_pct) and ((bar_index - array.get(lowB, b)) <= lookback)
                                array.set(usedL, b, true)
                                cnt := cnt + 1
                                lvl := math.min(lvl, q)
                near_ok = (near_pct <= 0.0) or (close > 0 and math.abs(lvl - close) / close * 100.0 <= near_pct)
                if (cnt >= min_touches) and ((cnt > min_touches) or near_ok)
                    ln = line.new(earliest, lvl, bar_index, lvl, xloc = xloc.bar_index, color = color.new(color.lime, 10), width = 2, extend = ext_r ? extend.right : extend.none)
                    lb = label.new(bar_index, lvl, str.tostring(cnt) + "× bottom " + str.tostring(lvl, format.mintick), xloc = xloc.bar_index, yloc = yloc.price, style = label.style_label_up, color = color.new(color.lime, 50), textcolor = color.white, size = size.small)
                    array.push(dLn, ln)
                    array.push(dLb, lb)

    // ----- cluster TOPS (resistance) -----
    nH = array.size(highP)
    if show_top and nH > 0
        usedH = array.new_bool(nH, false)
        for ha = 0 to nH - 1
            if not array.get(usedH, ha)
                hbase = array.get(highP, ha)
                hcnt = 0
                hlvl = hbase
                hearl = array.get(highB, ha)
                if hbase > 0
                    for hb = ha to nH - 1
                        if not array.get(usedH, hb)
                            hq = array.get(highP, hb)
                            if (hq > 0) and (math.abs(hq - hbase) / hbase * 100.0 <= tol_pct) and ((bar_index - array.get(highB, hb)) <= lookback)
                                array.set(usedH, hb, true)
                                hcnt := hcnt + 1
                                hlvl := math.max(hlvl, hq)
                hnear = (near_pct <= 0.0) or (close > 0 and math.abs(hlvl - close) / close * 100.0 <= near_pct)
                if (hcnt >= min_touches) and ((hcnt > min_touches) or hnear)
                    hln = line.new(hearl, hlvl, bar_index, hlvl, xloc = xloc.bar_index, color = color.new(color.red, 10), width = 2, extend = ext_r ? extend.right : extend.none)
                    hlb = label.new(bar_index, hlvl, str.tostring(hcnt) + "× top " + str.tostring(hlvl, format.mintick), xloc = xloc.bar_index, yloc = yloc.price, style = label.style_label_down, color = color.new(color.red, 50), textcolor = color.white, size = size.small)
                    array.push(dLn, hln)
                    array.push(dLb, hlb)

// ── Raw pivot markers (off by default) ──────────────────────────────
plotshape(show_piv and not na(pl), title = "pivot low",  location = location.belowbar, style = shape.circle, size = size.tiny, color = color.new(color.green, 35), offset = -piv_len)
plotshape(show_piv and not na(ph), title = "pivot high", location = location.abovebar, style = shape.circle, size = size.tiny, color = color.new(color.red, 35),   offset = -piv_len)
