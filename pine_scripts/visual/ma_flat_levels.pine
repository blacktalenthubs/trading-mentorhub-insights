//@version=5
// ─────────────────────────────────────────────────────────────────────────────
// MA Flat S/R (test) — daily MAs rendered as FLAT horizontal levels, like PDL.
// ─────────────────────────────────────────────────────────────────────────────
// PURPOSE: validate the "treat each daily MA as a flat S/R level" model BEFORE
// we wire any alerts. A DAILY moving average only updates on the daily close,
// so intraday it is a flat horizontal line — exactly like PDL/PWL. This plots
// each daily MA as that flat level and colors it by ROLE:
//   • SUPPORT  (green) — the stock came into the day ABOVE this level
//   • RESISTANCE (red) — the stock came into the day BELOW this level
// Role is anchored on the PRIOR DAILY CLOSE (stable all session, PDL-style), so
// the S/R call doesn't flicker as price wobbles. Flip `Role from live price` to
// watch the role change live instead.
//
// This is a VISUAL TEST ONLY — no alerts. Eyeball whether the green/red mapping
// matches how each MA is actually acting on the chart (support vs resistance).
// MAs are computed identically to the `ma-ema-daily` indicator so the levels
// line up 1:1 with the lines you already use.
// ─────────────────────────────────────────────────────────────────────────────
indicator("MA Flat S/R (test)", overlay = true, max_lines_count = 50, max_labels_count = 50)

// ── inputs ───────────────────────────────────────────────────────────────────
show_ema    = input.bool (true,  "Show EMAs  (8 / 21 / 50 / 100 / 200)")
show_sma    = input.bool (true,  "Show SMAs  (50 / 100 / 200)")
anchor_live = input.bool (false, "Role from LIVE price (default: prior daily close, PDL-style)")
line_len    = input.int  (60,    "Line length (bars back)", minval = 10, maxval = 500)
col_sup     = input.color(#26A69A, "Support color")
col_res     = input.color(#EF5350, "Resistance color")

// ── daily MAs (flat intraday) — same computation as ma-ema-daily ─────────────
ema8   = request.security(syminfo.tickerid, "D", ta.ema(close, 8)[1],   lookahead = barmerge.lookahead_on)
ema21  = request.security(syminfo.tickerid, "D", ta.ema(close, 21)[1],  lookahead = barmerge.lookahead_on)
ema50  = request.security(syminfo.tickerid, "D", ta.ema(close, 50)[1],  lookahead = barmerge.lookahead_on)
ema100 = request.security(syminfo.tickerid, "D", ta.ema(close, 100)[1], lookahead = barmerge.lookahead_on)
ema200 = request.security(syminfo.tickerid, "D", ta.ema(close, 200)[1], lookahead = barmerge.lookahead_on)
sma50  = request.security(syminfo.tickerid, "D", ta.sma(close, 50)[1],  lookahead = barmerge.lookahead_on)
sma100 = request.security(syminfo.tickerid, "D", ta.sma(close, 100)[1], lookahead = barmerge.lookahead_on)
sma200 = request.security(syminfo.tickerid, "D", ta.sma(close, 200)[1], lookahead = barmerge.lookahead_on)

// Side anchor: prior daily close (stable, PDL-style) unless the user wants live.
dclose_prev = request.security(syminfo.tickerid, "D", close[1], lookahead = barmerge.lookahead_on)
ref_price   = anchor_live ? close : dclose_prev

// SUPPORT = reference price is ABOVE the level (we're sitting on top of it).
is_support(float ma) => not na(ma) and not na(ref_price) and ref_price > ma

// ── render: one flat line + right-edge label per MA, redrawn on the last bar ─
var line[]  g_lines  = array.new_line(0)
var label[] g_labels = array.new_label(0)

draw_level(float ma, string name, bool dotted) =>
    if not na(ma)
        sup = is_support(ma)
        col = sup ? col_sup : col_res
        x1  = bar_index - line_len
        x2  = bar_index + 6
        ln  = line.new(x1, ma, x2, ma, color = col, width = dotted ? 1 : 2, style = dotted ? line.style_dotted : line.style_solid)
        lb  = label.new(x2, ma, name + (sup ? "  SUPPORT  " : "  RESIST  ") + str.tostring(ma, format.mintick), style = label.style_label_left, color = col, textcolor = color.white, size = size.small)
        array.push(g_lines, ln)
        array.push(g_labels, lb)

if barstate.islast
    if array.size(g_lines) > 0
        for i = 0 to array.size(g_lines) - 1
            line.delete(array.get(g_lines, i))
        array.clear(g_lines)
    if array.size(g_labels) > 0
        for i = 0 to array.size(g_labels) - 1
            label.delete(array.get(g_labels, i))
        array.clear(g_labels)
    if show_ema
        draw_level(ema8,   "EMA 8",   false)
        draw_level(ema21,  "EMA 21",  false)
        draw_level(ema50,  "EMA 50",  false)
        draw_level(ema100, "EMA 100", false)
        draw_level(ema200, "EMA 200", false)
    if show_sma
        draw_level(sma50,  "SMA 50",  true)
        draw_level(sma100, "SMA 100", true)
        draw_level(sma200, "SMA 200", true)
