//@version=5
// ─────────────────────────────────────────────────────────────────────────────
// PDH / PDL Flat — prior-day high & low as pure horizontal S/R lines.
// ─────────────────────────────────────────────────────────────────────────────
// PDH and PDL are single values set by the prior day, so they're flat all day
// (like a daily MA intraday). This draws each as ONE clean horizontal line at
// its level — no curving — colored by role:
//   • SUPPORT  (green) — price is currently ABOVE the level
//   • RESISTANCE (red) — price is currently BELOW the level (overhead)
// The role flips when price closes back across the line. PDL below price = the
// support you defend; PDH above = resistance/target until reclaimed.
// VISUAL ONLY — no alerts.
// ─────────────────────────────────────────────────────────────────────────────
indicator("PDH/PDL Flat", overlay = true, max_lines_count = 10, max_labels_count = 10)

// ── inputs ───────────────────────────────────────────────────────────────────
show_pdh = input.bool (true,  "Show PDH")
show_pdl = input.bool (true,  "Show PDL")
line_len = input.int  (60,    "Line length (bars back)", minval = 10, maxval = 500)
col_sup  = input.color(#26A69A, "Support color (price above)")
col_res  = input.color(#EF5350, "Resistance color (price below)")

// ── prior-day high / low (flat intraday) — same as ma-ema-daily ──────────────
pdh = request.security(syminfo.tickerid, "D", high[1], lookahead = barmerge.lookahead_on)
pdl = request.security(syminfo.tickerid, "D", low[1],  lookahead = barmerge.lookahead_on)

is_support(float lvl) => not na(lvl) and close > lvl

// ── flat line + label, redrawn on the last bar ──────────────────────────────
var line[]  g_lines  = array.new_line(0)
var label[] g_labels = array.new_label(0)

draw_level(float lvl, string nm) =>
    if not na(lvl)
        sup = is_support(lvl)
        col = sup ? col_sup : col_res
        ln  = line.new(bar_index - line_len, lvl, bar_index + 6, lvl, color = col, width = 2)
        lb  = label.new(bar_index + 6, lvl, nm + "  " + str.tostring(lvl, format.mintick), style = label.style_label_left, color = col, textcolor = color.white, size = size.small)
        array.push(g_lines, ln)
        array.push(g_labels, lb)

if barstate.islast
    if array.size(g_lines) > 0
        for i = 0 to array.size(g_lines) - 1
            line.delete(array.get(g_lines, i))
        array.clear(g_lines)
    if array.size(g_labels) > 0
        for i = 0 to array.size(g_labels) - 1
            label.delete(array.get(g_labels, i))
        array.clear(g_labels)
    if show_pdh
        draw_level(pdh, "PDH")
    if show_pdl
        draw_level(pdl, "PDL")
