//@version=5
// ═══════════════════════════════════════════════════════════════════════
// Multi-Period S/R — key multi-WEEK or multi-MONTH resistance / support
// ───────────────────────────────────────────────────────────────────────
// Finds prices where MULTIPLE completed periods share a HIGH (resistance) or
// a LOW (support) within a tolerance — institutional memory. Set tf = "W" for
// multi-week, "M" for multi-month. Works on ANY chart timeframe (it pulls the
// HTF bars via request.security), so you can see weekly/monthly walls while
// trading the 4h. Draws one line per cluster (>= min_touch periods), labelled
// with the touch count ("3W R" = 3 weeks rejected here, "3M S" = 3 months held).
//
// ALERTS (default-OFF type → land in Muted for validation): when price wicks
// INTO a cluster and rejects/holds — SHORT a resistance, LONG a support. Same
// shape as the lost-support reject: wick tags the level, close decides.
// ═══════════════════════════════════════════════════════════════════════
indicator("Multi-Period S/R", "MultiPd S/R", overlay = true, max_lines_count = 500, max_labels_count = 500)

// ── Inputs ───────────────────────────────────────────────────────────
tf        = input.string("W", "Cluster timeframe", options = ["W", "M"], group = "Cluster", tooltip = "W = multi-week, M = multi-month. Add the indicator twice for both.")
tol_pct   = input.float(0.6,  "Cluster tolerance (%)", minval = 0.0, step = 0.1, group = "Cluster") / 100.0
lookback  = input.int(52,     "Periods to scan", minval = 4, maxval = 260, group = "Cluster", tooltip = "Weeks or months back. Lower it for monthly (e.g. 24).")
min_touch = input.int(2,      "Min touches (periods at the level)", minval = 2, group = "Cluster")
show_res  = input.bool(true,  "Resistance — clustered HIGHS", group = "Show")
show_sup  = input.bool(true,  "Support — clustered LOWS", group = "Show")
res_col   = input.color(color.red,   "Resistance", group = "Show")
sup_col   = input.color(color.green, "Support", group = "Show")
alerts_on = input.bool(true,  "Fire S/R interaction alerts", group = "Alerts")

// ── Collect COMPLETED HTF highs + lows ───────────────────────────────
// high[1]/low[1] in the HTF context = the prior (completed) period, so the
// in-progress period never enters the cluster. Pushed once per period roll.
hi   = request.security(syminfo.tickerid, tf, high[1], lookahead = barmerge.lookahead_off)
lo   = request.security(syminfo.tickerid, tf, low[1],  lookahead = barmerge.lookahead_off)
newp = ta.change(time(tf)) != 0

var array<float> hs = array.new_float()
var array<float> ls = array.new_float()
if newp and not na(hi) and not na(lo)
    array.push(hs, hi)
    array.push(ls, lo)
    if array.size(hs) > lookback
        array.shift(hs)
        array.shift(ls)

// ── Cluster helpers ──────────────────────────────────────────────────
// Group SORTED values into clusters within tolerance; return the average price
// of each cluster that has >= min_touch members. Used by both draw + alerts.
cluster_levels(array<float> src) =>
    out = array.new_float()
    if array.size(src) >= min_touch
        s = array.copy(src)
        array.sort(s, order.ascending)
        i = 0
        while i < array.size(s)
            base = array.get(s, i)
            j = i
            cnt = 0
            sumv = 0.0
            while j < array.size(s)
                v = array.get(s, j)
                if (v - base) / base > tol_pct
                    break
                cnt += 1
                sumv += v
                j += 1
            if cnt >= min_touch
                array.push(out, sumv / cnt)
            i := j
    out

touches_near(array<float> src, float price) =>
    c = 0
    for v in src
        if price > 0 and math.abs(v - price) / price <= tol_pct
            c += 1
    c

res_lv = cluster_levels(hs)
sup_lv = cluster_levels(ls)

// ── Alerts: wick INTO a cluster + reject/hold ────────────────────────
// Resistance: poke up into it (high >= R) from below (high[1] < R), close back
// below (close < R) → SHORT. Support: poke down into it (low <= S) from above
// (low[1] > S), close back above (close > S) → LONG. high[1]/low[1] guard makes
// it fire once per approach, not every bar. freq=once_per_bar_close.
atrv = ta.atr(14)
buf  = na(atrv) ? 0.0 : atrv * 0.25
if alerts_on
    for R in res_lv
        if high >= R and close < R and high[1] < R
            cntr = touches_near(hs, R)
            plr = '{"symbol":"' + syminfo.ticker + '","price":"' + str.tostring(close, format.mintick) + '","rule":"htf_sr_reject","direction":"SHORT","interval":"' + timeframe.period + '","entry":"' + str.tostring(close, format.mintick) + '","stop":"' + str.tostring(R + buf, format.mintick) + '","note":"' + tf + ' resistance (' + str.tostring(cntr) + 'x) rejected","fired_at":"' + str.tostring(timenow) + '"}'
            alert(plr, alert.freq_once_per_bar_close)
    for S in sup_lv
        if low <= S and close > S and low[1] > S
            cnts = touches_near(ls, S)
            pls = '{"symbol":"' + syminfo.ticker + '","price":"' + str.tostring(close, format.mintick) + '","rule":"htf_sr_bounce","direction":"LONG","interval":"' + timeframe.period + '","entry":"' + str.tostring(close, format.mintick) + '","stop":"' + str.tostring(S - buf, format.mintick) + '","note":"' + tf + ' support (' + str.tostring(cnts) + 'x) held","fired_at":"' + str.tostring(timenow) + '"}'
            alert(pls, alert.freq_once_per_bar_close)

// ── Draw on the last bar (wipe + redraw each real-time bar) ──────────
var array<line>  d_lines  = array.new_line()
var array<label> d_labels = array.new_label()
if barstate.islast
    for ln in d_lines
        line.delete(ln)
    array.clear(d_lines)
    for lb in d_labels
        label.delete(lb)
    array.clear(d_labels)
    x1 = bar_index > 150 ? bar_index - 150 : 0
    if show_res
        for R in res_lv
            ln = line.new(x1, R, bar_index, R, color = res_col, width = 2, extend = extend.right)
            array.push(d_lines, ln)
            lb = label.new(bar_index, R, str.tostring(touches_near(hs, R)) + tf + " R", style = label.style_label_left, textcolor = res_col, color = color.new(res_col, 85), size = size.small)
            array.push(d_labels, lb)
    if show_sup
        for S in sup_lv
            ln = line.new(x1, S, bar_index, S, color = sup_col, width = 2, extend = extend.right)
            array.push(d_lines, ln)
            lb = label.new(bar_index, S, str.tostring(touches_near(ls, S)) + tf + " S", style = label.style_label_left, textcolor = sup_col, color = color.new(sup_col, 85), size = size.small)
            array.push(d_labels, lb)
