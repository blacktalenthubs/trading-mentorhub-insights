// @version=5
// MLV Directional Reclaim — VALIDATION snippet (visual only, NO alerts, LONG only).
//
// Marks a ▲ ONLY when a completed monthly level is reclaimed AS SUPPORT:
//     day_open > L   AND   bar low ≤ L   AND   bar close > L   (+ min wick penetration)
//
// The LEVEL and the day-open GATE are timeframe-independent (locked via M / D security),
// so the ONLY thing that changes with the chart TF is the reclaim granularity:
//   • load on 1h  → the NEAT, 1h-confirmed reclaims (what the real alert will use)
//   • load on 5m  → the noisy version (a monthly level "reclaimed" on a 5m poke)
// Flip the chart TF and watch the ▲ set shrink — that's the 1h-vs-5m call, made visible.
//
// Scans H/L/O/C of the last 6 completed months = 24 levels, no exceptions. Overlay this on
// your MLV visual (monthly_levels.pine) so the ▲ sit on the drawn rails/bodies.
indicator("MLV Directional Reclaim (validation)", "MLV-DR", overlay = true, max_labels_count = 500, max_lines_count = 60)

nMon   = input.int(6, "Completed months to scan", minval = 1, maxval = 6)
minPen = input.float(0.15, "Min wick penetration below the level (%)", minval = 0.0, step = 0.05) / 100.0
showLv = input.bool(false, "Draw the monthly levels (off if you already run monthly_levels.pine)")
showMk = input.bool(true,  "Mark ▲ support reclaims")
colUp  = input.color(color.lime, "▲ reclaim")

tid = syminfo.tickerid
// Daily open — the direction-gate reference. TF-independent, so the gate is identical on 5m/1h/D.
day_open = request.security(tid, "D", open, lookahead = barmerge.lookahead_off)

// Last 6 completed months — H/L/O/C/time, one security call each (24 levels from 6 calls).
[h1,l1,o1,c1,t1] = request.security(tid,"M",[high[1],low[1],open[1],close[1],time[1]],lookahead=barmerge.lookahead_on)
[h2,l2,o2,c2,t2] = request.security(tid,"M",[high[2],low[2],open[2],close[2],time[2]],lookahead=barmerge.lookahead_on)
[h3,l3,o3,c3,t3] = request.security(tid,"M",[high[3],low[3],open[3],close[3],time[3]],lookahead=barmerge.lookahead_on)
[h4,l4,o4,c4,t4] = request.security(tid,"M",[high[4],low[4],open[4],close[4],time[4]],lookahead=barmerge.lookahead_on)
[h5,l5,o5,c5,t5] = request.security(tid,"M",[high[5],low[5],open[5],close[5],time[5]],lookahead=barmerge.lookahead_on)
[h6,l6,o6,c6,t6] = request.security(tid,"M",[high[6],low[6],open[6],close[6],time[6]],lookahead=barmerge.lookahead_on)

prices = array.from(h1,l1,o1,c1, h2,l2,o2,c2, h3,l3,o3,c3, h4,l4,o4,c4, h5,l5,o5,c5, h6,l6,o6,c6)
mtimes = array.from(t1,t1,t1,t1, t2,t2,t2,t2, t3,t3,t3,t3, t4,t4,t4,t4, t5,t5,t5,t5, t6,t6,t6,t6)
kinds  = array.from("H","L","O","C","H","L","O","C","H","L","O","C","H","L","O","C","H","L","O","C")

// Once per level per day — reset the latch on each new session day.
var bool[] fired = array.new_bool(24, false)
newDay = ta.change(time("D")) != 0
if newDay
    for k = 0 to 23
        array.set(fired, k, false)

// Reclaim detection on the CONFIRMED chart bar (so on a 1h chart this IS the 1h reclaim).
if showMk and barstate.isconfirmed and not na(day_open)
    for k = 0 to nMon * 4 - 1
        float L = array.get(prices, k)
        bool support = not na(L) and day_open > L                     // opened above the level
        bool reclaim = not na(L) and low <= L and close > L           // wicked below, closed back above
        bool deep    = not na(L) and (L - low) / L >= minPen          // real test, not a penny kiss
        if support and reclaim and deep and not array.get(fired, k)
            array.set(fired, k, true)
            string mn  = str.format("{0,date,MMM}", int(array.get(mtimes, k)))
            string txt = "▲ " + mn + " " + array.get(kinds, k) + " " + str.tostring(L, format.mintick) + "  stop " + str.tostring(low, format.mintick)
            label.new(bar_index, low, txt, style = label.style_label_up, color = colUp, textcolor = color.black, size = size.small)

// Optional: draw the 24 levels (leave OFF if monthly_levels.pine is already on the chart).
var line[]  _ln = array.new_line()
var label[] _lb = array.new_label()
if showLv and barstate.islast
    for ln in _ln
        line.delete(ln)
    for lb in _lb
        label.delete(lb)
    array.clear(_ln)
    array.clear(_lb)
    for k = 0 to nMon * 4 - 1
        float L = array.get(prices, k)
        if not na(L)
            string kd = array.get(kinds, k)
            color cc = kd == "H" ? color.new(color.red, 40) : kd == "L" ? color.new(color.teal, 40) : color.new(color.gray, 30)
            array.push(_ln, line.new(bar_index - 60, L, bar_index + 4, L, color = cc, width = 1, style = line.style_dotted))
            string mn = str.format("{0,date,MMM}", int(array.get(mtimes, k)))
            array.push(_lb, label.new(bar_index + 5, L, mn + " " + kd, style = label.style_label_left, color = color.new(color.black, 100), textcolor = cc, size = size.tiny))
