// @version=5
//
// Weekly Stage (Weinstein) — long-term trend entry/exit. LOAD ON THE WEEKLY.
//
// The 30-week moving average is the trend spine. You only hold in STAGE 2; you
// exit when a weekly close breaks back below the 30-week MA. "Ride the trend
// until it's over."
//
//   Stage 1  Basing      — flat MA after a decline; watch for a breakout.
//   Stage 2  Advancing   — price ABOVE a RISING MA; HOLD / add. (the only buy zone)
//   Stage 3  Topping      — flat MA after an advance; tighten / trim.
//   Stage 4  Declining    — price BELOW a FALLING MA; out / avoid.
//
// Markers: ▲ BUY = weekly close back above a RISING MA (the break itself, not
// a lagging slope-threshold cross); ▼ EXIT on the trailing-stop break.
// Stage is a small state machine: definitive Stage 2 (above+rising) or 4
// (below+falling); when the MA goes flat it's Stage 3 if we were just advancing,
// Stage 1 if we were just declining.
//
// Pine v5: every function call on one line; single status label redrawn on the
// last bar.
//
indicator("Weekly Stage (Weinstein)", "WkStage", overlay = true, max_labels_count = 20)

ma_len    = input.int  (30,  "Trend MA length (weeks)", minval = 5, group = "Trend")
slope_lb  = input.int  (4,   "Slope lookback (weeks)", minval = 1, group = "Trend")
slope_thr = input.float(0.5, "Min |slope %| to count as rising/falling — BELOW this = FLAT (chop, no Stage 2/4). Higher = stricter, fewer chop entries", minval = 0.0, step = 0.05, group = "Trend")
show_sig  = input.bool(true, "Entry / exit markers", group = "Display")
show_bg   = input.bool(true, "Stage background tint", group = "Display")

exit_mode = input.string("Prior week low", "Trailing stop / exit rule", options = ["Prior week low", "Swing low", "30-week MA"], group = "Exit")
piv_lb    = input.int(3, "Swing-low strength (Swing-low mode only)", minval = 1, group = "Exit")

show_add  = input.bool(true, "Mark pullback-to-MA 'ADD' (MA = support in Stage 2)", group = "Entry")
ma_buf    = input.float(3.0, "Pullback buffer % — how near the rising MA counts as a test", minval = 0.0, step = 0.5, group = "Entry")

ma    = ta.sma(close, ma_len)
slope = ma[slope_lb] != 0 ? (ma - ma[slope_lb]) / ma[slope_lb] * 100.0 : 0.0
rising  = slope > slope_thr
falling = slope < -slope_thr
above   = close > ma

// State machine — last definitive trend disambiguates a flat MA (1 vs 3).
var int last_trend = 0
cur = (above and rising) ? 2 : (((not above) and falling) ? 4 : 0)
if cur != 0
    last_trend := cur
stage = cur != 0 ? cur : (last_trend == 2 ? 3 : (last_trend == 4 ? 1 : 0))

stage_col = stage == 2 ? color.lime : stage == 4 ? color.red : stage == 3 ? color.orange : stage == 1 ? color.gray : color.silver
plot(ma, "30wMA", color = stage_col, linewidth = 2)

// Entry = enters Stage 2 (close above a rising 30wMA).
// Exit  = a weekly close below the TRAILING STOP. Default "Prior week low" rides
//         the higher-lows of a clean trend (never triggers while each week's low
//         holds — AMD/MRVL held it the whole run) but exits NEAR THE TOP, instead
//         of giving it all back waiting for the lagging MA. Swing-low is looser
//         (rides bigger pullbacks); 30wMA is the loosest.
sw_piv = ta.pivotlow(low, piv_lb, piv_lb)
var float swing_low = na
if not na(sw_piv)
    swing_low := sw_piv
trail = exit_mode == "Prior week low" ? low[1] : (exit_mode == "Swing low" ? swing_low : ma)

// BUY = the BREAK itself: a weekly CLOSE back above the MA while the MA is
// RISING (net up over slope_lb weeks). This fires at the reclaim, not weeks
// later when the 4-week slope finally clears the 0.5% band. The MA-rising gate
// keeps it out of flat-MA chop (a reclaim of a flat/declining MA won't fire).
var bool in_pos = false
ma_up   = ma > ma[slope_lb]
buy_sig  = (not in_pos) and (close > ma) and (close[1] <= ma[1]) and ma_up
exit_sig = in_pos and (not na(trail)) and (close < trail)
if buy_sig
    in_pos := true
if exit_sig
    in_pos := false

plot(in_pos ? trail : na, "trailing stop", color = color.new(color.red, 10), style = plot.style_stepline, linewidth = 1)
plotshape(show_sig and buy_sig, title = "entry", style = shape.triangleup, location = location.belowbar, color = color.new(color.lime, 0), size = size.small, text = "BUY")
plotshape(show_sig and exit_sig, title = "exit", style = shape.triangledown, location = location.abovebar, color = color.new(color.red, 0), size = size.small, text = "EXIT")

// ADD — in Stage 2, price pulls back to the RISING MA and holds (close above):
// the MA caught it as support. A lower-risk continuation buy (stop just under
// the MA). Requires the prior week to have been CLEAR of the MA zone (a fresh
// test, not weeks hugging the line).
in_ma_zone = (not na(ma)) and (low <= ma * (1.0 + ma_buf / 100.0)) and (close > ma)
add_sig = show_add and rising and (stage == 2) and in_ma_zone and (low[1] > ma[1] * (1.0 + ma_buf / 100.0))
plotshape(add_sig, title = "add", style = shape.circle, location = location.belowbar, color = color.new(color.aqua, 0), size = size.tiny, text = "ADD")

bg = stage == 2 ? color.new(color.lime, 92) : stage == 4 ? color.new(color.red, 92) : stage == 3 ? color.new(color.orange, 94) : stage == 1 ? color.new(color.gray, 95) : na
bgcolor(show_bg ? bg : na, title = "stage tint")

// Status label on the last bar.
stage_name = stage == 2 ? "STAGE 2 · Advancing — HOLD / add" : stage == 4 ? "STAGE 4 · Declining — OUT / avoid" : stage == 3 ? "STAGE 3 · Topping — tighten / trim" : stage == 1 ? "STAGE 1 · Basing — watch for breakout" : "—"
var label statusLab = na
if barstate.islast
    if not na(statusLab)
        label.delete(statusLab)
    dist = ma != 0 ? (close - ma) / ma * 100.0 : 0.0
    txt = stage_name + "\n30wMA " + str.tostring(ma, format.mintick) + "  ·  slope " + str.tostring(slope, "#.##") + "%  ·  price " + (dist >= 0 ? "+" : "") + str.tostring(dist, "#.#") + "% vs MA"
    statusLab := label.new(bar_index, high, txt, xloc = xloc.bar_index, yloc = yloc.price, style = label.style_label_down, color = color.new(stage_col, 75), textcolor = color.white, size = size.normal)
