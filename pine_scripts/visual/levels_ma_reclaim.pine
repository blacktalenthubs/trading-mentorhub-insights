// @version=5
//
// LMR — Levels + MA Reclaim/Reject (day-trade). VISUAL ONLY (no alerts).
//
// Prior-day high/low (PDH/PDL) plus the 8 daily moving averages (EMA 8/21/50/100/200, SMA
// 50/100/200). Each is a FLAT intraday S/R level — locked via request.security so it sits at the
// same price on every chart TF (flip 1m ↔ 5m ↔ 1h and nothing moves). When a bar CLOSES BACK
// ABOVE a level it was below = RECLAIM (▲, bullish); CLOSES BACK BELOW a level it was above =
// REJECT / lose (▼, bearish). Each mark is a SUBTLE text tag naming the level (▲100E, ▼PDL).
//
// LOW-TIMEFRAME SCALING (the point of this pine):
//   • DEDUP — each level fires its reclaim/reject at most ONCE per session (latch, reset daily), so
//     on a 5m chart price chopping across the 100 EMA ten times gives ONE ▲, not ten.
//   • RECENT-ONLY — optionally only mark the last N days, so a 1m/5m chart doesn't drown in history.
//   • SUBTLE style_none tags (text, no bubble) + tiny size — readable without dominating the chart.
//
indicator("Levels + MA Reclaim · day-trade", "LMR", overlay = true, max_lines_count = 30, max_labels_count = 500)

tid = syminfo.tickerid

// ── Which levels to track ──
gL = "Levels"
usePDH  = input.bool(true, "PDH", group = gL, inline = "pd")
usePDL  = input.bool(true, "PDL", group = gL, inline = "pd")
usePWH  = input.bool(true, "PWH", group = gL, inline = "pw")
usePWL  = input.bool(true, "PWL", group = gL, inline = "pw")
usePMH  = input.bool(true, "PMH", group = gL, inline = "pm")
usePML  = input.bool(true, "PML", group = gL, inline = "pm")
useE8   = input.bool(true, "EMA 8",   group = gL, inline = "e")
useE21  = input.bool(true, "EMA 21",  group = gL, inline = "e")
useE50  = input.bool(true, "EMA 50",  group = gL, inline = "e")
useE100 = input.bool(true, "EMA 100", group = gL, inline = "f")
useE200 = input.bool(true, "EMA 200", group = gL, inline = "f")
useS50  = input.bool(true, "SMA 50",  group = gL, inline = "s")
useS100 = input.bool(true, "SMA 100", group = gL, inline = "s")
useS200 = input.bool(true, "SMA 200", group = gL, inline = "s")

// ── Reclaim / reject tags ──
gM = "Reclaim (▲) / Reject (▼) tags"
enMarks  = input.bool(true, "Show reclaim/reject tags", group = gM)
dedup    = input.bool(true, "One tag per level per SESSION (recommended for low TF)", group = gM)
markDays = input.int(5, "Only mark the last N days (0 = all history)", minval = 0, maxval = 90, group = gM)
tagSzIn  = input.string("tiny", "Tag size", options = ["tiny", "small", "normal"], group = gM)
colRc    = input.color(color.new(color.teal, 0), "Reclaim ▲", group = gM, inline = "c")
colRj    = input.color(color.new(color.red, 0),  "Reject ▼",  group = gM, inline = "c")
fire_alerts = input.bool(true, "Fire reclaim/reject ALERTS to webhook (bind this pine on your day-trade TF, e.g. 10m)", group = gM)
_tsz = tagSzIn == "small" ? size.small : tagSzIn == "normal" ? size.normal : size.tiny

// ── Flat level lines ──
gV = "Level lines"
showLines = input.bool(true, "Draw the levels as flat lines (green support / red resistance)", group = gV)
lineW     = input.int(2, "Line thickness", minval = 1, maxval = 6, group = gV)

// ── Daily levels — flat intraday, locked (yesterday's settled value via [1] + lookahead_on) ──
[ema8, ema21, ema50, ema100, ema200] = request.security(tid, "D", [ta.ema(close, 8)[1], ta.ema(close, 21)[1], ta.ema(close, 50)[1], ta.ema(close, 100)[1], ta.ema(close, 200)[1]], lookahead = barmerge.lookahead_on)
[sma50, sma100, sma200] = request.security(tid, "D", [ta.sma(close, 50)[1], ta.sma(close, 100)[1], ta.sma(close, 200)[1]], lookahead = barmerge.lookahead_on)
[pdh, pdl] = request.security(tid, "D", [high[1], low[1]], lookahead = barmerge.lookahead_on)
day_open = request.security(tid, "D", open, lookahead = barmerge.lookahead_off)   // today's daily open (gap detect)
// Prior WEEK + prior MONTH high/low — flat, locked. Same day-trade S/R role, bigger degree.
[pwh, pwl] = request.security(tid, "W", [high[1], low[1]], lookahead = barmerge.lookahead_on)
[pmh, pml] = request.security(tid, "M", [high[1], low[1]], lookahead = barmerge.lookahead_on)

newDay  = ta.change(time("D")) != 0
// Recent-only gate for scaling: on history older than markDays, don't draw marks. 86400000 ms = 1 day.
mark_ok = enMarks and (markDays == 0 or (timenow - time) <= markDays * 86400000)
atrC    = ta.atr(14)                                 // chart-TF ATR for the stop buffer

// Webhook payload (single line — Pine multi-line alert args are flaky). ma_tag uses the FULL level
// name ("EMA 100", "PDL") which carries no `<digit>E/S` token, so the backend's _ma_tag_to_suffix
// leaves the type clean (tv_lmr_reclaim / tv_lmr_reject), not a per-MA suffix.
f_pay(string rule, string dir, string tag, float e, float s, float t1, float t2) =>
    '{"symbol":"' + syminfo.ticker + '","exchange":"' + syminfo.prefix + '","interval":"' + timeframe.period + '","price":"' + str.tostring(close, format.mintick) + '","high":"' + str.tostring(high, format.mintick) + '","low":"' + str.tostring(low, format.mintick) + '","volume":"' + str.tostring(volume) + '","entry":"' + str.tostring(e, format.mintick) + '","stop":"' + str.tostring(s, format.mintick) + '","target_1":"' + str.tostring(t1, format.mintick) + '","target_2":"' + str.tostring(t2, format.mintick) + '","rule":"' + rule + '","direction":"' + dir + '","ma_tag":"' + tag + '"}'

// One level. Manual cross detection (the level is flat intraday, so close vs level is enough). Once-
// per-session dedup via `var` latches (Pine gives each CALL SITE its own copy → 10 independent
// latches). `not newDay` skips the session's first bar so the daily level JUMP isn't read as a cross.
// On the same fire, emit the alert (BUY on reclaim / SHORT on reject) — backend 60-min dedup handles
// repeats. Entry = close, stop = the level ± a small ATR buffer, targets = 2R / 3R.
f_level(float lev, string nm, string full, bool en) =>
    var bool rcFired = false
    var bool rjFired = false
    if newDay
        rcFired := false
        rjFired := false
    if en and mark_ok and not na(lev) and not na(close[1]) and not newDay
        if close > lev and close[1] <= lev and (not dedup or not rcFired)
            rcFired := true
            label.new(bar_index, low, "▲" + nm, yloc = yloc.belowbar, style = label.style_none, textcolor = colRc, size = _tsz)
            float s = lev - atrC * 0.2
            float r = math.max(close - s, close * 0.0005)
            if fire_alerts
                alert(f_pay("lmr_reclaim", "BUY", full, close, s, close + r * 2, close + r * 3), alert.freq_once_per_bar_close)
        if close < lev and close[1] >= lev and (not dedup or not rjFired)
            rjFired := true
            label.new(bar_index, high, "▼" + nm, yloc = yloc.abovebar, style = label.style_none, textcolor = colRj, size = _tsz)
            float s2 = lev + atrC * 0.2
            float r2 = math.max(s2 - close, close * 0.0005)
            if fire_alerts
                alert(f_pay("lmr_reject", "SHORT", full, close, s2, close - r2 * 2, close - r2 * 3), alert.freq_once_per_bar_close)

f_level(pdh,    "PDH",  "PDH",     usePDH)
f_level(pdl,    "PDL",  "PDL",     usePDL)
f_level(pwh,    "PWH",  "PWH",     usePWH)
f_level(pwl,    "PWL",  "PWL",     usePWL)
f_level(pmh,    "PMH",  "PMH",     usePMH)
f_level(pml,    "PML",  "PML",     usePML)
f_level(ema8,   "8E",   "EMA 8",   useE8)
f_level(ema21,  "21E",  "EMA 21",  useE21)
f_level(ema50,  "50E",  "EMA 50",  useE50)
f_level(ema100, "100E", "EMA 100", useE100)
f_level(ema200, "200E", "EMA 200", useE200)
f_level(sma50,  "50S",  "SMA 50",  useS50)
f_level(sma100, "100S", "SMA 100", useS100)
f_level(sma200, "200S", "SMA 200", useS200)

// ── GAP-AND-GO — the day OPENED COMPLETELY ABOVE the prior-day HIGH (a full gap up) and is HOLDING
// above the open. Distinct from a reclaim (no dip below): price gapped over PDH and is running. Fires
// once per session. Entry = close, stop = the gap floor (day open), targets 2R / 3R. ──
gG = "Gap-and-go (opened above PDH)"
enGap = input.bool(true, "Gap-and-go — opened above PDH & holding (day-trade long)", group = gG)
var bool gapFired = false
if newDay
    gapFired := false
gap_go = enGap and not na(day_open) and not na(pdh) and day_open > pdh and close > day_open and close > close[1] and not gapFired
if gap_go
    gapFired := true
    label.new(bar_index, high, "GAP↑", yloc = yloc.abovebar, style = label.style_label_down, color = color.new(color.orange, 0), textcolor = color.white, size = _tsz)
    if fire_alerts
        float gs = day_open
        float gr = math.max(close - gs, close * 0.001)
        alert(f_pay("gap_up_continuation_long", "BUY", "Gap-up", close, gs, close + gr * 2, close + gr * 3), alert.freq_once_per_bar_close)

// ── Flat level lines — drawn once on the last bar, colored by role (green support / red resistance). ──
var line[]  lnArr = array.new_line()
var label[] lbArr = array.new_label()
f_line(float lev, string nm, bool dotted, bool en) =>
    if showLines and en and not na(lev)
        bool sup = close > lev
        color mc = sup ? color.new(color.teal, 0) : color.new(color.red, 0)
        array.push(lnArr, line.new(bar_index - 50, lev, bar_index + 3, lev, color = mc, width = lineW, style = dotted ? line.style_dashed : line.style_solid))
        array.push(lbArr, label.new(bar_index + 3, lev, nm + (sup ? " S" : " R"), style = label.style_label_left, color = color.new(mc, 82), textcolor = mc, size = size.small))
if barstate.islast
    for l in lnArr
        line.delete(l)
    for lb in lbArr
        label.delete(lb)
    array.clear(lnArr)
    array.clear(lbArr)
    f_line(pdh,    "PDH",     false, usePDH)
    f_line(pdl,    "PDL",     false, usePDL)
    f_line(pwh,    "PWH",     true,  usePWH)
    f_line(pwl,    "PWL",     true,  usePWL)
    f_line(pmh,    "PMH",     true,  usePMH)
    f_line(pml,    "PML",     true,  usePML)
    f_line(ema8,   "EMA 8",   false, useE8)
    f_line(ema21,  "EMA 21",  false, useE21)
    f_line(ema50,  "EMA 50",  false, useE50)
    f_line(ema100, "EMA 100", false, useE100)
    f_line(ema200, "EMA 200", false, useE200)
    f_line(sma50,  "SMA 50",  true,  useS50)
    f_line(sma100, "SMA 100", true,  useS100)
    f_line(sma200, "SMA 200", true,  useS200)
