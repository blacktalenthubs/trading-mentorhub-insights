// @version=5
//
// Distance From Extremes — VISUAL ONLY.
//
// One-glance read on "where are we vs the highs and lows?" Useful when
// you're looking at a name like CCJ (ATH ~$130, now $104.75 → -19.4%)
// and want instant context on the drawdown without zooming out / manually
// drawing lines.
//
// Renders a compact corner table with one row per lookback period:
//
//   Period   Ref          Price    Distance
//   1mo      High         108.20   -3.20%
//   1mo      Low           98.50   +6.30%
//   3mo      High         115.00   -8.91%
//   3mo      Low           80.10  +30.78%
//   1yr      High         132.40  -20.88%
//   1yr      Low           42.50  +146.47%
//   ATH      High         145.60  -28.05%
//   ATL      Low           18.20  +475.55%
//
// Lookbacks are always based on DAILY bars (via request.security) so the
// readings are timeframe-agnostic — a 5m chart shows "1mo high = 21 daily
// bars ago", not "21 five-min bars ago".
//
// Per-period + per-direction (high vs low) toggles in the Inputs tab.
// Default: all on. Trim down to just what you care about.
//
// Pine v5 quirk notes:
//   • Single-line function calls only
//   • Table cells overwritten each bar — no accumulation
//
indicator("distance-from-extremes", overlay = true)

// ── Display toggles ────────────────────────────────────────────────
show_1m  = input.bool(true,  "1 month",       group = "Lookback periods")
show_3m  = input.bool(true,  "3 months",      group = "Lookback periods")
show_6m  = input.bool(false, "6 months",      group = "Lookback periods", tooltip = "Often redundant when ATH is within the last 6 months. Off by default; turn on for older-ATH names.")
show_1y  = input.bool(true,  "1 year (52wk)", group = "Lookback periods")
show_ath = input.bool(true,  "ATH (all-time high)", group = "Lookback periods")
show_atl = input.bool(false, "ATL (all-time low)",  group = "Lookback periods", tooltip = "Almost always shows huge meaningless numbers (e.g. +1876% from a decades-old low). Off by default.")

show_highs = input.bool(true, "Show distance from highs (drawdown)", group = "Direction")
show_lows  = input.bool(true, "Show distance from lows (rally)",     group = "Direction")

pos_choice = input.string("Top right", "Table position", options = ["Top right", "Top left", "Bottom right", "Bottom left", "Middle right"], group = "Display")

text_size_choice = input.string("Small", "Text size", options = ["Tiny", "Small", "Normal", "Large"], group = "Display")

hi_color  = input.color(color.new(color.red,   0),  "Highs / drawdown color", group = "Colors")
lo_color  = input.color(color.new(color.green, 0),  "Lows / rally color",     group = "Colors")
neutral_bg = input.color(color.new(color.gray, 80), "Header background",     group = "Colors")

// ── Daily-bar lookbacks (timeframe-agnostic) ───────────────────────
// 21 trading days ~ 1 month, 63 ~ 3mo, 126 ~ 6mo, 252 ~ 1yr
bars_1m  = 21
bars_3m  = 63
bars_6m  = 126
bars_1y  = 252

// Pull daily highest/lowest via request.security so this works the same
// on 5m, 15m, 1h, daily — readings always reflect calendar-period extremes
hi_1m = request.security(syminfo.tickerid, "D", ta.highest(high, bars_1m), lookahead = barmerge.lookahead_on)
lo_1m = request.security(syminfo.tickerid, "D", ta.lowest(low,   bars_1m), lookahead = barmerge.lookahead_on)
hi_3m = request.security(syminfo.tickerid, "D", ta.highest(high, bars_3m), lookahead = barmerge.lookahead_on)
lo_3m = request.security(syminfo.tickerid, "D", ta.lowest(low,   bars_3m), lookahead = barmerge.lookahead_on)
hi_6m = request.security(syminfo.tickerid, "D", ta.highest(high, bars_6m), lookahead = barmerge.lookahead_on)
lo_6m = request.security(syminfo.tickerid, "D", ta.lowest(low,   bars_6m), lookahead = barmerge.lookahead_on)
hi_1y = request.security(syminfo.tickerid, "D", ta.highest(high, bars_1y), lookahead = barmerge.lookahead_on)
lo_1y = request.security(syminfo.tickerid, "D", ta.lowest(low,   bars_1y), lookahead = barmerge.lookahead_on)

// ATH / ATL — running max/min accumulator across all available daily bars.
// Previous approach used ta.highest(high, 5000) which returns na when fewer
// than 5000 daily bars exist (e.g., CEG IPO'd 2022 → only ~1000 daily bars).
// Accumulator always works regardless of history depth.
get_running_max() =>
    var float _m = na
    _m := na(_m) ? high : math.max(_m, high)
    _m
get_running_min() =>
    var float _m = na
    _m := na(_m) ? low : math.min(_m, low)
    _m
hi_ath = request.security(syminfo.tickerid, "D", get_running_max(), lookahead = barmerge.lookahead_on)
lo_ath = request.security(syminfo.tickerid, "D", get_running_min(), lookahead = barmerge.lookahead_on)

// ── % distance helpers ─────────────────────────────────────────────
// pct_from(current, reference) → positive if current > reference (rally),
// negative if current < reference (drawdown)
f_pct(float cur, float ref) => na(ref) or ref == 0 ? na : (cur - ref) / ref * 100.0
f_pct_str(float v) => na(v) ? "—" : (v >= 0 ? "+" : "") + str.tostring(v, "0.00") + "%"
f_price_str(float v) => na(v) ? "—" : str.tostring(v, format.mintick)

// ── Resolve table position + text size ────────────────────────────
// Pine v5 quirk: multi-line ternaries silently break. Single-line only.
tbl_pos = pos_choice == "Top right" ? position.top_right : pos_choice == "Top left" ? position.top_left : pos_choice == "Bottom right" ? position.bottom_right : pos_choice == "Bottom left" ? position.bottom_left : position.middle_right

txt_size = text_size_choice == "Tiny" ? size.tiny : text_size_choice == "Small" ? size.small : text_size_choice == "Normal" ? size.normal : size.large

// ── Build table ────────────────────────────────────────────────────
// Table layout: 4 columns (Period / Ref / Price / Distance), variable rows
var table tbl = table.new(tbl_pos, 4, 12, border_width = 1, frame_color = color.new(color.gray, 60))

if barstate.islast
    // Clear the table first to avoid stale rows when toggles flip
    table.clear(tbl, 0, 0, 3, 11)

    row = 0

    // Header row — bg color, white text
    table.cell(tbl, 0, row, "Period",   text_color = color.white, bgcolor = neutral_bg, text_size = txt_size)
    table.cell(tbl, 1, row, "Ref",      text_color = color.white, bgcolor = neutral_bg, text_size = txt_size)
    table.cell(tbl, 2, row, "Price",    text_color = color.white, bgcolor = neutral_bg, text_size = txt_size)
    table.cell(tbl, 3, row, "Distance", text_color = color.white, bgcolor = neutral_bg, text_size = txt_size)
    row += 1

    // Helper closure-like pattern via inline blocks below.
    // Pine v5 quirk: can't really do closures, so we inline each row.

    // ── 1 month ─────────────────────────────────────────────────
    if show_1m and show_highs
        d = f_pct(close, hi_1m)
        c = d < 0 ? hi_color : lo_color
        table.cell(tbl, 0, row, "1mo",  text_size = txt_size)
        table.cell(tbl, 1, row, "High", text_color = hi_color, text_size = txt_size)
        table.cell(tbl, 2, row, f_price_str(hi_1m), text_size = txt_size)
        table.cell(tbl, 3, row, f_pct_str(d), text_color = c, text_size = txt_size)
        row += 1
    if show_1m and show_lows
        d = f_pct(close, lo_1m)
        c = d < 0 ? hi_color : lo_color
        table.cell(tbl, 0, row, "1mo",  text_size = txt_size)
        table.cell(tbl, 1, row, "Low",  text_color = lo_color, text_size = txt_size)
        table.cell(tbl, 2, row, f_price_str(lo_1m), text_size = txt_size)
        table.cell(tbl, 3, row, f_pct_str(d), text_color = c, text_size = txt_size)
        row += 1

    // ── 3 months ────────────────────────────────────────────────
    if show_3m and show_highs
        d = f_pct(close, hi_3m)
        c = d < 0 ? hi_color : lo_color
        table.cell(tbl, 0, row, "3mo",  text_size = txt_size)
        table.cell(tbl, 1, row, "High", text_color = hi_color, text_size = txt_size)
        table.cell(tbl, 2, row, f_price_str(hi_3m), text_size = txt_size)
        table.cell(tbl, 3, row, f_pct_str(d), text_color = c, text_size = txt_size)
        row += 1
    if show_3m and show_lows
        d = f_pct(close, lo_3m)
        c = d < 0 ? hi_color : lo_color
        table.cell(tbl, 0, row, "3mo",  text_size = txt_size)
        table.cell(tbl, 1, row, "Low",  text_color = lo_color, text_size = txt_size)
        table.cell(tbl, 2, row, f_price_str(lo_3m), text_size = txt_size)
        table.cell(tbl, 3, row, f_pct_str(d), text_color = c, text_size = txt_size)
        row += 1

    // ── 6 months ────────────────────────────────────────────────
    if show_6m and show_highs
        d = f_pct(close, hi_6m)
        c = d < 0 ? hi_color : lo_color
        table.cell(tbl, 0, row, "6mo",  text_size = txt_size)
        table.cell(tbl, 1, row, "High", text_color = hi_color, text_size = txt_size)
        table.cell(tbl, 2, row, f_price_str(hi_6m), text_size = txt_size)
        table.cell(tbl, 3, row, f_pct_str(d), text_color = c, text_size = txt_size)
        row += 1
    if show_6m and show_lows
        d = f_pct(close, lo_6m)
        c = d < 0 ? hi_color : lo_color
        table.cell(tbl, 0, row, "6mo",  text_size = txt_size)
        table.cell(tbl, 1, row, "Low",  text_color = lo_color, text_size = txt_size)
        table.cell(tbl, 2, row, f_price_str(lo_6m), text_size = txt_size)
        table.cell(tbl, 3, row, f_pct_str(d), text_color = c, text_size = txt_size)
        row += 1

    // ── 1 year (52wk) ───────────────────────────────────────────
    if show_1y and show_highs
        d = f_pct(close, hi_1y)
        c = d < 0 ? hi_color : lo_color
        table.cell(tbl, 0, row, "1yr",  text_size = txt_size)
        table.cell(tbl, 1, row, "High", text_color = hi_color, text_size = txt_size)
        table.cell(tbl, 2, row, f_price_str(hi_1y), text_size = txt_size)
        table.cell(tbl, 3, row, f_pct_str(d), text_color = c, text_size = txt_size)
        row += 1
    if show_1y and show_lows
        d = f_pct(close, lo_1y)
        c = d < 0 ? hi_color : lo_color
        table.cell(tbl, 0, row, "1yr",  text_size = txt_size)
        table.cell(tbl, 1, row, "Low",  text_color = lo_color, text_size = txt_size)
        table.cell(tbl, 2, row, f_price_str(lo_1y), text_size = txt_size)
        table.cell(tbl, 3, row, f_pct_str(d), text_color = c, text_size = txt_size)
        row += 1

    // ── ATH / ATL (independent toggles — ATL off by default) ────
    if show_ath and show_highs
        d = f_pct(close, hi_ath)
        c = d < 0 ? hi_color : lo_color
        table.cell(tbl, 0, row, "ATH",  text_size = txt_size)
        table.cell(tbl, 1, row, "High", text_color = hi_color, text_size = txt_size)
        table.cell(tbl, 2, row, f_price_str(hi_ath), text_size = txt_size)
        table.cell(tbl, 3, row, f_pct_str(d), text_color = c, text_size = txt_size)
        row += 1
    if show_atl and show_lows
        d = f_pct(close, lo_ath)
        c = d < 0 ? hi_color : lo_color
        table.cell(tbl, 0, row, "ATL",  text_size = txt_size)
        table.cell(tbl, 1, row, "Low",  text_color = lo_color, text_size = txt_size)
        table.cell(tbl, 2, row, f_price_str(lo_ath), text_size = txt_size)
        table.cell(tbl, 3, row, f_pct_str(d), text_color = c, text_size = txt_size)
        row += 1
