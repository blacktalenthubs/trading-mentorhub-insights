//@version=5
// ─────────────────────────────────────────────────────────────────────────────
// Weekly Position (WkPos) — the position-trader's weekly dashboard + ONE entry.
// ─────────────────────────────────────────────────────────────────────────────
// Complements WkStage (Weinstein 30wMA stage) and weekly_rc (prior-week-low
// reclaim). This adds the metrics those don't surface and fires the highest-value
// weekly entry: the pullback to a rising MA in an established uptrend.
//
// All weekly values are read via request.security("W", …) so the dashboard + the
// entry are IDENTICAL on any chart timeframe (put it on the weekly to view; the
// entry confirms once per week at the weekly close).
//
// DASHBOARD (top-right table):
//   • Stage      — price above a RISING 30wMA + 10w>30w = Stage 2 (the buy zone)
//   • MA stack   — 10 > 30 > 40 weekly, all in order = an orderly trend
//   • % off 52wH — leaders live near their highs; smaller = stronger
//   • RS vs SPY  — relative-strength ratio rising = outperforming the market (#1 edge)
//   • Accum      — up-week vs down-week volume over 10w (>1 = being bought)
//   • Wk RSI     — momentum; RSI 70 is the TARGET (sell strength), not an entry
//
// ENTRY — HELD / RECLAIM / BREAKOUT on the 10w AND the 30w (the same trio the staged
// PDH/PDL levels use). One condition: price CLOSES above the MA having interacted with
// it — dipped to it (low≤MA = HELD), been below last bar (close[1]≤MA = RECLAIM/BREAKOUT),
// or OPENED right at it (open within tol). 10w gated by Stage 2 (close>30w, 30w rising,
// 10w>30w); 30w gated by a rising 30w. Fires on EVERY qualifying touch (past + present),
// NOT the weekly close — bind on a daily/4h chart and enter at the MA. Re-armed per MA.
//   STOP   = just below the test bar's WICK LOW. A close below it = the MA failed → out.
//   target = weekly RSI 70 (the swing/position target). 30wMA below = runner trail.
//
// The 10w/30w are drawn as FLAT horizontal levels (anchored to the weekly value),
// so on a 4h/daily chart they read like PDL, not a curving MA.
//
// CHOP FILTERS (so it doesn't fire in a sideways range):
//   • 30wMA must be rising faster than a flat band (slope_floor_pct), not just >0.
//   • Re-arm: after a fire it stands down until price closes rearm_pct ABOVE the 10w.
// rule "weekly_ma_pullback" — default-OFF in the backend catalog; opt in to test.
// ─────────────────────────────────────────────────────────────────────────────
indicator("Weekly Position", "WkPos", overlay = true, max_labels_count = 200, max_lines_count = 100)

// ── inputs ───────────────────────────────────────────────────────────────────
ma_fast_len   = input.int  (10,   "Fast weekly MA", minval = 2, group = "Trend")
ma_slow_len   = input.int  (30,   "Slow weekly MA (Weinstein)", minval = 5, group = "Trend")
ma_long_len   = input.int  (40,   "Long weekly MA", minval = 5, group = "Trend")
slope_lb      = input.int  (4,    "MA slope lookback (weeks)", minval = 1, group = "Trend")
hi_lookback   = input.int  (52,   "52-week high lookback", minval = 10, group = "Metrics")
bench_sym     = input.symbol("SPY","RS benchmark (SPY/QQQ)", group = "Metrics")
rsi_len       = input.int  (14,   "Weekly RSI length", minval = 2, group = "Metrics")
accum_lb      = input.int  (10,   "Accumulation lookback (weeks)", minval = 4, group = "Metrics")
fire_pullback   = input.bool (true, "Fire MA-pullback-hold entry alert", group = "Entry")
pull_tol_pct    = input.float(2.0,  "Open-at-the-MA tolerance (% — counts a bar that opens right at the MA)", minval = 0.0, step = 0.5, group = "Entry")
slope_floor_pct = input.float(0.5,  "Chop filter — 30wMA min rising slope (% over the lookback)", minval = 0.0, step = 0.1, group = "Entry")
rearm_pct       = input.float(3.0,  "Re-arm — a week must close this % above the 10wMA before the next entry", minval = 0.5, step = 0.5, group = "Entry")
stop_buf_pct    = input.float(1.0,  "Stop buffer below the pullback low (%)", minval = 0.0, step = 0.5, group = "Entry")
show_stop       = input.bool (true, "Draw the stop line + label on each entry", group = "Display")
show_table    = input.bool (true, "Show metrics table", group = "Display")
col_up        = input.color(#26A69A, "Rising / healthy", group = "Display")
col_dn        = input.color(#EF5350, "Falling / caution", group = "Display")

// ── weekly series (anchored to "W" — identical on any chart TF) ──────────────
f_weekly() =>
    _f     = ta.sma(close, ma_fast_len)
    _s     = ta.sma(close, ma_slow_len)
    _l     = ta.sma(close, ma_long_len)
    _hi    = ta.highest(high, hi_lookback)
    _rsi   = ta.rsi(close, rsi_len)
    _slope = _s[slope_lb] != 0 ? (_s - _s[slope_lb]) / _s[slope_lb] * 100.0 : 0.0
    _upv   = math.sum(volume * (close > open ? 1.0 : 0.0), accum_lb)
    _dnv   = math.sum(volume * (close < open ? 1.0 : 0.0), accum_lb)
    _accum = _dnv > 0 ? _upv / _dnv : _upv
    // Stage 2 — above a 30wMA rising FASTER than the flat band (chop filter) + 10w>30w.
    // The ENTRY trigger is NOT computed here (it's a chart-level 10w touch — see below),
    // so we don't wait for the weekly close.
    _uptrend = (close > _s) and (_slope > slope_floor_pct) and (_f > _s)
    [_f, _s, _l, _hi, _rsi, _slope, _accum, _uptrend]

[wf, ws, wl, whi, wrsi, wslope, waccum, wuptrend] = request.security(syminfo.tickerid, "W", f_weekly(), lookahead = barmerge.lookahead_on)

// ── relative strength vs the benchmark (ratio + 4-week slope) ────────────────
sym_w  = request.security(syminfo.tickerid, "W", close,    lookahead = barmerge.lookahead_on)
sym_w4 = request.security(syminfo.tickerid, "W", close[slope_lb], lookahead = barmerge.lookahead_on)
bch_w  = request.security(bench_sym,        "W", close,    lookahead = barmerge.lookahead_on)
bch_w4 = request.security(bench_sym,        "W", close[slope_lb], lookahead = barmerge.lookahead_on)
rs_now  = not na(bch_w)  and bch_w  != 0 ? sym_w  / bch_w  : na
rs_prev = not na(bch_w4) and bch_w4 != 0 ? sym_w4 / bch_w4 : na
rs_rising = not na(rs_now) and not na(rs_prev) and rs_now > rs_prev

// ── derived display metrics ──────────────────────────────────────────────────
ma_stacked = not na(wf) and not na(ws) and not na(wl) and wf > ws and ws > wl
pct_off_hi = not na(whi) and whi != 0 ? (whi - close) / whi * 100.0 : na
accum_ok   = not na(waccum) and waccum > 1.0

// ── FLAT weekly MA lines — the 10w/30w drawn as ONE horizontal level each (like
// PDL), at the CURRENT weekly value, anchored via request.security("W"). So on a
// 4h/daily chart they read as flat weekly levels, not a curving MA. Same pattern as
// the flat S/R lines in ma-ema-daily. Redrawn on the last bar only.
show_ma_lines = input.bool(true, "Show flat weekly MA lines (10w/30w)", group = "Display")
ma_line_len   = input.int (60,   "Flat MA line length (bars back)", minval = 10, maxval = 500, group = "Display")
var line  ln_10w = na
var line  ln_30w = na
var label lb_10w = na
var label lb_30w = na
if show_ma_lines and barstate.islast
    line.delete(ln_10w)
    line.delete(ln_30w)
    label.delete(lb_10w)
    label.delete(lb_30w)
    if not na(wf)
        c10 = close > wf ? col_up : col_dn          // support (price above) / resistance (price below)
        ln_10w := line.new(bar_index - ma_line_len, wf, bar_index + 10, wf, color = c10, width = 2)
        lb_10w := label.new(bar_index + 10, wf, "10w " + (close > wf ? "SUP " : "RES ") + str.tostring(wf, format.mintick), style = label.style_label_left, color = c10, textcolor = color.white, size = size.small)
    if not na(ws)
        c30 = close > ws ? col_up : col_dn
        ln_30w := line.new(bar_index - ma_line_len, ws, bar_index + 10, ws, color = c30, width = 2)
        lb_30w := label.new(bar_index + 10, ws, "30w " + (close > ws ? "SUP " : "RES ") + str.tostring(ws, format.mintick), style = label.style_label_left, color = c30, textcolor = color.white, size = size.small)

// ── dashboard table (drawn on the last bar) ──────────────────────────────────
f_yn(bool ok) => ok ? "✓" : "✗"
var table t = table.new(position.top_right, 2, 6, border_width = 1)
if show_table and barstate.islast
    table.cell(t, 0, 0, "Stage 2",    text_color = color.white, text_size = size.small, bgcolor = wuptrend ? col_up : col_dn)
    table.cell(t, 1, 0, wuptrend ? "YES — buy zone" : "no", text_color = color.white, text_size = size.small, bgcolor = wuptrend ? col_up : col_dn)
    table.cell(t, 0, 1, "10>30>40",   text_color = color.white, text_size = size.small)
    table.cell(t, 1, 1, f_yn(ma_stacked), text_color = ma_stacked ? col_up : col_dn, text_size = size.small)
    table.cell(t, 0, 2, "% off 52wH", text_color = color.white, text_size = size.small)
    table.cell(t, 1, 2, na(pct_off_hi) ? "—" : str.tostring(pct_off_hi, "#.#") + "%", text_color = (not na(pct_off_hi) and pct_off_hi < 10) ? col_up : color.white, text_size = size.small)
    table.cell(t, 0, 3, "RS vs " + bench_sym, text_color = color.white, text_size = size.small)
    table.cell(t, 1, 3, rs_rising ? "▲ outperf" : "▼ lagging", text_color = rs_rising ? col_up : col_dn, text_size = size.small)
    table.cell(t, 0, 4, "Accum",      text_color = color.white, text_size = size.small)
    table.cell(t, 1, 4, na(waccum) ? "—" : str.tostring(waccum, "#.##") + "×", text_color = accum_ok ? col_up : color.white, text_size = size.small)
    table.cell(t, 0, 5, "Wk RSI",     text_color = color.white, text_size = size.small)
    table.cell(t, 1, 5, na(wrsi) ? "—" : str.tostring(wrsi, "#.#"), text_color = (not na(wrsi) and wrsi >= 70) ? col_dn : color.white, text_size = size.small)

// ── ENTRIES — held / reclaim / breakout on the 10w AND the 30w (the same trio the
// staged PDH/PDL levels use). One condition covers all three: price CLOSES above the
// MA having either tagged it this bar (low<=MA → HELD/wick-hold) or been below last bar
// (close[1]<=MA → RECLAIM or BREAKOUT). Fires on every qualifying touch — past and
// present — re-armed per MA so it can't cluster while price hugs the level.
//   STOP = just below the test bar's WICK LOW. A close below it = the MA failed → out.
// Qualifying touch: closes above the MA AND interacted with it —
//   • low <= MA          → dipped to it (HELD / wick-hold)
//   • close[1] <= MA     → was below last bar (RECLAIM / BREAKOUT)
//   • open within tol of MA → OPENED right at it (gap/open-at-the-level)
ma_entry(float ma) =>
    not na(ma) and close > ma and (low <= ma or (not na(close[1]) and close[1] <= ma) or math.abs(open - ma) / ma <= pull_tol_pct / 100.0)

// 10w entry — within Stage 2 (price>30w, 30w rising, 10w>30w).
e10 = wuptrend and ma_entry(wf)
var bool armed10 = true
if not na(wf) and close > wf * (1.0 + rearm_pct / 100.0)
    armed10 := true
fire10 = fire_pullback and e10 and armed10
if fire10
    armed10 := false

// 30w entry — the deeper support; gate on a RISING 30w (macro uptrend intact).
e30 = not na(ws) and not na(ws[slope_lb]) and ws > ws[slope_lb] and ma_entry(ws)
var bool armed30 = true
if not na(ws) and close > ws * (1.0 + rearm_pct / 100.0)
    armed30 := true
fire30 = fire_pullback and e30 and armed30
if fire30
    armed30 := false

fired_any  = fire10 or fire30
stop_level = low * (1.0 - stop_buf_pct / 100.0)

// Markers — green ▲ below the bar on EVERY qualifying touch (10w + 30w).
plotshape(fire10, title = "10w entry", style = shape.triangleup, location = location.belowbar, color = col_up, size = size.small, text = "10w")
plotshape(fire30, title = "30w entry", style = shape.triangleup, location = location.belowbar, color = color.new(color.teal, 0), size = size.small, text = "30w")

// Tags — Entry ABOVE the bar (not buried in the candle), Stop at the stop level.
if show_stop and fired_any
    line.new(bar_index, stop_level, bar_index + 8, stop_level, color = col_dn, width = 2, style = line.style_dashed)
    label.new(bar_index, high, "Entry " + str.tostring(close, format.mintick), yloc = yloc.abovebar, style = label.style_label_down, color = col_up, textcolor = color.white, size = size.small)
    label.new(bar_index, stop_level, "Stop " + str.tostring(stop_level, format.mintick), yloc = yloc.price, style = label.style_label_up, color = col_dn, textcolor = color.white, size = size.small)

if fired_any and barstate.isconfirmed
    _ma = fire10 ? "10w" : "30w"
    wp = '{"symbol":"' + syminfo.ticker + '","price":"' + str.tostring(close, format.mintick) + '","rule":"weekly_ma_pullback","direction":"BUY","interval":"W","entry":"' + str.tostring(close, format.mintick) + '","stop":"' + str.tostring(stop_level, format.mintick) + '","note":"Weekly ' + _ma + ' held/reclaim/breakout in a Stage-2 uptrend — price tested the rising ' + _ma + 'MA and closed back above it. STOP = just below the test-bar wick low (a close below = the MA failed). Target = weekly RSI 70.","target_rsi":"70","target_tf":"W","fired_at":"' + str.tostring(timenow) + '"}'
    alert(wp, alert.freq_once_per_bar_close)
