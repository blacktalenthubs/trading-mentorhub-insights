// @version=5
//
// open-line — Today's opening price as a key intraday level (VISUAL ONLY).
//
// Plots today's opening price as a horizontal line throughout the session
// and shows LOST/RECLAIM diamond markers at the cross bars.
//
// ALERTS LIVE IN `levels-day-vwap`, NOT HERE. This indicator is purely a
// visual layer so you can toggle the open line on/off independently of
// PDH/PDL/VWAP without affecting alert generation. Saves a TV watchlist-
// alert slot — `levels-day-vwap` fires open_lost / open_reclaimed via
// the same payload as PDH/PDL events.
//
// Markers shown here are duplicates of the alert-fire bars on the parent
// indicator — useful for visual confirmation when reviewing setups.
//
indicator("open-line", overlay = true)

show_open    = input.bool(true, "Show today's opening price line")
show_markers = input.bool(true, "Show LOST/RECLAIM diamonds")

// =====================================================================
// Today's opening price — captured on the first bar of each session
// =====================================================================
session_open_now = ta.change(time("D")) != 0
var float today_open = na

if session_open_now
    today_open := open

plot(show_open ? today_open : na, title = "Today's Open",
     color = color.new(#F59E0B, 20), style = plot.style_linebr, linewidth = 2)

// =====================================================================
// Lost / reclaimed detection — one-shot per session (visual flags only)
// =====================================================================
var bool was_above_open       = false
var bool open_lost_today      = false
var bool open_reclaimed_today = false

if session_open_now
    was_above_open       := false
    open_lost_today      := false
    open_reclaimed_today := false

if not na(today_open) and close > today_open
    was_above_open := true

just_lost_open      = was_above_open and not open_lost_today and not na(today_open) and not na(close[1]) and close < today_open and close[1] >= today_open
just_reclaimed_open = open_lost_today and not open_reclaimed_today and not na(today_open) and not na(close[1]) and close > today_open and close[1] <= today_open

if just_lost_open
    open_lost_today := true
if just_reclaimed_open
    open_reclaimed_today := true

// =====================================================================
// Visual markers — diamonds at the cross bars (no alerts fire here)
// =====================================================================
plotshape(show_markers and just_lost_open,
          title = "LOST OPEN", location = location.abovebar,
          color = color.new(#EF4444, 0), style = shape.diamond,
          size = size.tiny, text = "LOST OPEN", textcolor = color.white)
plotshape(show_markers and just_reclaimed_open,
          title = "RECLAIM OPEN", location = location.belowbar,
          color = color.new(#22C55E, 0), style = shape.diamond,
          size = size.tiny, text = "RECL OPEN", textcolor = color.white)
