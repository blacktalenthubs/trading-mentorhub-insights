// @version=5
//
// open-line — Today's opening price as a key intraday level (VISUAL ONLY).
//
// Plots today's opening price as a horizontal line throughout the session
// and shows LOST/RECLAIM diamond markers at the cross bars.
//
// Per-stock open-line ALERTS were retired (too noisy on individual names);
// the LOST/RECLAIM diamonds below stay as visual context only.
//
// Spec 61 (2026-06-03): ONE alert lives here now — an open-strength signal.
// The stepping open line acts as trailing trend support: while a symbol holds
// above each session's open (opens stepping higher), it's trending up. The
// alert fires when the symbol reclaims AND holds above today's open (two
// consecutive closes). The firing symbols are a comma-separated allow-list in
// the settings (default SPY,QQQ,DRAM) — add/remove names at will. Set the TV
// alert on the 1h chart for each symbol you list. Silent on anything not listed.
//
indicator("open-line", overlay = true)

show_open    = input.bool(true, "Show today's opening price line")
show_markers = input.bool(true, "Show LOST/RECLAIM diamonds")

// =====================================================================
// Today's opening price — captured on the first bar of each session
// =====================================================================
session_open_now = ta.change(time("D")) != 0
var float today_open = na

if session_open_now
    today_open := open

plot(show_open ? today_open : na, title = "Today's Open",
     color = color.new(#F59E0B, 20), style = plot.style_linebr, linewidth = 2)

// =====================================================================
// Lost / reclaimed detection — one-shot per session (visual flags only)
// =====================================================================
var bool was_above_open       = false
var bool open_lost_today      = false
var bool open_reclaimed_today = false

if session_open_now
    was_above_open       := false
    open_lost_today      := false
    open_reclaimed_today := false

if not na(today_open) and close > today_open
    was_above_open := true

just_lost_open      = was_above_open and not open_lost_today and not na(today_open) and not na(close[1]) and close < today_open and close[1] >= today_open
just_reclaimed_open = open_lost_today and not open_reclaimed_today and not na(today_open) and not na(close[1]) and close > today_open and close[1] <= today_open

if just_lost_open
    open_lost_today := true
if just_reclaimed_open
    open_reclaimed_today := true

// =====================================================================
// Visual markers — diamonds at the cross bars (no alerts fire here)
// =====================================================================
plotshape(show_markers and just_lost_open,
          title = "LOST OPEN", location = location.abovebar,
          color = color.new(#EF4444, 0), style = shape.diamond,
          size = size.tiny, text = "LOST OPEN", textcolor = color.white)
plotshape(show_markers and just_reclaimed_open,
          title = "RECLAIM OPEN", location = location.belowbar,
          color = color.new(#22C55E, 0), style = shape.diamond,
          size = size.tiny, text = "RECL OPEN", textcolor = color.white)

// =====================================================================
// Spec 61 — SPY / QQQ market-strength alert (reclaim & HOLD above open)
// =====================================================================
// Distinct from the single-bar just_reclaimed_open visual above: this
// requires the index to STAY above the open — two consecutive closes above
// today's open — so it covers both "opened above and held" and "dipped then
// reclaimed", without whipsawing on a one-bar poke. One alert per reclaim;
// re-arms after a close back below the open. Hard-gated to SPY/QQQ.
fire_index_open_alert = input.bool(true, "Fire the open-reclaim strength alert", group = "Index strength alert")
// Comma-separated allow-list — edit this in the indicator settings to add or
// remove symbols at will (e.g. "SPY,QQQ,DRAM,IWM,SMH"). Case/space-insensitive.
// The alert stays silent on any symbol not in this list, so it's safe to load
// the indicator everywhere. (You still set the actual TV alert per symbol.)
index_symbols = input.string("SPY,QQQ,DRAM", "Symbols allowed to fire (comma-separated)", group = "Index strength alert")
_idx_syms = "," + str.replace_all(str.upper(index_symbols), " ", "") + ","
is_index  = str.contains(_idx_syms, "," + str.upper(syminfo.ticker) + ",")

held_above_open = not na(today_open) and not na(close[1]) and close > today_open and close[1] > today_open
var bool open_strength_state = false
if session_open_now
    open_strength_state := false
enter_strength = held_above_open and not open_strength_state
if enter_strength
    open_strength_state := true
else if not na(today_open) and close < today_open
    open_strength_state := false

atr14_ol = nz(ta.atr(14)[1], close * 0.005)

build_index_open_payload(rule) =>
    '{"symbol":"' + syminfo.ticker
      + '","exchange":"' + syminfo.prefix
      + '","interval":"' + timeframe.period
      + '","price":"' + str.tostring(close, format.mintick)
      + '","entry":"' + str.tostring(close, format.mintick)
      + '","stop":"' + str.tostring(today_open, format.mintick)
      + '","target_1":"' + str.tostring(close + atr14_ol, format.mintick)
      + '","target_2":"' + str.tostring(close + atr14_ol * 2, format.mintick)
      + '","rule":"' + rule
      + '","direction":"BUY'
      + '","today_open":"' + str.tostring(today_open, format.mintick)
      + '","above_open":"true'
      + '","fired_at":"' + str.tostring(timenow) + '"}'

if fire_index_open_alert and is_index and enter_strength
    alert(build_index_open_payload("index_open_strength"), alert.freq_once_per_bar_close)

plotshape(show_markers and is_index and enter_strength,
          title = "OPEN STRENGTH", location = location.belowbar,
          color = color.new(#16A34A, 0), style = shape.triangleup,
          size = size.small, text = "STR", textcolor = color.white)
