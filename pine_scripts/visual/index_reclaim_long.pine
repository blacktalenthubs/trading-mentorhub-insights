// Core-Index Reclaim Long (#65) — the ONE pattern that backtested an edge over 3yr
// (SPY/QQQ, 15m: 77% win, +0.80R, +21%/trade on weekly-ATM options).
// Morning reclaim of the ORH or PDH: price is above the level, dips ~0.18% under it
// (shakeout), reclaims it within ~90 min above VWAP — AND there is ≥1R of room to the
// next resistance (don't buy into a ceiling) → LONG. Stop = the dip low. TARGET =
// take profit into the next resistance. RUN THIS ON A 15-MINUTE CHART (validated TF).
//@version=5
indicator("Index Reclaim Long — ORH/PDH", overlay=true, max_labels_count=500, max_lines_count=500)

dipPct      = input.float(0.18, "Shakeout dip below the level (%)", step=0.01) / 100.0
reclaimBars = input.int(6,  "Reclaim within N bars of the dip", minval=1)
orMin       = input.int(30, "Opening-range minutes", minval=5)
morningMin  = input.int(120, "Only fire in the first N minutes", minval=30)
minHeadroom = input.float(1.0, "Min room to next resistance (R)", step=0.5)
useVwap     = input.bool(true, "Require close above VWAP")
showLines   = input.bool(true, "Draw ORH/ORL / PDH/PDL / VWAP")

tfMin    = math.max(1.0, timeframe.in_seconds() / 60.0)
orBars   = math.max(1, math.round(orMin / tfMin))
mornBars = math.round(morningMin / tfMin)

newSession = ta.change(time("D")) != 0
var int sbar = 0
sbar := newSession ? 0 : sbar + 1

var float orh = na
var float orl = na
if newSession
    orh := high
    orl := low
else if sbar < orBars
    orh := math.max(orh, high)
    orl := math.min(orl, low)

pdh = request.security(syminfo.tickerid, "D", high[1], lookahead=barmerge.lookahead_on)
pdl = request.security(syminfo.tickerid, "D", low[1],  lookahead=barmerge.lookahead_on)

vwapv = ta.vwap(hlc3)
orReady   = sbar >= orBars
inMorning = sbar <= mornBars

// nearest of the four boundaries strictly above a price (the next resistance), or na.
f_next_above(float p) =>
    float best = na
    if not na(orh) and orh > p
        best := na(best) ? orh : math.min(best, orh)
    if not na(pdh) and pdh > p
        best := na(best) ? pdh : math.min(best, pdh)
    if not na(orl) and orl > p
        best := na(best) ? orl : math.min(best, orl)
    if not na(pdl) and pdl > p
        best := na(best) ? pdl : math.min(best, pdl)
    best

// Reclaim-long state machine + headroom gate. Returns [fire, stopLow, target].
f_reclaim(float L) =>
    var bool above  = false
    var bool dipped = false
    var bool fired  = false
    var int  dipbar = 0
    var float dlow  = na
    if newSession
        above := false
        dipped := false
        fired := false
        dlow := na
    bool sig = false
    float tgt = na
    if (not na(L)) and orReady and inMorning
        if close > L
            above := true
        if above and not dipped and low <= L * (1 - dipPct)
            dipped := true
            dipbar := sbar
            dlow := low
        if dipped and not fired
            dlow := math.min(dlow, low)
        bool reclaimed = dipped and not fired and close > L and (sbar - dipbar <= reclaimBars)
        bool vwapok = (not useVwap) or (close > vwapv)
        if reclaimed and vwapok
            float t = f_next_above(close)
            float risk = math.max(close - dlow, syminfo.mintick)
            float headroom = na(t) ? 99.0 : (t - close) / risk
            if headroom >= minHeadroom
                fired := true
                sig := true
                tgt := t
    [sig, dlow, tgt]

[orhSig, orhStop, orhTgt] = f_reclaim(orh)
[pdhSig, pdhStop, pdhTgt] = f_reclaim(pdh)

// Draw the take-profit target (next resistance) when a signal fires.
if orhSig and not na(orhTgt)
    line.new(bar_index, orhTgt, bar_index + 8, orhTgt, color=color.new(color.orange, 0), width=2)
    label.new(bar_index + 8, orhTgt, "TP", style=label.style_label_left, color=color.new(color.orange, 0), textcolor=color.white, size=size.tiny)
if pdhSig and not na(pdhTgt)
    line.new(bar_index, pdhTgt, bar_index + 8, pdhTgt, color=color.new(color.orange, 0), width=2)
    label.new(bar_index + 8, pdhTgt, "TP", style=label.style_label_left, color=color.new(color.orange, 0), textcolor=color.white, size=size.tiny)

plot(showLines ? vwapv : na, "VWAP", color=color.new(color.purple, 0), linewidth=1)
plot(showLines and orReady ? orh : na, "ORH", color=color.new(color.teal, 0), style=plot.style_linebr)
plot(showLines and orReady ? orl : na, "ORL", color=color.new(color.teal, 40), style=plot.style_linebr)
plot(showLines ? pdh : na, "PDH", color=color.new(color.gray, 30), style=plot.style_linebr)
plot(showLines ? pdl : na, "PDL", color=color.new(color.gray, 60), style=plot.style_linebr)

plotshape(orhSig, "ORH reclaim long", shape.triangleup, location.belowbar, color=color.new(color.lime, 0), size=size.small, text="ORH")
plotshape(pdhSig, "PDH reclaim long", shape.triangleup, location.belowbar, color=color.new(color.green, 0), size=size.small, text="PDH")

alertcondition(orhSig, "ORH reclaim long", "Reclaim of the opening-range high - long (room to next resistance)")
alertcondition(pdhSig, "PDH reclaim long", "Reclaim of the prior-day high - long (room to next resistance)")
