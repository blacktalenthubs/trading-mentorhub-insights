// @version=5
// SMA Flat S/R — the 5 / 20 / 50 / 100 / 200 DAILY SMAs drawn as FLAT horizontal
// support/resistance lines. A daily SMA only updates on the daily close, so it
// sits flat intraday (like PDL). Color follows PRICE POSITION:
//   GREEN = SUPPORT     (price is ABOVE the line)
//   RED   = RESISTANCE  (price is BELOW the line)
// The role flips when price closes back across the line. Visual only — no alerts.
// Locked to the DAILY value via request.security, so the lines stay put on ANY
// chart timeframe (5m ↔ 15m ↔ 1h ↔ D).
indicator("SMA Flat · 5·20·50·100·200", "SMA Flat", overlay = true, max_lines_count = 20, max_labels_count = 20)

// ── Which lines ──
show5   = input.bool(true, "SMA 5",   inline = "a", group = "Lines")
show20  = input.bool(true, "SMA 20",  inline = "a", group = "Lines")
show50  = input.bool(true, "SMA 50",  inline = "b", group = "Lines")
show100 = input.bool(true, "SMA 100", inline = "b", group = "Lines")
show200 = input.bool(true, "SMA 200", inline = "c", group = "Lines")

// ── Style ──
supCol  = input.color(#26A69A, "Support color (price above)",    group = "Style")
resCol  = input.color(#EF5350, "Resistance color (price below)", group = "Style")
lineW   = input.int(2, "Line width", minval = 1, maxval = 5, group = "Style")
lineLen = input.int(60, "Line length (bars back)", minval = 10, maxval = 500, group = "Style")
labSize = input.string("small", "Label size", options = ["tiny", "small", "normal", "large"], group = "Style")
_lsz = labSize == "tiny" ? size.tiny : labSize == "normal" ? size.normal : labSize == "large" ? size.large : size.small

// ── Daily SMAs (settled value via [1] + lookahead → flat + non-repainting on any TF) ──
sma5   = request.security(syminfo.tickerid, "D", ta.sma(close, 5)[1],   lookahead = barmerge.lookahead_on)
sma20  = request.security(syminfo.tickerid, "D", ta.sma(close, 20)[1],  lookahead = barmerge.lookahead_on)
sma50  = request.security(syminfo.tickerid, "D", ta.sma(close, 50)[1],  lookahead = barmerge.lookahead_on)
sma100 = request.security(syminfo.tickerid, "D", ta.sma(close, 100)[1], lookahead = barmerge.lookahead_on)
sma200 = request.security(syminfo.tickerid, "D", ta.sma(close, 200)[1], lookahead = barmerge.lookahead_on)

// ── Draw — one flat horizontal line per SMA at its current value, redrawn on the last bar ──
var line[]  _lines  = array.new_line(0)
var label[] _labels = array.new_label(0)

f_draw(float ma, string nm, bool show) =>
    if show and not na(ma)
        sup = close > ma
        col = sup ? supCol : resCol
        ln  = line.new(bar_index - lineLen, ma, bar_index + 6, ma, color = col, width = lineW)
        lb  = label.new(bar_index + 6, ma, nm + (sup ? "  SUPPORT  " : "  RESIST  ") + str.tostring(ma, format.mintick), style = label.style_label_left, color = col, textcolor = color.white, size = _lsz)
        array.push(_lines, ln)
        array.push(_labels, lb)

if barstate.islast
    if array.size(_lines) > 0
        for i = 0 to array.size(_lines) - 1
            line.delete(array.get(_lines, i))
        array.clear(_lines)
    if array.size(_labels) > 0
        for i = 0 to array.size(_labels) - 1
            label.delete(array.get(_labels, i))
        array.clear(_labels)
    f_draw(sma5,   "SMA 5",   show5)
    f_draw(sma20,  "SMA 20",  show20)
    f_draw(sma50,  "SMA 50",  show50)
    f_draw(sma100, "SMA 100", show100)
    f_draw(sma200, "SMA 200", show200)
