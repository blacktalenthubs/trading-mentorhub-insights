// @version=5
//
// 3ML — 3-Month (quarterly) candle levels. VISUAL ONLY (no alerts). Captures the last N 3-month candles'
// HIGH, LOW and BODY (open→close) as horizontal levels, LOCKED to the 3M timeframe via request.security
// (lookahead_on + fixed offsets) so they sit at the same price on EVERY chart TF — flip 3M ↔ M ↔ W ↔ D
// and nothing moves. The big-degree quarterly high/low = the strongest S/R; the body = where the quarter
// spent its value (open & close edges).
//
// Each candle draws: a HIGH rail + a LOW rail (projected right) and a translucent BODY box over the
// candle, green (close>open) / red (close<open). Right-edge tags name the recency (3M-cur / 3M-1 / 3M-2).
//
// Set the timeframe input to "3" if you actually want 3-MINUTE candles instead of 3-month.
//
indicator("3-Month Levels · H/L + Body", "3ML", overlay = true, max_lines_count = 20, max_boxes_count = 10, max_labels_count = 20)

gS = "Capture"
res      = input.timeframe("3M", "Candle timeframe to capture (3M = quarterly · use \"3\" for 3-minute)", group = gS)
nCap     = input.int(2, "How many quarters (current + prior)", minval = 1, maxval = 3, group = gS)
incCurr  = input.bool(false, "Include the current (developing) quarter — OFF: its H/L/C repaint until the quarter closes", group = gS)
gV = "Display"
showHL    = input.bool(true, "High / Low rails", group = gV)
showBody  = input.bool(true, "Body box (open→close)", group = gV)
showTag   = input.bool(true, "Right-edge S / R marks", group = gV)
showBodyTag = input.bool(true, "Include the body edges (Open / Close) as levels too", group = gV)
confTol   = input.float(0.4, "Confluence merge tolerance (%) — levels within this collapse to one mark", minval = 0.0, step = 0.1, group = gV) / 100.0
tagOff    = input.int(3, "Mark offset — bars to the RIGHT of the last candle", minval = 0, maxval = 60, group = gV)
colUp     = input.color(color.new(color.teal, 0),   "Up candle",   group = gV, inline = "c")
colDn     = input.color(color.new(color.red, 0),    "Down candle", group = gV, inline = "c")
bodyTrans = input.int(88, "Body fill transparency", minval = 50, maxval = 98, group = gV)

tid = syminfo.tickerid

// ── Fetch the current developing candle (0) + the last 3 completed (1..3), locked. The current bar uses
// lookahead_on so its developing values are correct on the realtime bar (off returns the PRIOR bar) — but
// note it still REPAINTS until the quarter closes, so it's off by default. ──
[h0, l0, o0, c0, t0] = request.security(tid, res, [high,    low,    open,    close,    time],    lookahead = barmerge.lookahead_on)
[h1, l1, o1, c1, t1] = request.security(tid, res, [high[1], low[1], open[1], close[1], time[1]], lookahead = barmerge.lookahead_on)
[h2, l2, o2, c2, t2] = request.security(tid, res, [high[2], low[2], open[2], close[2], time[2]], lookahead = barmerge.lookahead_on)
[h3, l3, o3, c3, t3] = request.security(tid, res, [high[3], low[3], open[3], close[3], time[3]], lookahead = barmerge.lookahead_on)

// Build the draw set. Each candle needs: high, low, open, close, LEFT edge (its start), RIGHT edge (the
// next-newer candle's start; the developing candle extends to now), and a recency name.
// incCurr → [current, prior, prior-2]; else → [prior, prior-2, prior-3].
hArr = incCurr ? array.from(h0, h1, h2) : array.from(h1, h2, h3)
lArr = incCurr ? array.from(l0, l1, l2) : array.from(l1, l2, l3)
oArr = incCurr ? array.from(o0, o1, o2) : array.from(o1, o2, o3)
cArr = incCurr ? array.from(c0, c1, c2) : array.from(c1, c2, c3)
lEdge = incCurr ? array.from(t0, t1, t2) : array.from(t1, t2, t3)     // candle start (left)
rEdge = incCurr ? array.from(time, t0, t1) : array.from(t0, t1, t2)   // next-newer start (right)
var line[]  lns  = array.new_line()
var box[]   bxs  = array.new_box()
var label[] lbls = array.new_label()

// True if `val` is a real number within [lo, hi] (cluster-membership test).
f_in(float val, float lo, float hi) =>
    not na(val) and val >= lo and val <= hi

// Quarter prefix by draw-index: 0 = current ("CQ"), 1 = prior ("PQ"), older → "P2Q", "P3Q"…
f_qpref(int qi) =>
    int back = incCurr ? qi : qi + 1
    back == 0 ? "CQ" : back == 1 ? "PQ" : back == 2 ? "PPQ" : "P" + str.tostring(back) + "Q"

// Append a level's NAME to `cur` (joined with "+") when its price falls inside the cluster [lo, hi].
f_addName(string cur, float val, float lo, float hi, string nm) =>
    f_in(val, lo, hi) ? (cur == "" ? nm : cur + "+" + nm) : cur

if barstate.islast
    for l in lns
        line.delete(l)
    for b in bxs
        box.delete(b)
    for lb in lbls
        label.delete(lb)
    array.clear(lns)
    array.clear(bxs)
    array.clear(lbls)
    float[] levs = array.new_float()                     // every edge, collected then clustered into named marks
    for i = 0 to nCap - 1
        float H = array.get(hArr, i)
        float L = array.get(lArr, i)
        float O = array.get(oArr, i)
        float C = array.get(cArr, i)
        int   xL = int(array.get(lEdge, i))
        int   xR = int(array.get(rEdge, i))
        color col = C >= O ? colUp : colDn
        bool  isCur = incCurr and i == 0                 // the live, still-forming quarter
        if not na(H) and not na(L) and not na(xL)
            if showHL
                array.push(lns, line.new(xL, H, int(time), H, xloc = xloc.bar_time, color = col, width = 1))
                array.push(lns, line.new(xL, L, int(time), L, xloc = xloc.bar_time, color = col, width = 1))
            if showBody and not na(O) and not na(C)
                array.push(bxs, box.new(xL, math.max(O, C), xR, math.min(O, C), xloc = xloc.bar_time, border_color = color.new(col, isCur ? 0 : 45), border_width = isCur ? 2 : 1, border_style = isCur ? line.style_dashed : line.style_solid, bgcolor = color.new(col, isCur ? bodyTrans - 8 : bodyTrans)))
            if showTag and showHL
                array.push(levs, H)
                array.push(levs, L)
            if showTag and showBodyTag and not na(O) and not na(C)
                array.push(levs, O)
                array.push(levs, C)
    // Cluster nearby edges → ONE mark, labelled by the quarter+edge NAMES it holds (CQH / PQL / PQC+CQO…).
    // Colour = role by side: price ABOVE the level → Support (green), BELOW → Resistance (red).
    if showTag and array.size(levs) > 0
        array.sort(levs, order.ascending)
        int nL = array.size(levs)
        int i = 0
        while i < nL
            float base = array.get(levs, i)
            float sum  = base
            int   j    = i + 1
            while j < nL and (array.get(levs, math.min(j, nL - 1)) - base) <= base * confTol
                sum := sum + array.get(levs, j)
                j := j + 1
            float avg  = sum / (j - i)
            float cmax = array.get(levs, j - 1)                  // top of this cluster (sorted)
            string nm = ""
            for qi = 0 to nCap - 1
                string pf = f_qpref(qi)
                nm := f_addName(nm, array.get(hArr, qi), base, cmax, pf + "H")
                if showBodyTag
                    nm := f_addName(nm, array.get(oArr, qi), base, cmax, pf + "O")
                    nm := f_addName(nm, array.get(cArr, qi), base, cmax, pf + "C")
                nm := f_addName(nm, array.get(lArr, qi), base, cmax, pf + "L")
            bool  conf  = str.contains(nm, "+")                  // 2+ named levels merged = confluence
            bool  isSup = close >= avg
            color rcol  = isSup ? color.new(color.green, 0) : color.new(color.red, 0)
            array.push(lbls, label.new(bar_index + tagOff, avg, nm, xloc = xloc.bar_index, style = label.style_label_left, color = color.new(rcol, conf ? 0 : 25), textcolor = color.white, size = conf ? size.normal : size.small))
            i := j
