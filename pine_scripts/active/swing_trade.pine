// @version=5
//
// PQHL — Prior Quarter · High / Low / Close. VISUAL + swing alerts. Draws the HIGH, LOW and CLOSE of
// the ONE last COMPLETED 3-month (quarterly) candle — the prior quarter (PQ, [1]). (User 2026-07-21:
// prior quarter only — the prior-PRIOR quarter added noise, dropped.) Locked via request.security so
// the levels sit at the same price on every chart TF; a completed quarter = fixed values (no repaint).
// The quarterly range is major, slow S/R — the starting block for longer-term (swing) entries. A
// reclaim of any of the 3 PQ levels fires pq_reclaim. BIND ON 4h — a 4h close above the level is a
// real reclaim, not a 1h wick.
//
indicator("Prior Quarter High/Low", "PQ H/L", overlay = true, max_lines_count = 20, max_labels_count = 20)

colH      = input.color(color.new(color.red, 0),   "Quarter HIGH",  group = "Lines")
colL      = input.color(color.new(color.teal, 0),  "Quarter LOW",   group = "Lines")
colC      = input.color(color.new(color.gray, 0),  "Quarter CLOSE", group = "Lines")
showClose = input.bool(true, "Show the CLOSE lines", group = "Lines")
lineW     = input.int(2, "Line thickness", minval = 1, maxval = 6, group = "Lines")
showPrice = input.bool(true, "Show price in the label", group = "Lines")

// The ONE last completed quarter's H/L/C — [1] = prior quarter (PQ).
// Locked + no repaint via lookahead_on on the 3M timeframe.
[pqh,  pql,  pqc]  = request.security(syminfo.tickerid, "3M", [high[1], low[1], close[1]], lookahead = barmerge.lookahead_on)
// Daily 200 EMA + 200 SMA — the institutional dip-buy zone. A DAILY-CLOSE bounce here is a SWING entry
// (an intraday bounce is a day-trade, already fired by LMR). Emits ma200_bounce.
[ema200d, sma200d] = request.security(syminfo.tickerid, "D", [ta.ema(close, 200)[1], ta.sma(close, 200)[1]], lookahead = barmerge.lookahead_on)
// Gap-and-go references (same as WLV/MLV): today's daily OPEN + the prior-day CLOSE. A stock that
// OPENS above a PQ level after the prior day closed under it has reclaimed it via the gap (NBIX over
// the PQ high) — the close-to-close cross misses that, so we add it explicitly below.
dOpen = request.security(syminfo.tickerid, "D", open,     lookahead = barmerge.lookahead_off)
pdc   = request.security(syminfo.tickerid, "D", close[1], lookahead = barmerge.lookahead_on)

// ── Draw all six quarterly levels (redrawn on the last bar; old ones cleared first) ──────────────
var line[]  pq_lines  = array.new_line(0)
var label[] pq_labels = array.new_label(0)
draw_q(float lvl, string nm, color col, bool dashed) =>
    if not na(lvl)
        ln = line.new(bar_index - 1, lvl, bar_index, lvl, extend = extend.both, color = col, width = lineW, style = dashed ? line.style_dashed : line.style_solid)
        lb = label.new(bar_index + 5, lvl, nm + (showPrice ? "  " + str.tostring(lvl, format.mintick) : ""), xloc = xloc.bar_index, style = label.style_label_left, color = color.new(col, 85), textcolor = col, size = size.small)
        array.push(pq_lines, ln)
        array.push(pq_labels, lb)
if barstate.islast
    if array.size(pq_lines) > 0
        for i = 0 to array.size(pq_lines) - 1
            line.delete(array.get(pq_lines, i))
        array.clear(pq_lines)
    if array.size(pq_labels) > 0
        for i = 0 to array.size(pq_labels) - 1
            label.delete(array.get(pq_labels, i))
        array.clear(pq_labels)
    draw_q(pqh, "PQ High", colH, false)
    draw_q(pql, "PQ Low",  colL, false)
    if showClose
        draw_q(pqc, "PQ Close", colC, true)

// ══════════════════════════════════════════════════════════════════════════════════════════════
// SWING ALERTS — fire THE MOMENT a quarterly level is reclaimed / broken, INTRADAY. BIND ON AN
// INTRADAY TF (1h recommended) so you catch the break as it happens (AAPL 317 → 326), NOT the EOD
// close. Deduped once per SESSION per level (the level breaks once, alerts once, resets next day).
// Fires pq_reclaim (BUY) with the level named. Bottom-bounce / value-reclaim / breakout swing:
// low win% (~25-40%) but 3-5:1 R:R — winners run the range (INOD 34→125), losers cut under the level.
// Entry = close, stop = 1.5% under the level, targets = up the range toward the quarter HIGH.
gA = "Swing alerts — bind on an INTRADAY TF (e.g. 1h)"
fireAlerts = input.bool(true, "Fire quarterly reclaim / break alerts when a level is crossed (intraday, once/session)", group = gA)
showMarks  = input.bool(true, "Show reclaim ▲ marks", group = gA)

f_pqpay(string rule, string tag, float e, float s, float t1, float t2) =>
    '{"symbol":"' + syminfo.ticker + '","exchange":"' + syminfo.prefix + '","interval":"' + timeframe.period + '","price":"' + str.tostring(close, format.mintick) + '","entry":"' + str.tostring(e, format.mintick) + '","stop":"' + str.tostring(s, format.mintick) + '","target_1":"' + str.tostring(t1, format.mintick) + '","target_2":"' + str.tostring(t2, format.mintick) + '","rule":"' + rule + '","direction":"BUY","ma_tag":"' + tag + '"}'

// Once-per-session latch per level — reset on a new day, so an intraday cross fires once (not on every
// re-cross in chop). The cross itself (close crosses above the level) is TF-agnostic — on a 1h chart
// it triggers on the 1h bar that breaks the level, i.e. intraday, not at the daily close.
newDay = ta.change(time("D")) != 0
var bool fL  = false
var bool fC  = false
var bool fH  = false
var bool fE2 = false
var bool fS2 = false
if newDay
    fL  := false
    fC  := false
    fH  := false
    fE2 := false
    fS2 := false
rng   = pqh - pql
// RECLAIM = open-agnostic + GAP-and-go (user 2026-07-21 · same rule as WLV/MLV). Fire when price
// CLOSED above the level AND either (a) it traded to/below the level this bar's day — a dip-and-
// reclaim / retest, tracked by a per-level swept latch that survives across bars — OR (b) the day
// OPENED above the level after the prior day closed under it (a gap-and-go: NBIX opening slightly
// above the PQ high and running). Open location no longer matters; the close divides support/resist.
// Once per level per day (the fired latch). Each call site keeps its OWN `swept` (Pine var-per-call).
f_reclaim(float L, bool fired) =>
    var bool swept = false
    if newDay
        swept := false
    if not na(L) and low <= L
        swept := true
    bool gap = not na(L) and not na(pdc) and dOpen > L and pdc <= L
    not na(L) and close > L and (swept or gap) and not fired
rc_low   = f_reclaim(pql, fL)          // PQ LOW  — bounce / reclaim from below
rc_close = f_reclaim(pqc, fC)          // PQ CLOSE — reclaim
rc_high  = f_reclaim(pqh, fH)          // PQ HIGH — break / gap-and-go over the level
// 200-day MA
rc_e200  = f_reclaim(ema200d, fE2)     // 200-EMA bounce
rc_s200  = f_reclaim(sma200d, fS2)     // 200-SMA bounce
if rc_low
    fL  := true
if rc_close
    fC  := true
if rc_high
    fH  := true
if rc_e200
    fE2 := true
if rc_s200
    fS2 := true

plotshape(showMarks and rc_low,   "Q Low bounce",    style = shape.triangleup, location = location.belowbar, color = color.new(color.lime, 0),  size = size.small, text = "Q-L")
plotshape(showMarks and rc_close, "Q Close reclaim", style = shape.triangleup, location = location.belowbar, color = color.new(color.teal, 0),  size = size.small, text = "Q-C")
plotshape(showMarks and rc_high,  "Q High break",    style = shape.triangleup, location = location.belowbar, color = color.new(color.aqua, 0),  size = size.small, text = "Q-H")
plotshape(showMarks and (rc_e200 or rc_s200),  "200-MA bounce",   style = shape.triangleup, location = location.belowbar, color = color.new(#7E57C2, 0), size = size.small, text = "200")

// PQ alerts
if fireAlerts and rc_low
    alert(f_pqpay("pq_reclaim", "PQ Low",   close, pql * 0.985, pqc, pqh), alert.freq_once_per_bar_close)
if fireAlerts and rc_close
    alert(f_pqpay("pq_reclaim", "PQ Close", close, pqc * 0.985, pqh, pqh + rng * 0.5), alert.freq_once_per_bar_close)
if fireAlerts and rc_high
    alert(f_pqpay("pq_reclaim", "PQ High",  close, pqh * 0.985, pqh + rng * 0.5, pqh + rng), alert.freq_once_per_bar_close)
// 200-MA alerts
if fireAlerts and rc_e200
    alert(f_pqpay("ma200_bounce", "EMA 200", close, ema200d * 0.985, close + (close - ema200d) * 2, close + (close - ema200d) * 3), alert.freq_once_per_bar_close)
if fireAlerts and rc_s200
    alert(f_pqpay("ma200_bounce", "SMA 200", close, sma200d * 0.985, close + (close - sma200d) * 2, close + (close - sma200d) * 3), alert.freq_once_per_bar_close)
