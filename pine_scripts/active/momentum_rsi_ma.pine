//@version=5
// ─────────────────────────────────────────────────────────────────────────────
// Momentum — RSI 70 + 5/20 EMA cross + RSI oversold-recovery.  VISUAL ONLY.
// ─────────────────────────────────────────────────────────────────────────────
// This is a CHART OVERLAY, not an alert source — drop it on any chart (any TF) to
// SEE the swing-momentum markers. The ALERTS for these fire from levels-day-vwap
// (folded in there so the watchlist stays at max 2 bound Pines); this Pine has no
// alert() calls. Markers here are computed on the chart's own bars for a quick
// visual; the alerts use the confirmed DAILY close.
//
//   ▲ RSI70 (orange) — RSI(14) crosses ABOVE 70 (parabolic ignition).
//   ▲ 5/20  (lime)   — 5 EMA crosses ABOVE the 20 EMA (Steve Burns).
//   ▲ OS    (aqua)   — RSI first closes in the 30–35 buy zone (never below 30).
// ─────────────────────────────────────────────────────────────────────────────
indicator("Momentum — RSI 70 / 5-20 cross / oversold (visual)", "Momentum", overlay = true, max_labels_count = 100)

show_ma   = input.bool(true,  "Plot 5 / 20 EMA")
os_floor  = input.float(30.0, "Oversold zone FLOOR — never below this RSI", minval = 20.0, maxval = 35.0, step = 1.0)
os_ceil   = input.float(35.0, "Oversold zone CEILING", minval = 30.0, maxval = 45.0, step = 1.0)

r   = ta.rsi(close, 14)
e5  = ta.ema(close, 5)
e20 = ta.ema(close, 20)
rsi70   = ta.crossover(r, 70.0)
cross   = ta.crossover(e5, e20)
in_zone    = (r >= os_floor) and (r <= os_ceil)
os_recover = in_zone and not in_zone[1]

plot(show_ma ? e5  : na, "EMA 5",  color = color.new(color.yellow, 0), linewidth = 2)
plot(show_ma ? e20 : na, "EMA 20", color = color.new(color.green, 0),  linewidth = 2)
plotshape(rsi70,      title = "RSI70", style = shape.triangleup, location = location.belowbar, color = color.new(color.orange, 0), text = "RSI70", size = size.small)
plotshape(cross,      title = "5x20",  style = shape.triangleup, location = location.belowbar, color = color.new(color.lime, 0),   text = "5/20",  size = size.small)
plotshape(os_recover, title = "OS",    style = shape.triangleup, location = location.belowbar, color = color.new(color.aqua, 0),   text = "OS",    size = size.small)
