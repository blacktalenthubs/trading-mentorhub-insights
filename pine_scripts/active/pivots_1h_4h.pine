// @version=5
//
// 4h support / resistance — VISUAL ONLY.
//
// Plots the most recent and prior 4h swing highs (resistance) and 4h
// swing lows (support) as horizontal forward-filled lines. No alerts
// fire from this indicator — the daily PDH/PDL events in
// `levels-day-vwap` already cover the actionable layer; this is pure
// HTF structure for chart context.
//
// Replaces the earlier `pivots-1h-4h` aligned-pivot detection. Reasons
// for the redesign:
//
//   • The aligned-pivot signal class was sparse (a few fires per week)
//     and shared the same trade structure as the existing daily PDH/PDL
//     alerts — no incremental signal worth the alert taxonomy.
//   • Persistent line.new() rendering produced visual clutter as new
//     pivots formed at near-identical prices.
//   • The simpler "4h swing structure visible at all times" pattern
//     gives the trader the right context without the noise.
//
// Indicator name retained as `pivots-1h-4h` for backwards-compat with
// any TV alerts you'd wired up under the old taxonomy (those alerts
// now fire nothing — Pine code has no `alert()` calls). Re-paste this
// source into TradingView to swap behavior.
//
indicator("pivots-4h", overlay = true)

// ── Inputs ──────────────────────────────────────────────────────────
show_resistance = input.bool(true, "Show 4h resistance lines")
show_support    = input.bool(true, "Show 4h support lines")
show_prior      = input.bool(true, "Show the prior level (faint) alongside current",
                              tooltip = "Off = only current level shown. On = current bold + prior faint")
piv_left        = input.int(3, "4h pivot — left bars",  minval = 2, maxval = 10,
                             tooltip = "Bars to the LEFT a swing needs for the pivot to qualify")
piv_right       = input.int(3, "4h pivot — right bars", minval = 2, maxval = 10,
                             tooltip = "Bars to the RIGHT a swing needs to be confirmed (= confirmation latency)")

// ── 4h pivot detection via request.security ─────────────────────────
// `ta.pivothigh/low` returns the pivot price `right` bars AFTER the
// swing has formed (i.e. confirmed). `lookahead_off` ensures we never
// peek into future bars — values lag by `piv_right` 4h bars (= 12 hours
// at default 3-right).
[ph_4h_raw, pl_4h_raw] = request.security(syminfo.tickerid, "240", [ta.pivothigh(high, piv_left, piv_right), ta.pivotlow(low, piv_left, piv_right)], lookahead = barmerge.lookahead_off)

// ── Forward-fill: track current + prior pivot of each kind ──────────
var float r_now  = na  // most recent confirmed 4h resistance
var float r_prev = na  // the one before that
var float s_now  = na  // most recent confirmed 4h support
var float s_prev = na

if not na(ph_4h_raw)
    r_prev := r_now
    r_now  := ph_4h_raw
if not na(pl_4h_raw)
    s_prev := s_now
    s_now  := pl_4h_raw

// ── Plots ───────────────────────────────────────────────────────────
// Current levels are bold; prior levels are faint (alpha 60). linebr
// style breaks the line cleanly at session/data gaps.
plot(show_resistance ? r_now : na,                  title = "4h R (current)", color = color.new(color.red,     0),  style = plot.style_linebr, linewidth = 2)
plot(show_resistance and show_prior ? r_prev : na,  title = "4h R (prior)",   color = color.new(color.red,    60),  style = plot.style_linebr, linewidth = 1)
plot(show_support    ? s_now : na,                  title = "4h S (current)", color = color.new(color.green,   0),  style = plot.style_linebr, linewidth = 2)
plot(show_support    and show_prior ? s_prev : na,  title = "4h S (prior)",   color = color.new(color.green,  60),  style = plot.style_linebr, linewidth = 1)
