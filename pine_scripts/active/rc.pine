// @version=5
//
// Reclaim (RC) — ONE pine, three timeframes: 4h · Weekly · Monthly.
//
// Every RC signal is the SAME idea — price UNDERCUTS a prior-period level then
// RECLAIMS it (the level held) — fired INTRADAY on the 5m bar that crosses back,
// exactly like PDH/PDL. Load + alert on a 5m chart, bind ONE "Any alert() call".
//
//   LEVEL  = the prior COMPLETED period's high/low (request.security(TF,high[1]/
//            low[1], lookahead_ON) — LOCKED: identical on every chart TF, no repaint).
//   UNDERCUT = the period must have traded BELOW the level first (a real retest).
//   TRIGGER  = the 5m close crossing back above the level. Once per period.
//
//   ▲ RC   = reclaim of the prior-period LOW  (undercut & reclaim = reversal) → BUY
//   ▲ RC-H = reclaim of the prior-period HIGH (broken high held = continuation) → BUY
//
// Cadence: 4h ≈ the day-trade engine (fires often). Weekly/Monthly are rare by
// nature (one period is long) — they surface the big swing/position reclaims.
//
// Routing: emits the EXACT catalog rule per signal so it routes with NO backend
// remap — 4h: "rc_4h_long"/"rc_4h_hrec" (long-only now); Weekly: "weekly_rc";
// Monthly: "monthly_rc". (The bare "rc_4h" rule is RETIRED — emitting it drops as
// unknown_type, which lost 15 of 16 morning RC fires on 2026-06-22.) interval
// tags the period ("240"/"W"/"M").
//
indicator("Reclaim (RC) · 4h/Wk/Mo", "RC", overlay = true, max_labels_count = 300, max_lines_count = 100, max_boxes_count = 60)

// ── Enables (per TF, per signal) ──────────────────────────────────────────
g4 = "4h RC — day-trade engine"
en4_long  = input.bool(true, "4h · RC long — reclaim prior 4h LOW (BUY)", group = g4)
// 4h · RC-H (4h HIGH reclaim) REMOVED 2026-07-12 — the 4h high chases resistance; keep only the 4h LOW.
// RC QUALITY FILTERS (2026-06-23, chart-derived). A 4h RC-H is a continuation only
// IN AN UPTREND — otherwise it's buying into overhead resistance (SPY-on-down-days
// trap). A 4h RC low is a spring only at SUPPORT — otherwise a naked lower-low knife.
// Regime = the DAILY trend (handles consolidations: a bull flag is still Stage-2,
// where local "higher highs" fails). Both gates toggleable.
gF = "RC quality filters (4h)"
gate_low  = input.bool(false, "RC-low: require daily uptrend OR support confluence (off = every reclaim fires, the reclaim-low stop is the judge)", group = gF)
ema_len   = input.int (20,    "Daily EMA length (trend reference)", minval = 5, group = gF)
slope_lb  = input.int (3,     "Daily EMA rising lookback (days)", minval = 1, group = gF)
conf_tol  = input.float(0.5,  "RC-low support tolerance % (to PDL/PWL/PML/10w/30w)", minval = 0.0, step = 0.1, group = gF)
gDay = "Daily RC — day-trade/swing (= PDH/PDL reclaim)"
enD_long  = input.bool(true, "Daily · RC — reclaim prior-DAY LOW / PDL (BUY)", group = gDay)
enD_hrec  = input.bool(true, "Daily · RC-H — reclaim prior-DAY HIGH / PDH (BUY)", group = gDay)
// ── PDH/PDL break + gap-and-go + index shorts (moved from levels_day 2026-07-12, simplified:
//    core level + volume + rc.pine's uptrend; dropped the VWAP/CVD/8-EMA confluence). ──
gPB = "PDH break · gap-and-go · index shorts (from levels_day)"
en_pdh_break  = input.bool(true, "PDH break — closed above the prior-day HIGH on volume + uptrend (BUY)", group = gPB)
en_gap_up     = input.bool(true, "Gap-and-go — opened above PDH and ran on volume (BUY)", group = gPB)
en_shorts     = input.bool(true, "Index SHORTS — PDL break-down + PDH rejection (SHORT, allowlist only)", group = gPB)
short_syms_pb = input.string("SPY,QQQ,IWM,BTCUSD,BTCUSDT,BTCUSDC", "  Shorts: allowed tickers (raw TV, comma-sep)", group = gPB)
vol_len_pb    = input.int(20, "  Volume-average length", minval = 5, group = gPB)
vol_break_min = input.float(2.0, "  PDH-break min volume ratio", minval = 1.0, step = 0.1, group = gPB)
vol_gap_min   = input.float(1.5, "  Gap-and-go min volume ratio", minval = 1.0, step = 0.1, group = gPB)
vol_short_min = input.float(1.5, "  Short min volume ratio", minval = 1.0, step = 0.1, group = gPB)
gW = "Weekly levels — WLV (wick-below-and-reclaim only)"
enWLV      = input.bool(true,  "WLV · weekly-level RECLAIM — opened above a level, wick below & reclaim (BUY)", group = gW)
wlvWk      = input.int(2,      "  WLV weeks to scan", minval = 1, maxval = 4, group = gW)
lvlHLonly  = input.bool(true,  "  Reclaim on HIGH & LOW only — skip the open/close body levels (WLV + MLV)", group = gW)
enWLVbelow = input.bool(false, "  └ ALSO fire reclaim-from-BELOW (opened UNDER & broke up through — NOT a wick-reclaim · default OFF)", group = gW)
wlvMinPen  = input.float(0.15, "  WLV min wick penetration below the level (%)", minval = 0.0, step = 0.05, group = gW) / 100.0
gM = "Monthly levels — MLV (wick-below-and-reclaim only)"
enMLV      = input.bool(true,  "MLV · monthly-level RECLAIM — opened above a level, wick below & reclaim (BUY)", group = gM)
mlvMon     = input.int(2,      "  MLV months to scan (H/L/O/C each)", minval = 1, maxval = 6, group = gM)
enMLVbelow = input.bool(false, "  └ ALSO fire reclaim-from-BELOW (opened UNDER & broke up through — NOT a wick-reclaim · default OFF)", group = gM)
mlvMinPen  = input.float(0.15, "  MLV min wick penetration below the level (%)", minval = 0.0, step = 0.05, group = gM) / 100.0
// Reclaim long (#65, merged from index_reclaim_long.pine 2026-06-25). Morning reclaim
// of the ORH/PDH with the option-strike payload. Windows are MINUTE-based so it behaves
// the same on any chart TF (defaults built for 5m: 15-min OR, 90-min reclaim window).
gRL = "Reclaim long — ORH/PDH morning reclaim (#65)"
en_reclaim = input.bool(true,  "Fire ORH/PDH reclaim-long (BUY, w/ ~ATM strike)", group = gRL)
en_orl     = input.bool(true,  "Fire ORL held + reclaim — the magnet bounce (BUY, w/ ~ATM call)", group = gRL)
en_orh_rej = input.bool(true,  "Fire ORH rejection — failed poke above the OR high (SHORT, w/ ~ATM put)", group = gRL)
rl_orMin   = input.int(15,    "Opening-range minutes (ORH/ORL)", minval = 5, group = gRL)
rl_dipPct  = input.float(0.18, "Shakeout dip below the level (%)", step = 0.01, group = gRL) / 100.0
rl_recMin  = input.int(90,    "Reclaim within N minutes of the dip", minval = 15, group = gRL)
rl_mornMin = input.int(120,   "Only fire in the first N minutes", minval = 30, group = gRL)
rl_minHead = input.float(1.0, "Min room to next resistance (R)", step = 0.5, group = gRL)
rl_useVwap = input.bool(true,  "Require close above VWAP", group = gRL)
rl_showOR  = input.bool(true,  "Draw the ORB 15m opening-range box (per session)", group = gRL)
gD = "Display — prior levels (merged from 'Prior Levels Flat')"
show_lvl  = input.bool(true, "Draw prior-level S/R lines", group = gD)
show_pdh  = input.bool(true, "  PDH / PDL — daily (solid)", group = gD)
show_pw   = input.bool(true, "  PWH / PWL — weekly (dashed)", group = gD)
show_pm   = input.bool(true, "  PMH / PML — monthly (dotted)", group = gD)
show_cml  = input.bool(true, "  CML — current-month low", group = gD)
lvl_bars  = input.int(60, "Line length (bars back)", minval = 10, maxval = 500, group = gD)
col_sup   = input.color(#26A69A, "Support color (price ABOVE the level)", group = gD)
col_res   = input.color(#EF5350, "Resistance color (price BELOW the level)", group = gD)
col_cml   = input.color(#FFA726, "CML color", group = gD)
gT = "RC chart tags"
show_tags = input.bool(true,  "Show RC tags (markers) on chart", group = gT)
tags_text = input.bool(false, "  Label tags with TF text (4hl/4hh/dl…) — off = tiniest, shape-only", group = gT)
gWk = "Weekly MA levels (visual — merged from 'Weekly Levels')"
show_10w  = input.bool(true, "Flat 10w MA line", group = gWk)
show_30w  = input.bool(true, "Flat 30w MA line", group = gWk)
show_marc = input.bool(true, "10w / 30w reclaim·hold signs", group = gWk)
en_w10    = input.bool(false, "ALERT: 10w MA reclaim·hold (weekly support, BUY)", group = gWk)
en_w30    = input.bool(false, "ALERT: 30w MA reclaim·hold (long-term entry, BUY)", group = gWk)
show_wrc  = input.bool(true, "Weekly RC sign (prior-week-low reclaim)", group = gWk)
wk_recent = input.int(8, "10w↑/30w↑ signs: recent WEEKS only (0 = all — they drift as the MA moves)", minval = 0, group = gWk)

// ── Per-TF levels. The LEVEL (prior completed high/low) MUST be LOCKED — identical
// on every chart TF. The non-repainting pattern for that is high[1]/low[1] WITH
// lookahead_on: [1] = the prior CLOSED period (no future leak), lookahead_on makes
// every lower-TF bar read the SAME confirmed value. (Using lookahead_off here was
// the bug: [1]+off double-lags on lower TFs — the monthly level showed May on the
// 1M chart but April on the 4h chart.)
[h4p, l4p] = request.security(syminfo.tickerid, "240", [high[1], low[1]], lookahead = barmerge.lookahead_on)
[hDp, lDp] = request.security(syminfo.tickerid, "D",   [high[1], low[1]], lookahead = barmerge.lookahead_on)
dOpen = request.security(syminfo.tickerid, "D", open, lookahead = barmerge.lookahead_off)  // today's open — the directional support gate, SHARED by daily RC + MLV + WLV
[hWp, lWp] = request.security(syminfo.tickerid, "W",   [high[1], low[1]], lookahead = barmerge.lookahead_on)
[hMp, lMp] = request.security(syminfo.tickerid, "M",   [high[1], low[1]], lookahead = barmerge.lookahead_on)
// Developing-period low (undercut check + stop) = the CURRENT period's running low,
// lookahead_off so it never leaks the future. (No [1] — we want this period, not last.)
l4d = request.security(syminfo.tickerid, "240", low, lookahead = barmerge.lookahead_off)
lDd = request.security(syminfo.tickerid, "D",   low, lookahead = barmerge.lookahead_off)
lWd = request.security(syminfo.tickerid, "W",   low, lookahead = barmerge.lookahead_off)
lMd = request.security(syminfo.tickerid, "M",   low, lookahead = barmerge.lookahead_off)
// CML (current-month low) for the visual — regular-session ticker + lookahead_on so
// the developing month's low reads identically on every chart TF (no EH leak).
cml = request.security(ticker.new(syminfo.prefix, syminfo.ticker, session.regular), "M", low, lookahead = barmerge.lookahead_on)
// Weekly 10w/30w MA + signs (visual, merged from "Weekly Levels") — all computed
// on the WEEKLY in one tuple w/ lookahead_on, so the signs sit in the SAME place on
// any chart TF. reclaim·hold = close above the MA after tagging it; wRC = undercut &
// reclaim of the prior-week low closing strong (up or top-half of the bar).
// held = the weekly low tagged the MA from ABOVE (within 0.5%) and never broke below,
// closing above it. reclaim = the weekly low went BELOW the MA and closed back above
// (undercut & reclaimed). Mutually exclusive by where the weekly low sits.
f_wk() =>
    _m10  = ta.sma(close, 10)
    _m30  = ta.sma(close, 30)
    _h10  = (close > _m10) and (low <= _m10 * 1.005) and (low >= _m10)
    _r10  = (close > _m10) and (low < _m10)
    _h30  = (close > _m30) and (low <= _m30 * 1.005) and (low >= _m30)
    _r30  = (close > _m30) and (low < _m30)
    _wrc  = (low < low[1]) and (close > low[1]) and ((close > open) or (close - low >= (high - low) * 0.5))
    [_m10, _m30, _h10, _r10, _h30, _r30, _wrc]
[w10, w30, h10, r10, h30, r30, wrc] = request.security(syminfo.tickerid, "W", f_wk(), lookahead = barmerge.lookahead_on)
// Daily trend reference for the RC quality gates — price above a RISING daily EMA =
// uptrend (Stage-2). Computed in the daily context so "rising" is day-over-day; this
// stays bullish through a consolidation/bull-flag (where local 4h higher-highs fails).
f_dtrend(int len, int lb) =>
    _e = ta.ema(close, len)
    [_e, _e > _e[lb]]
[d_ema, d_rising] = request.security(syminfo.tickerid, "D", f_dtrend(ema_len, slope_lb), lookahead = barmerge.lookahead_off)
uptrend = (not na(d_ema)) and (close > d_ema) and d_rising
near_lvl(float a, float b) => not na(a) and not na(b) and b != 0 and (math.abs(a - b) / b * 100.0 <= conf_tol)

// ═══════════════════════════════════════════════════════════════════════════
// MA BOUNCE (ported from ma_ema_daily, 2026-06-23) — buy a HELD test of a daily MA.
// Chart-derived spec (SPY/QQQ/NVDA/META/QCOM/UCTT):
//   ROLE     — an MA is SUPPORT only when price is ABOVE it (position-relative). We
//              never long an MA price is below (that's resistance).
//   TRIGGER  — price was above the MA, dipped to it (the bar's low tags it), and
//              CLOSED back above on a green bar = the support held.
//   STOP     — a close below the MA (support lost). Tight on fast MAs, wide on slow.
//   REGIME   — 8/21/50 fire ONLY in an uptrend (EMA 50>100>200 stacked). The deep
//              100/200 fire ALWAYS (institutions defend them even in a falling name).
//   COOLDOWN — re-arm only after price moves clearly ABOVE the MA again, so a "walk"
//              along the MA fires ONCE per touch, not every bar.
gMA = "MA bounce (daily MA, ported)"
en_ma     = input.bool(true,  "Fire MA-bounce longs (held test of a daily MA)", group = gMA)
ma_regime = input.bool(true,  "8/21/50 require uptrend (50>100>200); 100/200 always", group = gMA)
ma_tol    = input.float(0.25, "Touch tolerance % (low within this of the MA)", minval = 0.0, step = 0.05, group = gMA)
ma_rearm  = input.float(1.0,  "Re-arm % (price must move this far above the MA to reset)", minval = 0.1, step = 0.1, group = gMA)
ema8d   = request.security(syminfo.tickerid, "D", ta.ema(close, 8)[1],   lookahead = barmerge.lookahead_on)
ema21d  = request.security(syminfo.tickerid, "D", ta.ema(close, 21)[1],  lookahead = barmerge.lookahead_on)
ema50d  = request.security(syminfo.tickerid, "D", ta.ema(close, 50)[1],  lookahead = barmerge.lookahead_on)
ema100d = request.security(syminfo.tickerid, "D", ta.ema(close, 100)[1], lookahead = barmerge.lookahead_on)
ema200d = request.security(syminfo.tickerid, "D", ta.ema(close, 200)[1], lookahead = barmerge.lookahead_on)
ema_stacked = (not na(ema50d)) and (not na(ema100d)) and (not na(ema200d)) and (ema50d > ema100d) and (ema100d > ema200d)
ma_uptrend  = (not ma_regime) or ema_stacked
ma_bounce(float ma, bool eligible) =>
    var bool armed = false
    var bool fired = false
    if (not na(ma)) and (close > ma * (1.0 + ma_rearm / 100.0))
        armed := true
        fired := false
    touch = (not na(ma)) and (low <= ma * (1.0 + ma_tol / 100.0)) and (close > ma) and (close > open)
    fire = eligible and armed and touch and not fired
    if fire
        fired := true
    fire
mb_e8   = ma_bounce(ema8d,   en_ma and ma_uptrend)
mb_e21  = ma_bounce(ema21d,  en_ma and ma_uptrend)
mb_e50  = ma_bounce(ema50d,  en_ma and ma_uptrend)
mb_e100 = ma_bounce(ema100d, en_ma)
mb_e200 = ma_bounce(ema200d, en_ma)

// ═══════════════════════════════════════════════════════════════════════════
// MoBO — monthly BOX breakout + monthly RC-H (ported from monthly_breakout.pine, the
// validated visual). The LEVEL is the locked MONTHLY value computed from CLOSED months
// (lookahead_off → no repaint of the developing month); the TRIGGER is the live chart
// price CROSSING it — NOT a monthly close (by a monthly close price has run far past the
// level). Long-term/position entries → default OFF, gate-exempt (wired in the backend).
//   BOX  — a flat multi-month Darvas ceiling. Retires on a close ABOVE (cleared) or BELOW
//          the base low (failed base) so it never arms on a stale/failed level.
//   RC-H — a prior MONTHLY swing high that HELD as resistance >= minBelow months (the
//          high-side complement to monthly RC). Catches stair-step leaders the box can't.
gMoBO = "MoBO — monthly box + RC-H breakout (position, default OFF)"
en_mobo      = input.bool(false, "ALERT: monthly BOX breakout (locked flat-base ceiling, BUY)", group = gMoBO)
en_mobo_rch  = input.bool(false, "ALERT: monthly RC-H breakout (prior-high held resistance, BUY)", group = gMoBO)
mobo_N       = input.int(4,    "  Box lookback (months the ceiling caps price)", minval = 2, maxval = 12, group = gMoBO)
mobo_minFlat = input.int(3,    "  Box ceiling FLAT >= months", minval = 1, maxval = 8, group = gMoBO)
mobo_minBox  = input.float(3.0,  "  Box MIN depth %", minval = 0.0, group = gMoBO) / 100.0
mobo_maxBox  = input.float(60.0, "  Box MAX depth %", minval = 10.0, group = gMoBO) / 100.0
mobo_stage2  = input.bool(true,  "  Box requires Stage-2 (above the 10-month EMA)", group = gMoBO)
mobo_Nh      = input.int(8,    "  RC-H lookback (months for the prior high)", minval = 3, maxval = 18, group = gMoBO)
mobo_minBel  = input.int(2,    "  RC-H prior high CAPPED price >= months", minval = 1, maxval = 8, group = gMoBO)

f_mobo_box() =>
    lid = ta.highest(high, mobo_N)[1]
    boxLow = ta.lowest(low, mobo_N)[1]
    stg2 = close > ta.ema(close, 10)
    ceilingAge = ta.barssince(lid != lid[1])
    established = ceilingAge >= mobo_minFlat
    var float ceil = na
    var float bLow = na
    var bool  armed = false
    if established and close < lid
        if not armed
            bLow := boxLow
            armed := true
        ceil := na(ceil) ? lid : math.max(ceil, lid)
        bLow := math.min(bLow, low)
    if armed and not na(bLow) and close < bLow
        armed := false
        ceil  := na
        bLow  := na
    if armed and not na(ceil) and close > ceil
        armed := false
        ceil  := na
        bLow  := na
    depth = not na(ceil) and ceil > 0 ? (ceil - bLow) / ceil : na
    boxOK = not na(depth) and depth >= mobo_minBox and depth <= mobo_maxBox
    ready = armed and boxOK and (not mobo_stage2 or stg2)
    [ready ? ceil : na, bLow]

f_mobo_rch() =>
    lid = ta.highest(high, mobo_Nh)[1]
    belowAge = ta.barssince(high >= lid)
    held = belowAge >= mobo_minBel
    var float rl = na
    var float rlLow = na
    var bool  armedH = false
    if held and close < lid
        if not armedH
            rlLow := low
            armedH := true
        rl := na(rl) ? lid : math.max(rl, lid)
        rlLow := math.min(rlLow, low)
    if armedH and not na(rl) and close > rl
        armedH := false
        rl    := na
    [armedH ? rl : na, rlLow]

[mobo_ceil, mobo_low]  = request.security(syminfo.tickerid, "M", f_mobo_box(), lookahead = barmerge.lookahead_off)
[mobo_rl, mobo_rl_low] = request.security(syminfo.tickerid, "M", f_mobo_rch(), lookahead = barmerge.lookahead_off)

// Fire ONCE when live price crosses up through the locked level; re-arm only after price
// drops back below it (so a wiggle around the level doesn't re-fire every bar).
cross_up_once(float level, bool en) =>
    var bool armed = false
    var bool fired = false
    if not na(level) and close < level
        armed := true
        fired := false
    fire = en and armed and not fired and not na(level) and close >= level
    if fire
        fired := true
        armed := false
    fire
mobo_box_fire = cross_up_once(mobo_ceil, en_mobo)
mobo_rch_fire = cross_up_once(mobo_rl, en_mobo_rch)

// ── New-period flags (reset the sweep state at each period boundary) ───────
n4 = ta.change(time("240")) != 0
nD = ta.change(time("D"))   != 0
// ── PDH/PDL break + gap-and-go + index-short state (from levels_day, simplified) ──
vol_avg_pb   = ta.sma(volume, vol_len_pb)
vol_ratio_pb = vol_avg_pb > 0 ? volume / vol_avg_pb : na
_short_pb    = "," + str.replace_all(str.upper(short_syms_pb), " ", "") + ","
short_ok_pb  = str.contains(_short_pb, "," + str.upper(syminfo.ticker) + ",")
var float gap_low_pb   = na
var bool  gap_armed_pb = false
var bool  gap_fired_pb = false
var bool  pdhb_fired   = false
var bool  pdlbrk_fired = false
var bool  pdhrej_fired = false
if nD
    gap_low_pb   := low
    gap_armed_pb := (not na(hDp)) and (dOpen > hDp)
    gap_fired_pb := false
    pdhb_fired   := false
    pdlbrk_fired := false
    pdhrej_fired := false
if gap_armed_pb and ((not na(gap_low_pb) and low < gap_low_pb) or (not na(hDp) and close < hDp))
    gap_armed_pb := false
nW = ta.change(time("W"))   != 0
nM = ta.change(time("M"))   != 0

ok4 = not na(h4p) and not na(l4p) and not na(l4d)
okD = not na(hDp) and not na(lDp) and not na(lDd)
okW = not na(hWp) and not na(lWp) and not na(lWd)
okM = not na(hMp) and not na(lMp) and not na(lMd)

// ── The REAL reclaim = a SWEEP, enforced as a sequence (not a level-cross):
//   1) ARMED  — price was on the right side of the level FIRST (close > level)
//   2) SWEPT  — then it UNDERCUT the level (a bar's low dipped below it)
//   3) FIRE   — then it CLOSED BACK above the level
// This rejects plain breakouts / gap-recoveries that never swept (those are just
// crosses, not reclaims) and the trivially-true RC-H undercut. Per-call-site var
// state, reset each period, fires once. A single wick bar (low<level, close>level
// after being armed) still fires — that IS the sweep-and-reclaim.
sweep_reclaim(float level, bool en, bool ok, bool newper, bool arm_break = false) =>
    var bool armed = false
    var bool swept = false
    var bool fired = false
    if newper
        armed := false
        swept := false
        fired := false
    // ARM = price has accepted above the level. Normally a CLOSE above. For RC-H
    // (arm_break) a gap/break ABOVE (high>level) ALSO arms — so a gap-up that opens
    // OVER the prior high, pulls back THROUGH it, then reclaims still fires. Without
    // this, ACMR 6/29 missed: gapped over PWH 111.41, dipped to 110.10 (undercut),
    // ran to close 117.99 — but it undercut BEFORE any 5m bar closed above to arm.
    // (RC-low keeps close>level: high>prior-LOW is ~always true, would arm forever.)
    if ok and ((close > level) or (arm_break and high > level))
        armed := true
    if armed and ok and (low < level)
        swept := true
    bool fire = en and ok and swept and (close > level) and not fired
    if fire
        fired := true
    fire

// long = sweep & reclaim of the prior LOW · hrec = sweep & reclaim of the prior HIGH
// 4h quality gates (passed INTO sweep_reclaim via the en arg so the once/period latch
// only consumes on an actual fire). RC-H = uptrend only. RC-low = uptrend OR the swept
// prior-4h low sits AT a real support (PDL/PWL/PML/10w/30w) — else a naked knife.
l4_at_support = near_lvl(l4p, lDp) or near_lvl(l4p, lWp) or near_lvl(l4p, lMp) or near_lvl(l4p, w10) or near_lvl(l4p, w30)
gate4_long = (not gate_low)  or uptrend or l4_at_support
rc4_long = sweep_reclaim(l4p, en4_long and gate4_long, ok4, n4)
// rc_4h_hrec REMOVED 2026-07-12 (the 4h HIGH chases resistance; only the 4h LOW is kept).
// Daily RC is now DIRECTIONAL like MLV/WLV: fire only when the day OPENED ABOVE the level
// (dOpen > level = support), so the PDH reclaim is a defend-the-gap, not a chase.
rcD_long = sweep_reclaim(lDp, enD_long and dOpen > lDp, okD, nD)
rcD_hrec = sweep_reclaim(hDp, enD_hrec and dOpen > hDp, okD, nD, true)
// weekly_rc (rcW_long/rcW_hrec) REMOVED 2026-07-12 — folded into WLV (weekly_lvl_reclaim).
// Monthly RC / CML / PML alerts REMOVED 2026-07-11 — folded into MLV (monthly_lvl_reclaim).
// The value computations (hMp/lMp/lMd/cml) stay above — the visual PMH/PML/CML lines use them.

// ── RECLAIM LONG (#65, merged from index_reclaim_long.pine) ─────────────────
// Opening range (first rl_orMin of the session), the reclaim state machine, and the
// next-resistance headroom gate. Windows in MINUTES → TF-agnostic. Reuses rc.pine's
// PDH/PDL (hDp/lDp). ORL is computed for the visual; only the ORH/PDH reclaim fires.
rl_orBars  = math.max(1, math.round(rl_orMin  / math.max(1.0, timeframe.in_seconds() / 60.0)))
rl_recBars = math.max(1, math.round(rl_recMin / math.max(1.0, timeframe.in_seconds() / 60.0)))
rl_mornBar = math.round(rl_mornMin / math.max(1.0, timeframe.in_seconds() / 60.0))
var int rl_sbar = 0
rl_sbar := nD ? 0 : rl_sbar + 1
// LOCKED to the 15m timeframe (2026-07-07) — ORH/ORL are computed on 15m bars via request.security
// so they're IDENTICAL on ANY chart TF. Before, they were built from CHART bars, so a "15-min OR"
// silently became a 30-min OR on a 30m chart and shifted every time you changed timeframe. The OR is
// the first ceil(rl_orMin/15) 15m bars of the RTH session (rl_orMin=15 ⇒ one 15m bar, 9:30–9:45).
f_or15() =>
    var float _h = na
    var float _l = na
    var int _sb = 0
    _new = ta.change(time("D")) != 0
    _sb := _new ? 0 : _sb + 1
    _bars = math.max(1, math.round(rl_orMin / 15.0))
    if _new
        _h := high
        _l := low
    else if _sb < _bars
        _h := math.max(_h, high)
        _l := math.min(_l, low)
    [_h, _l]
[rl_orh, rl_orl] = request.security(syminfo.tickerid, "15", f_or15(), lookahead = barmerge.lookahead_on)
rl_vwap = ta.vwap(hlc3)
rl_orReady = not na(rl_orh) and (rl_sbar * math.max(1.0, timeframe.in_seconds() / 60.0)) >= rl_orMin
rl_inMorn  = rl_sbar <= rl_mornBar
// nearest of ORH/PDH/ORL/PDL strictly above a price (next resistance), or na.
rl_next_above(float p) =>
    float best = na
    if not na(rl_orh) and rl_orh > p
        best := na(best) ? rl_orh : math.min(best, rl_orh)
    if not na(hDp) and hDp > p
        best := na(best) ? hDp : math.min(best, hDp)
    if not na(rl_orl) and rl_orl > p
        best := na(best) ? rl_orl : math.min(best, rl_orl)
    if not na(lDp) and lDp > p
        best := na(best) ? lDp : math.min(best, lDp)
    best
// above the level → dip rl_dipPct under (shakeout) → reclaim within rl_recBars, in the
// morning, above VWAP, with ≥ rl_minHead R of room → fire. [sig, dipLow, target].
rl_reclaim(float L) =>
    var bool above  = false
    var bool dipped = false
    var bool fired  = false
    var int  dipbar = 0
    var float dlow  = na
    if nD
        above := false
        dipped := false
        fired := false
        dlow := na
    bool sig = false
    float tgt = na
    if (not na(L)) and rl_orReady and rl_inMorn
        if close > L
            above := true
        if above and not dipped and low <= L * (1 - rl_dipPct)
            dipped := true
            dipbar := rl_sbar
            dlow := low
        if dipped and not fired
            dlow := math.min(dlow, low)
        bool reclaimed = dipped and not fired and close > L and (rl_sbar - dipbar <= rl_recBars)
        bool vwapok = (not rl_useVwap) or (close > rl_vwap)
        if reclaimed and vwapok
            float t = rl_next_above(close)
            float risk = math.max(close - dlow, syminfo.mintick)
            float headroom = na(t) ? 99.0 : (t - close) / risk
            if headroom >= rl_minHead
                fired := true
                sig := true
                tgt := t
    [sig, dlow, tgt]
[rl_orhSig, rl_orhStop, rl_orhTgt] = rl_reclaim(rl_orh)
[rl_pdhSig, rl_pdhStop, rl_pdhTgt] = rl_reclaim(hDp)

// ── OR CHANNEL play — the OR edges are MAGNETS: capitalize on them EARLY (don't wait
// for the late ORH break). LONG the ORL bounce (calls) → target ORH · SHORT the ORH
// rejection (puts) → target ORL. Each fires once/day. Gated like normal day-trade
// entries (focus-list only in a weak tape via the gate + short allowlist).
orl_ok = rl_orReady and not na(rl_orl)
orh_ok = rl_orReady and not na(rl_orh)
// ORL reclaim = undercut the OR low (sweep) then close back above. stop = the day low.
rcORLrec = sweep_reclaim(rl_orl, en_orl, orl_ok, nD)
// ORL held = tag the OR low from above (within dip tol, never broke) + green close.
var bool orlh_fired = false
if nD
    orlh_fired := false
orlHeld = en_orl and orl_ok and (low >= rl_orl) and (low <= rl_orl * (1.0 + rl_dipPct)) and (close > rl_orl) and (close > open) and not orlh_fired
if orlHeld
    orlh_fired := true
// ORH rejection = poke above the OR high and close back below (failed break) → SHORT.
var bool orhr_fired = false
if nD
    orhr_fired := false
orhRej = en_orh_rej and orh_ok and (high > rl_orh) and (close < rl_orh) and (close < open) and not orhr_fired
if orhRej
    orhr_fired := true

// rc_4h_short (4h rejection short) RETIRED 2026-06-29 — the only shorts we want are the
// structural PDL break + PDH rejection (levels_day_vwap). No 4h/EMA rejection shorts.

// ── Markers — 4h ONLY (the day-trade engine). Tiny triangles; color = side
// (lime = low reclaim, teal = high reclaim, red = short); text = 4h + side
// (L = reclaim LOW, H = reclaim HIGH, ↓ = rejection short). Weekly & monthly draw
// NO marker on purpose — the horizontal level lines (+ W/M HI·LO labels) below mark
// the level, and the alert fires regardless, so a chart tag would just be clutter.
// Three states via show_tags + tags_text: OFF (nothing) · tiny SHAPE-ONLY (default,
// smallest footprint) · shape + TF text. Shape = TF (4h triangle · daily circle),
// color = side (lime low-reclaim · teal high-reclaim · red short). All size.tiny.
plotshape(show_tags and tags_text and rc4_long,  title = "4h RC",    style = shape.triangleup,   location = location.belowbar, color = color.new(color.lime, 0), size = size.tiny, text = "4hl")
plotshape(show_tags and tags_text and rcD_long,  title = "D RC",     style = shape.circle,       location = location.belowbar, color = color.new(color.lime, 0), size = size.tiny, text = "dl")
plotshape(show_tags and tags_text and rcD_hrec,  title = "D RC-H",   style = shape.circle,       location = location.belowbar, color = color.new(color.teal, 0), size = size.tiny, text = "dh")
plotshape(show_tags and not tags_text and rc4_long,  title = "4h RC",    style = shape.triangleup,   location = location.belowbar, color = color.new(color.lime, 0), size = size.tiny)
plotshape(show_tags and not tags_text and rcD_long,  title = "D RC",     style = shape.circle,       location = location.belowbar, color = color.new(color.lime, 0), size = size.tiny)
plotshape(show_tags and not tags_text and rcD_hrec,  title = "D RC-H",   style = shape.circle,       location = location.belowbar, color = color.new(color.teal, 0), size = size.tiny)

// ── Weekly 10w/30w reclaim·hold + weekly-RC signs (visual, from "Weekly Levels").
// Fire once per weekly event (and not [1]); 10w↑/30w↑ windowed to recent weeks.
wk_in_win = wk_recent == 0 or (timenow - time) <= wk_recent * 604800000
plotshape(show_marc and wk_in_win and (h10 or r10) and not (h10[1] or r10[1]), title = "10w reclaim/hold", style = shape.triangleup, location = location.belowbar, color = color.new(color.lime, 0), size = size.tiny, text = "10w↑")
plotshape(show_marc and wk_in_win and (h30 or r30) and not (h30[1] or r30[1]), title = "30w reclaim/hold", style = shape.triangleup, location = location.belowbar, color = color.new(color.teal, 0), size = size.tiny, text = "30w↑")
plotshape(show_wrc and wrc and not wrc[1], title = "Weekly RC", style = shape.diamond, location = location.belowbar, color = color.new(#2962FF, 0), size = size.tiny, text = "wRC")

// ── Prior-level S/R lines (merged from "Prior Levels Flat") — PDH/PDL · PWH/PWL ·
// PMH/PML drawn as flat horizontals, COLORED BY ROLE (green = support, price above
// it · red = resistance, price below it). Daily solid · weekly dashed · monthly
// dotted · CML orange. Reuses the SAME levels the RC alerts fire on (hDp/lDp = PDH/
// PDL, hWp/lWp = PWH/PWL, hMp/lMp = PMH/PML) so the visual and alerts never diverge.
// Redrawn on the last bar (old lines/labels cleared first).
is_support(float lvl) => not na(lvl) and close > lvl
var line[]  pl_lines  = array.new_line(0)
var label[] pl_labels = array.new_label(0)
draw_level(float lvl, string nm, int sty, int loff, color col_ovr) =>
    if not na(lvl)
        col = not na(col_ovr) ? col_ovr : (is_support(lvl) ? col_sup : col_res)
        lstyle = sty == 2 ? line.style_dotted : sty == 1 ? line.style_dashed : line.style_solid
        ln = line.new(bar_index - lvl_bars, lvl, bar_index + loff, lvl, color = col, width = 2, style = lstyle)
        lb = label.new(bar_index + loff, lvl, nm + "  " + str.tostring(lvl, format.mintick), style = label.style_label_left, color = col, textcolor = color.white, size = size.small)
        array.push(pl_lines, ln)
        array.push(pl_labels, lb)
if show_lvl and barstate.islast
    if array.size(pl_lines) > 0
        for i = 0 to array.size(pl_lines) - 1
            line.delete(array.get(pl_lines, i))
        array.clear(pl_lines)
    if array.size(pl_labels) > 0
        for i = 0 to array.size(pl_labels) - 1
            label.delete(array.get(pl_labels, i))
        array.clear(pl_labels)
    if show_pdh
        draw_level(hDp, "PDH", 0, 2, na)
        draw_level(lDp, "PDL", 0, 6, na)
    // Weekly/monthly levels (PWH/PWL · PMH/PML · CML · 10w/30w) moved to htf_levels.pine
    // (a separate overlay) so their FAR values no longer stretch rc.pine's price scale.
    // Their COMPUTATION stays above — weekly_rc / monthly_rc / CML / 10w-30w alerts still
    // use hWp/lWp/hMp/lMp/cml/w10/w30. (show_pw/show_pm/show_cml/show_10w/show_30w inputs
    // are now inert here; toggle these levels in htf_levels.pine instead.)

// (The weekly 10w/30w MA flat lines moved to htf_levels.pine — see the note above.
//  w10/w30 are still computed for the 10w/30w-held alerts; they just aren't drawn here.)

// ── (The old ORH/ORL reclaim lines were removed — the ORB opening-range BOX at the
//    end of the file replaces them. rl_orh/rl_orl are still computed above for the
//    ORH/PDH reclaim-long alert logic; they just aren't drawn as lines anymore.) ──

// ── Alerts ────────────────────────────────────────────────────────────────
// entry = the RECLAIMED LEVEL (the prior-period low for RC, high for RC-H) — NOT
// the bar's close. On a sharp V-reclaim the close can sit far above the level
// (GOOGL daily 2026-06-23: wick 340.20 → close 348, but the reclaimed PDL was
// 341.72 — entry must read 341.72, where the rc actually happened, stop 340.20).
// "price" stays the live close so the feed shows level → current.
rc_pay(string rule, string dir, string iv, float ent, float stp, string note) => '{"symbol":"' + syminfo.ticker + '","price":"' + str.tostring(close, format.mintick) + '","rule":"' + rule + '","direction":"' + dir + '","interval":"' + iv + '","entry":"' + str.tostring(ent, format.mintick) + '","stop":"' + str.tostring(stp, format.mintick) + '","note":"' + note + '","fired_at":"' + str.tostring(timenow) + '"}'

if rc4_long
    alert(rc_pay("rc_4h_long", "BUY", "240", l4p, l4d, "RC · reclaim of the prior 4h low — entry at the level " + str.tostring(l4p, format.mintick) + ", stop " + str.tostring(l4d, format.mintick)), alert.freq_once_per_bar_close)
// rc_4h_hrec fire REMOVED 2026-07-12 (4h high chases resistance).
if rcD_long
    alert(rc_pay("rc_daily_long", "BUY", "D", lDp, lDd, "Daily RC · reclaim of the prior-day LOW (PDL) — entry at the level " + str.tostring(lDp, format.mintick) + ", stop " + str.tostring(lDd, format.mintick)), alert.freq_once_per_bar_close)
if rcD_hrec
    alert(rc_pay("rc_daily_hrec", "BUY", "D", hDp, lDd, "Daily RC-H · breakout-retest of the prior-day HIGH (PDH) — entry " + str.tostring(hDp, format.mintick) + ", stop " + str.tostring(lDd, format.mintick)), alert.freq_once_per_bar_close)
// ── PDH/PDL break + gap-and-go + index shorts (moved from levels_day 2026-07-12, simplified) ──
if en_pdh_break and not na(hDp) and not na(close[1]) and close > hDp and close[1] <= hDp and not na(vol_ratio_pb) and vol_ratio_pb >= vol_break_min and uptrend and not pdhb_fired
    pdhb_fired := true
    alert(rc_pay("staged_pdh_break", "BUY", "D", close, low, "PDH break — closed above the prior-day HIGH on " + str.tostring(vol_ratio_pb, "#.#") + "x volume, uptrend — stop the break-bar low"), alert.freq_once_per_bar_close)
if en_gap_up and gap_armed_pb and not gap_fired_pb and not na(hDp) and close > hDp and close > open and not na(vol_ratio_pb) and vol_ratio_pb >= vol_gap_min
    gap_fired_pb := true
    alert(rc_pay("gap_up_continuation_long", "BUY", "D", close, gap_low_pb, "Gap-and-go — opened above PDH and ran on " + str.tostring(vol_ratio_pb, "#.#") + "x volume — stop the open low"), alert.freq_once_per_bar_close)
if en_shorts and short_ok_pb and not na(lDp) and close < lDp and close < open and not na(vol_ratio_pb) and vol_ratio_pb >= vol_short_min and not pdlbrk_fired
    pdlbrk_fired := true
    alert(rc_pay("staged_pdl_break", "SHORT", "D", close, lDp, "PDL break — lost the prior-day LOW on " + str.tostring(vol_ratio_pb, "#.#") + "x volume — stop the PDL"), alert.freq_once_per_bar_close)
if en_shorts and short_ok_pb and not na(hDp) and high >= hDp and close < hDp and close < open and not na(vol_ratio_pb) and vol_ratio_pb >= vol_short_min and not pdhrej_fired
    pdhrej_fired := true
    alert(rc_pay("staged_pdh_rejection", "SHORT", "D", close, hDp, "PDH rejection — rejected at the prior-day HIGH on " + str.tostring(vol_ratio_pb, "#.#") + "x volume — stop the PDH"), alert.freq_once_per_bar_close)
// weekly_rc fires REMOVED 2026-07-12 — folded into WLV (weekly_lvl_reclaim, below).
// monthly_rc / cml_reclaim / cml_held / pml_held fires REMOVED 2026-07-11 — folded into MLV.

// ── MLV — MONTHLY LEVELS · directional reclaim (spec 68 · 2026-07-11 rebuild). ───
// ONE alert for EVERY completed monthly level: H/L/O/C of the last 6 months (24 levels).
// A level is SUPPORT only when the day OPENED ABOVE it (day_open > L); entry = the wick-
// below-and-reclaim (low ≤ L and close > L) on the 5m bar — tight, exactly like rc_daily.
// Optional (enMLVbelow): ALSO fire RECLAIM-FROM-BELOW (opened under the level, closed back
// above). entry = the level · stop = the reclaim low · once per level per day · long only.
// Covers month[1] too → monthly_rc / pml_held are retired (folded in here).
// day-open support gate uses the shared dOpen (defined near the daily levels, above).
[mvh1, mvl1, mvo1, mvc1, mvt1] = request.security(syminfo.tickerid, "M", [high[1], low[1], open[1], close[1], time[1]], lookahead = barmerge.lookahead_on)
[mvh2, mvl2, mvo2, mvc2, mvt2] = request.security(syminfo.tickerid, "M", [high[2], low[2], open[2], close[2], time[2]], lookahead = barmerge.lookahead_on)
[mvh3, mvl3, mvo3, mvc3, mvt3] = request.security(syminfo.tickerid, "M", [high[3], low[3], open[3], close[3], time[3]], lookahead = barmerge.lookahead_on)
[mvh4, mvl4, mvo4, mvc4, mvt4] = request.security(syminfo.tickerid, "M", [high[4], low[4], open[4], close[4], time[4]], lookahead = barmerge.lookahead_on)
[mvh5, mvl5, mvo5, mvc5, mvt5] = request.security(syminfo.tickerid, "M", [high[5], low[5], open[5], close[5], time[5]], lookahead = barmerge.lookahead_on)
[mvh6, mvl6, mvo6, mvc6, mvt6] = request.security(syminfo.tickerid, "M", [high[6], low[6], open[6], close[6], time[6]], lookahead = barmerge.lookahead_on)
mlvPr  = array.from(mvh1, mvl1, mvo1, mvc1, mvh2, mvl2, mvo2, mvc2, mvh3, mvl3, mvo3, mvc3, mvh4, mvl4, mvo4, mvc4, mvh5, mvl5, mvo5, mvc5, mvh6, mvl6, mvo6, mvc6)
mlvTmA = array.from(mvt1, mvt1, mvt1, mvt1, mvt2, mvt2, mvt2, mvt2, mvt3, mvt3, mvt3, mvt3, mvt4, mvt4, mvt4, mvt4, mvt5, mvt5, mvt5, mvt5, mvt6, mvt6, mvt6, mvt6)
mlvKdA = array.from("H", "L", "O", "C", "H", "L", "O", "C", "H", "L", "O", "C", "H", "L", "O", "C", "H", "L", "O", "C", "H", "L", "O", "C")
var bool[] mlv_fired = array.new_bool(24, false)
if nD
    for k = 0 to 23
        array.set(mlv_fired, k, false)
if enMLV
    for k = 0 to mlvMon * 4 - 1
        float _L = array.get(mlvPr, k)
        bool _def = not na(_L) and dOpen > _L and low <= _L and close > _L and (_L - low) / _L >= mlvMinPen
        bool _bel = enMLVbelow and not na(_L) and dOpen < _L and close > _L and close[1] <= _L
        if (_def or _bel) and (k % 4 < 2 or not lvlHLonly) and not array.get(mlv_fired, k)
            array.set(mlv_fired, k, true)
            string _mn = str.format("{0,date,MMM}", int(array.get(mlvTmA, k)))
            string _kd = array.get(mlvKdA, k)
            string _src = _def ? "held from above" : "reclaimed from below"
            alert(rc_pay("monthly_lvl_reclaim", "BUY", "M", _L, low, "MLV · " + _mn + " " + _kd + " " + str.tostring(_L, format.mintick) + " " + _src + " — entry at the level, stop the reclaim low " + str.tostring(low, format.mintick)), alert.freq_once_per_bar_close)

// ── WLV — WEEKLY LEVELS · directional reclaim (spec 69 · 2026-07-12). ────────────
// The weekly twin of MLV: every completed weekly level — H/L/O/C of the last 4 weeks
// (16 levels). BUY when the day OPENED ABOVE the level (reuses dOpen) and price wicked
// below & reclaimed it; optional enWLVbelow = reclaim-from-below. entry = the level, stop =
// the reclaim low, once per level per day, 5m like rc_daily. Retires weekly_rc (folded in).
[wvh1, wvl1, wvo1, wvc1, wvt1] = request.security(syminfo.tickerid, "W", [high[1], low[1], open[1], close[1], time[1]], lookahead = barmerge.lookahead_on)
[wvh2, wvl2, wvo2, wvc2, wvt2] = request.security(syminfo.tickerid, "W", [high[2], low[2], open[2], close[2], time[2]], lookahead = barmerge.lookahead_on)
[wvh3, wvl3, wvo3, wvc3, wvt3] = request.security(syminfo.tickerid, "W", [high[3], low[3], open[3], close[3], time[3]], lookahead = barmerge.lookahead_on)
[wvh4, wvl4, wvo4, wvc4, wvt4] = request.security(syminfo.tickerid, "W", [high[4], low[4], open[4], close[4], time[4]], lookahead = barmerge.lookahead_on)
wlvPr  = array.from(wvh1, wvl1, wvo1, wvc1, wvh2, wvl2, wvo2, wvc2, wvh3, wvl3, wvo3, wvc3, wvh4, wvl4, wvo4, wvc4)
wlvTmA = array.from(wvt1, wvt1, wvt1, wvt1, wvt2, wvt2, wvt2, wvt2, wvt3, wvt3, wvt3, wvt3, wvt4, wvt4, wvt4, wvt4)
wlvKdA = array.from("H", "L", "O", "C", "H", "L", "O", "C", "H", "L", "O", "C", "H", "L", "O", "C")
var bool[] wlv_fired = array.new_bool(16, false)
if nD
    for k = 0 to 15
        array.set(wlv_fired, k, false)
if enWLV
    for k = 0 to wlvWk * 4 - 1
        float _WL = array.get(wlvPr, k)
        bool _wdef = not na(_WL) and dOpen > _WL and low <= _WL and close > _WL and (_WL - low) / _WL >= wlvMinPen
        bool _wbel = enWLVbelow and not na(_WL) and dOpen < _WL and close > _WL and close[1] <= _WL
        if (_wdef or _wbel) and (k % 4 < 2 or not lvlHLonly) and not array.get(wlv_fired, k)
            array.set(wlv_fired, k, true)
            string _wn  = str.format("{0,date,MMM d}", int(array.get(wlvTmA, k)))
            string _wkd = array.get(wlvKdA, k)
            string _wsrc = _wdef ? "held from above" : "reclaimed from below"
            alert(rc_pay("weekly_lvl_reclaim", "BUY", "W", _WL, low, "WLV · wk " + _wn + " " + _wkd + " " + str.tostring(_WL, format.mintick) + " " + _wsrc + " — entry at the level, stop the reclaim low " + str.tostring(low, format.mintick)), alert.freq_once_per_bar_close)

// MoBO — monthly BOX breakout + monthly RC-H (long-term/position; default OFF, gate-exempt).
// entry = the locked level (the buy point), stop = the base / pre-break low.
if mobo_box_fire
    alert(rc_pay("monthly_box", "BUY", "M", mobo_ceil, mobo_low, "MoBO · monthly BOX breakout — price cleared the locked flat-base ceiling " + str.tostring(mobo_ceil, format.mintick) + ", stop the base low " + str.tostring(mobo_low, format.mintick)), alert.freq_once_per_bar_close)
if mobo_rch_fire
    alert(rc_pay("mobo_rch", "BUY", "M", mobo_rl, mobo_rl_low, "MoBO RC-H · broke a prior MONTHLY high that held as resistance for months — entry " + str.tostring(mobo_rl, format.mintick) + ", stop " + str.tostring(mobo_rl_low, format.mintick)), alert.freq_once_per_bar_close)

// 10w / 30w MA support alert — fire INTRADAY the moment price reaches/reclaims the locked
// weekly MA level, ONCE PER TOUCH (re-arm when price moves clearly back above it), NOT once
// per week. Reuses ma_bounce() — the validated tag-from-above-and-hold + re-arm latch — on
// the locked w10/w30 levels. (Old per-WEEK latch + the sticky weekly-low held/reclaim
// conditions fired at most once a week; weekly_10w_reclaim / weekly_30w_reclaim retired —
// the single touch alert covers tag-and-hold + a shallow undercut-reclaim.)
// WICK & RECLAIM, not held (user 2026-07-08, MU: wicked to ~900 below the 10w @922 then reclaimed to
// 938 — a shallow "tag & held" MISSES that deep undercut). sweep_reclaim = armed above the MA, swept
// (low < MA = the wick below), then reclaimed (close back > MA). Latched once per week (nW). Stop = the
// reclaim/wick low, not the MA.
mb_w10 = sweep_reclaim(w10, en_w10, en_w10 and not na(w10), nW)
mb_w30 = sweep_reclaim(w30, en_w30, en_w30 and not na(w30), nW)
if mb_w10
    alert(rc_pay("weekly_10w_held", "BUY", "W", close, low, "10w MA · WICKED below & reclaimed the 10-week MA " + str.tostring(w10, format.mintick) + " — entry " + str.tostring(close, format.mintick) + ", stop the reclaim low " + str.tostring(low, format.mintick)), alert.freq_once_per_bar_close)
if mb_w30
    alert(rc_pay("weekly_30w_held", "BUY", "W", close, low, "30w MA · WICKED below & reclaimed the 30-week MA (LONG-TERM support) — entry " + str.tostring(close, format.mintick) + ", stop the reclaim low " + str.tostring(low, format.mintick)), alert.freq_once_per_bar_close)

// Reclaim long (#65) — entry = the reclaim close, stop = the dip low, target = next
// resistance. strike = nearest whole-dollar = the ~ATM call (small intraday moves need
// ATM delta to pay). rule = reclaim_long so the backend routes + records it unchanged.
reclaim_pay(string lvl, float ent, float stp, float tgt) => '{"symbol":"' + syminfo.ticker + '","price":"' + str.tostring(close, format.mintick) + '","rule":"reclaim_long","direction":"BUY","interval":"' + timeframe.period + '","entry":"' + str.tostring(ent, format.mintick) + '","stop":"' + str.tostring(stp, format.mintick) + '","strike":"' + str.tostring(int(math.round(ent))) + '","option":"~ATM ' + str.tostring(int(math.round(ent))) + 'C nearest weekly","note":"Reclaim long · reclaimed the ' + lvl + ' with room · stop ' + str.tostring(stp, format.mintick) + ' · take profit into ' + str.tostring(tgt, format.mintick) + ' · buy ≈ATM ' + str.tostring(int(math.round(ent))) + 'C, nearest weekly expiry","fired_at":"' + str.tostring(timenow) + '"}'
if en_reclaim and rl_orhSig
    alert(reclaim_pay("ORH", close, rl_orhStop, rl_orhTgt), alert.freq_once_per_bar_close)
if en_reclaim and rl_pdhSig
    alert(reclaim_pay("PDH", close, rl_pdhStop, rl_pdhTgt), alert.freq_once_per_bar_close)

// OR-channel option plays (orl_held / orl_reclaim / orh_reject) RETIRED 2026-06-27 —
// too NOISY (especially ORL). The original 60m staged_orl_held (levels_day_vwap.pine,
// scoped to the orl_always_symbols allowlist) is the one ORL play now. The ORH/ORL
// lines stay as VISUALS above; only the alert() emits were removed here.

// MA bounce — rule "ma_bounce_long_v3" + ma_tag (number+E); backend forms
// ma_bounce_long_v3_<ema>. entry = close (held above the MA), stop = the MA (close
// below = support lost). interval = the chart TF (intraday test of the daily MA).
ma_pay(string matag, float ma) => '{"symbol":"' + syminfo.ticker + '","price":"' + str.tostring(close, format.mintick) + '","rule":"ma_bounce_long_v3","direction":"BUY","ma_tag":"' + matag + '","interval":"' + timeframe.period + '","entry":"' + str.tostring(close, format.mintick) + '","stop":"' + str.tostring(ma, format.mintick) + '","note":"MA bounce — held the daily ' + matag + ' (stop = close below it)","fired_at":"' + str.tostring(timenow) + '"}'
if mb_e8
    alert(ma_pay("8E", ema8d), alert.freq_once_per_bar_close)
if mb_e21
    alert(ma_pay("21E", ema21d), alert.freq_once_per_bar_close)
if mb_e50
    alert(ma_pay("50E", ema50d), alert.freq_once_per_bar_close)
if mb_e100
    alert(ma_pay("100E", ema100d), alert.freq_once_per_bar_close)
if mb_e200
    alert(ma_pay("200E", ema200d), alert.freq_once_per_bar_close)

// ══════════════════════════════════════════════════════════════════════════════
// ORB — the 15m ALERT MACHINE (break/held/retest/exit) was REMOVED 2026-07-08
// (user: "there should be no orb in 15mins"). The ONE ORB alert is the 1h
// reclaim below. What remains of the 15m code: the opening-range BOX VISUAL
// (the look you liked) and the shared ORB symbol whitelist (gates the 1h too).
// ══════════════════════════════════════════════════════════════════════════════
gORB = "ORB — shared (symbol whitelist + 15m box visual)"

// OR = the first 15 MINUTES of the RTH session, built from NATIVE bars — works whether
// rc.pine is on the 5m alert chart or you're viewing it on 15m. (VISUAL ONLY now.)
var int orb_sbar = 0
orb_sbar := nD ? 0 : orb_sbar + 1
orb_orMinBars = math.max(1, math.round(15.0 / (timeframe.in_seconds() / 60.0)))
var float orb_orh = na
var float orb_orl = na
if nD
    orb_orh := high
    orb_orl := low
else if orb_sbar < orb_orMinBars
    orb_orh := math.max(orb_orh, high)
    orb_orl := math.min(orb_orl, low)
orb_orReady  = orb_sbar >= orb_orMinBars
orb_orJustSet = orb_sbar == orb_orMinBars

// SYMBOL WHITELIST (2026-07-08) — ORB alerts fire ONLY for these tickers, at the PINE
// level, so they can NEVER flood the whole watchlist (the 15m machine once fired for
// all 130+ symbols → ~57k alerts/day, all suppressed, burning TV alert capacity).
// Now gates the 1h reclaim only. Comma-separated, NO spaces.
orb_syms   = input.string("SPY,QQQ,IWM,DIA", "ORB: fire ONLY for these tickers — INDEX only (comma-sep, no spaces)", group = gORB)
orb_sym_ok = str.contains("," + str.upper(orb_syms) + ",", "," + str.upper(syminfo.ticker) + ",")

// ── ORB 1h reclaim (2026-07-07) — the CLEAN, low-noise ORB. A reclaim of the 1-HOUR opening-range
// LOW or HIGH (LONG, once per session), locked to 1h bars via request.security so it's identical on
// any chart TF. Lives HERE (not a 3rd pine) because alerts must be on an already-bound pine — the
// H-ORB pine is the VISUAL twin. Default OFF; gated by the orb_symbols allowlist in the backend.
gO1 = "ORB 1h — reclaim of the 1h opening range (clean, low-noise)"
en_orb1h  = input.bool(true,  "Fire ORB 1h reclaim (ORL/ORH reclaim · BUY · once per session)", group = gO1)
o1_orMin  = input.int(60, "  1h opening-range minutes (locked to 1h bars)", minval = 60, maxval = 240, step = 60, group = gO1)
f_or60() =>
    var float _h = na
    var float _l = na
    var int   _sb = 0
    _new = ta.change(time("D")) != 0
    _sb := _new ? 0 : _sb + 1
    _bars = math.max(1, math.round(o1_orMin / 60.0))
    if _new
        _h := high
        _l := low
    else if _sb < _bars
        _h := math.max(_h, high)
        _l := math.min(_l, low)
    [_h, _l]
[o1_orh, o1_orl] = request.security(syminfo.tickerid, "60", f_or60(), lookahead = barmerge.lookahead_on)
// FIRST ALERT ONLY AFTER THE 1h OR COMPLETES (user 2026-07-08: "first orb alert should be after 1h").
// Track the RTH session-open time and require at least o1_orMin minutes elapsed, so no reclaim can
// fire inside the opening hour even if lookahead surfaces the OR level early.
var int _o1_open = na
if nD
    _o1_open := time
o1_ready = not na(_o1_open) and (time - _o1_open) >= o1_orMin * 60 * 1000
// ORB now emits for EVERY watchlist symbol (crypto included). WHICH symbols a user
// actually RECEIVES is controlled entirely by the per-user ORB allowlist in Settings
// (backend orb_symbols) — no Pine-level symbol gate, so you add anything from Settings
// without editing/re-pasting this script. (orb_sym_ok + the crypto exclusion removed.)
o1_on = en_orb1h and o1_ready
o1_rcL = sweep_reclaim(o1_orl, o1_on, o1_on and not na(o1_orl), nD)
o1_rcH = sweep_reclaim(o1_orh, o1_on, o1_on and not na(o1_orh), nD, true)
if o1_on and o1_rcL
    alert(rc_pay("orb_reclaim", "BUY", "60", o1_orl, low, "ORB 1h · reclaimed the OR LOW " + str.tostring(o1_orl, format.mintick) + " — bounce off the opening range, stop the reclaim low"), alert.freq_once_per_bar_close)
if o1_on and o1_rcH
    alert(rc_pay("orb_reclaim", "BUY", "60", o1_orh, o1_orl, "ORB 1h · reclaimed the OR HIGH " + str.tostring(o1_orh, format.mintick) + " — breakout-retest of the opening range, stop the OR low"), alert.freq_once_per_bar_close)

// ══════════════════════════════════════════════════════════════════════════════
// ORB ORH/ORL VISUAL — MOVED OUT (2026-07-10, user: "page too busy, put in a separate pine").
// The opening-range BOX + ORH/ORL labels now live in the standalone opening_range.pine, so rc.pine
// stays clean. The ORB reclaim-long ALERT logic (rl_orh/rl_orl) + the PDH/PDL flat lines (draw_level
// above) STAY here — only the OR box + ORH/ORL labels were removed to declutter the chart.
// ══════════════════════════════════════════════════════════════════════════════
