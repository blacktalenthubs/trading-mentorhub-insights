// @version=5
//
// 4h Reclaim (RC) — ANCHORED. Markers + alerts, one per 4h bar.
//
// The reclaim is computed on the 4h candle via request.security("240"), so it is
// IDENTICAL on any chart TF and fires at most ONCE per 4h bar (no flood, even on a
// 5m alert).
//   ▲ RC   = 4h low < prior 4h low  AND 4h close > prior 4h low  — undercut & reclaim (BUY)
//   ▼ ↓    = 4h high > prior 4h high AND 4h close < prior 4h high — failed break (SHORT)
//   ▲ RC-H = 4h low < prior 4h high AND 4h close > prior 4h high — breakout-retest (BUY)
//   rule "rc_4h" → Day-trade. Backend sets the exit (next resistance).
//
// ⚠️ STANDALONE — DO NOT fold the weekly 10w/30w alert in here. Adding a
// request.security("W") to this anchored 4h script SILENTLY KILLS RC emission
// (validated 2026-06-21: RC went dark after every weekly merge; last RC 00:55,
// nothing after). The weekly_ma_held alert lives in levels_day_vwap.pine instead.
// Keep this Pine to ONE timeframe. Bind ONE TV alert with "Any alert() function call".
//
indicator("4h Reclaim (RC)", "RC4h", overlay = true, max_labels_count = 200, max_lines_count = 100)

show_long  = input.bool(true, "▲ RC long — reclaim of prior 4h LOW (BUY)", group = "4h RC")
show_short = input.bool(true, "▼ rejection short — failed break of prior 4h HIGH (SHORT)", group = "4h RC")
show_hrec  = input.bool(true, "▲ RC-H — reclaim of prior 4h HIGH / breakout-retest (BUY)", group = "4h RC")
rc_buf_pct = input.float(0.2, "Stop buffer beyond the reclaimed level (%)", minval = 0.0, step = 0.1, group = "4h RC")

// Prior COMPLETED 4h high/low — the levels to break / reclaim. lookahead_on + [1]
// pulls the PRIOR (already-closed) 4h bar, so the level is available INTRABAR and is
// identical on a 4h chart and a 5m chart (no repaint — [1] is a closed bar, never peeks).
rc4_phigh = request.security(syminfo.tickerid, "240", high[1], lookahead = barmerge.lookahead_on)
rc4_plow  = request.security(syminfo.tickerid, "240", low[1],  lookahead = barmerge.lookahead_on)
rc4_close = close

// Fire the MOMENT price crosses the level on the alert timeframe — NOT at the 4h close.
// The old rc4_newbar gate only evaluated at the 4h boundary, so it missed the break/
// reclaim as it happened. Same principle as the PDL/level alerts, which fire intrabar
// on the 5m bar that breaks/holds the level. The level-stable guard skips the 4h-
// boundary bar so a stepping level can't fake a cross; crossover is one-shot, and the
// backend dedup window collapses any re-test chop.
hi_stable = rc4_phigh == rc4_phigh[1]
lo_stable = rc4_plow  == rc4_plow[1]
rc4_long  = show_long  and lo_stable and ta.crossover (close, rc4_plow)   // reclaim the prior 4h LOW (reversal long)
rc4_short = show_short and hi_stable and ta.crossunder(close, rc4_phigh)  // reject the prior 4h HIGH (short)
rc4_hrec  = show_hrec  and hi_stable and ta.crossover (close, rc4_phigh)  // break the prior 4h HIGH (breakout long)

plotshape(rc4_long,  title = "RC long",  style = shape.triangleup,   location = location.belowbar, color = color.new(color.lime, 0), size = size.small, text = "RC")
plotshape(rc4_short, title = "RC short", style = shape.triangledown, location = location.abovebar, color = color.new(color.red, 0),  size = size.small, text = "↓")
plotshape(rc4_hrec,  title = "RC-H",     style = shape.triangleup,   location = location.belowbar, color = color.new(color.teal, 0), size = size.small, text = "RC-H")

rc_payload(string dir, float stp, string note) => '{"symbol":"' + syminfo.ticker + '","price":"' + str.tostring(rc4_close, format.mintick) + '","rule":"rc_4h","direction":"' + dir + '","interval":"240","entry":"' + str.tostring(rc4_close, format.mintick) + '","stop":"' + str.tostring(stp, format.mintick) + '","note":"' + note + '","fired_at":"' + str.tostring(timenow) + '"}'

// Stop = just BEYOND the reclaimed/rejected LEVEL (rc4_plow / rc4_phigh), not the deep
// undercut wick. Thesis: "that prior 4h level held" — so losing the level = setup failed.
if rc4_long
    alert(rc_payload("BUY", rc4_plow * (1 - rc_buf_pct / 100.0), "RC · reclaim of the prior 4h low · stop just below the reclaimed low"), alert.freq_once_per_bar_close)
if rc4_short
    alert(rc_payload("SHORT", rc4_phigh * (1 + rc_buf_pct / 100.0), "RC · rejection at the prior 4h high · stop just above the level"), alert.freq_once_per_bar_close)
if rc4_hrec
    alert(rc_payload("BUY", rc4_phigh * (1 - rc_buf_pct / 100.0), "RC-H · breakout-retest reclaim of the prior 4h high · stop just below the reclaimed high"), alert.freq_once_per_bar_close)
