// @version=5
//
// Prior Day Levels (Staged) v2 — Phase A order-flow additions.
//
// Identical to `prior_day_levels_staged.pine` (same 4 alerts, same stage
// detection, same structural stops) plus three new payload fields:
//
//   • volume_ratio   — fire-bar volume / N-bar average (1.0 = avg, 1.5 = 50% above)
//   • cvd_delta      — CVD change over lookback (positive = aggressive buying)
//   • cvd_diverging  — true if price/CVD direction conflicts (bearish div on
//                      LONGs, bullish div on SHORTs)
//
// CVD is approximated from candle structure (close near high = aggressive
// buy proxy). Pine has no native bid/ask classification for non-futures.
// Magnitude is approximate; direction and divergence are reliable.
//
// Backend uses these to DEGRADE conviction (not mute) and surface explicit
// warnings ("⚠️ low volume", "⚠️ CVD diverging") in Telegram. v1 still
// works unchanged — backend treats missing fields as neutral.
//
// Indicator name suffixed " v2" so TV treats it as a separate script slot —
// you can run both v1 and v2 side-by-side and compare.
//
indicator("levels-day-vwap", overlay = true)

show_lines        = input.bool(true,  "Show PDH/PDL lines")
show_midpoint     = input.bool(true,  "Show range midpoint line (gray dashed)")
fire_open_alerts  = input.bool(true,  "Fire open_lost / open_reclaimed alerts")
show_signals      = input.bool(true,  "Show LONG/SHORT entry markers")
show_sweep        = input.bool(true,  "Show SWEEP composite markers")
show_vwap         = input.bool(true,  "Show VWAP")
show_stage_badge  = input.bool(true,  "Show day-type badge (top-center)")
fire_vwap_alerts  = input.bool(false, "Fire VWAP reclaim/reject/support alerts (NOTICE — SPY/QQQ only; ignored on other symbols)")
// Note: macro-symbol gate is shared across VWAP alerts and the
// failed-PDH session window expansion. Open-line alerts live in the
// separate `open-line` indicator.
is_macro_symbol   = syminfo.ticker == "SPY" or syminfo.ticker == "QQQ" or syminfo.ticker == "AIQ" or syminfo.ticker == "NDX"
sweep_window_bars = input.int (5,     "Sweep window (bars)", minval = 1, maxval = 10)
atr_buffer_mult   = input.float(0.3,  "ATR buffer for stops (× ATR14)", minval = 0.1, maxval = 2.0, step = 0.1)
vwap_lookback     = input.int (20,    "VWAP slope lookback (bars)", minval = 5, maxval = 60)
vwap_slope_thresh = input.float(0.1,  "VWAP slope threshold (%)", minval = 0.01, maxval = 1.0, step = 0.01)
vol_avg_lookback  = input.int (20,    "Volume average lookback (bars)", minval = 5, maxval = 60)
cvd_lookback      = input.int (10,    "CVD divergence lookback (bars)", minval = 3, maxval = 30)
vwap_setup_bars   = input.int (3,     "VWAP setup: bars on wrong side before reclaim/reject fires", minval = 1, maxval = 10)

// =====================================================================
// PDH / PDL
// =====================================================================
[pdh, pdl] = request.security(syminfo.tickerid, "D", [high[1], low[1]],
                              lookahead = barmerge.lookahead_on)

// PDH/PDL: thick blue straight lines (no breaks). User preference —
// keeps the chart visually consistent: blue = key prior-day level.
plot(show_lines ? pdh : na, title = "PDH",
     color = color.new(color.blue, 0), style = plot.style_line, linewidth = 4)
plot(show_lines ? pdl : na, title = "PDL",
     color = color.new(color.blue, 0), style = plot.style_line, linewidth = 4)

// =====================================================================
// PWH/PWL + PMH/PML — fetched silently (NOT plotted here)
// =====================================================================
// Per 2026-05-06 unification, these levels participate in the same alert
// events as PDH/PDL (a PWL reclaim fires `staged_pdl_reclaim`, etc.) and
// feed the confluence count + T1/T2 target hierarchy. Visual plots live
// in the `levels-week-month` indicator so users can toggle the higher-TF
// lines off without affecting alert quality.
// =====================================================================
[pwh, pwl] = request.security(syminfo.tickerid, "W", [high[1], low[1]],
                              lookahead = barmerge.lookahead_on)
[pmh, pml] = request.security(syminfo.tickerid, "M", [high[1], low[1]],
                              lookahead = barmerge.lookahead_on)

// =====================================================================
// VWAP + slope
// =====================================================================
vwap_v    = ta.vwap(hlc3)
vwap_past = vwap_v[vwap_lookback]
vwap_slope_pct = not na(vwap_past) and vwap_past != 0 ? (vwap_v - vwap_past) / vwap_past * 100 : na

vwap_rising  = not na(vwap_slope_pct) and vwap_slope_pct >  vwap_slope_thresh
vwap_falling = not na(vwap_slope_pct) and vwap_slope_pct < -vwap_slope_thresh
vwap_flat    = not na(vwap_slope_pct) and not vwap_rising and not vwap_falling

// VWAP: thick purple straight line. Same visual weight as PDH/PDL so
// the three institutional reference lines read as a coherent set.
plot(show_vwap ? vwap_v : na, title = "VWAP",
     color = color.new(#9C27B0, 20), style = plot.style_line, linewidth = 4)

// =====================================================================
// Volume confirmation — fire-bar volume vs N-bar SMA
// =====================================================================
vol_avg = ta.sma(volume, vol_avg_lookback)
volume_ratio = vol_avg > 0 ? volume / vol_avg : na

// =====================================================================
// CVD (Cumulative Volume Delta) — candle-structure approximation
// close near high  → aggressive buying skew
// close near low   → aggressive selling skew
// Magnitude approximate; trend / divergence reliable.
// =====================================================================
bar_range = high - low
buy_vol  = bar_range > 0 ? ((close - low) / bar_range) * volume : volume * 0.5
sell_vol = bar_range > 0 ? ((high - close) / bar_range) * volume : volume * 0.5
delta_v = buy_vol - sell_vol
cvd     = ta.cum(delta_v)

cvd_past   = cvd[cvd_lookback]
price_past = close[cvd_lookback]
cvd_slope_n   = not na(cvd_past)   ? cvd - cvd_past     : na
price_slope_n = not na(price_past) ? close - price_past : na

// LONG entries care about bearish divergence: price up, CVD flat/down
bearish_div = not na(cvd_slope_n) and not na(price_slope_n) and price_slope_n > 0 and cvd_slope_n <= 0
// SHORT entries care about bullish divergence: price down, CVD flat/up
bullish_div = not na(cvd_slope_n) and not na(price_slope_n) and price_slope_n < 0 and cvd_slope_n >= 0

// =====================================================================
// STAGE DETECTION
// =====================================================================
above_pdh   = not na(pdh) and close > pdh
below_pdl   = not na(pdl) and close < pdl
in_range    = not na(pdh) and not na(pdl) and close >= pdl and close <= pdh
above_vwap  = not na(vwap_v) and close > vwap_v
below_vwap  = not na(vwap_v) and close < vwap_v

is_stage2 = above_pdh and vwap_rising  and above_vwap
is_stage4 = below_pdl and vwap_falling and below_vwap
is_stage3 = above_pdh and not is_stage2 and (vwap_flat or vwap_falling)
is_stage1 = in_range  and vwap_flat

string stage_text = "TRANSITIONING\nno clean regime\nHALF SIZE — sweeps only"
color  stage_bg   = color.new(color.purple, 30)
if na(vwap_slope_pct)
    stage_text := "INSUFFICIENT DATA\nVWAP loading\nWAIT for slope to settle"
    stage_bg   := color.new(color.gray, 30)
else if is_stage2
    stage_text := "STAGE 2: ADVANCING\nabove PDH + VWAP rising\nLONGS at PDH/VWAP pullbacks"
    stage_bg   := color.new(color.green, 10)
else if is_stage4
    stage_text := "STAGE 4: DECLINING\nbelow PDL + VWAP falling\nSHORTS at VWAP pops"
    stage_bg   := color.new(color.red, 10)
else if is_stage3
    stage_text := "STAGE 3: TOPPING\nabove PDH but VWAP rolling\nTRIM LONGS — fade rejects"
    stage_bg   := color.new(color.orange, 10)
else if is_stage1
    stage_text := "STAGE 1: BASING\ninside range + VWAP flat\nWAIT — sweeps only"
    stage_bg   := color.new(color.gray, 30)

// stage_text is still computed (used by stage_json in the alert payload —
// the triage agent uses it for scoring). It's no longer rendered as the
// chart badge — the day-type classification below replaces it for the
// visual since "GAP UP / INSIDE / TEST PDH" is more actionable than
// "STAGE 2 ADVANCING" for instinct trading.
//
// Stage / event bgcolor tints removed 2026-05-14 — user kept unchecking
// them in the Style tab. The plotshape markers (BREAK+, RECLAIM, REJECT,
// BREAK-, SWEEP+, SWEEP-) are sufficient visual cues for event firing.

// =====================================================================
// Level break / reject / reclaim — unified across daily/weekly/monthly
// =====================================================================
// User direction (2026-05-06): "treat all levels as same — if PWL holds
// it's support too." Expanded triggers fire on any of the three timeframe
// levels, but the existing event names (pdh_break, pdl_reclaim, etc) are
// preserved so already-bound TV alerts keep working.
//
// When multiple levels cross on the same bar (e.g. gap-up clears PDH and
// PWH together), we use the LEVEL CLOSEST TO PRIOR-BAR-CLOSE as the
// reference for stops — that's the level price actually defended/broke.

// Helpers — return the just-crossed level (na if no cross this bar).
// Lowest resistance just broken: lowest level above prior close that's
// now below current close.
lowest_res_just_broken() =>
    p_pdh = not na(pdh) and close > pdh and close[1] <= pdh ? pdh : 9.0e15
    p_pwh = not na(pwh) and close > pwh and close[1] <= pwh ? pwh : 9.0e15
    p_pmh = not na(pmh) and close > pmh and close[1] <= pmh ? pmh : 9.0e15
    m = math.min(p_pdh, math.min(p_pwh, p_pmh))
    m == 9.0e15 ? float(na) : m

// Highest support just reclaimed: highest level below prior close that's
// now above current close.
highest_sup_just_reclaimed() =>
    p_pdl = not na(pdl) and close > pdl and close[1] <= pdl ? pdl : -9.0e15
    p_pwl = not na(pwl) and close > pwl and close[1] <= pwl ? pwl : -9.0e15
    p_pml = not na(pml) and close > pml and close[1] <= pml ? pml : -9.0e15
    m = math.max(p_pdl, math.max(p_pwl, p_pml))
    m == -9.0e15 ? float(na) : m

// Highest resistance just rejected: wick tagged level from below + closed back under.
highest_res_just_rejected() =>
    p_pdh = not na(pdh) and high >= pdh and close < pdh and high[1] < pdh ? pdh : -9.0e15
    p_pwh = not na(pwh) and high >= pwh and close < pwh and high[1] < pwh ? pwh : -9.0e15
    p_pmh = not na(pmh) and high >= pmh and close < pmh and high[1] < pmh ? pmh : -9.0e15
    m = math.max(p_pdh, math.max(p_pwh, p_pmh))
    m == -9.0e15 ? float(na) : m

// Lowest support just broken: lowest level below prior close that's now broken below.
lowest_sup_just_broken() =>
    p_pdl = not na(pdl) and close < pdl and close[1] >= pdl ? pdl : 9.0e15
    p_pwl = not na(pwl) and close < pwl and close[1] >= pwl ? pwl : 9.0e15
    p_pml = not na(pml) and close < pml and close[1] >= pml ? pml : 9.0e15
    m = math.min(p_pdl, math.min(p_pwl, p_pml))
    m == 9.0e15 ? float(na) : m

broken_resistance   = lowest_res_just_broken()
reclaimed_support   = highest_sup_just_reclaimed()
rejected_resistance = highest_res_just_rejected()
broken_support      = lowest_sup_just_broken()

pdh_break     = not na(broken_resistance)
pdh_rejection = not na(rejected_resistance)
pdl_break     = not na(broken_support)
pdl_reclaim   = not na(reclaimed_support)

// =====================================================================
// Confluence count — how many of {PDH/PWH/PMH} or {PDL/PWL/PML} are
// stacked within 1% of the just-broken/reclaimed level. Higher count =
// more institutional memory at that price = stronger breakout/reclaim.
// User direction 2026-05-06: "the more convinced the better we are at
// executing." A 3-of-3 confluence break is materially higher conviction
// than a single-level break.
// =====================================================================
within_zone(float a, float b, float pct) =>
    not na(a) and not na(b) and math.abs(a - b) / b <= pct

confluence_count_at(float anchor, float l1, float l2, float l3) =>
    if na(anchor)
        0
    else
        c = 0
        // Anchor itself counts if it's one of the three
        if not na(l1) and l1 == anchor
            c := c + 1
        if not na(l2) and l2 == anchor
            c := c + 1
        if not na(l3) and l3 == anchor
            c := c + 1
        // Add levels within 1% that aren't the anchor itself
        if not na(l1) and l1 != anchor and within_zone(l1, anchor, 0.01)
            c := c + 1
        if not na(l2) and l2 != anchor and within_zone(l2, anchor, 0.01)
            c := c + 1
        if not na(l3) and l3 != anchor and within_zone(l3, anchor, 0.01)
            c := c + 1
        // Cap at 3 — anchor itself shouldn't double-count beyond its
        // membership in the level list
        math.min(c, 3)

confluence_resistance = confluence_count_at(broken_resistance, pdh, pwh, pmh)
confluence_support    = confluence_count_at(reclaimed_support, pdl, pwl, pml)
confluence_rej        = confluence_count_at(rejected_resistance, pdh, pwh, pmh)
confluence_brk_sup    = confluence_count_at(broken_support, pdl, pwl, pml)

// Failed breakout — price closed above a resistance level (PDH/PWH/PMH)
// and now closes back below it. Different from `_just_rejected` (wick
// test that never closed above). This is the trap pattern: breakout
// buyers above are now underwater and forced to cover.
// User 2026-05-07: "if SPY goes above PDH and then reverses below, that's
// a short signal." Adding as a new SHORT event.
highest_res_just_failed() =>
    p_pdh = not na(pdh) and close < pdh and close[1] > pdh ? pdh : -9.0e15
    p_pwh = not na(pwh) and close < pwh and close[1] > pwh ? pwh : -9.0e15
    p_pmh = not na(pmh) and close < pmh and close[1] > pmh ? pmh : -9.0e15
    m = math.max(p_pdh, math.max(p_pwh, p_pmh))
    m == -9.0e15 ? float(na) : m

failed_resistance = highest_res_just_failed()
confluence_failed = confluence_count_at(failed_resistance, pdh, pwh, pmh)

// =====================================================================
// Triggered-timeframe tag — D / W / M / "" (na)
// =====================================================================
// Per user direction 2026-05-12: weekly/monthly level events should fire
// as NOTICE (heads-up), not BUY/SHORT. Daily level events stay BUY/SHORT.
// Identifies which TF actually triggered the break/reclaim/rejection by
// comparing the anchor price (broken_resistance / reclaimed_support /
// rejected_resistance / failed_resistance / broken_support) against the
// PDH/PWH/PMH or PDL/PWL/PML values. Daily wins ties (first match).
level_tf(float lvl, float d, float w, float m) =>
    na(lvl) ? "" :
      not na(d) and lvl == d ? "D" :
      not na(w) and lvl == w ? "W" :
      not na(m) and lvl == m ? "M" : ""

// Direction picker: daily levels keep their actionable direction;
// weekly/monthly levels degrade to NOTICE so triage muting kicks in.
dir_for_tf(string tf, string actionable_dir) =>
    tf == "D" ? actionable_dir : "NOTICE"

var int pdl_break_bar = na
var int pdh_break_bar = na
if pdl_break
    pdl_break_bar := bar_index
if pdh_break
    pdh_break_bar := bar_index

// pdh_failed now unified — fires on close-back-below ANY of PDH/PWH/PMH.
pdh_failed = not na(failed_resistance)

bars_since_pdl_break = na(pdl_break_bar) ? 9999 : bar_index - pdl_break_bar
bars_since_pdh_break = na(pdh_break_bar) ? 9999 : bar_index - pdh_break_bar

// Effective sweep window — SPY/QQQ use a session-wide window (200 bars,
// covers a full RTH session on any chart TF). For other symbols the
// configured window (default 5 bars) keeps the "quick trap" semantics.
// Rationale: SPY/QQQ failed-PDH reversals are macro-relevant whether
// they happen 5 bars after the break or 5 hours after — both are the
// same "the breakout failed" narrative for the index.
effective_sweep_window = is_macro_symbol ? 200 : sweep_window_bars
sweep_reclaim_long   = pdl_reclaim and bars_since_pdl_break <= effective_sweep_window
sweep_reversal_short = pdh_failed  and bars_since_pdh_break <= effective_sweep_window

sweep_active = sweep_reclaim_long or sweep_reversal_short

// (bgcolor() tints for PDH break / PDL reclaim / PDH rejection / PDL break /
// Sweep LONG / Sweep SHORT events removed 2026-05-14 — plotshape arrows
// below serve the same purpose without painting the whole bar background.)

plotshape(show_signals and pdh_break,
          title = "BREAK+ LONG", location = location.belowbar,
          color = color.new(color.green, 0), style = shape.triangleup,
          size = size.normal, text = "BREAK+", textcolor = color.white)
plotshape(show_signals and pdl_reclaim and not sweep_reclaim_long,
          title = "RECLAIM LONG", location = location.belowbar,
          color = color.new(color.aqua, 0), style = shape.triangleup,
          size = size.normal, text = "RECLAIM", textcolor = color.black)
plotshape(show_signals and pdh_rejection,
          title = "REJECT SHORT", location = location.abovebar,
          color = color.new(color.orange, 0), style = shape.triangledown,
          size = size.normal, text = "REJECT", textcolor = color.white)
plotshape(show_signals and pdl_break and not sweep_reversal_short,
          title = "BREAK- SHORT", location = location.abovebar,
          color = color.new(color.red, 0), style = shape.triangledown,
          size = size.normal, text = "BREAK-", textcolor = color.white)

plotshape(show_sweep and sweep_reclaim_long,
          title = "SWEEP+ HC LONG", location = location.belowbar,
          color = color.new(color.lime, 0), style = shape.diamond,
          size = size.large, text = "SWEEP+", textcolor = color.black)
plotshape(show_sweep and sweep_reversal_short,
          title = "SWEEP- HC SHORT", location = location.abovebar,
          color = color.new(color.fuchsia, 0), style = shape.diamond,
          size = size.large, text = "SWEEP-", textcolor = color.white)

// =====================================================================
// Today's open + open-line PDH/PDL confluence flags
// =====================================================================
// today_open is captured on the first bar of each session. It feeds both
// gap-context detection (further down) AND the open_lost/open_reclaimed
// alerts (further still). near_pdh_open / near_pdl_open mark when the
// open sits at PDH/PDL — used by the webhook to collapse confluence twins.
// These need to be declared BEFORE build_payload_v2 because the payload
// references them by name.
session_open_now = ta.change(time("D")) != 0
var float today_open       = na
var float bar1_low         = na
var int   first_bar_time   = na

if session_open_now
    today_open := open
    bar1_low := low
    first_bar_time := time
else if not na(first_bar_time) and (time - first_bar_time) <= 10 * 60 * 1000
    bar1_low := math.min(nz(bar1_low, low), low)

open_confluence_tol = 0.003  // 0.3%
near_pdh_open = not na(today_open) and not na(pdh) and math.abs(today_open - pdh) / pdh <= open_confluence_tol
near_pdl_open = not na(today_open) and not na(pdl) and math.abs(today_open - pdl) / pdl <= open_confluence_tol

// Inside-day flag: today's open sits between yesterday's high and low.
// These days tend to range — useful as a conviction-degrade signal for the
// triage agent. Outside-day opens (above PDH or below PDL = gap-up/gap-down)
// have stronger directional bias.
is_inside_day = not na(today_open) and not na(pdh) and not na(pdl) and today_open > pdl and today_open < pdh

// =====================================================================
// Day type — actionable session classification displayed on chart badge.
// Replaces the Stage 1/2/3/4 labels since "GAP UP / INSIDE / TEST PDH" is
// more directly useful for sizing + bias than "STAGE 2 ADVANCING".
//
// Seven buckets (mutually exclusive):
//   GAP UP        open > PDH                trend bias, longs at pullback
//   TEST PDH      open ≈ PDH                break-or-fail
//   INSIDE HIGH   open in upper half of range   range, lean long
//   INSIDE MID    open near range midpoint      true 2-sided range
//   INSIDE LOW    open in lower half of range   range, lean short
//   TEST PDL      open ≈ PDL                bounce-or-break
//   GAP DOWN      open < PDL                distribution risk, avoid longs
// =====================================================================
gap_threshold_pct = 0.0001  // > 0.01% past PDH/PDL counts as a "gap"
is_gap_up   = not na(today_open) and not na(pdh) and today_open > pdh * (1.0 + gap_threshold_pct)
is_gap_down = not na(today_open) and not na(pdl) and today_open < pdl * (1.0 - gap_threshold_pct)
is_test_pdh = near_pdh_open and not is_gap_up
is_test_pdl = near_pdl_open and not is_gap_down

range_midpoint = not na(pdh) and not na(pdl) ? (pdh + pdl) / 2.0 : float(na)
is_inside_high = is_inside_day and not na(range_midpoint) and today_open > range_midpoint and not is_test_pdh
is_inside_low  = is_inside_day and not na(range_midpoint) and today_open < range_midpoint and not is_test_pdl
is_inside_mid  = is_inside_day and not is_inside_high and not is_inside_low and not is_test_pdh and not is_test_pdl

// Range midpoint — natural pivot between INSIDE HIGH and INSIDE LOW.
// Useful as a stop/invalidation level on inside days: long bias above mid,
// short bias below. Plotted as a silver solid line — light enough to read
// on dark themes, thinner than the bold PDH/PDL/VWAP so it stays secondary.
plot(show_midpoint and not na(range_midpoint) ? range_midpoint : na,
     title = "Range Mid",
     color = color.new(color.silver, 0),
     style = plot.style_line,
     linewidth = 2)

string day_text = "INSUFFICIENT DATA\nPDH/PDL loading\nWAIT for context"
color  day_bg   = color.new(color.gray, 30)
if not na(today_open) and not na(pdh) and not na(pdl)
    pdh_str = str.tostring(pdh, format.mintick)
    pdl_str = str.tostring(pdl, format.mintick)
    mid_str = not na(range_midpoint) ? str.tostring(range_midpoint, format.mintick) : "—"
    if is_gap_up
        day_text := "GAP UP\nopen above PDH " + pdh_str + "\nLEAN: longs at pullbacks"
        day_bg   := color.new(color.green, 10)
    else if is_test_pdh
        day_text := "TEST PDH\nopen at PDH " + pdh_str + "\nLEAN: trade the break/fail"
        day_bg   := color.new(color.yellow, 25)
    else if is_inside_high
        day_text := "INSIDE HIGH\nmid " + mid_str + " · range " + pdl_str + " / " + pdh_str + "\nLEAN: range, upper half"
        day_bg   := color.new(color.aqua, 40)
    else if is_inside_mid
        day_text := "INSIDE MID\nmid " + mid_str + " · range " + pdl_str + " / " + pdh_str + "\nLEAN: range, fade extremes"
        day_bg   := color.new(color.blue, 40)
    else if is_inside_low
        day_text := "INSIDE LOW\nmid " + mid_str + " · range " + pdl_str + " / " + pdh_str + "\nLEAN: range, lower half"
        day_bg   := color.new(color.aqua, 40)
    else if is_test_pdl
        day_text := "TEST PDL\nopen at PDL " + pdl_str + "\nLEAN: bounce-or-break"
        day_bg   := color.new(color.yellow, 25)
    else if is_gap_down
        day_text := "GAP DOWN\nopen below PDL " + pdl_str + "\nLEAN: avoid longs, fade pops"
        day_bg   := color.new(color.red, 10)

// Top-center placement so the day-type label sits front-and-center on
// the chart, not crammed against the right-side watchlist panel where
// it's easy to miss during fast markets.
var table day_t = table.new(position.top_center, 1, 1, frame_color = color.gray, frame_width = 1, border_width = 1)
if show_stage_badge and barstate.islast
    table.cell(day_t, 0, 0, day_text, text_color = color.white, bgcolor = day_bg, text_size = size.large)

// =====================================================================
// Alert payload — adds volume_ratio, cvd_delta, cvd_diverging
// =====================================================================
stage_json = str.replace_all(stage_text, "\n", " — ")

build_payload_v2(rule, direction,
                 entry_p, stop_p, t1_p, t2_p,
                 gap_ctx_v,
                 confluence_n,
                 vr, cvd_d, cvd_div) =>
    '{"symbol":"' + syminfo.ticker
      + '","exchange":"' + syminfo.prefix
      + '","interval":"' + timeframe.period
      + '","price":"' + str.tostring(close, format.mintick)
      + '","high":"' + str.tostring(high, format.mintick)
      + '","low":"' + str.tostring(low, format.mintick)
      + '","volume":"' + str.tostring(volume)
      + '","entry":"' + str.tostring(entry_p, format.mintick)
      + '","stop":"' + str.tostring(stop_p, format.mintick)
      + '","target_1":"' + str.tostring(t1_p, format.mintick)
      + '","target_2":"' + str.tostring(t2_p, format.mintick)
      + '","rule":"' + rule
      + '","direction":"' + direction
      + '","stage":"' + stage_json
      + '","vwap":"' + str.tostring(vwap_v, format.mintick)
      + '","vwap_slope_pct":"' + str.tostring(vwap_slope_pct, "#.##")
      + '","above_vwap":"' + (above_vwap ? "true" : "false")
      + '","gap_context":"' + (gap_ctx_v ? "true" : "false")
      + '","confluence_count":"' + str.tostring(confluence_n)
      + '","pwh":"' + str.tostring(pwh, format.mintick)
      + '","pwl":"' + str.tostring(pwl, format.mintick)
      + '","volume_ratio":"' + str.tostring(vr, "#.##")
      + '","cvd_delta":"' + str.tostring(cvd_d, "#.##")
      + '","cvd_diverging":"' + (cvd_div ? "true" : "false")
      + '","today_open":"' + str.tostring(today_open, format.mintick)
      + '","near_pdh":"' + (near_pdh_open ? "true" : "false")
      + '","near_pdl":"' + (near_pdl_open ? "true" : "false")
      + '","inside_day":"' + (is_inside_day ? "true" : "false")
      + '","fired_at":"' + str.tostring(timenow) + '"}'

atr14      = nz(ta.atr(14)[1], close * 0.005)
atr_buffer = atr14 * atr_buffer_mult

// Daily ATR for the target-hierarchy ATR fallback (intraday-scaled at 0.5×
// because daily ATR is too wide for a single-session target).
atr_d_raw = request.security(syminfo.tickerid, "D", ta.atr(14)[1],
                             lookahead = barmerge.lookahead_on)
atr_d     = nz(atr_d_raw, close * 0.005)

// =====================================================================
// Gap-and-go detection (spec C1) — uses today_open + bar1_low
// =====================================================================
// today_open / bar1_low / first_bar_time are computed above (before
// build_payload_v2 so the payload can reference them). This block just
// builds the gap_context flag from those values.

// Gap-up + hold flags. gap_context true = use tight first-bar stop.
gap_up      = not na(today_open) and not na(pdh) and today_open >= pdh * 1.005
gap_held    = not na(bar1_low)   and not na(pdh) and bar1_low > pdh
gap_context = gap_up and gap_held

// =====================================================================
// Open-line state machine: lost / reclaimed / support-hold (one each per session)
// =====================================================================
// Three patterns we care about:
//   • open_lost        → bearish shift; was above open, then closed below
//   • open_reclaimed   → recovery; lost then came back above
//   • open_support_hold → defense; was above open, wicked DOWN to it, held
//                        without ever closing below. "From high to open and
//                        hold" — high-conviction strength signal (AVGO,
//                        ORCL-style trend day defenses).
//
// All three are one-shot per session (state vars reset at session open).
// Hold and reclaim are mutually exclusive: once we've closed below open,
// hold is blocked (it's a reclaim play now, not a hold).
//
// Routing:
//   open_reclaimed     → BUY on every symbol
//   open_support_hold  → BUY on every symbol (same strength bucket)
//   open_lost          → NOTICE on SPY/QQQ/AIQ/NDX only (bearish info)
var bool ol_was_above_open       = false
var bool ol_lost_today           = false
var bool ol_reclaimed_today      = false
var bool ol_held_today           = false

if session_open_now
    ol_was_above_open       := false
    ol_lost_today           := false
    ol_reclaimed_today      := false
    ol_held_today           := false

if not na(today_open) and close > today_open
    ol_was_above_open := true

ol_just_lost      = ol_was_above_open and not ol_lost_today and not na(today_open) and not na(close[1]) and close < today_open and close[1] >= today_open
// open_reclaimed: not gated by ol_reclaimed_today anymore — Pine fires
// on every fresh lose-and-reclaim cycle. Backend applies a 90-min rolling
// dedup so chop within the same hour collapses to one alert, but a true
// second lose-reclaim cycle later in the session (e.g., morning reclaim
// → lunch shakeout → afternoon re-reclaim) gets its own alert.
ol_just_reclaimed = ol_lost_today and not na(today_open) and not na(close[1]) and close > today_open and close[1] <= today_open

// open_support_hold: defended the open from above without ever closing
// below. Pattern: was above earlier, current bar wicks DOWN to within
// 0.2% of today_open, closes back above on a green bar. Mutually
// exclusive with reclaim — once ol_lost_today is true, hold is blocked.
open_hold_tol_pct = 0.002  // 0.2% — wicks within this band count as a test
ol_just_held = ol_was_above_open and not ol_lost_today and not ol_held_today and not na(today_open) and low <= today_open * (1.0 + open_hold_tol_pct) and close > today_open and close > open

if ol_just_lost
    ol_lost_today := true
if ol_just_reclaimed
    // Re-arm: reset ol_lost_today so a subsequent lose-reclaim cycle can
    // fire later in the session. Pair with backend 90-min dedup window
    // so we don't get spammed by rapid chop.
    ol_lost_today      := false
    ol_reclaimed_today := true
if ol_just_held
    ol_held_today := true

// =====================================================================
// Target hierarchy helpers (spec C4)
// =====================================================================
// Walk: structural overhead/support → next round number → 0.5× daily ATR
// extension → 0.75% floor. Always returns a target at least 0.5% from
// entry (so tight-stop alerts don't get tight targets too).

next_round_above(float p) =>
    incr = p > 200 ? 5.0 : (p > 50 ? 1.0 : 0.5)
    math.ceil(p / incr) * incr

next_round_below(float p) =>
    incr = p > 200 ? 5.0 : (p > 50 ? 1.0 : 0.5)
    math.floor(p / incr) * incr

// Closest valid level above entry within 3% (na if none).
nearest_above(float e, float l1, float l2) =>
    a1 = not na(l1) and l1 > e and (l1 - e) / e <= 0.03 ? l1 : 9.0e15
    a2 = not na(l2) and l2 > e and (l2 - e) / e <= 0.03 ? l2 : 9.0e15
    r  = math.min(a1, a2)
    r == 9.0e15 ? float(na) : r

nearest_below(float e, float l1, float l2) =>
    a1 = not na(l1) and l1 < e and (e - l1) / e <= 0.03 ? l1 : -9.0e15
    a2 = not na(l2) and l2 < e and (e - l2) / e <= 0.03 ? l2 : -9.0e15
    r  = math.max(a1, a2)
    r == -9.0e15 ? float(na) : r

t1_long_hier(float e, float l1, float l2, float atr_daily) =>
    s = nearest_above(e, l1, l2)
    not na(s) ? s :
      next_round_above(e) > e * 1.005 ? next_round_above(e) :
      e + atr_daily * 0.5 > e * 1.005 ? e + atr_daily * 0.5 :
      e * 1.0075

t1_short_hier(float e, float l1, float l2, float atr_daily) =>
    s = nearest_below(e, l1, l2)
    not na(s) ? s :
      next_round_below(e) < e * 0.995 ? next_round_below(e) :
      e - atr_daily * 0.5 < e * 0.995 ? e - atr_daily * 0.5 :
      e * 0.9925

t2_extend_long(float e, float t1)  => math.max(t1 + (t1 - e) * 0.5, t1 * 1.005)
t2_extend_short(float e, float t1) => math.min(t1 - (e - t1) * 0.5, t1 * 0.995)

// LONG alerts pass bearish_div (price up, CVD lagging = bad for longs)
// SHORT alerts pass bullish_div (price down, CVD lifting = bad for shorts)
//
// Alert frequency (2026-05-04 v2): all alerts fire on bar close. Intra-bar
// firing was tried but rejected — wick-fakeouts on PDH/PDL crosses caused
// false entries that close-confirmation prevents. Use a 10m chart TF on
// the TV alert side for faster delivery (10min close beats 15min close
// for entry timing) without sacrificing the close-confirmation guarantee.
//
// Stop sizing notes:
//   • staged_pdh_break — gap_context=true means use first-10min-bar low as
//     stop (tight, ~1-2%) instead of yesterday's swing. Without gap context,
//     fall back to the prior `pdh - atr_buffer` logic.
//   • staged_pdh_rejection — stop above the rejection wick.
//   • staged_pdl_break — stop just above the broken level.
//   • staged_pdl_reclaim — stop at the sweep low (current bar's low).
//
// Target sizing: t1_long_hier / t1_short_hier walks structural → round →
// ATR/2 → 0.75% floor. For LONG breakout (pdh_break), candidates are
// PWH first then n/a — round/ATR fallback handles ATH cases. For LONG
// reclaim (pdl_reclaim), candidates are PDH then PWH (further out).
if pdh_break
    e   = close
    s_default = broken_resistance - atr_buffer
    s   = gap_context and not na(bar1_low) ? bar1_low - atr_buffer * 0.5 : s_default
    t1  = t1_long_hier(e, pwh, pmh, atr_d)
    t2  = t2_extend_long(e, t1)
    tf  = level_tf(broken_resistance, pdh, pwh, pmh)
    dir = dir_for_tf(tf, "BUY")
    alert(build_payload_v2("staged_pdh_break", dir, e, s, t1, t2,
                           gap_context, confluence_resistance,
                           volume_ratio, cvd_slope_n, bearish_div),
          alert.freq_once_per_bar_close)
if pdh_rejection
    e   = close
    s   = high + atr_buffer
    t1_a = not na(vwap_v) and vwap_v < e ? vwap_v : pdl
    t1  = na(t1_a) ? t1_short_hier(e, pdl, pwl, atr_d) : t1_a
    t2  = t2_extend_short(e, t1)
    tf  = level_tf(rejected_resistance, pdh, pwh, pmh)
    dir = dir_for_tf(tf, "SHORT")
    alert(build_payload_v2("staged_pdh_rejection", dir, e, s, t1, t2,
                           false, confluence_rej,
                           volume_ratio, cvd_slope_n, bullish_div),
          alert.freq_once_per_bar_close)
if sweep_reversal_short
    e   = close
    s   = math.max(high, high[1]) + atr_buffer
    t1_a = not na(vwap_v) and vwap_v < e ? vwap_v : pdl
    t1  = na(t1_a) ? t1_short_hier(e, pdl, pwl, atr_d) : t1_a
    t2  = t2_extend_short(e, t1)
    tf  = level_tf(failed_resistance, pdh, pwh, pmh)
    dir = dir_for_tf(tf, "SHORT")
    alert(build_payload_v2("staged_pdh_failed_short", dir, e, s, t1, t2,
                           false, confluence_failed,
                           volume_ratio, cvd_slope_n, bullish_div),
          alert.freq_once_per_bar_close)
if pdl_break
    e   = close
    s   = broken_support + atr_buffer
    t1  = t1_short_hier(e, pwl, pml, atr_d)
    t2  = t2_extend_short(e, t1)
    tf  = level_tf(broken_support, pdl, pwl, pml)
    dir = dir_for_tf(tf, "SHORT")
    alert(build_payload_v2("staged_pdl_break", dir, e, s, t1, t2,
                           false, confluence_brk_sup,
                           volume_ratio, cvd_slope_n, bullish_div),
          alert.freq_once_per_bar_close)
if pdl_reclaim
    e   = close
    s   = low - atr_buffer
    t1_struct = nearest_above(e, pdh, pwh)
    t1 = not na(t1_struct) ? t1_struct : t1_long_hier(e, pdh, pmh, atr_d)
    t2 = not na(pwh) and pwh > t1 ? pwh : (not na(pmh) and pmh > t1 ? pmh : t2_extend_long(e, t1))
    tf  = level_tf(reclaimed_support, pdl, pwl, pml)
    dir = dir_for_tf(tf, "BUY")
    alert(build_payload_v2("staged_pdl_reclaim", dir, e, s, t1, t2,
                           false, confluence_support,
                           volume_ratio, cvd_slope_n, bearish_div),
          alert.freq_once_per_bar_close)

// =====================================================================
// Open-line alert fires — open_lost (NOTICE, index only) +
// open_reclaimed (BUY, all symbols)
// =====================================================================
// Stops/targets sized in-line: open_lost is small projected drawdown
// (NOTICE), open_reclaimed is standard long-side projection. The triage
// agent re-ranks based on confluence. near_pdh / near_pdl flags ride on
// build_payload_v2 so the webhook can collapse confluence twins.
if fire_open_alerts and ol_just_lost and is_macro_symbol
    e  = close
    s  = math.max(high, high[1]) + atr_buffer
    t1 = e * 0.9925
    t2 = e * 0.985
    alert(build_payload_v2("open_lost", "NOTICE", e, s, t1, t2,
                           false, 1,
                           volume_ratio, cvd_slope_n, bullish_div),
          alert.freq_once_per_bar_close)

if fire_open_alerts and ol_just_reclaimed
    e  = close
    s  = math.min(low, low[1]) - atr_buffer
    t1 = e * 1.0075
    t2 = e * 1.015
    alert(build_payload_v2("open_reclaimed", "BUY", e, s, t1, t2,
                           false, 1,
                           volume_ratio, cvd_slope_n, bearish_div),
          alert.freq_once_per_bar_close)

// open_support_hold — defended open from above (no close-below). BUY on
// every symbol. Stop is tight, just below today_open (we entered right at
// the defended line).
if fire_open_alerts and ol_just_held
    e  = close
    s  = today_open - atr_buffer
    t1 = e * 1.0075
    t2 = e * 1.015
    alert(build_payload_v2("open_support_hold", "BUY", e, s, t1, t2,
                           false, 1,
                           volume_ratio, cvd_slope_n, bearish_div),
          alert.freq_once_per_bar_close)

// =====================================================================
// VWAP reclaim → PDH (LONG) / VWAP reject → PDL (SHORT)
// =====================================================================
// Earlier-entry setup than PDH/PDL break — when price closes back above
// VWAP after N consecutive bars below, PDH becomes a clean structural
// target. R:R is materially better than waiting for PDH break (entry at
// the level being defended, not at the breakout).
//
// Skip if already past the target (above PDH for longs, below PDL for
// shorts) — no clean target overhead/below in those cases.
//
// Backend dedup (30 min, 0.5%, direction-aware) handles same-direction
// re-fires from VWAP whipsaw. State machine here only checks the "wrong
// side first" precondition.
//
// Helper: true if all of the last `n` bars closed strictly below VWAP.
all_closes_below_vwap(int n) =>
    result = true
    for i = 1 to n
        if na(vwap_v[i]) or close[i] >= vwap_v[i]
            result := false
    result

all_closes_above_vwap(int n) =>
    result = true
    for i = 1 to n
        if na(vwap_v[i]) or close[i] <= vwap_v[i]
            result := false
    result

was_below_vwap = all_closes_below_vwap(vwap_setup_bars)
was_above_vwap = all_closes_above_vwap(vwap_setup_bars)

vwap_reclaim_long = not na(vwap_v) and not na(pdh) and was_below_vwap and close > vwap_v and close > open and close < pdh
vwap_reject_short = not na(vwap_v) and not na(pdl) and was_above_vwap and close < vwap_v and close < open and close > pdl

// VWAP support hold — price was above VWAP for `vwap_setup_bars` consecutive
// bars, then wicked DOWN to/through VWAP on this bar, but closed back above
// on a green bar. "VWAP defended" — bullish continuation context for SPY-like
// trend days where VWAP is the live institutional reference. NOTICE only.
// vwap_tolerance: how close the wick has to come to VWAP to count as a test.
vwap_tolerance_pct = 0.001  // 0.1% — tight test, not just "in the area"
vwap_support_hold = not na(vwap_v) and was_above_vwap and low <= vwap_v * (1.0 + vwap_tolerance_pct) and close > vwap_v and close > open

// Visual markers
plotshape(show_signals and vwap_reclaim_long,
          title = "VWAP reclaim LONG", location = location.belowbar,
          color = color.new(#00BCD4, 0), style = shape.triangleup,
          size = size.small)
plotshape(show_signals and vwap_support_hold,
          title = "VWAP support HOLD", location = location.belowbar,
          color = color.new(#9C27B0, 0), style = shape.circle,
          size = size.small)
plotshape(show_signals and vwap_reject_short,
          title = "VWAP reject SHORT", location = location.abovebar,
          color = color.new(#E91E63, 0), style = shape.triangledown,
          size = size.small)

if show_signals and vwap_reclaim_long
    label.new(bar_index, low, "VWAP→PDH",
              style = label.style_label_up,
              color = color.new(#00BCD4, 0),
              textcolor = color.white,
              size = size.tiny,
              yloc = yloc.belowbar)
if show_signals and vwap_support_hold
    label.new(bar_index, low, "VWAP HOLD",
              style = label.style_label_up,
              color = color.new(#9C27B0, 0),
              textcolor = color.white,
              size = size.tiny,
              yloc = yloc.belowbar)
if show_signals and vwap_reject_short
    label.new(bar_index, high, "VWAP→PDL",
              style = label.style_label_down,
              color = color.new(#E91E63, 0),
              textcolor = color.white,
              size = size.tiny,
              yloc = yloc.abovebar)

// VWAP alerts — gated to SPY / QQQ only.
//
// VWAP as a level matters most as an INSTITUTIONAL REFERENCE on the index
// ETFs (SPY/QQQ). On individual stocks, VWAP is noisy and the alerts
// aren't actionable — most stocks oscillate around VWAP without it being
// a meaningful structural level. Hardcoding the macro-symbol filter at
// the Pine level so alerts don't fire on unintended charts even if a
// user accidentally toggles `fire_vwap_alerts=true`.
//
// The visual VWAP line + markers still paint on any chart (useful as
// context). Only the alert() calls are restricted.
// (is_macro_symbol declared near top, alongside fire_vwap_alerts input)

if fire_vwap_alerts and is_macro_symbol and vwap_reclaim_long
    e = close
    s = math.min(low, low[1]) - atr_buffer
    t1 = pdh
    t2 = pdh + (pdh - e) * 0.5
    msg_vwap_long = build_payload_v2("vwap_reclaim_long", "NOTICE", e, s, t1, t2,
                                     false, 1,
                                     volume_ratio, cvd_slope_n, bearish_div)
    alert(msg_vwap_long, alert.freq_once_per_bar_close)

if fire_vwap_alerts and is_macro_symbol and vwap_reject_short
    e = close
    s = math.max(high, high[1]) + atr_buffer
    t1 = pdl
    t2 = pdl - (e - pdl) * 0.5
    msg_vwap_short = build_payload_v2("vwap_reject_short", "NOTICE", e, s, t1, t2,
                                      false, 1,
                                      volume_ratio, cvd_slope_n, bullish_div)
    alert(msg_vwap_short, alert.freq_once_per_bar_close)

// VWAP support hold — defended pullback to VWAP, NOTICE only. Stop below
// the wick low of the holding bar; T1 = next overhead (PDH); T2 = PDH +
// projection. Most useful on SPY 10m chart: when SPY's VWAP holds during
// a pullback, the broader long bias for the day is intact.
if fire_vwap_alerts and is_macro_symbol and vwap_support_hold
    e = close
    s = low - atr_buffer
    t1 = pdh
    t2 = not na(pdh) ? pdh + (pdh - e) * 0.5 : e * 1.005
    msg_vwap_hold = build_payload_v2("vwap_support_hold", "NOTICE", e, s, t1, t2,
                                     false, 1,
                                     volume_ratio, cvd_slope_n, bearish_div)
    alert(msg_vwap_hold, alert.freq_once_per_bar_close)

// vwap_lose_short was added briefly 2026-05-05 and removed same day.
// AAPL 1h chart showed 7 LOSE VWAP labels in a single session because
// candle bodies routinely brush VWAP in chop. Single bar-close cross
// without setup_bars confirmation is too noisy to be tradeable; the
// existing vwap_reject_short already covers the actionable case (price
// rejecting VWAP from below after `vwap_setup_bars` consecutive bars).
// SPY short remains gated on staged_pdh_rejection / staged_pdl_break /
// vwap_reject_short — no behaviour lost.

// PWH/PWL/PMH/PML events have been UNIFIED into the daily PDH/PDL events
// above (see `lowest_res_just_broken` / `highest_sup_just_reclaimed`
// helpers). Per user direction 2026-05-06: "treat all levels as same —
// if PWL holds it's support too." A reclaim of any of {PDL, PWL, PML}
// fires the existing `staged_pdl_reclaim` alert with the highest reclaimed
// level as stop reference. Same for the other 3 events. PWH/PWL/PMH/PML
// remain visible on chart as datapoints but no longer emit separate alerts.
