// @version=5
// Swing seed — RSI-oversold reclaim. The ONE live alert kept from the old levels-day-vwap
// pine; ALL the day-trade level machinery (PDH/PDL/PWH/PMH staged, gaps, breaks, index
// shorts, AVWAP, weekly-stage) moved to rc.pine or was retired (2026-07-12). This is the
// clean BASE for the swing / long-term pine — it'll be renamed + extended when we build
// swing. rsi_oversold stays here.
//
// rsi_oversold: BUY when the DAILY RSI(14) first ENTERS the 30-35 band (was outside last
// bar) — the "turn is coming" oversold-reclaim zone (never below 30). Fires intraday, once
// per day. Context: T1 = RSI 50, T2 = RSI 70, stop = a daily close back under RSI 30.
indicator("levels-day-vwap", overlay = true)

fire_swing = input.bool(true, "Fire swing RSI-oversold alerts (daily RSI 30-35 reclaim zone)", group = "Swing")

// Daily RSI(14) entering the 30-35 band — computed on the DAILY, read intraday.
f_swing() =>
    _r   = ta.rsi(close, 14)
    _inz = (_r >= 30.0) and (_r <= 35.0)
    _inz and not _inz[1]
sw_os = request.security(syminfo.tickerid, "D", f_swing(), lookahead = barmerge.lookahead_off)

// Once per session.
var bool sw_os_done = false
if ta.change(time("D")) != 0
    sw_os_done := false

if fire_swing and sw_os and not sw_os_done
    sw_os_done := true
    swp = '{"symbol":"' + syminfo.ticker + '","price":"' + str.tostring(close, format.mintick) + '","rule":"rsi_oversold","direction":"BUY","interval":"D","entry":"' + str.tostring(close, format.mintick) + '","note":"RSI oversold buy zone — daily RSI in 30-35 (reclaim/hold, never below 30). T1 RSI 50, T2 RSI 70. STOP = daily close back under RSI 30","fired_at":"' + str.tostring(timenow) + '"}'
    alert(swp, alert.freq_once_per_bar_close)
