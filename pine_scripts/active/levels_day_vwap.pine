// @version=5
//
// Prior Day Levels (Staged) v2 — Phase A order-flow additions.
//
// Identical to `prior_day_levels_staged.pine` (same 4 alerts, same stage
// detection, same structural stops) plus three new payload fields:
//
//   • volume_ratio   — fire-bar volume / N-bar average (1.0 = avg, 1.5 = 50% above)
//   • cvd_delta      — CVD change over lookback (positive = aggressive buying)
//   • cvd_diverging  — true if price/CVD direction conflicts (bearish div on
//                      LONGs, bullish div on SHORTs)
//
// CVD is approximated from candle structure (close near high = aggressive
// buy proxy). Pine has no native bid/ask classification for non-futures.
// Magnitude is approximate; direction and divergence are reliable.
//
// Backend uses these to DEGRADE conviction (not mute) and surface explicit
// warnings ("⚠️ low volume", "⚠️ CVD diverging") in Telegram. v1 still
// works unchanged — backend treats missing fields as neutral.
//
// Indicator name suffixed " v2" so TV treats it as a separate script slot —
// you can run both v1 and v2 side-by-side and compare.
//
indicator("levels-day-vwap", overlay = true)

show_lines        = input.bool(true,  "Show PDH/PDL lines")
show_level_labels = input.bool(true,  "Show PDH/PDL value labels at right edge")
show_midpoint     = input.bool(true,  "Show range midpoint line (gray dashed)")
// Open-line alerts re-enabled 2026-05-21. Pine fires all four; the backend
// alert_type_config table (Settings > Alert Types) decides which are delivered.
fire_open_alerts        = input.bool(true, "Fire open-line alerts (MASTER toggle — overrides per-type below)")
// Spec 58 (2026-05-22) — open-line entries RETIRED (FR-007). Defaults to
// false; the open-line plot is still drawn as a visual reference. Re-enable
// from indicator settings ONLY if you want to bring the alerts back.
fire_open_held          = input.bool(false, "  → open_held (retired — spec 58)", group = "Open-line per-type")
fire_open_wick_reclaim  = input.bool(false, "  → open_wick_reclaim (retired — spec 58)", group = "Open-line per-type")
fire_open_reclaimed     = input.bool(false, "  → open_reclaimed (retired — spec 58)", group = "Open-line per-type")
fire_open_lost          = input.bool(false, "  → open_lost (retired — spec 58)", group = "Open-line per-type")
show_signals      = input.bool(true,  "Show LONG/SHORT entry markers")
show_sweep        = input.bool(true,  "Show SWEEP composite markers")
show_vwap         = input.bool(true,  "Show VWAP")
// Day-type badge / SPY regime banner removed 2026-05-23 — visual clutter,
// not actionable. The underlying day_text / spy_line / sym_line / day_bg
// state computations below are kept as dead code (they don't fire any
// alerts) in case the banner is wanted back later.
ema_proximity_pct  = input.float(0.3,  "EMA proximity threshold (%) — flag as 'at EMA' if within", minval = 0.1, maxval = 2.0, step = 0.1)
fire_vwap_alerts  = input.bool(false, "Fire VWAP reclaim/reject/support alerts (NOTICE — SPY/QQQ only; ignored on other symbols)")
// HTF level alerts (2026-05-16) — hold/wick-reclaim per HTF level + proximity NOTICE.
// Re-enabled 2026-05-20 (S1) — the 8 hold/wick alerts now COLLAPSE to one
// `htf_support_held` BUY and the 4 proximity NOTICEs to one `htf_proximity`,
// so re-enabling no longer means chop-day spam. See collapse block below.
fire_htf_alerts   = input.bool(true,  "Fire HTF level alerts (collapsed: htf_support_held + htf_proximity)")
// HTF staged alerts — when a WEEKLY or MONTHLY level is broken or reclaimed,
// the `pdh_break` / `pdl_reclaim` / etc. blocks emit `staged_pwh_break` /
// `staged_pml_reclaim` / etc. via tf_high_prefix().
// Re-enabled 2026-05-20 (S1 item 2): with S0 position-relative direction
// now correct, W/M crossings are structurally-significant low-frequency
// events, not noise — a weekly/monthly level only gets crossed occasionally.
fire_htf_staged   = input.bool(true,  "Fire HTF staged break/reclaim alerts (PWH/PWL/PMH/PML break/rejection/reclaim)")
htf_proximity_pct = input.float(0.5,  "HTF proximity threshold (%)", minval = 0.1, maxval = 2.0, step = 0.1)
htf_test_tol_pct  = input.float(0.2,  "HTF hold tolerance (%)",      minval = 0.05, maxval = 1.0, step = 0.05)
// Note: macro-symbol gate is shared across VWAP alerts and the
// failed-PDH session window expansion. Open-line alerts live in the
// separate `open-line` indicator.
is_macro_symbol   = syminfo.ticker == "SPY" or syminfo.ticker == "QQQ" or syminfo.ticker == "AIQ" or syminfo.ticker == "NDX"
sweep_window_bars = input.int (5,     "Sweep window (bars)", minval = 1, maxval = 10)
atr_buffer_mult   = input.float(0.3,  "ATR buffer for stops (× ATR14)", minval = 0.1, maxval = 2.0, step = 0.1)
vwap_lookback     = input.int (20,    "VWAP slope lookback (bars)", minval = 5, maxval = 60)
vwap_slope_thresh = input.float(0.1,  "VWAP slope threshold (%)", minval = 0.01, maxval = 1.0, step = 0.01)
vol_avg_lookback  = input.int (20,    "Volume average lookback (bars)", minval = 5, maxval = 60)
cvd_lookback      = input.int (10,    "CVD divergence lookback (bars)", minval = 3, maxval = 30)
vwap_setup_bars   = input.int (3,     "VWAP setup: bars on wrong side before reclaim/reject fires", minval = 1, maxval = 10)

// Spec 60 — v2 break rule inputs (single-bar break with confluence) ----------
fire_break_v2     = input.bool (true,  "Fire v2 break rules (PDH/PWH/PMH break with VWAP+vol confluence)", group = "Quality v2 — breaks")
v2_break_vol_min  = input.float(2.0,   "v2 break: minimum volume_ratio",  minval = 1.0, maxval = 5.0, step = 0.1, group = "Quality v2 — breaks")
v2_break_slope_min = input.float(0.05, "v2 break: minimum VWAP slope (%)", minval = -0.5, maxval = 1.0, step = 0.01, group = "Quality v2 — breaks")
fire_gap_up_v2    = input.bool (true,  "Fire v2 gap_up_continuation_long (opened above PDH, makes HH)", group = "Quality v2 — gap-up")
v2_gap_vol_min    = input.float(1.5,   "v2 gap: minimum volume_ratio",     minval = 0.5, maxval = 5.0, step = 0.1, group = "Quality v2 — gap-up")

// =====================================================================
// PDH / PDL
// =====================================================================
[pdh, pdl] = request.security(syminfo.tickerid, "D", [high[1], low[1]],
                              lookahead = barmerge.lookahead_on)

// PDH/PDL: thick blue straight lines (no breaks). User preference —
// keeps the chart visually consistent: blue = key prior-day level.
plot(show_lines ? pdh : na, title = "PDH",
     color = color.new(color.blue, 0), style = plot.style_line, linewidth = 4)
plot(show_lines ? pdl : na, title = "PDL",
     color = color.new(color.blue, 0), style = plot.style_line, linewidth = 4)

// Right-edge value labels for PDH/PDL — same pattern as the HTF labels
// in levels-week-month. Floating "PDH 411.84" / "PDL 405.11" at the
// right end of each line so the level is readable mid-trade without
// hovering on the price axis. Var refs persist across bars; we redraw
// on the last bar only.
var label lb_pdh_v = na
var label lb_pdl_v = na
if barstate.islast
    label.delete(lb_pdh_v)
    label.delete(lb_pdl_v)
    if show_lines and show_level_labels and not na(pdh)
        lb_pdh_v := label.new(bar_index, pdh, text = "PDH " + str.tostring(pdh, format.mintick), color = color.new(color.blue, 25), textcolor = color.new(color.white, 0), style = label.style_label_left, size = size.small)
    if show_lines and show_level_labels and not na(pdl)
        lb_pdl_v := label.new(bar_index, pdl, text = "PDL " + str.tostring(pdl, format.mintick), color = color.new(color.blue, 25), textcolor = color.new(color.white, 0), style = label.style_label_left, size = size.small)

// =====================================================================
// PWH/PWL + PMH/PML — fetched silently (NOT plotted here)
// =====================================================================
// Per 2026-05-06 unification, these levels participate in the same alert
// events as PDH/PDL (a PWL reclaim fires `staged_pdl_reclaim`, etc.) and
// feed the confluence count + T1/T2 target hierarchy. Visual plots live
// in the `levels-week-month` indicator so users can toggle the higher-TF
// lines off without affecting alert quality.
// =====================================================================
[pwh, pwl] = request.security(syminfo.tickerid, "W", [high[1], low[1]],
                              lookahead = barmerge.lookahead_on)
[pmh, pml] = request.security(syminfo.tickerid, "M", [high[1], low[1]],
                              lookahead = barmerge.lookahead_on)

// =====================================================================
// Spec 58 (2026-05-22) — uptrend gate + nearby levels + MTD AVWAP
// =====================================================================
// Mirrors the same computation in ma_ema_daily.pine so the new pdh_held /
// pwh_held / pmh_held entry alerts can carry the spec-58 payload fields
// (uptrend_pass, overhead_mas, nearby_levels, mtd_avwap). The backend
// uptrend gate enforces FR-001/FR-003 against `uptrend_pass=false`.
// Names suffixed `_d` (daily) and `_58` (spec 58) to avoid collisions with
// the file's existing pwh_held_fired / pwh_was_above HTF logic.
ema8_d   = request.security(syminfo.tickerid, "D", ta.ema(close, 8)[1],   lookahead = barmerge.lookahead_on)
ema21_d  = request.security(syminfo.tickerid, "D", ta.ema(close, 21)[1],  lookahead = barmerge.lookahead_on)
ema50_d  = request.security(syminfo.tickerid, "D", ta.ema(close, 50)[1],  lookahead = barmerge.lookahead_on)
ema100_d = request.security(syminfo.tickerid, "D", ta.ema(close, 100)[1], lookahead = barmerge.lookahead_on)
ema200_d = request.security(syminfo.tickerid, "D", ta.ema(close, 200)[1], lookahead = barmerge.lookahead_on)
sma50_d  = request.security(syminfo.tickerid, "D", ta.sma(close, 50)[1],  lookahead = barmerge.lookahead_on)
sma100_d = request.security(syminfo.tickerid, "D", ta.sma(close, 100)[1], lookahead = barmerge.lookahead_on)
sma200_d = request.security(syminfo.tickerid, "D", ta.sma(close, 200)[1], lookahead = barmerge.lookahead_on)

// Spec L (2026-06-19) — daily RSI(14) carried in every payload as the day/swing
// classification input + the Case-B momentum-target reference (RSI 70/80). lookahead_off
// so it's the live developing-day RSI at fire time (matches the swing book's f_swing).
rsi_d = request.security(syminfo.tickerid, "D", ta.rsi(close, 14), lookahead = barmerge.lookahead_off)

uptrend_pass_58 = close > nz(ema8_d, 1e9) and close > nz(ema21_d, 1e9) and close > nz(ema50_d, 1e9) and close > nz(sma50_d, 1e9) and close > nz(ema100_d, 1e9) and close > nz(sma100_d, 1e9) and close > nz(ema200_d, 1e9) and close > nz(sma200_d, 1e9)

// Spec 61 — market-regime gate. The OPEN gate was REMOVED 2026-06-05: price
// shops around the open line all day (too noisy to gate on). PDL is now the
// ONLY gate — SPY breaking its PRIOR-DAY LOW is rare in a real uptrend, and
// when it does the broad tape is genuinely broken (e.g. 2026-06-05: SPY broke
// PDL and sold off to -2.2%). The backend HARD-BLOCKS every buy when
// spy_above_pdl=false; self-healing (two closes back above PDL re-enables).
// Carried in every payload (build_payload_v2).
spy_close_61 = request.security("SPY", timeframe.period, close)
spy_pdl_61   = request.security("SPY", "D", low[1], lookahead = barmerge.lookahead_on)
spy_below_pdl_now  = (not na(spy_pdl_61)) and (not na(spy_close_61)) and spy_close_61 < spy_pdl_61
spy_below_pdl_prev = (not na(spy_pdl_61)) and (not na(spy_close_61[1])) and spy_close_61[1] < spy_pdl_61
spy_above_pdl_61   = not (spy_below_pdl_now or spy_below_pdl_prev)

overhead_mas_str_58 = (close < nz(ema8_d, -1e9) ? "EMA 8," : "") + (close < nz(ema21_d, -1e9) ? "EMA 21," : "") + (close < nz(ema50_d, -1e9) ? "EMA 50," : "") + (close < nz(sma50_d, -1e9) ? "SMA 50," : "") + (close < nz(ema100_d, -1e9) ? "EMA 100," : "") + (close < nz(sma100_d, -1e9) ? "SMA 100," : "") + (close < nz(ema200_d, -1e9) ? "EMA 200," : "") + (close < nz(sma200_d, -1e9) ? "SMA 200," : "")

// Monthly anchored VWAPs — MTD + PM (prior month) + -2M (2 months prior).
// Rolling-shift pattern: on each new month the accumulators shift down
//   (PM becomes -2M, MTD becomes PM, MTD restarts), then ALL three keep
//   accumulating the new bar going forward. So PM AVWAP = "anchored to
//   the 1st of last month, continues through today" — matches the
//   anchored_vwap_manual.pine visual exactly.
var float mtd_pv_58  = 0.0
var float mtd_vv_58  = 0.0
var float pm_pv_58   = 0.0
var float pm_vv_58   = 0.0
var float p2m_pv_58  = 0.0
var float p2m_vv_58  = 0.0
if month != nz(month[1], month)
    p2m_pv_58 := pm_pv_58
    p2m_vv_58 := pm_vv_58
    pm_pv_58  := mtd_pv_58
    pm_vv_58  := mtd_vv_58
    mtd_pv_58 := nz(hlc3 * volume, 0.0)
    mtd_vv_58 := nz(volume, 0.0)
    pm_pv_58  := pm_pv_58  + nz(hlc3 * volume, 0.0)
    pm_vv_58  := pm_vv_58  + nz(volume, 0.0)
    p2m_pv_58 := p2m_pv_58 + nz(hlc3 * volume, 0.0)
    p2m_vv_58 := p2m_vv_58 + nz(volume, 0.0)
else
    mtd_pv_58 := mtd_pv_58 + nz(hlc3 * volume, 0.0)
    mtd_vv_58 := mtd_vv_58 + nz(volume, 0.0)
    pm_pv_58  := pm_pv_58  + nz(hlc3 * volume, 0.0)
    pm_vv_58  := pm_vv_58  + nz(volume, 0.0)
    p2m_pv_58 := p2m_pv_58 + nz(hlc3 * volume, 0.0)
    p2m_vv_58 := p2m_vv_58 + nz(volume, 0.0)
mtd_avwap_58 = mtd_vv_58 > 0 ? mtd_pv_58 / mtd_vv_58 : na
pm_avwap_58  = pm_vv_58  > 0 ? pm_pv_58  / pm_vv_58  : na
p2m_avwap_58 = p2m_vv_58 > 0 ? p2m_pv_58 / p2m_vv_58 : na

// nearby_levels CSV — pipe between fields ("kind|value|label"), comma
// between entries. The backend adapter parses this for confluence detection.
nearby_parts_58 = array.new<string>()
if not na(ema8_d)
    array.push(nearby_parts_58, "ema8|" + str.tostring(ema8_d, "#.##") + "|EMA 8")
if not na(ema21_d)
    array.push(nearby_parts_58, "ema21|" + str.tostring(ema21_d, "#.##") + "|EMA 21")
if not na(ema50_d)
    array.push(nearby_parts_58, "ema50|" + str.tostring(ema50_d, "#.##") + "|EMA 50")
if not na(sma50_d)
    array.push(nearby_parts_58, "sma50|" + str.tostring(sma50_d, "#.##") + "|SMA 50")
if not na(ema100_d)
    array.push(nearby_parts_58, "ema100|" + str.tostring(ema100_d, "#.##") + "|EMA 100")
if not na(sma100_d)
    array.push(nearby_parts_58, "sma100|" + str.tostring(sma100_d, "#.##") + "|SMA 100")
if not na(ema200_d)
    array.push(nearby_parts_58, "ema200|" + str.tostring(ema200_d, "#.##") + "|EMA 200")
if not na(sma200_d)
    array.push(nearby_parts_58, "sma200|" + str.tostring(sma200_d, "#.##") + "|SMA 200")
if not na(pdh)
    array.push(nearby_parts_58, "pdh|" + str.tostring(pdh, "#.##") + "|PDH")
if not na(pdl)
    array.push(nearby_parts_58, "pdl|" + str.tostring(pdl, "#.##") + "|PDL")
if not na(pwh)
    array.push(nearby_parts_58, "pwh|" + str.tostring(pwh, "#.##") + "|PWH")
if not na(pwl)
    array.push(nearby_parts_58, "pwl|" + str.tostring(pwl, "#.##") + "|PWL")
if not na(pmh)
    array.push(nearby_parts_58, "pmh|" + str.tostring(pmh, "#.##") + "|PMH")
if not na(pml)
    array.push(nearby_parts_58, "pml|" + str.tostring(pml, "#.##") + "|PML")
if not na(mtd_avwap_58)
    array.push(nearby_parts_58, "mtd_avwap|" + str.tostring(mtd_avwap_58, "#.##") + "|MTD AVWAP")
nearby_levels_csv_58 = array.join(nearby_parts_58, ",")

// Spec 58 — Buy 2 prior-high held-from-above detection (FR-004/FR-005).
// Price was above the level on the prior bar, retraced to it intraday
// (low <= level), and closed back above it (close >= level). The held-
// from-above pattern. Distinct from staged_pwh_break/pmh_break (retired
// breakout-into-resistance) and from the existing htf_support_held (which
// uses a wider tolerance band and no uptrend gate).
// Issue #4 (2026-06-13) — OPEN-ABOVE only (mirror of the MA bounce). A "held"
// fires only when price is ESTABLISHED ABOVE the level (the bar OPENED above it
// = support), dipped to it, held. A rally UP into the level from below is
// resistance (a target), not a held. 2026-06-15: use the DAILY open (day_open),
// NOT the chart bar's open — on an intraday chart the bar-open lets a break-up-
// through-then-retest fire a false "held" (same root cause as the MA strict_long
// NVDA bug). The DAY must open above the level for it to be support.
day_open = request.security(syminfo.tickerid, "D", open, lookahead = barmerge.lookahead_off)
s58_pdh_held = not na(pdh) and day_open > pdh and low <= pdh and close >= pdh
s58_pwh_held = not na(pwh) and day_open > pwh and low <= pwh and close >= pwh
s58_pmh_held = not na(pmh) and day_open > pmh and low <= pmh and close >= pmh

// Spec 58 (2026-05-23) — symmetric low-held-from-above detection.
// Wick tested the prior low and closed back above without closing below
// it. ETH on 2026-05-23 wicked PML 2016.5, bounced hard, never closed
// below — the existing pml_reclaim doesn't fire (needs a close-below
// first), but the wick-and-hold is a real event the trader wants to take.
// Strict touch: low <= level. No tolerance noise. If the level fails on
// a future bar, the existing _reclaim/_break alerts cover the next event.
s58_pdl_held = not na(pdl) and day_open > pdl and low <= pdl and close >= pdl
s58_pwl_held = not na(pwl) and day_open > pwl and low <= pwl and close >= pwl
s58_pml_held = not na(pml) and day_open > pml and low <= pml and close >= pml

// Proximity bounce — fires when price comes NEAR the prior low without
// actually touching it, then closes green. HOOD 2026-06-02 example: PDL
// $87.45, bar low $88.67 (1.4% above) — never touched the level but the
// market clearly respected it. Strict held alerts miss this. Tolerance
// default 1.5% — tunable, errs wider since "near support that holds" is
// a real intraday pattern. Bar must close above where it opened to confirm
// the bounce, otherwise this is just "near a level and falling" which is
// not a setup.
// ATR-scaled band (was a fixed %, which was far too loose on low-vol names:
// 1.5% of SPY ≈ $11, wider than its whole daily range). 0.5× the symbol's
// DAILY ATR auto-tightens on SPY (~$3 ≈ 0.5%) and stays wide on ETH (~$30 ≈
// 1.5%) — one knob, no per-symbol tuning. atr_d is defined later, so the
// daily ATR is fetched here for the early proximity detectors.
proximity_atr_mult = input.float(0.5, "Proximity bounce: × daily ATR from prior low (near-support band)", minval=0.1, maxval=2.0, step=0.1, group="Proximity")
atr_prox_61  = nz(request.security(syminfo.tickerid, "D", ta.atr(14)[1], lookahead = barmerge.lookahead_on), close * 0.005)
prox_band_61 = proximity_atr_mult * atr_prox_61
s58_pdl_prox = not na(pdl) and not na(close[1]) and close[1] > pdl and low > pdl and low <= pdl + prox_band_61 and close > open
s58_pwl_prox = not na(pwl) and not na(close[1]) and close[1] > pwl and low > pwl and low <= pwl + prox_band_61 and close > open

// Spec 60 — v2 quality gates on *_held rules. Three layered structural
// checks applied to every held rule's firing condition below:
//   1. Close buffer ≥ 25 bps above the level — kills the "price oscillating
//      on the level" pattern (NFLX 86.33 → 86.34 today fired three times).
//   2. Bullish body — close > open AND body ≥ 40% of bar range. Catches
//      doji / distribution bars that technically meet the close ≥ level
//      condition but don't represent real defense (LITE 5.98× volume bar
//      today that "held" then dumped).
//   3. Close in upper half — (close - low) / (high - low) ≥ 0.5. Belt-and-
//      suspenders against weak closes on otherwise-valid candles.
v2_held_buffer_bps = input.float (25.0, "v2: minimum bps buffer above held level", minval = 5.0, maxval = 100.0, step = 5.0, group = "Quality v2")
v2_body_pct_min    = input.float (0.40, "v2: minimum bullish body as % of bar range", minval = 0.1, maxval = 0.9, step = 0.05, group = "Quality v2")
v2_held_gates_on   = input.bool  (true, "v2: apply quality gates to *_held rules", group = "Quality v2")

bar_rng = high - low
v2_body_ok = (not v2_held_gates_on) or (bar_rng > 0 and close > open and (close - open) / bar_rng >= v2_body_pct_min and (close - low) / bar_rng >= 0.5)
v2_buf_pdh = (not v2_held_gates_on) or (not na(pdh) and pdh > 0 and (close - pdh) / pdh * 10000 >= v2_held_buffer_bps)
v2_buf_pwh = (not v2_held_gates_on) or (not na(pwh) and pwh > 0 and (close - pwh) / pwh * 10000 >= v2_held_buffer_bps)
v2_buf_pmh = (not v2_held_gates_on) or (not na(pmh) and pmh > 0 and (close - pmh) / pmh * 10000 >= v2_held_buffer_bps)
v2_buf_pdl = (not v2_held_gates_on) or (not na(pdl) and pdl > 0 and (close - pdl) / pdl * 10000 >= v2_held_buffer_bps)
v2_buf_pwl = (not v2_held_gates_on) or (not na(pwl) and pwl > 0 and (close - pwl) / pwl * 10000 >= v2_held_buffer_bps)
v2_buf_pml = (not v2_held_gates_on) or (not na(pml) and pml > 0 and (close - pml) / pml * 10000 >= v2_held_buffer_bps)

// Apply combined gates to each held trigger. The held detector still
// computes the underlying pattern (used by visual markers); the alert-
// firing logic below ANDs the v2 gates on top.
s58_pdh_held_v2 = s58_pdh_held and v2_buf_pdh and v2_body_ok
s58_pwh_held_v2 = s58_pwh_held and v2_buf_pwh and v2_body_ok
s58_pmh_held_v2 = s58_pmh_held and v2_buf_pmh and v2_body_ok
s58_pdl_held_v2 = s58_pdl_held and v2_buf_pdl and v2_body_ok
s58_pwl_held_v2 = s58_pwl_held and v2_buf_pwl and v2_body_ok
s58_pml_held_v2 = s58_pml_held and v2_buf_pml and v2_body_ok

// Spec 58 (2026-05-23 evening) — monthly AVWAP defense detection.
// Combined trigger: EITHER wick-and-hold (price was at/above the AVWAP,
// wicked to it, closed above) OR lost-and-reclaim (price closed below
// the AVWAP on the prior bar, closed back above on this bar). Both are
// "the AVWAP was defended" — one alert per defense, regardless of path.
// Live validation 2026-05-23 on ETH MTD Apr $2,246.15 — price stalled
// exactly at that level after the PWL reclaim cascade.
s58_mtd_avwap_held = not na(mtd_avwap_58) and not na(close[1]) and ((close[1] >= mtd_avwap_58 and low <= mtd_avwap_58 and close >= mtd_avwap_58) or (close[1] < mtd_avwap_58 and close >= mtd_avwap_58))
s58_pm_avwap_held  = not na(pm_avwap_58)  and not na(close[1]) and ((close[1] >= pm_avwap_58  and low <= pm_avwap_58  and close >= pm_avwap_58)  or (close[1] < pm_avwap_58  and close >= pm_avwap_58))
s58_p2m_avwap_held = not na(p2m_avwap_58) and not na(close[1]) and ((close[1] >= p2m_avwap_58 and low <= p2m_avwap_58 and close >= p2m_avwap_58) or (close[1] < p2m_avwap_58 and close >= p2m_avwap_58))

// Spec 60 — v2 gates on AVWAP held rules (P2.6). The 2026-05-28 LITE case:
// MTD AVWAP "held" fired with 5.98× volume — looked great structurally —
// but LITE was in a daily downtrend and the bar was distribution, not
// defense. Stock dumped −4.62%. Two new gates fix this:
//   1. close > daily EMA21 — kills counter-trend AVWAP defenses where the
//      stock is in a clear daily downtrend.
//   2. Real bullish body (reuses v2_body_ok from above) — kills doji /
//      distribution bars that technically meet close ≥ level.
// Today's worked example: 3/3 winners retained (PLTR/MSFT/AMZN),
// 3/3 losers killed (LITE/GOOGL/AAOI). LITE killed by daily EMA21;
// GOOGL/AAOI killed by the basing-chop slope gate already in place.
v2_avwap_trend_ok = (not v2_held_gates_on) or (not na(ema21_d) and close > ema21_d)

s58_mtd_avwap_held_v2 = s58_mtd_avwap_held and v2_avwap_trend_ok and v2_body_ok
s58_pm_avwap_held_v2  = s58_pm_avwap_held  and v2_avwap_trend_ok and v2_body_ok
s58_p2m_avwap_held_v2 = s58_p2m_avwap_held and v2_avwap_trend_ok and v2_body_ok

// =====================================================================
// VWAP + slope
// =====================================================================
vwap_v    = ta.vwap(hlc3)
vwap_past = vwap_v[vwap_lookback]
vwap_slope_pct = not na(vwap_past) and vwap_past != 0 ? (vwap_v - vwap_past) / vwap_past * 100 : na

vwap_rising  = not na(vwap_slope_pct) and vwap_slope_pct >  vwap_slope_thresh
vwap_falling = not na(vwap_slope_pct) and vwap_slope_pct < -vwap_slope_thresh
vwap_flat    = not na(vwap_slope_pct) and not vwap_rising and not vwap_falling

// VWAP: thick purple straight line. Same visual weight as PDH/PDL so
// the three institutional reference lines read as a coherent set.
plot(show_vwap ? vwap_v : na, title = "VWAP",
     color = color.new(#9C27B0, 20), style = plot.style_line, linewidth = 4)

// =====================================================================
// Volume confirmation — fire-bar volume vs N-bar SMA
// =====================================================================
vol_avg = ta.sma(volume, vol_avg_lookback)
volume_ratio = vol_avg > 0 ? volume / vol_avg : na

// =====================================================================
// CVD (Cumulative Volume Delta) — candle-structure approximation
// close near high  → aggressive buying skew
// close near low   → aggressive selling skew
// Magnitude approximate; trend / divergence reliable.
// =====================================================================
bar_range = high - low
buy_vol  = bar_range > 0 ? ((close - low) / bar_range) * volume : volume * 0.5
sell_vol = bar_range > 0 ? ((high - close) / bar_range) * volume : volume * 0.5
delta_v = buy_vol - sell_vol
cvd     = ta.cum(delta_v)

cvd_past   = cvd[cvd_lookback]
price_past = close[cvd_lookback]
cvd_slope_n   = not na(cvd_past)   ? cvd - cvd_past     : na
price_slope_n = not na(price_past) ? close - price_past : na

// LONG entries care about bearish divergence: price up, CVD flat/down
bearish_div = not na(cvd_slope_n) and not na(price_slope_n) and price_slope_n > 0 and cvd_slope_n <= 0
// SHORT entries care about bullish divergence: price down, CVD flat/up
bullish_div = not na(cvd_slope_n) and not na(price_slope_n) and price_slope_n < 0 and cvd_slope_n >= 0

// =====================================================================
// STAGE DETECTION
// =====================================================================
above_pdh   = not na(pdh) and close > pdh
below_pdl   = not na(pdl) and close < pdl
in_range    = not na(pdh) and not na(pdl) and close >= pdl and close <= pdh
above_vwap  = not na(vwap_v) and close > vwap_v
below_vwap  = not na(vwap_v) and close < vwap_v

is_stage2 = above_pdh and vwap_rising  and above_vwap
is_stage4 = below_pdl and vwap_falling and below_vwap
is_stage3 = above_pdh and not is_stage2 and (vwap_flat or vwap_falling)
is_stage1 = in_range  and vwap_flat

string stage_text = "TRANSITIONING\nno clean regime\nHALF SIZE — sweeps only"
color  stage_bg   = color.new(color.purple, 30)
if na(vwap_slope_pct)
    stage_text := "INSUFFICIENT DATA\nVWAP loading\nWAIT for slope to settle"
    stage_bg   := color.new(color.gray, 30)
else if is_stage2
    stage_text := "STAGE 2: ADVANCING\nabove PDH + VWAP rising\nLONGS at PDH/VWAP pullbacks"
    stage_bg   := color.new(color.green, 10)
else if is_stage4
    stage_text := "STAGE 4: DECLINING\nbelow PDL + VWAP falling\nSHORTS at VWAP pops"
    stage_bg   := color.new(color.red, 10)
else if is_stage3
    stage_text := "STAGE 3: TOPPING\nabove PDH but VWAP rolling\nTRIM LONGS — fade rejects"
    stage_bg   := color.new(color.orange, 10)
else if is_stage1
    stage_text := "STAGE 1: BASING\ninside range + VWAP flat\nWAIT — sweeps only"
    stage_bg   := color.new(color.gray, 30)

// stage_text is still computed (used by stage_json in the alert payload —
// the triage agent uses it for scoring). It's no longer rendered as the
// chart badge — the day-type classification below replaces it for the
// visual since "GAP UP / INSIDE / TEST PDH" is more actionable than
// "STAGE 2 ADVANCING" for instinct trading.
//
// Stage / event bgcolor tints removed 2026-05-14 — user kept unchecking
// them in the Style tab. The plotshape markers (BREAK+, RECLAIM, REJECT,
// BREAK-, SWEEP+, SWEEP-) are sufficient visual cues for event firing.

// =====================================================================
// Level break / reject / reclaim — unified across daily/weekly/monthly
// =====================================================================
// User direction (2026-05-06): "treat all levels as same — if PWL holds
// it's support too." Expanded triggers fire on any of the three timeframe
// levels, but the existing event names (pdh_break, pdl_reclaim, etc) are
// preserved so already-bound TV alerts keep working.
//
// When multiple levels cross on the same bar (e.g. gap-up clears PDH and
// PWH together), we use the LEVEL CLOSEST TO PRIOR-BAR-CLOSE as the
// reference for stops — that's the level price actually defended/broke.

// Helpers — return the just-crossed level (na if no cross this bar).
// Lowest resistance just broken AND HELD: a level price has now closed above
// for 2 consecutive bars (and was at/below the bar before) — filters the
// single-bar poke that closes straight back through. na if no confirmed break.
lowest_res_just_broken() =>
    p_pdh = not na(pdh) and not na(close[2]) and close > pdh and close[1] > pdh and close[2] <= pdh ? pdh : 9.0e15
    p_pwh = not na(pwh) and not na(close[2]) and close > pwh and close[1] > pwh and close[2] <= pwh ? pwh : 9.0e15
    p_pmh = not na(pmh) and not na(close[2]) and close > pmh and close[1] > pmh and close[2] <= pmh ? pmh : 9.0e15
    m = math.min(p_pdh, math.min(p_pwh, p_pmh))
    m == 9.0e15 ? float(na) : m

// Highest support just reclaimed: highest level below prior close that's
// now above current close.
// DUAL-ROLE GUARD (#64 Sub-spec A, 2026-06-19): require day_open > level — a level is
// SUPPORT only if the day OPENED above it. A rally up INTO a level from below (day opened
// below it) is RESISTANCE, not a reclaim → no long. Mirrors s58_pdl_held. Fixes longs
// firing into resistance (the SPCX PDL case). Purely additive: only suppresses bad fires.
highest_sup_just_reclaimed() =>
    p_pdl = not na(pdl) and day_open > pdl and close > pdl and close[1] <= pdl ? pdl : -9.0e15
    p_pwl = not na(pwl) and day_open > pwl and close > pwl and close[1] <= pwl ? pwl : -9.0e15
    p_pml = not na(pml) and day_open > pml and close > pml and close[1] <= pml ? pml : -9.0e15
    m = math.max(p_pdl, math.max(p_pwl, p_pml))
    m == -9.0e15 ? float(na) : m

// Highest resistance just rejected: a LIQUIDITY GRAB above the level — wick
// pokes up THROUGH it (high >= level), closes back UNDER it on a RED bar. The
// `close < open` (2026-06-09) makes it a true down-bar, the exact mirror of the
// MA-bounce long (wick below support, close back above on a GREEN bar).
highest_res_just_rejected() =>
    p_pdh = not na(pdh) and high >= pdh and close < pdh and close < open and high[1] < pdh ? pdh : -9.0e15
    p_pwh = not na(pwh) and high >= pwh and close < pwh and close < open and high[1] < pwh ? pwh : -9.0e15
    p_pmh = not na(pmh) and high >= pmh and close < pmh and close < open and high[1] < pmh ? pmh : -9.0e15
    m = math.max(p_pdh, math.max(p_pwh, p_pmh))
    m == -9.0e15 ? float(na) : m

// Lowest support just broken: lowest level below prior close that's now broken below.
lowest_sup_just_broken() =>
    p_pdl = not na(pdl) and close < pdl and close[1] >= pdl ? pdl : 9.0e15
    p_pwl = not na(pwl) and close < pwl and close[1] >= pwl ? pwl : 9.0e15
    p_pml = not na(pml) and close < pml and close[1] >= pml ? pml : 9.0e15
    m = math.min(p_pdl, math.min(p_pwl, p_pml))
    m == 9.0e15 ? float(na) : m

broken_resistance   = lowest_res_just_broken()
reclaimed_support   = highest_sup_just_reclaimed()
rejected_resistance = highest_res_just_rejected()
broken_support      = lowest_sup_just_broken()

pdh_break     = not na(broken_resistance)
pdh_rejection = not na(rejected_resistance)
pdl_break     = not na(broken_support)
pdl_reclaim   = not na(reclaimed_support)

// =====================================================================
// Confluence count — how many of {PDH/PWH/PMH} or {PDL/PWL/PML} are
// stacked within 1% of the just-broken/reclaimed level. Higher count =
// more institutional memory at that price = stronger breakout/reclaim.
// User direction 2026-05-06: "the more convinced the better we are at
// executing." A 3-of-3 confluence break is materially higher conviction
// than a single-level break.
// =====================================================================
within_zone(float a, float b, float pct) =>
    not na(a) and not na(b) and math.abs(a - b) / b <= pct

confluence_count_at(float anchor, float l1, float l2, float l3) =>
    if na(anchor)
        0
    else
        c = 0
        // Anchor itself counts if it's one of the three
        if not na(l1) and l1 == anchor
            c := c + 1
        if not na(l2) and l2 == anchor
            c := c + 1
        if not na(l3) and l3 == anchor
            c := c + 1
        // Add levels within 1% that aren't the anchor itself
        if not na(l1) and l1 != anchor and within_zone(l1, anchor, 0.01)
            c := c + 1
        if not na(l2) and l2 != anchor and within_zone(l2, anchor, 0.01)
            c := c + 1
        if not na(l3) and l3 != anchor and within_zone(l3, anchor, 0.01)
            c := c + 1
        // Cap at 3 — anchor itself shouldn't double-count beyond its
        // membership in the level list
        math.min(c, 3)

confluence_resistance = confluence_count_at(broken_resistance, pdh, pwh, pmh)
confluence_support    = confluence_count_at(reclaimed_support, pdl, pwl, pml)
confluence_rej        = confluence_count_at(rejected_resistance, pdh, pwh, pmh)
confluence_brk_sup    = confluence_count_at(broken_support, pdl, pwl, pml)

// Failed breakout — price closed above a resistance level (PDH/PWH/PMH)
// and now closes back below it. Different from `_just_rejected` (wick
// test that never closed above). This is the trap pattern: breakout
// buyers above are now underwater and forced to cover.
// User 2026-05-07: "if SPY goes above PDH and then reverses below, that's
// a short signal." Adding as a new SHORT event.
highest_res_just_failed() =>
    p_pdh = not na(pdh) and close < pdh and close[1] > pdh ? pdh : -9.0e15
    p_pwh = not na(pwh) and close < pwh and close[1] > pwh ? pwh : -9.0e15
    p_pmh = not na(pmh) and close < pmh and close[1] > pmh ? pmh : -9.0e15
    m = math.max(p_pdh, math.max(p_pwh, p_pmh))
    m == -9.0e15 ? float(na) : m

failed_resistance = highest_res_just_failed()
confluence_failed = confluence_count_at(failed_resistance, pdh, pwh, pmh)

// =====================================================================
// Triggered-timeframe tag — D / W / M / "" (na)
// =====================================================================
// Identifies which TF actually triggered the break/reclaim/rejection by
// comparing the anchor price (broken_resistance / reclaimed_support /
// rejected_resistance / failed_resistance / broken_support) against the
// PDH/PWH/PMH or PDL/PWL/PML values. Daily wins ties (first match).
//
// Direction routing (2026-05-16): weekly/monthly level events now fire
// as BUY/SHORT (was NOTICE) — per user direction, HTF level breaks and
// reclaims are real actionable signals on all stocks, not just heads-up
// info. The TF tag is preserved in the alert payload so the Telegram
// label can read "PWH break ↑" / "PML reclaim ↑" instead of conflating
// with the daily PDH/PDL events.
level_tf(float lvl, float d, float w, float m) =>
    na(lvl) ? "" :
      not na(d) and lvl == d ? "D" :
      not na(w) and lvl == w ? "W" :
      not na(m) and lvl == m ? "M" : ""

// Direction picker: all timeframes use the actionable direction now.
// Triage / Telegram layer reads the TF tag from the payload to pick the
// right human label (PDH vs PWH vs PMH break, etc.).
dir_for_tf(string tf, string actionable_dir) =>
    actionable_dir

var int pdl_break_bar = na
var int pdh_break_bar = na
if pdl_break
    pdl_break_bar := bar_index
if pdh_break
    pdh_break_bar := bar_index

// pdh_failed now unified — fires on close-back-below ANY of PDH/PWH/PMH.
pdh_failed = not na(failed_resistance)

bars_since_pdl_break = na(pdl_break_bar) ? 9999 : bar_index - pdl_break_bar
bars_since_pdh_break = na(pdh_break_bar) ? 9999 : bar_index - pdh_break_bar

// Effective sweep window — SPY/QQQ use a session-wide window (200 bars,
// covers a full RTH session on any chart TF). For other symbols the
// configured window (default 5 bars) keeps the "quick trap" semantics.
// Rationale: SPY/QQQ failed-PDH reversals are macro-relevant whether
// they happen 5 bars after the break or 5 hours after — both are the
// same "the breakout failed" narrative for the index.
effective_sweep_window = is_macro_symbol ? 200 : sweep_window_bars
sweep_reclaim_long   = pdl_reclaim and bars_since_pdl_break <= effective_sweep_window
sweep_reversal_short = pdh_failed  and bars_since_pdh_break <= effective_sweep_window

sweep_active = sweep_reclaim_long or sweep_reversal_short

// (bgcolor() tints for PDH break / PDL reclaim / PDH rejection / PDL break /
// Sweep LONG / Sweep SHORT events removed 2026-05-14 — plotshape arrows
// below serve the same purpose without painting the whole bar background.)

plotshape(show_signals and pdh_break,
          title = "BREAK+ LONG", location = location.belowbar,
          color = color.new(color.green, 0), style = shape.triangleup,
          size = size.normal, text = "BREAK+", textcolor = color.white)
plotshape(show_signals and pdl_reclaim and not sweep_reclaim_long,
          title = "RECLAIM LONG", location = location.belowbar,
          color = color.new(color.aqua, 0), style = shape.triangleup,
          size = size.normal, text = "RECLAIM", textcolor = color.black)
plotshape(show_signals and pdh_rejection,
          title = "REJECT SHORT", location = location.abovebar,
          color = color.new(color.orange, 0), style = shape.triangledown,
          size = size.normal, text = "REJECT", textcolor = color.white)
plotshape(show_signals and pdl_break and not sweep_reversal_short,
          title = "BREAK- SHORT", location = location.abovebar,
          color = color.new(color.red, 0), style = shape.triangledown,
          size = size.normal, text = "BREAK-", textcolor = color.white)

plotshape(show_sweep and sweep_reclaim_long,
          title = "SWEEP+ HC LONG", location = location.belowbar,
          color = color.new(color.lime, 0), style = shape.diamond,
          size = size.large, text = "SWEEP+", textcolor = color.black)
plotshape(show_sweep and sweep_reversal_short,
          title = "SWEEP- HC SHORT", location = location.abovebar,
          color = color.new(color.fuchsia, 0), style = shape.diamond,
          size = size.large, text = "SWEEP-", textcolor = color.white)

// =====================================================================
// Today's open + open-line PDH/PDL confluence flags
// =====================================================================
// today_open is captured on the first bar of each session. It feeds both
// gap-context detection (further down) AND the open_lost/open_reclaimed
// alerts (further still). near_pdh_open / near_pdl_open mark when the
// open sits at PDH/PDL — used by the webhook to collapse confluence twins.
// These need to be declared BEFORE build_payload_v2 because the payload
// references them by name.
session_open_now = ta.change(time("D")) != 0
var float today_open       = na
var float bar1_low         = na
var int   first_bar_time   = na

if session_open_now
    today_open := open
    bar1_low := low
    first_bar_time := time
else if not na(first_bar_time) and (time - first_bar_time) <= 10 * 60 * 1000
    bar1_low := math.min(nz(bar1_low, low), low)

// Spec 61 — opening-range low (first 15 min of the session). Locked once
// the OR window closes; for the rest of the day a pullback that wicks to
// this level and closes back above it green is the "buy the low of day,
// PDH = first target" entry. Elapsed-time window (not a bar count) so it
// behaves the same on 1m/5m/10m/15m charts. SPY thesis (2026-06-03): the
// 15m low usually decides the day — stocks either defend it or roll over.
fire_orl_held   = input.bool(true, "Fire opening-range-low held entry (15m OR low defended)", group = "Opening range")
or_test_tol_pct = input.float(0.15, "OR-low test tolerance (% above the OR low)", minval = 0.0, maxval = 1.0, step = 0.05, group = "Opening range")
var float orl_61     = na      // opening-range low (first 15 min)
var bool  or_done_61 = false
// Per-session fire cap (2026-06-19) — the ORL defense works best on the FIRST
// dip back to the opening-range low; after that, price oscillating around the
// level re-fired the alert all day (it was the #1 alert by volume). Cap per
// session: 1 for stocks, 2 for crypto (24/7 — one defense/day is too few).
orl_fire_cap_61 = syminfo.type == "crypto" ? 2 : 1
var int   orl_fire_count_61 = 0
if session_open_now
    orl_61     := low
    or_done_61 := false
    orl_fire_count_61 := 0
else if not na(first_bar_time) and (time - first_bar_time) < 15 * 60 * 1000
    orl_61 := math.min(nz(orl_61, low), low)
else if not na(first_bar_time)
    or_done_61 := true
// Held detector: OR window done, bar wicked down to/near the OR low, then
// closed back above it on a green bar. Strict — the bar must actually
// reach the level (low <= OR low + tol), so this fires at the bottom of
// the range, never up into resistance.
s58_orl_held = or_done_61 and not na(orl_61) and low <= orl_61 * (1.0 + or_test_tol_pct / 100.0) and close > orl_61 and close > open

// Spec 61 — PDH reclaim + PDH proximity (high-side mirrors of the PDL set).
//
// PDH RECLAIM is distinct from pdh_break: a *break* is the first cross up
// through PDH (resistance becoming support). A *reclaim* is when PDH was
// already acting as SUPPORT (price closed above it earlier this session),
// price then LOST it on a close, and now closes back above on a green bar —
// the failed-breakdown-of-support continuation. The was-above / lost state
// machine is what keeps it from colliding with the fresh break.
var bool pdh_was_above_61 = false
var bool pdh_lost_61      = false
if session_open_now
    pdh_was_above_61 := false
    pdh_lost_61      := false
if not na(pdh) and close > pdh
    pdh_was_above_61 := true
if pdh_was_above_61 and not na(pdh) and close < pdh
    pdh_lost_61 := true
s58_pdh_reclaim = pdh_was_above_61 and pdh_lost_61 and not na(pdh) and not na(close[1]) and close > pdh and close[1] <= pdh and close > open and day_open > pdh

// PDH PROXIMITY: price is holding ABOVE PDH (PDH acting as support) and pulls
// back NEAR it without retesting — the bar low comes within the ATR-scaled
// band (prox_band_61) above PDH but stays above it, green close. Mirror of
// staged_pdl_proximity for a relative-strength name riding above its PDH.
s58_pdh_prox = not na(pdh) and not na(close[1]) and close[1] > pdh and low > pdh and low <= pdh + prox_band_61 and close > open

// Spec 58 (FR-006) — higher-high chop gate. Buy 2 alerts only fire while
// the stock is still making new session highs OR within 30 minutes of the
// last new high. Stops Buy 2 alerts in the afternoon chop that follows
// a strong morning run (validation: INTC 2026-05-22 made its high on bar
// 5, then 21 bars of chop — chop gate would have stood down ~30 min in).
var float session_high_58       = na
var int   last_new_high_time_58 = na
if session_open_now
    session_high_58       := high
    last_new_high_time_58 := time
else
    if high > nz(session_high_58, -1e9)
        session_high_58       := high
        last_new_high_time_58 := time
chop_gate_pass_58 = not na(last_new_high_time_58) and (time - last_new_high_time_58) <= 30 * 60 * 1000

open_confluence_tol = 0.003  // 0.3%
near_pdh_open = not na(today_open) and not na(pdh) and math.abs(today_open - pdh) / pdh <= open_confluence_tol
near_pdl_open = not na(today_open) and not na(pdl) and math.abs(today_open - pdl) / pdl <= open_confluence_tol

// Inside-day flag: today's open sits between yesterday's high and low.
// These days tend to range — useful as a conviction-degrade signal for the
// triage agent. Outside-day opens (above PDH or below PDL = gap-up/gap-down)
// have stronger directional bias.
is_inside_day = not na(today_open) and not na(pdh) and not na(pdl) and today_open > pdl and today_open < pdh

// =====================================================================
// Day type — actionable session classification displayed on chart badge.
// Replaces the Stage 1/2/3/4 labels since "GAP UP / INSIDE / TEST PDH" is
// more directly useful for sizing + bias than "STAGE 2 ADVANCING".
//
// Seven buckets (mutually exclusive):
//   GAP UP        open > PDH                trend bias, longs at pullback
//   TEST PDH      open ≈ PDH                break-or-fail
//   INSIDE HIGH   open in upper half of range   range, lean long
//   INSIDE MID    open near range midpoint      true 2-sided range
//   INSIDE LOW    open in lower half of range   range, lean short
//   TEST PDL      open ≈ PDL                bounce-or-break
//   GAP DOWN      open < PDL                distribution risk, avoid longs
// =====================================================================
gap_threshold_pct = 0.0001  // > 0.01% past PDH/PDL counts as a "gap"
is_gap_up   = not na(today_open) and not na(pdh) and today_open > pdh * (1.0 + gap_threshold_pct)
is_gap_down = not na(today_open) and not na(pdl) and today_open < pdl * (1.0 - gap_threshold_pct)
is_test_pdh = near_pdh_open and not is_gap_up
is_test_pdl = near_pdl_open and not is_gap_down

range_midpoint = not na(pdh) and not na(pdl) ? (pdh + pdl) / 2.0 : float(na)
is_inside_high = is_inside_day and not na(range_midpoint) and today_open > range_midpoint and not is_test_pdh
is_inside_low  = is_inside_day and not na(range_midpoint) and today_open < range_midpoint and not is_test_pdl
is_inside_mid  = is_inside_day and not is_inside_high and not is_inside_low and not is_test_pdh and not is_test_pdl

// Range midpoint — natural pivot between INSIDE HIGH and INSIDE LOW.
// Useful as a stop/invalidation level on inside days: long bias above mid,
// short bias below. Plotted as a silver solid line — light enough to read
// on dark themes, thinner than the bold PDH/PDL/VWAP so it stays secondary.
plot(show_midpoint and not na(range_midpoint) ? range_midpoint : na,
     title = "Range Mid",
     color = color.new(color.silver, 0),
     style = plot.style_line,
     linewidth = 2)

string day_text = "INSUFFICIENT DATA\nPDH/PDL loading\nWAIT for context"
color  day_bg   = color.new(color.gray, 30)
if not na(today_open) and not na(pdh) and not na(pdl)
    pdh_str = str.tostring(pdh, format.mintick)
    pdl_str = str.tostring(pdl, format.mintick)
    mid_str = not na(range_midpoint) ? str.tostring(range_midpoint, format.mintick) : "—"
    if is_gap_up
        day_text := "GAP UP\nPDH " + pdh_str + " · mid " + mid_str + "\nLEAN: longs at pullbacks"
        day_bg   := color.new(color.green, 10)
    else if is_test_pdh
        day_text := "TEST PDH\nopen at PDH " + pdh_str + "\nLEAN: trade the break/fail"
        day_bg   := color.new(color.yellow, 25)
    else if is_inside_high
        day_text := "INSIDE HIGH\nmid " + mid_str + " · range " + pdl_str + " / " + pdh_str + "\nLEAN: range, upper half"
        day_bg   := color.new(color.aqua, 40)
    else if is_inside_mid
        day_text := "INSIDE MID\nmid " + mid_str + " · range " + pdl_str + " / " + pdh_str + "\nLEAN: range, fade extremes"
        day_bg   := color.new(color.blue, 40)
    else if is_inside_low
        day_text := "INSIDE LOW\nmid " + mid_str + " · range " + pdl_str + " / " + pdh_str + "\nLEAN: range, lower half"
        day_bg   := color.new(color.aqua, 40)
    else if is_test_pdl
        day_text := "TEST PDL\nopen at PDL " + pdl_str + "\nLEAN: bounce-or-break"
        day_bg   := color.new(color.yellow, 25)
    else if is_gap_down
        day_text := "GAP DOWN\nPDL " + pdl_str + " · mid " + mid_str + "\nLEAN: avoid longs, fade pops to mid"
        day_bg   := color.new(color.red, 10)

// =====================================================================
// EMA regime — honest position description (no misleading state labels).
//
// Action tier is based on WHICH EMA is broken (longer = bigger concern):
//   below SMA200          → scalp only, NO OVERNIGHT (true weakness)
//   below EMA100          → day trades only, no swings/overnight
//   below EMA50           → day trades · no overnight
//   below EMA10/21 only   → day trades · manage tight (normal pullback)
//   below EMA5 only       → day trades · stay nimble (momentum cool)
//   above all EMAs        → full size · swings/overnight OK
//
// We DO NOT call AMZN-below-EMA10 "WEAK" — that's misleading. True
// weakness is below SMA200. AMZN below EMA10 is just a normal pullback
// in a healthy trend.
//
// Display: shows AT EMA(n) if price within proximity threshold of any
// EMA, otherwise the position description (which EMAs are below).
// =====================================================================
get_regime(string sym) =>
    _ema5  = request.security(sym, "D", ta.ema(close, 5)[1])
    _ema10 = request.security(sym, "D", ta.ema(close, 10)[1])
    _ema21 = request.security(sym, "D", ta.ema(close, 21)[1])
    _close = request.security(sym, timeframe.period, close)

    // Track per-EMA was-below state for the session (reclaim recognition).
    _sess_reset = ta.change(time("D")) != 0
    var bool _was_below_5  = false
    var bool _was_below_10 = false
    var bool _was_below_21 = false
    if _sess_reset
        _was_below_5  := false
        _was_below_10 := false
        _was_below_21 := false

    _above_5  = not na(_ema5)  and not na(_close) and _close > _ema5
    _above_10 = not na(_ema10) and not na(_close) and _close > _ema10
    _above_21 = not na(_ema21) and not na(_close) and _close > _ema21

    if not _above_5
        _was_below_5 := true
    if not _above_10
        _was_below_10 := true
    if not _above_21
        _was_below_21 := true

    // Reclaim count: EMAs that were below earlier today but now closed above.
    _recl_5  = _above_5  and _was_below_5
    _recl_10 = _above_10 and _was_below_10
    _recl_21 = _above_21 and _was_below_21
    _reclaim_count = (_recl_5 ? 1 : 0) + (_recl_10 ? 1 : 0) + (_recl_21 ? 1 : 0)

    // State classification — descending strength.
    _state  = "NO TREND"
    _action = "scalp only · NO OVERNIGHT"
    _sub    = "below EMA21"

    if _above_5 and _above_10 and _above_21
        _state  := "STRONG TREND"
        _action := "full size · swings/overnight OK"
        _sub    := "above all EMAs (5/10/21)"
    else if _above_10 and _above_21
        _state  := "PULLBACK"
        _action := "day trades · manage tight"
        _sub    := "below EMA5 (momentum cool)"
    else if _above_21
        _state  := "WEAK"
        _action := "day trades only · no swings"
        _sub    := "below EMA10"
    else
        _state  := "NO TREND"
        _action := "scalp only · NO OVERNIGHT"
        _sub    := _above_10 ? "below EMA21 only" : (_above_5 ? "below EMA10/21" : "below all EMAs")

    // Append reclaim tag if any EMA was reclaimed this session.
    if _reclaim_count > 0
        _sub := _sub + " · ↑ reclaimed " + str.tostring(_reclaim_count) + " EMA"

    [_state, _action, _sub]

regime_bg(string state) =>
    state == "STRONG TREND" ? color.new(color.green, 10) : state == "PULLBACK" ? color.new(color.blue, 20) : state == "WEAK" ? color.new(color.yellow, 15) : state == "NO TREND" ? color.new(color.red, 15) : color.new(color.gray, 60)

regime_fg(string state) =>
    state == "WEAK" ? color.black : color.white

regime_emoji(string state) =>
    state == "STRONG TREND" ? "🚀" : state == "PULLBACK" ? "🔵" : state == "WEAK" ? "⚠️" : state == "NO TREND" ? "🔴" : "·"

[spy_state, spy_action, spy_sub] = get_regime("SPY")

// Banner removed 2026-05-23 — spy_line kept as empty for dead-code safety.
spy_line = ""

// =====================================================================
// Current-symbol EMA position — same regime classifier applied to the
// chart's loaded symbol. Tells trader where THIS stock sits on its own
// EMA stack + flags proximity to any specific EMA ("AT EMA10") when
// price is within ema_proximity_pct of an EMA value.
// =====================================================================
[sym_state, sym_action, sym_sub] = get_regime(syminfo.tickerid)

// Proximity check — flag which EMA is being tested if within threshold.
// Includes structural longer-term EMAs (50/100) and SMA200 since price
// often hugs these as key levels even when the 5/10/21 stack is fine
// (e.g., MSFT in STRONG TREND but testing EMA100 from above).
_sym_ema5   = request.security(syminfo.tickerid, "D", ta.ema(close, 5)[1])
_sym_ema10  = request.security(syminfo.tickerid, "D", ta.ema(close, 10)[1])
_sym_ema21  = request.security(syminfo.tickerid, "D", ta.ema(close, 21)[1])
_sym_ema50  = request.security(syminfo.tickerid, "D", ta.ema(close, 50)[1])
_sym_ema100 = request.security(syminfo.tickerid, "D", ta.ema(close, 100)[1])
_sym_sma200 = request.security(syminfo.tickerid, "D", ta.sma(close, 200)[1])
_sym_close = close
_prox_frac = ema_proximity_pct / 100.0
_at_5   = not na(_sym_ema5)   and _sym_ema5   != 0 and math.abs(_sym_close - _sym_ema5)   / _sym_ema5   <= _prox_frac
_at_10  = not na(_sym_ema10)  and _sym_ema10  != 0 and math.abs(_sym_close - _sym_ema10)  / _sym_ema10  <= _prox_frac
_at_21  = not na(_sym_ema21)  and _sym_ema21  != 0 and math.abs(_sym_close - _sym_ema21)  / _sym_ema21  <= _prox_frac
_at_50  = not na(_sym_ema50)  and _sym_ema50  != 0 and math.abs(_sym_close - _sym_ema50)  / _sym_ema50  <= _prox_frac
_at_100 = not na(_sym_ema100) and _sym_ema100 != 0 and math.abs(_sym_close - _sym_ema100) / _sym_ema100 <= _prox_frac
_at_200 = not na(_sym_sma200) and _sym_sma200 != 0 and math.abs(_sym_close - _sym_sma200) / _sym_sma200 <= _prox_frac
// Priority: longer/structural EMAs first (more meaningful when tested).
// SMA200 > EMA100 > EMA50 > EMA21 > EMA10 > EMA5.
sym_at_tag = _at_200 ? " · AT SMA200 (key structural)" : _at_100 ? " · AT EMA100 (key structural)" : _at_50 ? " · AT EMA50 (trend filter)" : _at_21 ? " · AT EMA21 (testing)" : _at_10 ? " · AT EMA10 (testing)" : _at_5 ? " · AT EMA5 (testing)" : ""

// Banner removed 2026-05-23 — sym_line kept as empty for dead-code safety.
sym_line = ""

combined_day_text = day_text + spy_line + sym_line

// Day-type badge / SPY regime banner removed 2026-05-23 — visual clutter,
// not actionable for the trader. The state-text computations above
// (day_text, spy_line, sym_line, combined_day_text, day_bg) are unused
// now; left in place so they can be revived if the banner ever returns.

// =====================================================================
// Alert payload — adds volume_ratio, cvd_delta, cvd_diverging
// =====================================================================
stage_json = str.replace_all(stage_text, "\n", " — ")

build_payload_v2(rule, direction,
                 entry_p, stop_p, t1_p, t2_p,
                 gap_ctx_v,
                 confluence_n,
                 vr, cvd_d, cvd_div) =>
    '{"symbol":"' + syminfo.ticker
      + '","exchange":"' + syminfo.prefix
      + '","interval":"' + timeframe.period
      + '","price":"' + str.tostring(close, format.mintick)
      + '","high":"' + str.tostring(high, format.mintick)
      + '","low":"' + str.tostring(low, format.mintick)
      + '","volume":"' + str.tostring(volume)
      + '","entry":"' + str.tostring(entry_p, format.mintick)
      + '","stop":"' + str.tostring(stop_p, format.mintick)
      + '","target_1":"' + str.tostring(t1_p, format.mintick)
      + '","target_2":"' + str.tostring(t2_p, format.mintick)
      + '","rule":"' + rule
      + '","direction":"' + direction
      + '","stage":"' + stage_json
      + '","vwap":"' + str.tostring(vwap_v, format.mintick)
      + '","vwap_slope_pct":"' + str.tostring(vwap_slope_pct, "#.##")
      + '","above_vwap":"' + (above_vwap ? "true" : "false")
      + '","gap_context":"' + (gap_ctx_v ? "true" : "false")
      + '","confluence_count":"' + str.tostring(confluence_n)
      + '","pwh":"' + str.tostring(pwh, format.mintick)
      + '","pwl":"' + str.tostring(pwl, format.mintick)
      + '","volume_ratio":"' + str.tostring(vr, "#.##")
      + '","cvd_delta":"' + str.tostring(cvd_d, "#.##")
      + '","cvd_diverging":"' + (cvd_div ? "true" : "false")
      + '","today_open":"' + str.tostring(today_open, format.mintick)
      + '","near_pdh":"' + (near_pdh_open ? "true" : "false")
      + '","near_pdl":"' + (near_pdl_open ? "true" : "false")
      + '","inside_day":"' + (is_inside_day ? "true" : "false")
      + '","fired_at":"' + str.tostring(timenow)
      + '","uptrend_pass":"' + (uptrend_pass_58 ? "true" : "false")
      + '","overhead_mas":"' + overhead_mas_str_58
      + '","nearby_levels":"' + nearby_levels_csv_58
      + '","mtd_avwap":"' + (na(mtd_avwap_58) ? "" : str.tostring(mtd_avwap_58, "#.##"))
      + '","rsi":"' + str.tostring(rsi_d, "#.##")
      + '","spy_above_pdl":"' + (spy_above_pdl_61 ? "true" : "false") + '"}'

atr14      = nz(ta.atr(14)[1], close * 0.005)
atr_buffer = atr14 * atr_buffer_mult

// Daily ATR for the target-hierarchy ATR fallback (intraday-scaled at 0.5×
// because daily ATR is too wide for a single-session target).
atr_d_raw = request.security(syminfo.tickerid, "D", ta.atr(14)[1],
                             lookahead = barmerge.lookahead_on)
atr_d     = nz(atr_d_raw, close * 0.005)

// =====================================================================
// Gap-and-go detection (spec C1) — uses today_open + bar1_low
// =====================================================================
// today_open / bar1_low / first_bar_time are computed above (before
// build_payload_v2 so the payload can reference them). This block just
// builds the gap_context flag from those values.

// Gap-up + hold flags. gap_context true = use tight first-bar stop.
gap_up      = not na(today_open) and not na(pdh) and today_open >= pdh * 1.005
gap_held    = not na(bar1_low)   and not na(pdh) and bar1_low > pdh
gap_context = gap_up and gap_held

// =====================================================================
// Open-line state machine: lost / reclaimed / support-hold (one each per session)
// =====================================================================
// Four patterns we care about (progressively stronger signals):
//   • open_held         → cleanest defense; low touched WITHIN 0.2% above
//                         open, never crossed. Weakest signal (no wick
//                         test) — confirms level holds.
//   • open_wick_reclaim → wick CROSSED below today_open, body held above,
//                         green bar bounce. Mid-tier — real test happened,
//                         no close flip (AAPL 2026-05-15 9:55 ET pattern).
//   • open_reclaimed    → full recovery; a close flipped below open, then
//                         price reclaimed AND HELD it for 2 consecutive
//                         closes (~30 min). Strongest open signal.
//   • open_lost         → bearish shift; was above open, then closed below.
//                         NOTICE on indexes only.
//
// Mutual exclusion at the bar level: open_held requires low >= today_open;
// open_wick_reclaim requires low < today_open. Across the session, once
// ol_wick_dipped_today is true, open_held is blocked (the day's character
// is "wick was tested" — clean-defense category no longer applies).
// Once ol_lost_today is true, both hold and wick_reclaim are blocked
// (we're now in reclaim territory).
//
// One-shot per session per type. open_reclaimed re-arms after fire (see
// below) for genuine multi-leg reclaim days.
//
// Routing:
//   open_held / open_wick_reclaim / open_reclaimed → BUY on every symbol
//   open_lost → NOTICE on SPY/QQQ/AIQ/NDX only (bearish info)
var bool ol_was_above_open       = false
var bool ol_lost_today           = false
var bool ol_reclaimed_today      = false
var bool ol_held_today           = false
var bool ol_wick_reclaimed_today = false
var bool ol_wick_dipped_today    = false
var int  ol_bars_above           = 0

if session_open_now
    ol_was_above_open       := false
    ol_lost_today           := false
    ol_reclaimed_today      := false
    ol_held_today           := false
    ol_wick_reclaimed_today := false
    ol_wick_dipped_today    := false
    ol_bars_above           := 0

if not na(today_open) and close > today_open
    ol_was_above_open := true

// Wick-level lose tracker — true once ANY bar's low crosses below today_open
// (independent of close). Used to gate open_held (clean defense).
if not na(today_open) and low < today_open
    ol_wick_dipped_today := true

// Bars-held-above-open counter — consecutive closes above today_open, reset
// to 0 on any close at/below it. Gates open_reclaimed: the reclaim must HOLD.
if not na(today_open)
    ol_bars_above := close > today_open ? ol_bars_above + 1 : 0

ol_just_lost      = ol_was_above_open and not ol_lost_today and not na(today_open) and not na(close[1]) and close < today_open and close[1] >= today_open
// open_reclaimed: lost the open, then RECLAIMED AND HELD — fires only once
// price has closed above today_open for 2 consecutive bars (~30 min). A
// single choppy cross is one bar that falls back the next -> never reaches
// 2 -> no alert. Re-arms after fire (ol_lost_today reset below) so a genuine
// later lose-reclaim cycle still gets its own confirmed alert.
ol_just_reclaimed = ol_lost_today and not na(today_open) and ol_bars_above == 2

// open_held: clean defense — low tested within 0.2% ABOVE today_open but
// never crossed below. Weakest of the three BUY signals (no real test).
open_test_tol_pct = 0.002
ol_just_held = ol_was_above_open and not ol_lost_today and not ol_held_today and not ol_wick_dipped_today and not na(today_open) and low <= today_open * (1.0 + open_test_tol_pct) and low >= today_open and close > today_open and close > open

// open_wick_reclaim: wick CROSSED below today_open, body held above, green
// bar bounce. Stronger than held (real test happened), weaker than full
// reclaimed (no close flip). One-shot per session.
ol_just_wick_reclaimed = ol_was_above_open and not ol_lost_today and not ol_wick_reclaimed_today and not na(today_open) and low < today_open and close > today_open and close > open

if ol_just_lost
    ol_lost_today := true
if ol_just_reclaimed
    // Re-arm: reset ol_lost_today so a subsequent lose-reclaim cycle can
    // fire later in the session. Pair with backend 90-min dedup window
    // so we don't get spammed by rapid chop.
    ol_lost_today      := false
    ol_reclaimed_today := true
if ol_just_held
    ol_held_today := true
if ol_just_wick_reclaimed
    ol_wick_reclaimed_today := true

// =====================================================================
// Target hierarchy helpers (spec C4)
// =====================================================================
// Walk: structural overhead/support → next round number → 0.5× daily ATR
// extension → 0.75% floor. Always returns a target at least 0.5% from
// entry (so tight-stop alerts don't get tight targets too).

next_round_above(float p) =>
    incr = p > 200 ? 5.0 : (p > 50 ? 1.0 : 0.5)
    math.ceil(p / incr) * incr

next_round_below(float p) =>
    incr = p > 200 ? 5.0 : (p > 50 ? 1.0 : 0.5)
    math.floor(p / incr) * incr

// Closest valid level above entry within 3% (na if none).
nearest_above(float e, float l1, float l2) =>
    a1 = not na(l1) and l1 > e and (l1 - e) / e <= 0.03 ? l1 : 9.0e15
    a2 = not na(l2) and l2 > e and (l2 - e) / e <= 0.03 ? l2 : 9.0e15
    r  = math.min(a1, a2)
    r == 9.0e15 ? float(na) : r

nearest_below(float e, float l1, float l2) =>
    a1 = not na(l1) and l1 < e and (e - l1) / e <= 0.03 ? l1 : -9.0e15
    a2 = not na(l2) and l2 < e and (e - l2) / e <= 0.03 ? l2 : -9.0e15
    r  = math.max(a1, a2)
    r == -9.0e15 ? float(na) : r

// Full-stack nearest level/EMA above/below entry (#64-A) — the REAL target. Scans every
// daily/weekly/monthly level AND the daily MAs, picks the nearest one >=~1% away. The ~1%
// band skips the entry's OWN level/cluster (the support you're firing AT) so the target is
// the NEXT neighbor wall — e.g. SPCX firing at the PWH (~177) targets the PDL (187), not the
// PWH itself. na if none in reach → callers fall back to round/ATR.
nearest_stack_above(float e) =>
    best = 9.0e15
    cands = array.from(pdh, pdl, pwh, pwl, pmh, pml, ema8_d, ema21_d, ema50_d, ema100_d, ema200_d, sma50_d, sma100_d, sma200_d)
    for i = 0 to array.size(cands) - 1
        v = array.get(cands, i)
        if not na(v) and v > e * 1.01 and v < best
            best := v
    best == 9.0e15 ? float(na) : best

nearest_stack_below(float e) =>
    best = -9.0e15
    cands = array.from(pdh, pdl, pwh, pwl, pmh, pml, ema8_d, ema21_d, ema50_d, ema100_d, ema200_d, sma50_d, sma100_d, sma200_d)
    for i = 0 to array.size(cands) - 1
        v = array.get(cands, i)
        if not na(v) and v < e * 0.99 and v > best
            best := v
    best == -9.0e15 ? float(na) : best

t1_long_hier(float e, float l1, float l2, float atr_daily) =>
    s = nearest_stack_above(e)
    not na(s) ? s :
      next_round_above(e) > e * 1.005 ? next_round_above(e) :
      e + atr_daily * 0.5 > e * 1.005 ? e + atr_daily * 0.5 :
      e * 1.0075

t1_short_hier(float e, float l1, float l2, float atr_daily) =>
    s = nearest_stack_below(e)
    not na(s) ? s :
      next_round_below(e) < e * 0.995 ? next_round_below(e) :
      e - atr_daily * 0.5 < e * 0.995 ? e - atr_daily * 0.5 :
      e * 0.9925

t2_extend_long(float e, float t1)  => math.max(t1 + (t1 - e) * 0.5, t1 * 1.005)
t2_extend_short(float e, float t1) => math.min(t1 - (e - t1) * 0.5, t1 * 0.995)

// LONG alerts pass bearish_div (price up, CVD lagging = bad for longs)
// SHORT alerts pass bullish_div (price down, CVD lifting = bad for shorts)
//
// Alert frequency (2026-05-04 v2): all alerts fire on bar close. Intra-bar
// firing was tried but rejected — wick-fakeouts on PDH/PDL crosses caused
// false entries that close-confirmation prevents. Use a 10m chart TF on
// the TV alert side for faster delivery (10min close beats 15min close
// for entry timing) without sacrificing the close-confirmation guarantee.
//
// Stop sizing notes:
//   • staged_pdh_break — gap_context=true means use first-10min-bar low as
//     stop (tight, ~1-2%) instead of yesterday's swing. Without gap context,
//     fall back to the prior `pdh - atr_buffer` logic.
//   • staged_pdh_rejection — stop above the rejection wick.
//   • staged_pdl_break — stop just above the broken level.
//   • staged_pdl_reclaim — stop at the sweep low (current bar's low).
//
// Target sizing: t1_long_hier / t1_short_hier walks structural → round →
// ATR/2 → 0.75% floor. For LONG breakout (pdh_break), candidates are
// PWH first then n/a — round/ATR fallback handles ATH cases. For LONG
// reclaim (pdl_reclaim), candidates are PDH then PWH (further out).
// Helper: name the alert per TF so Telegram can render the right label.
// Daily → staged_pdh_*, Weekly → staged_pwh_*, Monthly → staged_pmh_*
// (and analogously for the "pdl/pwl/pml" set). The Pine event logic is
// unified across TFs (it's still "the level that was crossed"), only
// the emitted alert_type differs so backend dedup + Telegram labelling
// stay clean per-level.
tf_high_prefix(string tf) =>
    tf == "W" ? "staged_pwh_" : tf == "M" ? "staged_pmh_" : "staged_pdh_"
tf_low_prefix(string tf) =>
    tf == "W" ? "staged_pwl_" : tf == "M" ? "staged_pml_" : "staged_pdl_"

// HTF gate: daily (tf == "D") always fires; weekly only when user opts
// in via fire_htf_staged. Monthly (tf == "M") DISABLED 2026-06-01 — PMH
// / PML levels stay drawn on chart as visual only, no alerts.
htf_allowed(string tf) =>
    tf == "D" or (tf == "W" and fire_htf_staged)

// Spec 58 — pdh_break LONG retired (FR-005, breakout-into-resistance).
// The `if false and pdh_break` neutralizes the alert while leaving the
// block in place for easy revert. The SHORT-side pdh_rejection block
// below is unchanged (shorts are out of spec-58 scope).
if false and pdh_break
    e   = close
    s_default = broken_resistance - atr_buffer
    s   = gap_context and not na(bar1_low) ? bar1_low - atr_buffer * 0.5 : s_default
    t1  = t1_long_hier(e, pwh, pmh, atr_d)
    t2  = t2_extend_long(e, t1)
    tf  = level_tf(broken_resistance, pdh, pwh, pmh)
    if htf_allowed(tf)
        dir = dir_for_tf(tf, "BUY")
        alert(build_payload_v2(tf_high_prefix(tf) + "break", dir, e, s, t1, t2, gap_context, confluence_resistance, volume_ratio, cvd_slope_n, bearish_div), alert.freq_once_per_bar_close)

// Spec 60 — v2 break rules. Re-introduce the retired PDH/PWH/PMH break
// family with built-in confluence: close > level + close[1] ≤ level
// (single-bar break, no chasing) + close > VWAP + slope ≥ +0.05% + volume
// ≥ 2.0× + uptrend_pass. Five orthogonal confirmations on one bar — the
// rule cannot fire on weak fakeouts (the failure mode spec 58 was right
// to worry about) but DOES fire on textbook breakouts like SPY through
// $751.38 today. Catalog default-disabled; user opts in per type.
v2_break_pdh = (not na(pdh)) and (not na(close[1])) and close > pdh and close[1] <= pdh
v2_break_pwh = (not na(pwh)) and (not na(close[1])) and close > pwh and close[1] <= pwh
v2_break_pmh = (not na(pmh)) and (not na(close[1])) and close > pmh and close[1] <= pmh

v2_break_vol_ok = (not na(volume_ratio)) and volume_ratio >= v2_break_vol_min
v2_break_slope_ok = (not na(vwap_slope_pct)) and vwap_slope_pct >= v2_break_slope_min
v2_break_vwap_ok = (not na(vwap_v)) and close > vwap_v
v2_break_confluence = fire_break_v2 and v2_break_vol_ok and v2_break_slope_ok and v2_break_vwap_ok and uptrend_pass_58

// Spec 61 (2026-06-04) — PDH/PWH BREAK DROPPED. A break into PDH after a rally
// from below is buying resistance/exhaustion (AAOI ran +$24 into PDH, then a
// long fired at the top). The trusted PDH entry is staged_pdh_held (price gets
// above PDH and retests it as support). Gap-and-go (open ABOVE PDH) is a
// separate alert and is unaffected. `if false` keeps the blocks for revert.
// 2026-06-18: staged_pdh_break RE-ENABLED (#291) — user wants the high-volume PDH
// breakout (close above PDH + volume_ratio>=2 + rising VWAP). #277 had reverted it.
if v2_break_pdh and v2_break_confluence
    e_b = close
    s_b = low - atr_buffer
    t1_b = not na(pwh) and pwh > e_b ? pwh : (not na(pmh) and pmh > e_b ? pmh : e_b * 1.015)
    t2_b = not na(pmh) and pmh > t1_b ? pmh : t2_extend_long(e_b, t1_b)
    alert(build_payload_v2("staged_pdh_break", "BUY", e_b, s_b, t1_b, t2_b, false, 1, volume_ratio, cvd_slope_n, bearish_div), alert.freq_once_per_bar_close)

if false and v2_break_pwh and v2_break_confluence
    e_b = close
    s_b = low - atr_buffer
    t1_b = not na(pmh) and pmh > e_b ? pmh : e_b * 1.02
    t2_b = t2_extend_long(e_b, t1_b)
    alert(build_payload_v2("staged_pwh_break", "BUY", e_b, s_b, t1_b, t2_b, false, 1, volume_ratio, cvd_slope_n, bearish_div), alert.freq_once_per_bar_close)

// =====================================================================
// Spec 61 (2026-06-06) — SPY/QQQ/IWM index SHORT alerts.
// =====================================================================
// Trade WITH the breakdown, not against it: short a CONFIRMED PDL break on
// heavy volume (the same break that gates your longs off), and short a PDH
// REJECTION (rallied into resistance, sellers defended it). Both confirm on a
// CLOSE (red bar) — wick-only triggers get squeezed. Fires only on the index
// allow-list; the backend short-routing delivers SPY/QQQ/IWM only. Pine fires
// it (records for review); the Settings catalog toggle (default OFF) gates
// Telegram until you trust the count. Structural stops above the level.
fire_index_shorts = input.bool (true,  "Fire index SHORT alerts (PDL break / PDH rejection)", group = "Index shorts")
short_index_list  = input.string("SPY,QQQ,IWM,BTCUSD,BTCUSDT,BTCUSDC", "Symbols allowed to fire shorts — RAW TV tickers (BTC runs 24/7 to validate)", group = "Index shorts")
short_vol_min     = input.float (1.5,  "Short: min volume ratio (heavy volume)", minval = 1.0, step = 0.1, group = "Index shorts")
_short_syms    = "," + str.replace_all(str.upper(short_index_list), " ", "") + ","
is_short_index = str.contains(_short_syms, "," + str.upper(syminfo.ticker) + ",")

pdl_break_short  = not na(pdl) and close < pdl and close < open and not na(volume_ratio) and volume_ratio >= short_vol_min
pdh_reject_short = not na(pdh) and high >= pdh and close < pdh and close < open and not na(volume_ratio) and volume_ratio >= short_vol_min

var bool pdl_break_fired  = false
var bool pdh_reject_fired = false
if session_open_now
    pdl_break_fired  := false
    pdh_reject_fired := false

if fire_index_shorts and is_short_index and pdl_break_short and not pdl_break_fired
    pdl_break_fired := true
    e_sh  = close
    s_sh  = pdl + atr_buffer
    t1_sh = not na(pwl) and pwl < e_sh ? pwl : e_sh - atr_d
    t2_sh = t1_sh - atr_d
    alert(build_payload_v2("staged_pdl_break", "SHORT", e_sh, s_sh, t1_sh, t2_sh, false, 1, volume_ratio, cvd_slope_n, bearish_div), alert.freq_once_per_bar_close)

if fire_index_shorts and is_short_index and pdh_reject_short and not pdh_reject_fired
    pdh_reject_fired := true
    e_sh  = close
    s_sh  = pdh + atr_buffer
    t1_sh = not na(today_open) and today_open < e_sh ? today_open : e_sh - atr_d
    t2_sh = not na(pdl) and pdl < t1_sh ? pdl : t1_sh - atr_d
    alert(build_payload_v2("staged_pdh_rejection", "SHORT", e_sh, s_sh, t1_sh, t2_sh, false, 1, volume_ratio, cvd_slope_n, bearish_div), alert.freq_once_per_bar_close)

// 2026-06-01 — staged_pmh_break DISABLED. Monthly TF too coarse for
// intraday triggers; PMH stays drawn on chart as visual only.
// if v2_break_pmh and v2_break_confluence
//     e_b = close
//     s_b = low - atr_buffer
//     t1_b = e_b * 1.03
//     t2_b = e_b * 1.05
//     alert(build_payload_v2("staged_pmh_break", "BUY", e_b, s_b, t1_b, t2_b, false, 1, volume_ratio, cvd_slope_n, bearish_div), alert.freq_once_per_bar_close)

// Spec 60 — gap_up_continuation_long. Catches ONDS-style trades that
// gapped over PDH at the bell and never retest. None of the held/break
// rules fire because there's no retest bar. Stop = first-15m low (NOT
// the alert bar's low) — gap thesis breaks when price falls back through
// the opening range, not when this individual bar dips.
// Issue #2 (2026-06-13) — fire ONCE, EARLY, not as a mid-day continuation. ARM
// at the open when the session gapped completely above PDH; fire on the first
// holding/green bar so the entry lands near the OPEN LOW. Stop = the FIXED open
// low (not a drifting session min). INVALIDATE the setup if price breaks the
// open low or trades back below PDH — a failed gap-and-go (NBIS 2026-06-12).
var float gap_open_low = na
var bool  gap_armed    = false
var bool  gap_fired    = false
if session_open_now
    gap_open_low := low
    gap_armed := (not na(pdh)) and (open > pdh)
    gap_fired := false
if gap_armed and ((not na(gap_open_low) and low < gap_open_low) or (not na(pdh) and close < pdh))
    gap_armed := false
v2_gap_up_cont = fire_gap_up_v2 and gap_armed and (not gap_fired) and (not na(pdh)) and close > pdh and close > open and (not na(vwap_v)) and close > vwap_v and (not na(vwap_slope_pct)) and vwap_slope_pct >= v2_break_slope_min and (not na(volume_ratio)) and volume_ratio >= v2_gap_vol_min and uptrend_pass_58

if v2_gap_up_cont
    gap_fired := true
    e_g = close
    s_g = gap_open_low - atr_buffer * 0.5
    t1_g = not na(pwh) and pwh > e_g ? pwh : e_g * 1.02
    t2_g = not na(pmh) and pmh > t1_g ? pmh : t2_extend_long(e_g, t1_g)
    alert(build_payload_v2("gap_up_continuation_long", "BUY", e_g, s_g, t1_g, t2_g, true, 1, volume_ratio, cvd_slope_n, bearish_div), alert.freq_once_per_bar_close)
// Spec 58 (2026-05-23 night) — SHORT alerts removed from Pine.
// This script now fires LONG entries only. The deleted blocks were:
//   • pdh_rejection (SHORT — wick to PDH/PWH/PMH from below, closes back below)
//   • sweep_reversal_short / pdh_failed (SHORT — close-above-then-below trap)
//   • pdl_break (SHORT — close below PDL/PWL/PML)
// Detection variables (pdh_rejection, pdh_failed, pdl_break, broken_support
// etc.) remain in the file as dead code in case the alerts are revived.

if pdl_reclaim
    e   = close
    s   = low - atr_buffer
    t1_struct = nearest_stack_above(e)
    t1 = not na(t1_struct) ? t1_struct : t1_long_hier(e, pdh, pmh, atr_d)
    t2 = not na(pwh) and pwh > t1 ? pwh : (not na(pmh) and pmh > t1 ? pmh : t2_extend_long(e, t1))
    tf  = level_tf(reclaimed_support, pdl, pwl, pml)
    if htf_allowed(tf)
        dir = dir_for_tf(tf, "BUY")
        // gap_context=true marks this as a gap-down recovery reclaim — opened
        // below PDL, now closing back above. Backend uses the flag to label
        // the Telegram header as "PDL reclaim — gap-down recovery ↑".
        // Only meaningful for tf=="D" (gap context applies to today's open).
        alert(build_payload_v2(tf_low_prefix(tf) + "reclaim", dir, e, s, t1, t2, tf == "D" and is_gap_down, confluence_support, volume_ratio, cvd_slope_n, bearish_div), alert.freq_once_per_bar_close)

// =====================================================================
// Spec 58 — Buy 2: prior-high held-from-above (FR-004, refined 2026-05-23)
// =====================================================================
// One alert per held level (PDH / PWH / PMH). The pattern itself encodes
// the relevant precondition (price was above the level on the prior bar).
// Gate logic:
//   • In an uptrend (uptrend_pass_58 = true) → require chop_gate_pass_58
//     so we don't fire late-day continuation alerts in afternoon chop.
//   • In a downtrend (uptrend_pass_58 = false) → bypass the chop gate.
//     Held-from-above in a downtrend is a REVERSAL play, not continuation
//     (e.g., SWMR holding WH 38.06 with overhead MA stack — valid setup).
// Targets stack to the next higher level. Stop = day's low − ATR buffer.
if s58_pdh_held_v2 and (not uptrend_pass_58 or chop_gate_pass_58)
    e_pdh  = pdh
    s_pdh  = low - atr_buffer
    t1_pdh = not na(pwh) and pwh > e_pdh ? pwh : (not na(pmh) and pmh > e_pdh ? pmh : e_pdh * 1.0075)
    t2_pdh = not na(pmh) and pmh > t1_pdh ? pmh : t2_extend_long(e_pdh, t1_pdh)
    alert(build_payload_v2("staged_pdh_held", "BUY", e_pdh, s_pdh, t1_pdh, t2_pdh, false, 1, volume_ratio, cvd_slope_n, bearish_div), alert.freq_once_per_bar_close)

if s58_pwh_held_v2 and (not uptrend_pass_58 or chop_gate_pass_58)
    e_pwh  = pwh
    s_pwh  = low - atr_buffer
    t1_pwh = not na(pmh) and pmh > e_pwh ? pmh : e_pwh * 1.0075
    t2_pwh = t2_extend_long(e_pwh, t1_pwh)
    alert(build_payload_v2("staged_pwh_held", "BUY", e_pwh, s_pwh, t1_pwh, t2_pwh, false, 1, volume_ratio, cvd_slope_n, bearish_div), alert.freq_once_per_bar_close)

// 2026-06-01 — staged_pmh_held DISABLED. PMH stays drawn on chart as visual.
// if s58_pmh_held_v2 and (not uptrend_pass_58 or chop_gate_pass_58)
//     e_pmh  = pmh
//     s_pmh  = low - atr_buffer
//     t1_pmh = e_pmh * 1.0075
//     t2_pmh = e_pmh * 1.015
//     alert(build_payload_v2("staged_pmh_held", "BUY", e_pmh, s_pmh, t1_pmh, t2_pmh, false, 1, volume_ratio, cvd_slope_n, bearish_div), alert.freq_once_per_bar_close)

// =====================================================================
// Spec 58 (2026-05-23) — Buy 2: prior-low held-from-above (wick test)
// =====================================================================
// Entry = the level itself (the wick-tested low — much tighter fill than
// the corresponding _reclaim alert that fires later if the level fails).
// Stop = wick low − ATR buffer. Targets stack to nearest overhead PDH/PWH/PMH.
// Same gate as held-highs: bypass chop gate in downtrends (reversal play).
if s58_pdl_held_v2 and (not uptrend_pass_58 or chop_gate_pass_58)
    e_pdl_h  = pdl
    s_pdl_h  = low - atr_buffer
    t1_pdl_h = not na(pdh) and pdh > e_pdl_h ? pdh : (not na(pwh) and pwh > e_pdl_h ? pwh : e_pdl_h * 1.015)
    t2_pdl_h = not na(pwh) and pwh > t1_pdl_h ? pwh : (not na(pmh) and pmh > t1_pdl_h ? pmh : t2_extend_long(e_pdl_h, t1_pdl_h))
    alert(build_payload_v2("staged_pdl_held", "BUY", e_pdl_h, s_pdl_h, t1_pdl_h, t2_pdl_h, false, 1, volume_ratio, cvd_slope_n, bearish_div), alert.freq_once_per_bar_close)

if s58_pwl_held_v2 and (not uptrend_pass_58 or chop_gate_pass_58)
    e_pwl_h  = pwl
    s_pwl_h  = low - atr_buffer
    t1_pwl_h = not na(pdh) and pdh > e_pwl_h ? pdh : (not na(pwh) and pwh > e_pwl_h ? pwh : e_pwl_h * 1.02)
    t2_pwl_h = not na(pwh) and pwh > t1_pwl_h ? pwh : (not na(pmh) and pmh > t1_pwl_h ? pmh : t2_extend_long(e_pwl_h, t1_pwl_h))
    alert(build_payload_v2("staged_pwl_held", "BUY", e_pwl_h, s_pwl_h, t1_pwl_h, t2_pwl_h, false, 1, volume_ratio, cvd_slope_n, bearish_div), alert.freq_once_per_bar_close)

// 2026-06-02 — Proximity bounce alerts. HOOD pattern: price holds well
// above PDL but the level still acts as support. Entry = current close
// (since the level wasn't actually touched), stop = bar low − atr_buffer
// (tighter than the level itself), targets stack to next overhead PDH/PWH.
// Spec 61 (2026-06-04) — ALL PROXIMITY DROPPED (PDL/PWL/PDH). Entry = close,
// which after a bounce off the level lands far away (TSLA PDL 416, alert fired
// at 423). "Near support" wasn't near. The _held / _reclaim rules already cover
// when price actually touches and defends the level. `if false` keeps for revert.
if false and s58_pdl_prox and (not uptrend_pass_58 or chop_gate_pass_58)
    e_pdl_p  = close
    s_pdl_p  = low - atr_buffer
    // Below-open day → OPEN line is the realistic first target; otherwise the
    // structural overhead (PDH/PWH).
    t1s_pdl_p = not na(pdh) and pdh > e_pdl_p ? pdh : (not na(pwh) and pwh > e_pdl_p ? pwh : e_pdl_p * 1.015)
    below_open_pdl = not na(today_open) and today_open > e_pdl_p
    t1_pdl_p = below_open_pdl ? today_open : t1s_pdl_p
    t2_pdl_p = below_open_pdl ? t1s_pdl_p : (not na(pwh) and pwh > t1_pdl_p ? pwh : (not na(pmh) and pmh > t1_pdl_p ? pmh : t2_extend_long(e_pdl_p, t1_pdl_p)))
    alert(build_payload_v2("staged_pdl_proximity", "BUY", e_pdl_p, s_pdl_p, t1_pdl_p, t2_pdl_p, false, 1, volume_ratio, cvd_slope_n, bearish_div), alert.freq_once_per_bar_close)

if false and s58_pwl_prox and (not uptrend_pass_58 or chop_gate_pass_58)
    e_pwl_p  = close
    s_pwl_p  = low - atr_buffer
    t1_pwl_p = not na(pdh) and pdh > e_pwl_p ? pdh : (not na(pwh) and pwh > e_pwl_p ? pwh : e_pwl_p * 1.02)
    t2_pwl_p = not na(pwh) and pwh > t1_pwl_p ? pwh : (not na(pmh) and pmh > t1_pwl_p ? pmh : t2_extend_long(e_pwl_p, t1_pwl_p))
    alert(build_payload_v2("staged_pwl_proximity", "BUY", e_pwl_p, s_pwl_p, t1_pwl_p, t2_pwl_p, false, 1, volume_ratio, cvd_slope_n, bearish_div), alert.freq_once_per_bar_close)

// 2026-06-03 — Opening-range-low held entry (spec 61). Buy the defended
// 15m low of day; stop sits just under the OR low (structural); first
// target is the nearest overhead level (PDH/PWH) via the hierarchy, so it
// works whether PDH is above (target) or already cleared (extension). v2
// body gate kills doji/distribution holds. NOT SPY-gated — defending the
// low is a relative-strength setup. Catalog default-OFF; opt in to test.
if fire_orl_held and s58_orl_held and v2_body_ok and orl_fire_count_61 < orl_fire_cap_61
    orl_fire_count_61 += 1
    e_orl  = close
    s_orl  = orl_61 - atr_buffer
    // On a weak (below-open) day the OPEN line is the realistic first target
    // (price bounces from the low up to the open); PDH is too far. When below
    // the open, T1 = open, T2 = the structural hierarchy target. Otherwise
    // keep the normal hierarchy.
    t1_hier_orl = t1_long_hier(e_orl, pdh, pwh, atr_d)
    below_open_orl = not na(today_open) and today_open > e_orl
    t1_orl = below_open_orl ? today_open : t1_hier_orl
    t2_orl = below_open_orl ? t1_hier_orl : t2_extend_long(e_orl, t1_orl)
    alert(build_payload_v2("staged_orl_held", "BUY", e_orl, s_orl, t1_orl, t2_orl, false, 1, volume_ratio, cvd_slope_n, bearish_div), alert.freq_once_per_bar_close)

// Spec 61 — PDH reclaim. PDH was lost on a close then reclaimed green =
// failed-breakdown-of-support continuation. Entry = close, stop = bar low
// - buffer, targets stack to the next overhead high (PWH/PMH). Ungated
// like pdl_reclaim (it's a level play, not SPY-gated — defending PDH as
// support while the tape is weak is relative strength).
if s58_pdh_reclaim
    e_pdh_r  = close
    s_pdh_r  = low - atr_buffer
    t1_pdh_r = not na(pwh) and pwh > e_pdh_r ? pwh : (not na(pmh) and pmh > e_pdh_r ? pmh : e_pdh_r * 1.0075)
    t2_pdh_r = not na(pmh) and pmh > t1_pdh_r ? pmh : t2_extend_long(e_pdh_r, t1_pdh_r)
    alert(build_payload_v2("staged_pdh_reclaim", "BUY", e_pdh_r, s_pdh_r, t1_pdh_r, t2_pdh_r, false, 1, volume_ratio, cvd_slope_n, bearish_div), alert.freq_once_per_bar_close)

// Spec 61 — PDH proximity. Holding above PDH, pulled back near it without a
// retest, closed green. Same stop/target shape as the reclaim.
if false and s58_pdh_prox and (not uptrend_pass_58 or chop_gate_pass_58)
    e_pdh_p  = close
    s_pdh_p  = low - atr_buffer
    t1_pdh_p = not na(pwh) and pwh > e_pdh_p ? pwh : (not na(pmh) and pmh > e_pdh_p ? pmh : e_pdh_p * 1.0075)
    t2_pdh_p = not na(pmh) and pmh > t1_pdh_p ? pmh : t2_extend_long(e_pdh_p, t1_pdh_p)
    alert(build_payload_v2("staged_pdh_proximity", "BUY", e_pdh_p, s_pdh_p, t1_pdh_p, t2_pdh_p, false, 1, volume_ratio, cvd_slope_n, bearish_div), alert.freq_once_per_bar_close)

// 2026-06-01 — staged_pml_held DISABLED. PML stays drawn on chart as visual.
// if s58_pml_held_v2 and (not uptrend_pass_58 or chop_gate_pass_58)
//     e_pml_h  = pml
//     s_pml_h  = low - atr_buffer
//     t1_pml_h = not na(pwh) and pwh > e_pml_h ? pwh : (not na(pmh) and pmh > e_pml_h ? pmh : e_pml_h * 1.03)
//     t2_pml_h = not na(pmh) and pmh > t1_pml_h ? pmh : t2_extend_long(e_pml_h, t1_pml_h)
//     alert(build_payload_v2("staged_pml_held", "BUY", e_pml_h, s_pml_h, t1_pml_h, t2_pml_h, false, 1, volume_ratio, cvd_slope_n, bearish_div), alert.freq_once_per_bar_close)

// =====================================================================
// 2026-06-01 — Anchored-VWAP defense alerts DISABLED entirely.
// =====================================================================
// MTD / prior-month / 2-months-prior AVWAP lines stay DRAWN on chart as
// visual reference (variables mtd_avwap_58 / pm_avwap_58 / p2m_avwap_58
// + plot logic untouched), but no alerts emit. Live evaluation: 8 of
// today's 15 missed-to-Telegram alerts were mtd_avwap_held with no
// follow-through. Too noisy for the entry-rule shortlist.
//
// if s58_mtd_avwap_held_v2 and (not uptrend_pass_58 or chop_gate_pass_58)
//     e_mtd  = mtd_avwap_58
//     s_mtd  = low - atr_buffer
//     t1_mtd = not na(pm_avwap_58) and pm_avwap_58 > e_mtd ? pm_avwap_58 : (not na(pwh) and pwh > e_mtd ? pwh : e_mtd * 1.015)
//     t2_mtd = not na(pwh) and pwh > t1_mtd ? pwh : (not na(pmh) and pmh > t1_mtd ? pmh : t2_extend_long(e_mtd, t1_mtd))
//     alert(build_payload_v2("staged_mtd_avwap_held", "BUY", e_mtd, s_mtd, t1_mtd, t2_mtd, false, 1, volume_ratio, cvd_slope_n, bearish_div), alert.freq_once_per_bar_close)
//
// if s58_pm_avwap_held_v2 and (not uptrend_pass_58 or chop_gate_pass_58)
//     e_pm  = pm_avwap_58
//     s_pm  = low - atr_buffer
//     t1_pm = not na(p2m_avwap_58) and p2m_avwap_58 > e_pm ? p2m_avwap_58 : (not na(pwh) and pwh > e_pm ? pwh : e_pm * 1.02)
//     t2_pm = not na(pwh) and pwh > t1_pm ? pwh : (not na(pmh) and pmh > t1_pm ? pmh : t2_extend_long(e_pm, t1_pm))
//     alert(build_payload_v2("staged_pm_avwap_held", "BUY", e_pm, s_pm, t1_pm, t2_pm, false, 1, volume_ratio, cvd_slope_n, bearish_div), alert.freq_once_per_bar_close)
//
// if s58_p2m_avwap_held_v2 and (not uptrend_pass_58 or chop_gate_pass_58)
//     e_p2m  = p2m_avwap_58
//     s_p2m  = low - atr_buffer
//     t1_p2m = not na(pwh) and pwh > e_p2m ? pwh : (not na(pmh) and pmh > e_p2m ? pmh : e_p2m * 1.03)
//     t2_p2m = not na(pmh) and pmh > t1_p2m ? pmh : t2_extend_long(e_p2m, t1_p2m)
//     alert(build_payload_v2("staged_p2m_avwap_held", "BUY", e_p2m, s_p2m, t1_p2m, t2_p2m, false, 1, volume_ratio, cvd_slope_n, bearish_div), alert.freq_once_per_bar_close)

// =====================================================================
// Open-line alert fires — open_lost (NOTICE, index only) +
// open_reclaimed (BUY, all symbols)
// =====================================================================
// Stops/targets sized in-line: open_lost is small projected drawdown
// (NOTICE), open_reclaimed is standard long-side projection. The triage
// agent re-ranks based on confluence. near_pdh / near_pdl flags ride on
// build_payload_v2 so the webhook can collapse confluence twins.
// Spec 58 (2026-05-23 night) — open-line entry alerts removed entirely
// (open_lost NOTICE, plus open_reclaimed / open_held / open_wick_reclaim
// BUYs that were already disabled via fire_open_* input defaults). The
// open-line plot lives in visual/open_line.pine for chart context only.
// Open-line state-machine variables (ol_just_*, ol_was_above_open, etc.)
// remain in the file as dead code — harmless and easy to revive if ever
// wanted.

// =====================================================================
// VWAP reclaim → PDH (LONG) / VWAP reject → PDL (SHORT)
// =====================================================================
// Earlier-entry setup than PDH/PDL break — when price closes back above
// VWAP after N consecutive bars below, PDH becomes a clean structural
// target. R:R is materially better than waiting for PDH break (entry at
// the level being defended, not at the breakout).
//
// Skip if already past the target (above PDH for longs, below PDL for
// shorts) — no clean target overhead/below in those cases.
//
// Backend dedup (30 min, 0.5%, direction-aware) handles same-direction
// re-fires from VWAP whipsaw. State machine here only checks the "wrong
// side first" precondition.
//
// Helper: true if all of the last `n` bars closed strictly below VWAP.
all_closes_below_vwap(int n) =>
    result = true
    for i = 1 to n
        if na(vwap_v[i]) or close[i] >= vwap_v[i]
            result := false
    result

all_closes_above_vwap(int n) =>
    result = true
    for i = 1 to n
        if na(vwap_v[i]) or close[i] <= vwap_v[i]
            result := false
    result

was_below_vwap = all_closes_below_vwap(vwap_setup_bars)
was_above_vwap = all_closes_above_vwap(vwap_setup_bars)

vwap_reclaim_long = not na(vwap_v) and not na(pdh) and was_below_vwap and close > vwap_v and close > open and close < pdh
vwap_reject_short = not na(vwap_v) and not na(pdl) and was_above_vwap and close < vwap_v and close < open and close > pdl

// VWAP support hold — price was above VWAP for `vwap_setup_bars` consecutive
// bars, then wicked DOWN to/through VWAP on this bar, but closed back above
// on a green bar. "VWAP defended" — bullish continuation context for SPY-like
// trend days where VWAP is the live institutional reference. NOTICE only.
// vwap_tolerance: how close the wick has to come to VWAP to count as a test.
vwap_tolerance_pct = 0.001  // 0.1% — tight test, not just "in the area"
vwap_support_hold = not na(vwap_v) and was_above_vwap and low <= vwap_v * (1.0 + vwap_tolerance_pct) and close > vwap_v and close > open

// Visual markers
plotshape(show_signals and vwap_reclaim_long,
          title = "VWAP reclaim LONG", location = location.belowbar,
          color = color.new(#00BCD4, 0), style = shape.triangleup,
          size = size.small)
plotshape(show_signals and vwap_support_hold,
          title = "VWAP support HOLD", location = location.belowbar,
          color = color.new(#9C27B0, 0), style = shape.circle,
          size = size.small)
plotshape(show_signals and vwap_reject_short,
          title = "VWAP reject SHORT", location = location.abovebar,
          color = color.new(#E91E63, 0), style = shape.triangledown,
          size = size.small)

if show_signals and vwap_reclaim_long
    label.new(bar_index, low, "VWAP→PDH",
              style = label.style_label_up,
              color = color.new(#00BCD4, 0),
              textcolor = color.white,
              size = size.tiny,
              yloc = yloc.belowbar)
if show_signals and vwap_support_hold
    label.new(bar_index, low, "VWAP HOLD",
              style = label.style_label_up,
              color = color.new(#9C27B0, 0),
              textcolor = color.white,
              size = size.tiny,
              yloc = yloc.belowbar)
if show_signals and vwap_reject_short
    label.new(bar_index, high, "VWAP→PDL",
              style = label.style_label_down,
              color = color.new(#E91E63, 0),
              textcolor = color.white,
              size = size.tiny,
              yloc = yloc.abovebar)

// VWAP alerts — gated to SPY / QQQ only.
//
// VWAP as a level matters most as an INSTITUTIONAL REFERENCE on the index
// ETFs (SPY/QQQ). On individual stocks, VWAP is noisy and the alerts
// aren't actionable — most stocks oscillate around VWAP without it being
// a meaningful structural level. Hardcoding the macro-symbol filter at
// the Pine level so alerts don't fire on unintended charts even if a
// user accidentally toggles `fire_vwap_alerts=true`.
//
// The visual VWAP line + markers still paint on any chart (useful as
// context). Only the alert() calls are restricted.
// (is_macro_symbol declared near top, alongside fire_vwap_alerts input)

// Spec 58 (2026-05-23 night) — VWAP NOTICE alerts removed (Pine is long-only).
// The deleted blocks were vwap_reclaim_long, vwap_reject_short, vwap_support_hold.
// VWAP visual plot remains for chart context (see `show_vwap` input above).

// vwap_lose_short was added briefly 2026-05-05 and removed same day.
// AAPL 1h chart showed 7 LOSE VWAP labels in a single session because
// candle bodies routinely brush VWAP in chop. Single bar-close cross
// without setup_bars confirmation is too noisy to be tradeable; the
// existing vwap_reject_short already covers the actionable case (price
// rejecting VWAP from below after `vwap_setup_bars` consecutive bars).
// SPY short remains gated on staged_pdh_rejection / staged_pdl_break /
// vwap_reject_short — no behaviour lost.

// PWH/PWL/PMH/PML break/reclaim/rejection events are UNIFIED into the
// daily PDH/PDL alert blocks above (see `lowest_res_just_broken` /
// `highest_sup_just_reclaimed` helpers). The alert_type is now
// TF-suffixed via `tf_high_prefix()` / `tf_low_prefix()` — a weekly-high
// break fires `staged_pwh_break`, a monthly-low reclaim fires
// `staged_pml_reclaim`, etc. Direction is BUY/SHORT for all TFs
// (per 2026-05-16 update — was NOTICE for weekly/monthly).

// =====================================================================
// HTF level lifecycle — hold / wick_reclaim / proximity NOTICE
// =====================================================================
// Adds per-level state machines for PWH/PWL/PMH/PML mirroring the
// open-line patterns. When price is ABOVE an HTF level (level acts as
// support), fire `pwh_held` / `pwh_wick_reclaim` etc. on test-and-bounce.
// Proximity NOTICEs fire when close is within `htf_proximity_pct` of any
// HTF level (both sides — resistance test from below, support test from
// above).
//
// State reset cadence: **per session (daily)**. Critical HTF levels can
// be tested multiple times in the same week/month — Monday's PWH defense
// and Wednesday's PWH defense are independent meaningful events, each
// gets its own alert. State also resets when the level value itself
// changes (new week locks in PWH/PWL, new month for PMH/PML).
//
// Eligibility: each per-level "was_above" flag must be set (close >
// level on some bar) before hold/wick/reclaim are eligible. Mirrors
// open-line semantics.

// Reset cadence: per session (daily). Critical levels can be tested in
// multiple sessions through the week/month — each fresh session deserves
// its own hold/wick alert if the level is challenged. Backend 60-min
// identity dedup still collapses intra-bar churn so we get at most one
// hold + one wick_reclaim per level per session per symbol.

// --- PWH state -------------------------------------------------------
var bool pwh_was_above       = false
var bool pwh_lost            = false
var bool pwh_held_fired      = false
var bool pwh_wick_recl_fired = false
var bool pwh_wick_dipped     = false
if session_open_now or (not na(pwh) and not na(pwh[1]) and pwh != pwh[1])
    pwh_was_above       := false
    pwh_lost            := false
    pwh_held_fired      := false
    pwh_wick_recl_fired := false
    pwh_wick_dipped     := false
if not na(pwh) and close > pwh
    pwh_was_above := true
if not na(pwh) and low < pwh
    pwh_wick_dipped := true
pwh_just_held = pwh_was_above and not pwh_lost and not pwh_held_fired and not pwh_wick_dipped and not na(pwh) and low <= pwh * (1.0 + htf_test_tol_pct / 100.0) and low >= pwh and close > pwh and close > open
pwh_just_wick = pwh_was_above and not pwh_lost and not pwh_wick_recl_fired and not na(pwh) and low < pwh and close > pwh and close > open
if pwh_just_held
    pwh_held_fired := true
if pwh_just_wick
    pwh_wick_recl_fired := true

// --- PWL state -------------------------------------------------------
var bool pwl_was_above       = false
var bool pwl_lost            = false
var bool pwl_held_fired      = false
var bool pwl_wick_recl_fired = false
var bool pwl_wick_dipped     = false
if session_open_now or (not na(pwl) and not na(pwl[1]) and pwl != pwl[1])
    pwl_was_above       := false
    pwl_lost            := false
    pwl_held_fired      := false
    pwl_wick_recl_fired := false
    pwl_wick_dipped     := false
if not na(pwl) and close > pwl
    pwl_was_above := true
if not na(pwl) and low < pwl
    pwl_wick_dipped := true
pwl_just_held = pwl_was_above and not pwl_lost and not pwl_held_fired and not pwl_wick_dipped and not na(pwl) and low <= pwl * (1.0 + htf_test_tol_pct / 100.0) and low >= pwl and close > pwl and close > open
pwl_just_wick = pwl_was_above and not pwl_lost and not pwl_wick_recl_fired and not na(pwl) and low < pwl and close > pwl and close > open
if pwl_just_held
    pwl_held_fired := true
if pwl_just_wick
    pwl_wick_recl_fired := true

// --- PMH state -------------------------------------------------------
var bool pmh_was_above       = false
var bool pmh_lost            = false
var bool pmh_held_fired      = false
var bool pmh_wick_recl_fired = false
var bool pmh_wick_dipped     = false
if session_open_now or (not na(pmh) and not na(pmh[1]) and pmh != pmh[1])
    pmh_was_above       := false
    pmh_lost            := false
    pmh_held_fired      := false
    pmh_wick_recl_fired := false
    pmh_wick_dipped     := false
if not na(pmh) and close > pmh
    pmh_was_above := true
if not na(pmh) and low < pmh
    pmh_wick_dipped := true
pmh_just_held = pmh_was_above and not pmh_lost and not pmh_held_fired and not pmh_wick_dipped and not na(pmh) and low <= pmh * (1.0 + htf_test_tol_pct / 100.0) and low >= pmh and close > pmh and close > open
pmh_just_wick = pmh_was_above and not pmh_lost and not pmh_wick_recl_fired and not na(pmh) and low < pmh and close > pmh and close > open
if pmh_just_held
    pmh_held_fired := true
if pmh_just_wick
    pmh_wick_recl_fired := true

// --- PML state -------------------------------------------------------
var bool pml_was_above       = false
var bool pml_lost            = false
var bool pml_held_fired      = false
var bool pml_wick_recl_fired = false
var bool pml_wick_dipped     = false
if session_open_now or (not na(pml) and not na(pml[1]) and pml != pml[1])
    pml_was_above       := false
    pml_lost            := false
    pml_held_fired      := false
    pml_wick_recl_fired := false
    pml_wick_dipped     := false
if not na(pml) and close > pml
    pml_was_above := true
if not na(pml) and low < pml
    pml_wick_dipped := true
pml_just_held = pml_was_above and not pml_lost and not pml_held_fired and not pml_wick_dipped and not na(pml) and low <= pml * (1.0 + htf_test_tol_pct / 100.0) and low >= pml and close > pml and close > open
pml_just_wick = pml_was_above and not pml_lost and not pml_wick_recl_fired and not na(pml) and low < pml and close > pml and close > open
if pml_just_held
    pml_held_fired := true
if pml_just_wick
    pml_wick_recl_fired := true

// --- Alert fire: HTF support held — COLLAPSED to ONE alert (S1, 2026-05-20)
// The 8 prior per-level alerts (pwh/pwl/pmh/pml × held/wick_reclaim) are
// merged into a single BUY alert. They were always the same setup — an HTF
// level holding as SUPPORT. Each `*_just_held` already requires `*_was_above`
// (price closed above the level earlier this session), so this is inherently
// S0-correct: it only fires when the level is genuinely support, never when
// price is grinding UP into the level from below (that's resistance, and the
// staged break/rejection path handles it).
//
// confluence_count carries HOW MANY HTF levels held this bar (1-4 = stronger
// confluence).
//
// STOP (fixed 2026-05-20): stop is the FIRING BAR's wick low - atr_buffer —
// a tight structural stop. The previous "lowest held level - buffer" logic
// produced absurd stops (e.g. INTC entry 115.62, stop 95.23 = -17%) because
// a held level can sit far from price. A genuine `*_just_held` means the bar
// low IS within tolerance of the level, so `low - atr_buffer` is the correct
// tight stop right under the bounce.
//
// Item-1 suppression (2026-05-20): a staged break/reject/reclaim event is the
// richer, primary signal for the bar. When one fired, the HTF held/proximity
// alerts are redundant — suppress them so a bar produces ONE alert, not two.
any_staged_event = pdh_break or pdh_rejection or sweep_reversal_short or pdl_break or pdl_reclaim

htf_held_count = (pwh_just_held or pwh_just_wick ? 1 : 0) + (pwl_just_held or pwl_just_wick ? 1 : 0) + (pmh_just_held or pmh_just_wick ? 1 : 0) + (pml_just_held or pml_just_wick ? 1 : 0)
// Spec 58 (2026-05-23 night) — htf_support_held BUY removed entirely.
// Superseded by the granular staged_p[dwm]h_held (highs) + staged_p[dwm]l_held
// (lows wick test) types, which carry the spec-58 payload (uptrend_pass,
// nearby_levels for confluence). htf_held_count still computed above as
// dead code in case any future signal wants it.

// --- Alert fire: HTF proximity — COLLAPSED to ONE NOTICE (S1, 2026-05-20)
// The 4 prior per-level proximity NOTICEs merged into one. Fires when close
// is within `htf_proximity_pct` of ANY HTF level. confluence_count = how
// many levels are in proximity. NOTICE direction — informational context.
near_pct(float lvl, float pct) =>
    not na(lvl) and not na(close) and lvl != 0 and (math.abs(close - lvl) / lvl) * 100.0 <= pct
htf_prox_count = (near_pct(pwh, htf_proximity_pct) ? 1 : 0) + (near_pct(pwl, htf_proximity_pct) ? 1 : 0) + (near_pct(pmh, htf_proximity_pct) ? 1 : 0) + (near_pct(pml, htf_proximity_pct) ? 1 : 0)
// Spec 58 (2026-05-23 night) — htf_proximity NOTICE alert removed (long-only).
// htf_prox_count still computed in case htf_support_held wants confluence context.

// ═══════════════════════════════════════════════════════════════════════
// Weekly Stage alerts (spec 61, 2026-06-07) — fire the long-term RC/BUY/ADD/
// EXIT through THIS indicator's existing alert (TradingView caps the watchlist
// at 2 alerts). VISUALS live in the separate "WkStage" indicator; this block is
// ALERTS ONLY (no plots). Computed on the weekly via request.security so it's
// correct regardless of the chart TF the alert is set on; fires ~once/week.
// ═══════════════════════════════════════════════════════════════════════
wk_alerts    = input.bool(true,  "Weekly Stage alerts (RC/BUY/ADD/EXIT)", group = "Weekly Stage alerts")
wk_ma_len    = input.int  (30,   "Weekly — MA length (weeks)", minval = 5, group = "Weekly Stage alerts")
wk_slope_lb  = input.int  (4,    "Weekly — slope lookback", minval = 1, group = "Weekly Stage alerts")
wk_slope_thr = input.float(0.5,  "Weekly — flat band %", minval = 0.0, step = 0.05, group = "Weekly Stage alerts")
wk_ma_buf    = input.float(3.0,  "Weekly — pullback buffer %", minval = 0.0, step = 0.5, group = "Weekly Stage alerts")

f_wkstage() =>
    _m = ta.sma(close, wk_ma_len)
    _sl = _m[wk_slope_lb] != 0 ? (_m - _m[wk_slope_lb]) / _m[wk_slope_lb] * 100.0 : 0.0
    _rising = _sl > wk_slope_thr
    _above = close > _m
    _maup = _m > _m[wk_slope_lb]
    _buy = (not na(_m)) and (close > _m) and (close[1] <= _m[1]) and _maup
    _trail = low[1]
    var bool _inp = false
    _b = _buy and (not _inp)
    _x = _inp and (not na(_trail)) and (close < _trail)
    if _b
        _inp := true
    if _x
        _inp := false
    _inzone = (not na(_m)) and (low <= _m * (1.0 + wk_ma_buf / 100.0)) and (close > _m)
    _add = _rising and _above and _inzone and (low[1] > _m[1] * (1.0 + wk_ma_buf / 100.0))
    // close > open (GREEN week) required — a reclaim that closes the week DOWN
    // (red) is a weak/false reclaim (OKLO + GOOGL 2026-06-08 both swept the level
    // but closed red). A real reclaim finishes the week up.
    _rcbase = (low < low[1]) and (close > low[1]) and (close > open) and (not na(_m))
    _rcb = _rcbase and (close < _m)
    _rca = _rcbase and (close >= _m)
    [_m, _b, _x, _trail, _add, _rcb, _rca, low]

[wk_ma, wk_buy, wk_exit, wk_trail, wk_add, wk_rcb, wk_rca, wk_low] = request.security(syminfo.tickerid, "W", f_wkstage(), lookahead = barmerge.lookahead_off)

// Issue #3 (2026-06-13) — the generic "weekly_stage" BUY/ADD/EXIT/stage NOTICEs
// were unclear / not actionable in the day-trade feed, so they're SUPPRESSED
// (removed). Only the actionable weekly reclaim survives, now under its own
// clear rule "weekly_rc" (was mislabeled "weekly_stage"). wk_buy/wk_add/wk_exit
// stay in the tuple but no longer fire.
if wk_alerts and wk_rcb and not wk_rcb[1]
    wrbn = "Weekly RC · undercut & reclaim of the prior-week low (below 30wMA = bottoming, green week) · stop " + str.tostring(wk_low, format.mintick)
    wrbp = '{"symbol":"' + syminfo.ticker + '","price":"' + str.tostring(close, format.mintick) + '","rule":"weekly_rc","direction":"BUY","interval":"W","entry":"' + str.tostring(close, format.mintick) + '","stop":"' + str.tostring(wk_low, format.mintick) + '","note":"' + wrbn + '","target_rsi":"70","target_tf":"W","fired_at":"' + str.tostring(timenow) + '"}'
    alert(wrbp, alert.freq_once_per_bar_close)
if wk_alerts and wk_rca and not wk_rca[1]
    wran = "Weekly RC · in-uptrend dip-reclaim of the prior-week low (above 30wMA, green week) · stop " + str.tostring(wk_low, format.mintick)
    wrap = '{"symbol":"' + syminfo.ticker + '","price":"' + str.tostring(close, format.mintick) + '","rule":"weekly_rc","direction":"BUY","interval":"W","entry":"' + str.tostring(close, format.mintick) + '","stop":"' + str.tostring(wk_low, format.mintick) + '","note":"' + wran + '","target_rsi":"70","target_tf":"W","fired_at":"' + str.tostring(timenow) + '"}'
    alert(wrap, alert.freq_once_per_bar_close)

// ── Swing book (2026-06-13) — daily RSI/EMA momentum, folded in so it fires from
// this one watchlist-bound Pine (keeps the user at max 2 bound Pines). SAME
// payload pattern as every other alert; the ONLY difference is a "SWING" tag in
// the note + the expected hold length. Computed on the DAILY; fired ONCE at the
// RTH close (the 16:00 bar — the daily RSI/EMA are final there, so confirmed +
// towards-EOD). Visual markers live in the standalone "Momentum" indicator.
fire_swing = input.bool(true, "Fire swing momentum alerts (daily RSI / 5-20 EMA)", group = "Swing")
f_swing() =>
    _r   = ta.rsi(close, 14)
    _e5  = ta.ema(close, 5)
    _e20 = ta.ema(close, 20)
    _rsi70 = ta.crossover(_r, 70.0)
    _xc    = ta.crossover(_e5, _e20)
    _inz   = (_r >= 30.0) and (_r <= 35.0)
    _os    = _inz and not _inz[1]
    [_rsi70, _xc, _os, _e20]
[sw_rsi70, sw_cross, sw_os, sw_e20] = request.security(syminfo.tickerid, "D", f_swing(), lookahead = barmerge.lookahead_off)
// Swing alerts fire INTRADAY the moment a valid daily setup forms — NO EOD gate
// (removed 2026-06-15 per founder: a valid setup should alert immediately, not
// wait for the 16:00 close). Once-per-day guard so each rule fires once per
// session, not on every intraday bar while the daily condition stays true.
sw_newday = ta.change(time("D")) != 0
var bool sw_rsi70_done = false
var bool sw_cross_done = false
var bool sw_os_done = false
if sw_newday
    sw_rsi70_done := false
    sw_cross_done := false
    sw_os_done := false
if fire_swing and sw_rsi70 and not sw_rsi70_done
    sw_rsi70_done := true
    swp1 = '{"symbol":"' + syminfo.ticker + '","price":"' + str.tostring(close, format.mintick) + '","rule":"rsi_70","direction":"BUY","interval":"D","entry":"' + str.tostring(close, format.mintick) + '","note":"RSI 70 — daily RSI crossed above 70; can begin a parabolic run","fired_at":"' + str.tostring(timenow) + '"}'
    alert(swp1, alert.freq_once_per_bar_close)
if fire_swing and sw_cross and not sw_cross_done
    sw_cross_done := true
    swp2 = '{"symbol":"' + syminfo.ticker + '","price":"' + str.tostring(close, format.mintick) + '","rule":"ema_5_20_cross","direction":"BUY","interval":"D","entry":"' + str.tostring(close, format.mintick) + '","stop":"' + str.tostring(sw_e20, format.mintick) + '","note":"5/20 EMA bullish cross (Steve Burns). STOP = 5/20 cross-under at the close (~20 EMA). Target = RSI 70","target_rsi":"70","target_tf":"D","fired_at":"' + str.tostring(timenow) + '"}'
    alert(swp2, alert.freq_once_per_bar_close)
if fire_swing and sw_os and not sw_os_done
    sw_os_done := true
    swp3 = '{"symbol":"' + syminfo.ticker + '","price":"' + str.tostring(close, format.mintick) + '","rule":"rsi_oversold","direction":"BUY","interval":"D","entry":"' + str.tostring(close, format.mintick) + '","note":"RSI oversold buy zone — daily RSI in 30-35 (reclaim/hold, never below 30). T1 RSI 50, T2 RSI 70. STOP = daily close back under RSI 30","target_rsi":"70","target_tf":"D","fired_at":"' + str.tostring(timenow) + '"}'
    alert(swp3, alert.freq_once_per_bar_close)

// 4h RC alerts MOVED to the standalone "RC4h" indicator (#292, 2026-06-18). The
// request.security("240") version here diverged from the RC4h markers — it caught
// shorts but missed the longs you could see. RC now fires from RC4h on the chart's
// own bars (long, short, AND RC-H): what-you-see-is-what-fires. rule stays "rc_4h".

// ═══════════════════════════════════════════════════════════════════════
// Gap alerts (spec 61, 2026-06-07) — fire from THIS indicator (one of your 2
// bound TV alerts). DETECTION ONLY — the visual gap boxes live in the "Gaps"
// indicator. Tracks unfilled gaps and fires DIRECTIONAL S/R entries on them:
// gap_support BUY (dip to a gap you opened above), gap_fill BUY (close into a
// gap below from underneath → run to the far edge), gap_reject SHORT (tag an
// overhead gap and fail). Role decided by day_open. Enable per type in Settings
// → Alert Types (default OFF). Replaces the old gap_zone info-notice.
// ═══════════════════════════════════════════════════════════════════════
gp_alerts   = input.bool(true, "Gap S/R entries (support / fill / reject)", group = "Gap alerts")
gp_min_pct  = input.float(0.15, "Gap — min size %", minval = 0.0, step = 0.05, group = "Gap alerts")
gp_lookback = input.int(300, "Gap — drop gaps older than N bars", minval = 20, group = "Gap alerts")

var array<float> gpTop = array.new_float()
var array<float> gpBot = array.new_float()
var array<int>   gpBar = array.new_int()
var array<bool>  gpUp  = array.new_bool()

gp_up_new = (low > high[1]) and (high[1] > 0) and ((low - high[1]) / high[1] * 100.0 >= gp_min_pct)
gp_dn_new = (high < low[1]) and (low[1] > 0) and ((low[1] - high) / low[1] * 100.0 >= gp_min_pct)
if gp_up_new
    array.push(gpTop, low)
    array.push(gpBot, high[1])
    array.push(gpBar, bar_index)
    array.push(gpUp, true)
if gp_dn_new
    array.push(gpTop, low[1])
    array.push(gpBot, high)
    array.push(gpBar, bar_index)
    array.push(gpUp, false)

if array.size(gpTop) > 0
    gp_i = array.size(gpTop) - 1
    while gp_i >= 0
        gp_top = array.get(gpTop, gp_i)
        gp_bot = array.get(gpBot, gp_i)
        gp_isup = array.get(gpUp, gp_i)
        gp_filled = gp_isup ? (low <= gp_bot) : (high >= gp_top)
        gp_stale = (bar_index - array.get(gpBar, gp_i)) > gp_lookback
        // Directional gap S/R entries (2026-06-15). day_open decides the role:
        // gap-UP opened-above = support (bounce BUY); gap-DOWN = resistance — reject
        // SHORT at the near edge, or BUY the FILL on a close INTO the void (the one
        // level you can buy into — no supply inside the gap). [1] = fire once on the
        // transition (first touch / first close-in), not every bar in the zone.
        gp_sup_buy  = gp_isup     and day_open > gp_top and low <= gp_top and low[1] > gp_top and close > gp_top and close > open
        gp_fill_buy = not gp_isup and close[1] <= gp_bot and close > gp_bot and close <= gp_top and close > open
        gp_rej_sht  = not gp_isup and day_open < gp_bot and high >= gp_bot and high[1] < gp_bot and close < gp_bot and close < open
        if gp_alerts and gp_sup_buy
            gp_sp = '{"symbol":"' + syminfo.ticker + '","price":"' + str.tostring(close, format.mintick) + '","rule":"gap_support","direction":"BUY","interval":"' + timeframe.period + '","entry":"' + str.tostring(close, format.mintick) + '","stop":"' + str.tostring(gp_bot, format.mintick) + '","note":"Gap-support bounce — opened above the gap, dipped to its top edge and held","fired_at":"' + str.tostring(timenow) + '"}'
            alert(gp_sp, alert.freq_once_per_bar_close)
        if gp_alerts and gp_fill_buy
            gp_fp = '{"symbol":"' + syminfo.ticker + '","price":"' + str.tostring(close, format.mintick) + '","rule":"gap_fill","direction":"BUY","interval":"' + timeframe.period + '","entry":"' + str.tostring(close, format.mintick) + '","stop":"' + str.tostring(gp_bot, format.mintick) + '","target_1":"' + str.tostring(gp_top, format.mintick) + '","note":"Gap fill — closed into the void from below; runs to the far edge (no supply inside)","fired_at":"' + str.tostring(timenow) + '"}'
            alert(gp_fp, alert.freq_once_per_bar_close)
        if gp_alerts and gp_rej_sht
            gp_rp = '{"symbol":"' + syminfo.ticker + '","price":"' + str.tostring(close, format.mintick) + '","rule":"gap_reject","direction":"SHORT","interval":"' + timeframe.period + '","entry":"' + str.tostring(close, format.mintick) + '","stop":"' + str.tostring(gp_top, format.mintick) + '","note":"Gap-resistance reject — opened below the gap, tagged the near edge and closed back under","fired_at":"' + str.tostring(timenow) + '"}'
            alert(gp_rp, alert.freq_once_per_bar_close)
        if gp_stale or gp_filled
            array.remove(gpTop, gp_i)
            array.remove(gpBot, gp_i)
            array.remove(gpBar, gp_i)
            array.remove(gpUp, gp_i)
        gp_i := gp_i - 1


// ═══════════════════════════════════════════════════════════════════════
// Lost-support rejection (2026-06-16) — a LOW level (PDL/PWL/PML) you've LOST
// (price now below it) acts as RESISTANCE: a wick UP into it that closes back
// BELOW on a red bar -> SHORT. The low levels only had break/held/reclaim; this
// gives them the same dual-role the EMAs + high levels already have (mirror of
// highest_res_just_rejected, the ma_ema strict_short shape). high[1] < L means
// the level was approached from BELOW (price had lost it). Honest: a lost support
// is resistance until reclaimed. Wick tags (high >= L), close decides (close < L).
// Once per level per day; catalog type default-OFF so it lands in Muted first.
// ═══════════════════════════════════════════════════════════════════════
lsr_alerts = input.bool(true, "Lost-support rejection (PDL/PWL/PML as resistance)", group = "Levels")
lsr_rej(float L) => not na(L) and high >= L and close < L and close < open and high[1] < L
lsr_newday = ta.change(time("D")) != 0
var bool lsr_pdl_done = false
var bool lsr_pwl_done = false
var bool lsr_pml_done = false
if lsr_newday
    lsr_pdl_done := false
    lsr_pwl_done := false
    lsr_pml_done := false
if lsr_alerts and lsr_rej(pdl) and not lsr_pdl_done
    lsr_pdl_done := true
    lsr_dp = '{"symbol":"' + syminfo.ticker + '","price":"' + str.tostring(close, format.mintick) + '","rule":"lost_support_reject","direction":"SHORT","interval":"' + timeframe.period + '","entry":"' + str.tostring(close, format.mintick) + '","stop":"' + str.tostring(pdl + atr_buffer, format.mintick) + '","note":"PDL lost - now resistance: wicked up into it and closed back below","fired_at":"' + str.tostring(timenow) + '"}'
    alert(lsr_dp, alert.freq_once_per_bar_close)
if lsr_alerts and lsr_rej(pwl) and not lsr_pwl_done
    lsr_pwl_done := true
    lsr_wp = '{"symbol":"' + syminfo.ticker + '","price":"' + str.tostring(close, format.mintick) + '","rule":"lost_support_reject","direction":"SHORT","interval":"' + timeframe.period + '","entry":"' + str.tostring(close, format.mintick) + '","stop":"' + str.tostring(pwl + atr_buffer, format.mintick) + '","note":"PWL lost - now resistance: wicked up into it and closed back below","fired_at":"' + str.tostring(timenow) + '"}'
    alert(lsr_wp, alert.freq_once_per_bar_close)
if lsr_alerts and lsr_rej(pml) and not lsr_pml_done
    lsr_pml_done := true
    lsr_mp = '{"symbol":"' + syminfo.ticker + '","price":"' + str.tostring(close, format.mintick) + '","rule":"lost_support_reject","direction":"SHORT","interval":"' + timeframe.period + '","entry":"' + str.tostring(close, format.mintick) + '","stop":"' + str.tostring(pml + atr_buffer, format.mintick) + '","note":"PML lost - now resistance: wicked up into it and closed back below","fired_at":"' + str.tostring(timenow) + '"}'
    alert(lsr_mp, alert.freq_once_per_bar_close)
