// @version=5
// SMA + Levels Flat — the 5/20/50/100/200 DAILY SMAs AND the prior-period levels
// (PDH/PDL · PWH/PWL · PMH/PML), all drawn as FLAT horizontal support/resistance
// lines. A daily SMA only updates on the daily close, so it sits flat intraday —
// exactly like a prior-day level. Everything is locked to its settled value via
// request.security([1] + lookahead_on), so the lines stay put on ANY chart TF
// (5m ↔ 15m ↔ 1h ↔ D) and never repaint.
//
// Color = ROLE, by where price sits right now:
//   GREEN = SUPPORT     (price is ABOVE the line)
//   RED   = RESISTANCE  (price is BELOW the line — overhead / target)
// The role flips when price closes back across the line.
//
// Line styles keep the three level tiers readable at a glance:
//   SMAs + daily (PDH/PDL) = solid · weekly (PWH/PWL) = dashed · monthly (PMH/PML) = dotted
//
// VISUAL ONLY — no alerts (the day_trade pine owns the level/MA alerts). The SMA twin
// of "EMA + Levels Flat" — run whichever MA family you trade, or both.
indicator("SMA + Levels Flat · 5·20·50·100·200", "SMA+Lvl", overlay = true, max_lines_count = 20, max_labels_count = 20)

// ── Which MAs ──
gM = "Moving averages (daily SMA · flat)"
show5   = input.bool(true, "SMA 5",   inline = "a", group = gM)
show20  = input.bool(true, "SMA 20",  inline = "a", group = gM)
show50  = input.bool(true, "SMA 50",  inline = "b", group = gM)
show100 = input.bool(true, "SMA 100", inline = "b", group = gM)
show200 = input.bool(true, "SMA 200", inline = "c", group = gM)

// ── Which levels ──
gL = "Prior-period levels (flat)"
show_pdh = input.bool(true, "PDH", inline = "d", group = gL)
show_pdl = input.bool(true, "PDL", inline = "d", group = gL)
show_pwh = input.bool(true, "PWH", inline = "e", group = gL)
show_pwl = input.bool(true, "PWL", inline = "e", group = gL)
show_pmh = input.bool(true, "PMH", inline = "f", group = gL)
show_pml = input.bool(true, "PML", inline = "f", group = gL)

// ── Style ──
gS = "Style"
supCol  = input.color(#26A69A, "Support color (price above)",    group = gS)
resCol  = input.color(#EF5350, "Resistance color (price below)", group = gS)
lineW   = input.int(2, "Line width", minval = 1, maxval = 5, group = gS)
lineLen = input.int(60, "Line length (bars back)", minval = 10, maxval = 500, group = gS)
labSize = input.string("small", "Label size", options = ["tiny", "small", "normal", "large"], group = gS)
_lsz = labSize == "tiny" ? size.tiny : labSize == "normal" ? size.normal : labSize == "large" ? size.large : size.small

// ── Daily SMAs (settled value via [1] + lookahead → flat + non-repainting on any TF) ──
tid = syminfo.tickerid
sma5   = request.security(tid, "D", ta.sma(close, 5)[1],   lookahead = barmerge.lookahead_on)
sma20  = request.security(tid, "D", ta.sma(close, 20)[1],  lookahead = barmerge.lookahead_on)
sma50  = request.security(tid, "D", ta.sma(close, 50)[1],  lookahead = barmerge.lookahead_on)
sma100 = request.security(tid, "D", ta.sma(close, 100)[1], lookahead = barmerge.lookahead_on)
sma200 = request.security(tid, "D", ta.sma(close, 200)[1], lookahead = barmerge.lookahead_on)

// ── Prior-day / week / month high & low (flat intraday) ──
pdh = request.security(tid, "D", high[1], lookahead = barmerge.lookahead_on)
pdl = request.security(tid, "D", low[1],  lookahead = barmerge.lookahead_on)
pwh = request.security(tid, "W", high[1], lookahead = barmerge.lookahead_on)
pwl = request.security(tid, "W", low[1],  lookahead = barmerge.lookahead_on)
pmh = request.security(tid, "M", high[1], lookahead = barmerge.lookahead_on)
pml = request.security(tid, "M", low[1],  lookahead = barmerge.lookahead_on)

// ── Draw — one flat line per level/MA at its current value, redrawn on the last bar ──
var line[]  _lines  = array.new_line(0)
var label[] _labels = array.new_label(0)

// sty: 0 = solid · 1 = dashed · 2 = dotted. loff staggers the label x so nearby
// lines don't hide each other's labels. maRole = show the "S"/"R" letter (MAs only).
f_draw(float lvl, string nm, bool show, int sty, int loff, bool maRole) =>
    if show and not na(lvl)
        sup = close > lvl
        col = sup ? supCol : resCol
        lstyle = sty == 2 ? line.style_dotted : sty == 1 ? line.style_dashed : line.style_solid
        txt = maRole ? nm + (sup ? " S " : " R ") + str.tostring(lvl, format.mintick) : nm + "  " + str.tostring(lvl, format.mintick)
        ln  = line.new(bar_index - lineLen, lvl, bar_index + loff, lvl, color = col, width = lineW, style = lstyle)
        lb  = label.new(bar_index + loff, lvl, txt, style = label.style_label_left, color = col, textcolor = color.white, size = _lsz)
        array.push(_lines, ln)
        array.push(_labels, lb)

if barstate.islast
    if array.size(_lines) > 0
        for i = 0 to array.size(_lines) - 1
            line.delete(array.get(_lines, i))
        array.clear(_lines)
    if array.size(_labels) > 0
        for i = 0 to array.size(_labels) - 1
            label.delete(array.get(_labels, i))
        array.clear(_labels)
    // MAs — labels near the price axis (x + 4)
    f_draw(sma5,   "SMA 5",   show5,   0, 4, true)
    f_draw(sma20,  "SMA 20",  show20,  0, 4, true)
    f_draw(sma50,  "SMA 50",  show50,  0, 4, true)
    f_draw(sma100, "SMA 100", show100, 0, 4, true)
    f_draw(sma200, "SMA 200", show200, 0, 4, true)
    // Levels — labels stepped further out so they clear the MA labels
    f_draw(pdh, "PDH", show_pdh, 0, 10, false)
    f_draw(pdl, "PDL", show_pdl, 0, 14, false)
    f_draw(pwh, "PWH", show_pwh, 1, 18, false)
    f_draw(pwl, "PWL", show_pwl, 1, 22, false)
    f_draw(pmh, "PMH", show_pmh, 2, 26, false)
    f_draw(pml, "PML", show_pml, 2, 30, false)
